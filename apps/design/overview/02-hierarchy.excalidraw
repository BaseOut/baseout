      "version": 1,
      "updated": 0,
      "link": null,
      "locked": false,
      "boundElements": [],
      "customData": null,
      "id": "el-1v-7fu6v8",
      "type": "text",
      "x": 60,
      "y": 715,
      "width": 980,
      "height": 20,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "text": "• Each Space is bound to exactly one Platform (Airtable in V1; Notion / HubSpot / Salesforce later).",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "• Each Space is bound to exactly one Platform (Airtable in V1; Notion / HubSpot / Salesforce later).",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "isDeleted": false,
      "fillStyle": "solid",
      "strokeWidth": 1,
