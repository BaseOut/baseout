      "type": "text",
      "x": 60,
      "y": 740,
      "width": 980,
      "height": 20,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "text": "• A Space's backup configuration is its own — pick bases, schedule, and destination independently.",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "• A Space's backup configuration is its own — pick bases, schedule, and destination independently.",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "isDeleted": false,
