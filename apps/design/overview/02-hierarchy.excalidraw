      "id": "el-1u-5wicao",
      "type": "text",
      "x": 60,
      "y": 690,
      "width": 980,
      "height": 20,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "text": "• One Connection per Platform can serve many Spaces — you don't re-auth Airtable for each Space.",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "• One Connection per Platform can serve many Spaces — you don't re-auth Airtable for each Space.",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "isDeleted": false,
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "groupIds": [],
