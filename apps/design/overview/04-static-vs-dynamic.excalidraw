      "id": "el-39-5gjv0d",
      "type": "text",
      "x": 420,
      "y": 690,
      "width": 320,
      "height": 200,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "text": "Pick DYNAMIC when:\n\n• You want to query backups with SQL.\n• You want a \"live mirror\" of\n  Airtable kept in sync continuously.\n• You're on Pro+ and want the\n  Schema / Reports surfaces to show\n  data-level (not just schema) info.",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 11,
      "containerId": "el-38-cjvd2q",
      "originalText": "Pick DYNAMIC when:\n\n• You want to query backups with SQL.\n• You want a \"live mirror\" of\n  Airtable kept in sync continuously.\n• You're on Pro+ and want the\n  Schema / Reports surfaces to show\n  data-level (not just schema) info.",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "isDeleted": false,
