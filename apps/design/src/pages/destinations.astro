---
// Harness route — account-level Destinations registry (skeleton).
import SidebarLayout from '../layouts/SidebarLayout.astro';
import DestinationsView from '@web/views/DestinationsView.astro';
import { getBreadcrumbs } from '@web/lib/config';
import { FIXTURE_DESTINATIONS, FIXTURE_DESTINATIONS_EMPTY, newDestination } from '../fixtures/destinations';
import { getDestinationProviders } from '@web/lib/provider-catalog';
import ScenarioSwitcher from '../components/ScenarioSwitcher.astro';
import { DEMO_FLOWS } from '../lib/demo-flows';

const breadcrumbs = getBreadcrumbs('/settings');
const fixture = Astro.url.searchParams.get('fixture');
const status = Astro.url.searchParams.get('status');
const type = Astro.url.searchParams.get('type');
const baseList = fixture === 'empty' ? FIXTURE_DESTINATIONS_EMPTY : FIXTURE_DESTINATIONS;
// After "Save destination", the new one appears at the top of the registry, ready to connect.
const justAdded = status === 'added' ? newDestination(type) : null;
const destinations = justAdded ? [justAdded, ...baseList] : baseList;
const notice = justAdded
  ? (justAdded.status === 'connected'
      ? `${justAdded.providerLabel} created and ready to use.`
      : `${justAdded.providerLabel} created. Connect it to start backing up.`)
  : null;
---

<SidebarLayout pageTitle="Destinations" breadcrumbs={breadcrumbs}>
  <DestinationsView destinations={destinations} notice={notice} providers={getDestinationProviders()} />
  <ScenarioSwitcher flows={DEMO_FLOWS} />
</SidebarLayout>
