---
import SidebarLayout from '../layouts/SidebarLayout.astro';
// The redesign was promoted into IntegrationsView.astro (production); the
// pre-redesign screen lives on as IntegrationsView.legacy.astro for "Old".
// (Deliberate divergence from ui-only, which still carries IntegrationsView =
// old + IntegrationsView.redesign = redesign as separate candidates.)
import IntegrationsViewRedesign from '@web/views/IntegrationsView.astro';
import IntegrationsViewLegacy from '@web/views/IntegrationsView.legacy.astro';
import SpaceOverviewView from '@web/views/SpaceOverviewView.astro';
import ScenarioSwitcher from '../components/ScenarioSwitcher.astro';
import { DEMO_FLOWS } from '../lib/demo-flows';
import { getBreadcrumbs } from '@web/lib/config';
import {
  FIXTURE_INTEGRATIONS_STATE,
  FIXTURE_INTEGRATIONS_STATE_EMPTY,
  FIXTURE_INTEGRATIONS_STATE_REAUTH,
  FIXTURE_INTEGRATIONS_STATE_INVALID,
  FIXTURE_INTEGRATIONS_STATE_REFRESHING,
  FIXTURE_INTEGRATIONS_STATE_NOBASES,
  FIXTURE_INTEGRATIONS_STATE_CAPPED,
  FIXTURE_INTEGRATIONS_STATE_SETUP,
  FIXTURE_INTEGRATIONS_STATE_SETUP_MANY,
} from '../fixtures/integrations';
import { FIXTURE_BACKUP_RUNS, FIXTURE_BACKUP_RUNS_EMPTY, FIXTURE_BACKUP_RUNS_FAILED } from '../fixtures/backup-runs';
import { findSource } from '../fixtures/sources';
import { FIXTURE_DESTINATIONS } from '../fixtures/destinations';

const breadcrumbs = getBreadcrumbs('/integrations');
const fixture = Astro.url.searchParams.get('fixture');
const statusParam = Astro.url.searchParams.get('status');

const stateByFixture: Record<string, typeof FIXTURE_INTEGRATIONS_STATE> = {
  empty: FIXTURE_INTEGRATIONS_STATE_EMPTY,
  reauth: FIXTURE_INTEGRATIONS_STATE_REAUTH,
  invalid: FIXTURE_INTEGRATIONS_STATE_INVALID,
  refreshing: FIXTURE_INTEGRATIONS_STATE_REFRESHING,
  nobases: FIXTURE_INTEGRATIONS_STATE_NOBASES,
  capped: FIXTURE_INTEGRATIONS_STATE_CAPPED,
  setup: FIXTURE_INTEGRATIONS_STATE_SETUP,
};
const state = (fixture && stateByFixture[fixture]) || FIXTURE_INTEGRATIONS_STATE;

// 'saved'/'running' = just-finished first-time setup: protected, but no prior succeeded run yet.
const initialRuns =
  fixture === 'empty' || fixture === 'nobases' || fixture === 'setup' || fixture === 'firstbackup'
    || statusParam === 'saved' || statusParam === 'running' ? FIXTURE_BACKUP_RUNS_EMPTY
  : fixture === 'failed' ? FIXTURE_BACKUP_RUNS_FAILED
  : FIXTURE_BACKUP_RUNS;

// Preview the OAuth-return / save alerts (hardcoded null in prod shell): ?status=connected | error | saved
const statusCode = statusParam === 'connected' ? 'connected' : statusParam === 'error' ? 'error' : statusParam === 'saved' ? 'saved' : statusParam === 'running' ? 'running' : null;
const errorReason = statusCode === 'error' ? (Astro.url.searchParams.get('reason') ?? 'access_denied') : null;

// Design-version switcher. Harness-only; never shipped. The new Space Overview is the default.
const v = Astro.url.searchParams.get('v') ?? 'overview';
// The Space Overview references the account Source + Destination(s) this Space uses.
const unconfigured = fixture === 'empty' || fixture === 'setup' || fixture === 'nobases';
const brokenScenario = fixture === 'reauth' || fixture === 'invalid';
const ovStatus = statusParam === 'saved' ? 'saved' : statusParam === 'running' ? 'running' : null;

let ovState = state;
let ovSource = unconfigured ? null : findSource(brokenScenario ? 'src-founder' : 'src-ops');
let ovDestinations = unconfigured ? [] : FIXTURE_DESTINATIONS.filter((d) => d.id === 'company-drive');

// The setup wizard finishes by passing the just-created names + base count, so the
// running overview reflects what was set up (the harness has no real persistence).
const wzSrc = Astro.url.searchParams.get('src');
const wzDest = Astro.url.searchParams.get('dest');
const wzBases = Number.parseInt(Astro.url.searchParams.get('bases') ?? '', 10);
if (statusParam === 'running' && (wzSrc || wzDest || Number.isFinite(wzBases))) {
  const n = Math.max(1, Math.min(FIXTURE_INTEGRATIONS_STATE_SETUP_MANY.bases.length, Number.isFinite(wzBases) ? wzBases : 1));
  ovState = { ...FIXTURE_INTEGRATIONS_STATE_SETUP_MANY, bases: FIXTURE_INTEGRATIONS_STATE_SETUP_MANY.bases.map((b, i) => ({ ...b, isIncluded: i < n })) };
  const baseSrc = findSource('src-ops');
  ovSource = baseSrc ? { ...baseSrc, name: wzSrc ?? 'Airtable', account: 'connected via OAuth', status: 'connected' } : baseSrc;
  const baseDest = FIXTURE_DESTINATIONS.find((d) => d.id === 'company-drive');
  ovDestinations = baseDest ? [{ ...baseDest, name: wzDest ?? 'Google Drive backup' }] : [];
}

// ?broken=src|dest|both flips the configured overview into the paused state — amber
// connectors + the reconnect alert. SpaceOverviewView already renders it from status.
const ovBroken = (Astro.url.searchParams.get('broken') ?? '').toLowerCase();
if (!unconfigured) {
  if ((ovBroken === 'src' || ovBroken === 'both') && ovSource) ovSource = { ...ovSource, status: 'reconnect' as const };
  if (ovBroken === 'dest' || ovBroken === 'both') ovDestinations = ovDestinations.map((d) => (d.kind === 'file' ? { ...d, status: 'reconnect' as const } : d));
}
---

<SidebarLayout pageTitle="Overview" breadcrumbs={breadcrumbs} spaceScoped={true}>
  {v === 'overview' ? (
    <SpaceOverviewView state={ovState} source={ovSource} destinations={ovDestinations} statusCode={ovStatus} />
  ) : v === 'redesign' ? (
    <IntegrationsViewRedesign state={state} statusCode={statusCode} errorReason={errorReason} initialRuns={initialRuns} />
  ) : (
    <IntegrationsViewLegacy state={state} statusCode={statusCode === 'connected' || statusCode === 'error' ? statusCode : null} errorReason={errorReason} initialRuns={initialRuns} />
  )}
  <ScenarioSwitcher flows={DEMO_FLOWS} />
</SidebarLayout>
