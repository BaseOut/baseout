---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import IntegrationsSetupWizard from '@web/views/IntegrationsSetupWizard.astro';
import { getBreadcrumbs } from '@web/lib/config';
import { FIXTURE_INTEGRATIONS_STATE_SETUP_MANY } from '../../fixtures/integrations';
import { FIXTURE_SOURCES } from '../../fixtures/sources';
import { FIXTURE_DESTINATIONS } from '../../fixtures/destinations';

const breadcrumbs = getBreadcrumbs('/integrations');
// ?first=1 (the empty-Overview CTA) = first-run SETUP: no account Sources/Destinations
// yet, created inline via the drawer; gated stepper. Otherwise (the overview's
// "Configure" button) = EDIT: account objects + the current config already present,
// free tabs to change anything.
const isFirst = Astro.url.searchParams.get('first') === '1';
const mode = isFirst ? 'setup' : 'edit';
// The wizard demo runs ALL objects connected by default (so switching sources is a
// clean edge-case-#2 demo). ?broken=src|dest|db|both injects ONE lost-access object
// for the inline-reconnect demo (#1). We normalize here rather than mutate the shared
// fixtures, which keep their own reconnect examples for the Sources/Destinations pages.
const brokenParam = (Astro.url.searchParams.get('broken') ?? '').toLowerCase();
const breakSrc = brokenParam === 'src' || brokenParam === 'both';
const breakFileDest = brokenParam === 'dest' || brokenParam === 'both';
const breakDbDest = brokenParam === 'db';
const sources = isFirst
  ? []
  : FIXTURE_SOURCES.map((s, i) => ({ ...s, status: breakSrc && i === 0 ? ('reconnect' as const) : ('connected' as const) }));
let firstFileSeen = false;
const destinations = isFirst
  ? []
  : FIXTURE_DESTINATIONS.map((d) => {
      if (d.kind === 'file') {
        const isFirstFile = !firstFileSeen;
        firstFileSeen = true;
        return { ...d, status: breakFileDest && isFirstFile ? ('reconnect' as const) : ('connected' as const) };
      }
      return { ...d, status: breakDbDest ? ('reconnect' as const) : ('connected' as const) };
    });
// ?newbases=N marks the last N bases as "discovered since the last backup" (edit mode)
// to demo the new-bases notify surface. They are unincluded + tagged New.
const newBases = Number(Astro.url.searchParams.get('newbases') ?? '0') || 0;
const state = isFirst
  ? FIXTURE_INTEGRATIONS_STATE_SETUP_MANY
  : {
      ...FIXTURE_INTEGRATIONS_STATE_SETUP_MANY,
      bases: FIXTURE_INTEGRATIONS_STATE_SETUP_MANY.bases.map((b, i, arr) => ({
        ...b,
        isIncluded: i < 2,
        isNew: newBases > 0 && i >= arr.length - newBases,
      })),
    };
---

<SidebarLayout pageTitle={isFirst ? 'Set up backup' : 'Configure backup'} breadcrumbs={breadcrumbs} spaceScoped={true}>
  <IntegrationsSetupWizard state={state} sources={sources} destinations={destinations} mode={mode} />
</SidebarLayout>
