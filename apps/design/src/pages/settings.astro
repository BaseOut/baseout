---
import SidebarLayout from '../layouts/SidebarLayout.astro';
import Card from '@web/components/ui/Card.astro';
import { getBreadcrumbs } from '@web/lib/config';

const breadcrumbs = getBreadcrumbs('/settings');
---

<SidebarLayout pageTitle="Settings" breadcrumbs={breadcrumbs}>
  <div class="space-y-6">
    <Card variant="outlined">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined icon-xl text-primary">tune</span>
        <h3 class="text-lg font-bold">Account Settings</h3>
      </div>
      <p class="text-sm opacity-70">
        Baseout uses passwordless magic-link sign-in — there is no password to manage.
        Additional account controls will appear here as they are added.
      </p>
    </Card>

    <a href="/settings/destinations" class="settings-link">
      <span class="settings-link-ic"><span class="iconify lucide--hard-drive"></span></span>
      <span class="min-w-0 flex-1">
        <span class="block font-semibold">Destinations</span>
        <span class="block text-sm text-base-content/60 mt-0.5">Storage and databases your Spaces back up to. Set up once, reuse across Spaces.</span>
      </span>
      <span class="iconify lucide--chevron-right text-base-content/40"></span>
    </a>
  </div>
</SidebarLayout>

<style>
  .settings-link { display: flex; align-items: center; gap: .9rem; padding: 1rem 1.1rem; border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); text-decoration: none; color: inherit; transition: border-color .12s ease, background .12s ease; }
  .settings-link:hover { border-color: oklch(from var(--color-primary) l c h / .5); background: oklch(from var(--color-primary) l c h / .04); }
  .settings-link-ic { width: 2.4rem; height: 2.4rem; border-radius: .6rem; display: grid; place-items: center; background: oklch(from var(--color-base-200) l c h / .8); flex: none; }
  .settings-link-ic .iconify { font-size: 1.2rem; color: oklch(from var(--color-base-content) l c h / .7); }
</style>
