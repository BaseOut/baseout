---
// Harness route — account-level Sources registry (skeleton).
import SidebarLayout from '../layouts/SidebarLayout.astro';
import SourcesView from '@web/views/SourcesView.astro';
import { getBreadcrumbs } from '@web/lib/config';
import { FIXTURE_SOURCES, FIXTURE_SOURCES_EMPTY, newSource } from '../fixtures/sources';
import ScenarioSwitcher from '../components/ScenarioSwitcher.astro';
import { DEMO_FLOWS } from '../lib/demo-flows';

const breadcrumbs = getBreadcrumbs('/settings');
const fixture = Astro.url.searchParams.get('fixture');
const status = Astro.url.searchParams.get('status');
const method = Astro.url.searchParams.get('method');
const baseList = fixture === 'empty' ? FIXTURE_SOURCES_EMPTY : FIXTURE_SOURCES;
// After "Test & create", the new source appears at the top, ready to connect.
const justAdded = status === 'added' ? newSource(method) : null;
const sources = justAdded ? [justAdded, ...baseList] : baseList;
const notice = justAdded ? 'Airtable source created. Connect it to use in your Spaces.' : null;
---

<SidebarLayout pageTitle="Sources" breadcrumbs={breadcrumbs}>
  <SourcesView sources={sources} notice={notice} />
  <ScenarioSwitcher flows={DEMO_FLOWS} />
</SidebarLayout>
