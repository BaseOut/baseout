---
import AuthLayout from '../layouts/AuthLayout.astro';
import TextInput from '@web/components/ui/TextInput.astro';
import Select from '@web/components/ui/Select.astro';
import Checkbox from '@web/components/ui/Checkbox.astro';
import Button from '@web/components/ui/Button.astro';
import { getProductName } from '@web/lib/config';

const productName = getProductName();
const user = Astro.locals.user;

const referralOptions = [
  { value: 'google', label: 'Google' },
  { value: 'twitter_x', label: 'Twitter / X' },
  { value: 'friend', label: 'Friend' },
  { value: 'podcast', label: 'Podcast' },
  { value: 'other', label: 'Other' },
];
---

<AuthLayout title={`Welcome — ${productName}`}>
  <div class="auth-card-inner">
    <h2 class="auth-card-title">Welcome{user?.email ? `, ${user.email}` : ''}</h2>
    <p class="auth-card-subtitle">A few quick details and you're in.</p>

    <form id="welcome-form" class="auth-form" novalidate>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <TextInput
          type="text"
          name="firstName"
          label="First Name"
          icon="user"
          placeholder="Ada"
          autocomplete="given-name"
          required
        />
        <TextInput
          type="text"
          name="lastName"
          label="Last Name"
          placeholder="Lovelace"
          autocomplete="family-name"
          required
        />
      </div>

      <TextInput
        type="text"
        name="jobTitle"
        label="Job Title"
        icon="id-card"
        placeholder="Founder"
        autocomplete="organization-title"
        required
      />

      <TextInput
        type="text"
        name="orgName"
        label="Organization Name"
        icon="building-2"
        placeholder="Acme Corp"
        autocomplete="organization"
        required
      />

      <Select
        name="referralSource"
        label="How did you hear about us?"
        icon="megaphone"
        placeholder="Select one (optional)"
        options={referralOptions}
      />

      <Checkbox
        name="marketingOptIn"
        label="I'd like to receive product updates and announcements."
      />

      <Checkbox name="termsAccepted" label="I agree to the terms and privacy policy" />

      <div id="welcome-error" class="fieldset-label text-error flex items-center gap-1 hidden" role="alert">
        <span class="iconify lucide--circle-alert icon-sm" aria-hidden="true"></span>
        <span id="welcome-error-text"></span>
      </div>

      <Button variant="primary" type="submit" class="w-full mt-1">
        Continue
        <span class="iconify lucide--arrow-right icon-lg ml-1" aria-hidden="true"></span>
      </Button>
    </form>
  </div>
</AuthLayout>

<script>
  import { setButtonLoading } from '@web/lib/ui';

  function init() {
    const form = document.getElementById('welcome-form') as HTMLFormElement | null;
    const errorEl = document.getElementById('welcome-error') as HTMLElement | null;
    const errorText = document.getElementById('welcome-error-text') as HTMLElement | null;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    if (!form || !errorEl || !errorText || !submitBtn) return;

    function showError(msg: string) {
      errorText!.textContent = msg;
      errorEl!.classList.remove('hidden');
    }

    function hideError() {
      errorEl!.classList.add('hidden');
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form!);
      hideError();
      if (!((data.get('firstName') as string) ?? '').trim()) return showError('Please enter your first name.');
      if (!((data.get('lastName') as string) ?? '').trim()) return showError('Please enter your last name.');
      if (!((data.get('jobTitle') as string) ?? '').trim()) return showError('Please enter your job title.');
      if (!((data.get('orgName') as string) ?? '').trim()) return showError('Please enter your organization name.');
      if (!data.get('termsAccepted')) return showError('Please accept the terms to continue.');

      setButtonLoading(submitBtn!, true);
      window.setTimeout(() => {
        window.location.href = '/';
      }, 500);
    });
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
