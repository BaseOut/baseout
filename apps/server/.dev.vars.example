# Local-dev configuration for apps/server (Cloudflare Worker — backup engine).
# Copy to .dev.vars and fill in real values. .dev.vars is gitignored.
# CI gets these from GitHub secrets / wrangler secret put at deploy time.
#
# DO NOT wrap values in quotes (KEY="value"). Wrangler's .dev.vars loader
# treats the surrounding quotes as part of the value, so `INTERNAL_TOKEN="abc"`
# becomes the literal string `"abc"` (with quotes) at runtime. Mismatched
# against any caller that sent the bare token. Write `KEY=value` exactly.

# === Master DB (baseout-master Postgres on DigitalOcean) ===
# The engine reads connections + writes backup_runs here. apps/web owns
# the schema (migrations live there) and writes all customer-facing data into
# the same DB — point this at the same value apps/web has.
#
# Local dev requires your laptop's public IP on the openside-db cluster's
# Trusted Sources list (Cloudflare Console → Databases → openside-db →
# Settings → Trusted Sources).
DATABASE_URL=postgres://USER:PASS@HOST:25060/baseout-dev?sslmode=require

# === Trigger.dev ===
# Project-scoped secret key from https://cloud.trigger.dev for the
# baseout-backup-engine project. CI uses TRIGGER_ACCESS_TOKEN for deploys.
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxx
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxxxxxxxxxx

# === Internal-token gate ===
# Shared secret between apps/web (which calls the engine to enqueue
# backups) and the engine for /api/internal/* routes. 32+ random bytes, base64.
# apps/web must hold the same value in its .env / .dev.vars as
# BACKUP_ENGINE_INTERNAL_TOKEN.
INTERNAL_TOKEN=replace-with-32-bytes-of-base64-randomness

# === Master encryption key (cron now reads AND writes) ===
# AES-256-GCM key for the *_enc columns in baseout.connections (and other
# encrypted-at-rest columns). Same value apps/web has in its
# BASEOUT_ENCRYPTION_KEY var. apps/web's OAuth callback is the canonical
# writer at initial connect; the engine's OAuth-refresh cron is the second
# writer (openspec/changes/baseout-server-cron-oauth-refresh/). All other
# engine paths only decrypt.
# Generate: `openssl rand -base64 32`.
BASEOUT_ENCRYPTION_KEY=replace-with-base64-of-32-random-bytes

# === Airtable OAuth app credentials (cron-only — same as apps/web) ===
# Used by the OAuth-refresh cron to POST grant_type=refresh_token to
# https://airtable.com/oauth2/v1/token with HTTP Basic auth on
# client_id:client_secret. Must match the values in apps/web/.dev.vars.
# Boss owns the OAuth app — see memory project_leaked_secrets_pending_rotate
# for rotation steps.
AIRTABLE_OAUTH_CLIENT_ID=
AIRTABLE_OAUTH_CLIENT_SECRET=

# === Optional: local-dev TLS bypass ===
# Set DRIZZLE_SSL=false ONLY if connecting to a local Postgres without TLS.
# Leave unset / "require" for any DigitalOcean managed DB.
# DRIZZLE_SSL=require
