{
  "name": "@baseout/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Backup engine, restore engine, background services, schema diff, DB provisioning, On2Air migration. See ./openspec/proposal.md.",
  "scripts": {
    "dev": "node --env-file-if-exists=.env scripts/launch.mjs dev && wrangler dev --port 4341",
    "render-config": "node --env-file-if-exists=.env scripts/launch.mjs dev",
    "build": "tsup src/index.ts --format esm --dts",
    "deploy": "node --env-file-if-exists=.env scripts/launch.mjs deploy && wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@baseout/db-schema": "workspace:*",
    "@baseout/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20240924.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.61.1"
  }
}
