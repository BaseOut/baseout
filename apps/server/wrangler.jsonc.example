// Template for apps/server/wrangler.jsonc. Rendered by scripts/launch.mjs:
//   - the DATABASE_URL placeholder below is replaced with the value from
//     .dev.vars, written into the gitignored wrangler.jsonc
//
// Why a template + renderer (mirrors apps/web's pattern):
//   localConnectionString is read by `wrangler dev` BEFORE .dev.vars is
//   loaded by the worker runtime, so it can't come from a runtime secret.
//   Committing the literal credential is forbidden (CLAUDE.md §3.3 +
//   PRD §20.1: secrets via Cloudflare Secrets or .env, never committed).
//   The template lets us version control the structure while the credential
//   stays in apps/server/.dev.vars (gitignored).
//
// Deployed Workers do NOT use localConnectionString — they connect via the
// Hyperdrive `id`. So the placeholder rendering matters only for local dev.

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "baseout-server",
  "main": "./src/index.ts",
  "compatibility_date": "2026-04-22",
  "compatibility_flags": ["nodejs_compat"],

  // Durable Objects — canonical names per CLAUDE.md §5.3.
  // ConnectionDO: per-Airtable-Connection rate-limit gateway + state holder.
  // SpaceDO: per-Space scheduler + backup controller.
  "durable_objects": {
    "bindings": [
      { "name": "CONNECTION_DO", "class_name": "ConnectionDO" },
      { "name": "SPACE_DO", "class_name": "SpaceDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ConnectionDO", "SpaceDO"] }
  ],

  // R2 buckets — TODO(phase-1): wire when backup output streaming lands.
  // "r2_buckets": [
  //   { "binding": "BACKUP_BUCKET", "bucket_name": "baseout-backups" }
  // ],

  // Hyperdrive — local dev uses localConnectionString; the `id` is just a
  // label until the Hyperdrive is provisioned for staging/production deploy.
  // postgres-js direct TLS hangs inside workerd's nodejs_compat — Hyperdrive
  // (which proxies the connection) is what actually makes per-request
  // postgres-js usable from a Worker. See apps/web/wrangler.jsonc for the
  // matching binding (same dev DB cluster, same id is fine for local dev).
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "ba2652f40f864918a2da0849f24d12a2",
      "localConnectionString": "{{DATABASE_URL}}"
    }
  ],

  // Cron triggers — TODO(phase-2): one per background service.
  // "triggers": {
  //   "crons": [
  //     "0 6 * * *",     // webhook renewal — daily at 06:00 UTC
  //     "*/15 * * * *",  // OAuth token refresh — every 15 minutes
  //     "0 * * * *",     // trial-expiry monitor — hourly
  //     "0 * * * *",     // quota-usage monitor — hourly
  //     "0 2 * * *"      // smart-cleanup scheduler — daily at 02:00 UTC
  //   ]
  // },

  // Service bindings (incoming forwards from hooks + api)
  // are configured via the Cloudflare dashboard once those Workers exist.

  // Secrets (set via `wrangler secret put` in deployed envs; .dev.vars locally):
  //   INTERNAL_TOKEN          — shared secret with apps/web (BACKUP_ENGINE_INTERNAL_TOKEN)
  //   DATABASE_URL            — master DB (postgres-js per-request, per CLAUDE.md §5.1)
  //                             only used in local wrangler dev; deployed envs read HYPERDRIVE.
  //   BASEOUT_ENCRYPTION_KEY  — AES-256-GCM key for *_enc columns; must match apps/web
  //   TRIGGER_SECRET_KEY      — Trigger.dev v3 server-side key
  //   TRIGGER_PROJECT_REF     — Trigger.dev project ID
  //   CLOUDFLARE_API_TOKEN, STRIPE_API_KEY, MAILGUN_API_KEY — phase-2

  // Wrangler does NOT inherit non-inheritable keys (vars, hyperdrive,
  // kv_namespaces, send_email, durable_objects) from top-level into env
  // blocks — every env redeclares the full set. Migrations stay top-level.
  // See: https://developers.cloudflare.com/workers/wrangler/configuration/#environments
  //
  // env.staging / env.production are placeholders today — they'll get full
  // redeclarations under the follow-up openspec change covering staging+prod
  // service-binding wiring.
  "env": {
    "dev": {
      "name": "baseout-server-dev",
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "ba2652f40f864918a2da0849f24d12a2",
          "localConnectionString": "{{DATABASE_URL}}"
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "CONNECTION_DO", "class_name": "ConnectionDO" },
          { "name": "SPACE_DO", "class_name": "SpaceDO" }
        ]
      }
    },
    "production": {
      "name": "baseout-server"
    },
    "staging": {
      "name": "baseout-server-staging"
    }
  }
}
