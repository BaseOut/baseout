// Test-profile wrangler config for the @cloudflare/vitest-pool-workers harness.
// Defines the DO bindings + migrations the test isolate needs to mount the
// worker entry point.
//
// Note: `vars` are NOT defined here. Test values are passed via
// `miniflare.bindings` in vitest.config.ts so they cleanly override any
// `.dev.vars` the developer has locally — without that override, miniflare's
// .dev.vars loader would shadow the test bindings with real local secrets.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "baseout-server-test",
  "main": "./src/index.ts",
  "compatibility_date": "2026-04-22",
  "compatibility_flags": ["nodejs_compat"],

  "durable_objects": {
    "bindings": [
      { "name": "CONNECTION_DO", "class_name": "ConnectionDO" },
      { "name": "SPACE_DO", "class_name": "SpaceDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ConnectionDO", "SpaceDO"] }
  ],

  // R2 buckets — Miniflare backs these with an in-process bucket so tests
  // can drive R2 writes via env.BACKUPS_R2 without real Cloudflare creds.
  // The bucket_name is opaque to Miniflare; we use the prod-shaped name so
  // tests are explicit about what they're standing in for.
  "r2_buckets": [
    { "binding": "BACKUPS_R2", "bucket_name": "baseout-backups-dev" }
  ]
}
