# Local development secrets for @baseout/web. Copy to .dev.vars and fill in.
# .dev.vars is gitignored.
DATABASE_URL=postgres://localhost:5432/baseout_dev
MASTER_ENCRYPTION_KEY=
BETTER_AUTH_SECRET=
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
MAILGUN_API_KEY=
AIRTABLE_OAUTH_CLIENT_SECRET=
# Google OAuth (Drive). App registered in Google Cloud Console.
# Redirect URI on Worker side: <origin>/oauth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
SERVICE_HMAC_TO_BACKUP=
POSTHOG_PROJECT_KEY=
DUB_CO_API_KEY=

# === Backup engine (@baseout/server) ===
# apps/web reaches @baseout/server through a Cloudflare Worker service
# binding (env.BACKUP_ENGINE) declared in wrangler.jsonc.example. There is
# no URL to configure — Cloudflare resolves the binding to the deployed
# Worker named `baseout-server-<env>` in the same account.
#
# Deploy precondition (one-time per developer):
#   pnpm --filter @baseout/server deploy:dev
# This lands `baseout-server-dev.openside.workers.dev`, which the dev
# binding resolves to. See shared/internal/ops-setup.md for details +
# how to redeploy when apps/server changes.
#
# Token: defense-in-depth header sent on every binding fetch — must equal
# apps/server's INTERNAL_TOKEN (32+ random bytes, base64). Generate once:
# `openssl rand -base64 32`. Mismatch = engine 401 → web 502.
BACKUP_ENGINE_INTERNAL_TOKEN=replace-with-32-bytes-of-base64-randomness

# === E2E / AI-verification token ===
# HMAC secret consumed by /api/internal/test/last-verification, the test-only
# endpoint that lets Playwright (and Claude's MCP-driven AI verification, see
# apps/web/.claude/CLAUDE.md §3.5) read back a magic-link token without going
# through a real inbox. Must match the value used by the caller to sign the
# email in the X-E2E-Test-Auth header. Generate with `openssl rand -base64 32`.
#
# Required for: `pnpm test:e2e` against the local dev worker, and Claude's
# AI verification pass during UI-touching work. Without it set the test
# endpoint 401s and verification cannot sign in.
#
# Production / staging hold the equivalent value via `wrangler secret put
# E2E_TEST_TOKEN`. Leave unset in any environment where E2E_TEST_MODE != "true".
E2E_TEST_TOKEN=replace-with-32-bytes-of-base64-randomness
