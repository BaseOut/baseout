# Local development secrets for @baseout/web. Copy to .dev.vars and fill in.
# .dev.vars is gitignored.
DATABASE_URL=postgres://localhost:5432/baseout_dev
MASTER_ENCRYPTION_KEY=
BETTER_AUTH_SECRET=
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
MAILGUN_API_KEY=
AIRTABLE_OAUTH_CLIENT_SECRET=
SERVICE_HMAC_TO_BACKUP=
POSTHOG_PROJECT_KEY=
DUB_CO_API_KEY=

# === Backup engine (@baseout/server) ===
# apps/web calls @baseout/server over HTTP with x-internal-token header
# (CLAUDE.md §5.2 + §3.3). Both vars below must match apps/server's
# .dev.vars: BACKUP_ENGINE_URL points at apps/server's wrangler dev port,
# and BACKUP_ENGINE_INTERNAL_TOKEN equals apps/server's INTERNAL_TOKEN.
#
# URL: matches apps/server's wrangler dev port (8787 = wrangler default).
BACKUP_ENGINE_URL=http://localhost:8787
# Token: same value as apps/server's INTERNAL_TOKEN (32+ random bytes, base64).
# Generate once: `openssl rand -base64 32`. Paste the same value into both
# apps/web/.dev.vars (here as BACKUP_ENGINE_INTERNAL_TOKEN) and
# apps/server/.dev.vars (as INTERNAL_TOKEN). Mismatch = engine 401 → web 502.
BACKUP_ENGINE_INTERNAL_TOKEN=replace-with-32-bytes-of-base64-randomness
