# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.
#
# Runtime (Cloudflare Worker) does NOT read this file. Runtime config lives in
# wrangler.jsonc (Hyperdrive binding + vars) and wrangler secrets. These vars
# are used by:
#   - drizzle-kit  (migrations: drizzle.config.ts reads DATABASE_URL)
#   - npm run seed (scripts/seed.ts connects via src/db/node.ts)
#   - BETTER_AUTH_SECRET is also surfaced to local `astro dev` via platformProxy
#     (in production, set via `npx wrangler secret put BETTER_AUTH_SECRET`).

# Postgres connection string (Drizzle + postgres.js, Node-only tooling).
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Better Auth signing secret. Generate a new one with:
#   openssl rand -base64 32
# In production, set via:  npx wrangler secret put BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32

# Transactional email provider (Resend). In development, sendEmail() logs the
# magic-link payload to the console and does not call Resend — these values are
# only required for staging/production. In production, store the API key as a
# Cloudflare Secret:  npx wrangler secret put RESEND_API_KEY
RESEND_API_KEY=

# "From" header for transactional mail. Must be a verified sender on the
# Cloudflare Email Sending service domain.
# Example: "Baseout <login@mail.baseout.dev>"
EMAIL_FROM=

# Stripe — used by /api/onboarding/complete to create a $0 trial Customer +
# Subscription at signup. When both keys are set, onboarding runs the real
# Stripe trial flow end-to-end.
# In production, store as a Cloudflare Secret:
#   npx wrangler secret put STRIPE_SECRET_KEY
# (.env is not read at runtime — add Stripe keys to .dev.vars for local dev,
# or wrangler secrets for deploys.)
STRIPE_SECRET_KEY=

# Stripe Price ID (not Product ID) used to seed the 7-day trial subscription.
STRIPE_TRIAL_PRICE_ID=

# Dev-only escape hatch for /api/onboarding/complete. When set to "1" in
# .dev.vars, the handler skips Stripe customer/subscription creation and still
# finishes onboarding (Org + Space persisted, terms accepted). Use ONLY until
# Stripe test mode is provisioned; then set the two STRIPE_* keys in .dev.vars
# and remove this flag. MUST NOT be set in production — .dev.vars is local
# only, and wrangler.jsonc does not declare DEV_SKIP_STRIPE.
DEV_SKIP_STRIPE=

# FontAwesome Pro npm registry token. Referenced by .npmrc as
# ${FONTAWESOME_TOKEN} so `npm install` can authenticate to
# npm.fontawesome.com for @fortawesome/fontawesome-pro.
# npm itself does NOT read this file — export the token in your shell
# (e.g. ~/.zshrc) or run `set -a; source .env; set +a; npm install`.
# In CF Workers Builds, set via:  npx wrangler secret put FONTAWESOME_TOKEN
FONTAWESOME_TOKEN=

# GitHub Packages token for the @opensided scope (used when pulling
# @opensided/* packages off GitHub Packages). The vendored theme
# (vendor/@opensided/theme) makes this optional locally, but keep it
# set if you also pull other @opensided scoped packages.
NPM_TOKEN=

# ─── Airtable integration ─────────────────────────────────────────────────────
# OAuth app client credentials.
#
# AUTHORITATIVE source-of-truth for which redirect URIs must be registered per
# env + current registration status: shared/internal/oauth-setup.md §3.1, §4.2
#
# Quick reference (✅ = registered today, ❌ = MISSING):
#   ❌ https://localhost:4331/api/connections/airtable/callback                       (local — use the baseout-dev workaround per oauth-setup.md §5.2 until this is added)
#   ✅ https://baseout.local:4331/api/connections/airtable/callback                   (local via /etc/hosts mapping)
#   ✅ https://baseout-dev.openside.workers.dev/api/connections/airtable/callback     (deployed dev worker)
#   ❌ https://baseout-staging.openside.workers.dev/api/connections/airtable/callback (staging)
#   ❌ https://console.baseout.dev/api/connections/airtable/callback                  (prod)
#
# In production, store as Cloudflare Secrets:
#   npx wrangler secret put AIRTABLE_OAUTH_CLIENT_ID
#   npx wrangler secret put AIRTABLE_OAUTH_CLIENT_SECRET
# For local dev, add both to .dev.vars (gitignored).
AIRTABLE_OAUTH_CLIENT_ID=
AIRTABLE_OAUTH_CLIENT_SECRET=

# Dev-only: impersonate airtable.com via local routes under /api/stub/airtable/*
# so the full OAuth + Meta API round-trip runs without real Airtable creds.
# When set to "1", resolveAirtableUrls() rewrites the authorize/token/api URLs
# to point at the local stubs; the stub routes return 404 unless this var is
# also "1". Use when the localhost:4331 Airtable URI is not yet registered
# (see oauth-setup.md §5.3). MUST NOT be set in production — only .dev.vars.
AIRTABLE_STUBS_ENABLED=

# ─── Google Drive integration (BYOS storage) ──────────────────────────────────
# OAuth 2.0 client credentials from Google Cloud Console, project `baseout-dev`.
#
# AUTHORITATIVE source-of-truth for which redirect URIs must be registered per
# env + current registration status: shared/internal/oauth-setup.md §3.2, §4.1
#
# Callback path on THIS branch (autumn/backup-fix-local):
#   /api/connections/storage/google-drive/callback
# (Some other branches use /oauth/callback/google — code-defined per branch.
# Always match the URI you register to the path your branch's handler serves.)
#
# Quick reference (✅ = registered today, ❌ = MISSING):
#   ❌ https://localhost:4331/api/connections/storage/google-drive/callback                       (local)
#   ❌ https://baseout.local:4331/api/connections/storage/google-drive/callback                   (local via /etc/hosts)
#   ❌ https://baseout-dev.openside.workers.dev/api/connections/storage/google-drive/callback     (deployed dev worker)
#   ❌ https://baseout-staging.openside.workers.dev/api/connections/storage/google-drive/callback (staging)
#   ❌ https://console.baseout.dev/api/connections/storage/google-drive/callback                  (prod)
# NOTE: Google currently has the OTHER branch's path registered
# (/oauth/callback/google for localhost + console.baseout.dev). Those URIs do
# not route to a handler on this branch. See oauth-setup.md §4.1.
#
# Scope: https://www.googleapis.com/auth/drive.file (least privilege — app
# only sees files it creates).
#
# In production, store as Cloudflare Secrets:
#   npx wrangler secret put GOOGLE_DRIVE_OAUTH_CLIENT_ID
#   npx wrangler secret put GOOGLE_DRIVE_OAUTH_CLIENT_SECRET
# For local dev, add both to .dev.vars (gitignored).
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=

# Master key for AES-256-GCM encryption of OAuth tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must decode to exactly 32 bytes. Rotating this key invalidates all stored
# OAuth tokens; all connections will require re-auth. In production, store via:
#   npx wrangler secret put BASEOUT_ENCRYPTION_KEY
BASEOUT_ENCRYPTION_KEY=
