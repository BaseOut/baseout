{
  "name": "@baseout/web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env scripts/dev.mjs",
    "setup:certs": "mkdir -p .certs && mkcert -install && mkcert -cert-file .certs/baseout.local.pem -key-file .certs/baseout.local-key.pem baseout.local localhost 127.0.0.1",
    "setup:hosts": "grep -q baseout.local /etc/hosts || echo '127.0.0.1 baseout.local' | sudo tee -a /etc/hosts",
    "build": "node --env-file-if-exists=.env scripts/launch.mjs build",
    "wrangler": "node --env-file-if-exists=.env scripts/launch.mjs build local && wrangler dev --remote --port 4331 --var PUBLIC_AUTH_BASE_URL:https://baseout.local:4331",
    "wrangler:baseout": "node --env-file-if-exists=.env scripts/launch.mjs build local && wrangler dev --remote --port 4331 --var PUBLIC_AUTH_BASE_URL:https://baseout.dev",
    "deploy": "node --env-file-if-exists=.env scripts/launch.mjs build && wrangler deploy --config dist/server/wrangler.json && pnpm run secrets:sync",
    "secrets:sync": "node scripts/sync-secrets.mjs --config dist/server/wrangler.json",
    "deploy:staging": "CLOUDFLARE_ENV=staging node --env-file-if-exists=.env scripts/launch.mjs build && wrangler deploy --config dist/server/wrangler.json",
    "deploy:production": "CLOUDFLARE_ENV=production node --env-file-if-exists=.env scripts/launch.mjs build && wrangler deploy --config dist/server/wrangler.json",
    "versions:upload:production": "CLOUDFLARE_ENV=production node --env-file-if-exists=.env scripts/launch.mjs build && wrangler versions upload --config dist/server/wrangler.json",
    "versions:deploy:production": "wrangler versions deploy --name baseout",
    "cf-typegen": "wrangler types",
    "astro": "astro",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build -o dist/storybook",
    "audit:components": "vitest run src/components/ui/stories-coverage.test.ts src/components/component-classification.test.ts && storybook build -o dist/storybook",
    "setup": "node scripts/setup.mjs --force",
    "setup:tokens": "node scripts/setup.mjs --tokens-only",
    "seed": "node --env-file=.env --import tsx/esm scripts/seed.ts",
    "db:migrate": "node --env-file-if-exists=.env scripts/migrate.mjs",
    "db:check": "node --env-file-if-exists=.env scripts/check-migrations.mjs",
    "typecheck": "astro check",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@baseout/db-schema": "workspace:*",
    "@opensided/theme": "file:./vendor/@opensided/theme",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.2",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "nanostores": "^1.3.0",
    "postgres": "^3.4.9",
    "stripe": "^22.0.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20250906.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@iconify-json/lucide": "^1.2.105",
    "@iconify/tailwind4": "^1.2.3",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-themes": "10.4.3",
    "@storybook/html-vite": "10.4.3",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.4",
    "storybook": "10.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "7.3.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.61.1"
  },
  "overrides": {
    "vite": "~7.3.1"
  }
}