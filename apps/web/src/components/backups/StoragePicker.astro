---
/**
 * Wizard step 4 — Storage destination picker.
 *
 * `r2_managed` is the legacy default; `google_drive`, `box`, and `dropbox`
 * are the shipped BYOS cloud destinations (openspec/changes/shared-byos-drive
 * + box + dropbox provider commit chains). Other rows are visibly disabled
 * with a "Coming soon" label. The PATCH route validates the value against
 * the same accept list as defense-in-depth.
 *
 * Box and Dropbox visibility are env-gated: each radio only appears as
 * enabled when its respective OAUTH_CLIENT_ID is configured. A half-
 * configured deploy keeps the option as "Coming soon" rather than a
 * connect button that 503s.
 *
 * Props:
 *   spaceId             — UUID of the active Space
 *   selectedStorageType — currently saved value (defaults to 'r2_managed')
 */

import { env } from 'cloudflare:workers'

interface Props {
  spaceId: string
  selectedStorageType?: string
}

const { spaceId, selectedStorageType = 'r2_managed' } = Astro.props as Props

const workerEnv = env as unknown as {
  BOX_OAUTH_CLIENT_ID?: string
  DROPBOX_OAUTH_CLIENT_ID?: string
  MICROSOFT_OAUTH_CLIENT_ID?: string
}
const boxEnabled = Boolean(workerEnv.BOX_OAUTH_CLIENT_ID)
const dropboxEnabled = Boolean(workerEnv.DROPBOX_OAUTH_CLIENT_ID)
const oneDriveEnabled = Boolean(workerEnv.MICROSOFT_OAUTH_CLIENT_ID)

const ALL_OPTIONS: {
  value: string
  label: string
  helper: string
  enabled: boolean
}[] = [
  {
    value: 'r2_managed',
    label: 'Cloudflare R2 (managed by Baseout)',
    helper: 'Default — encrypted at rest, no setup required.',
    enabled: true,
  },
  {
    value: 'google_drive',
    label: 'Google Drive',
    helper:
      'Connect your Google account; backups land in a per-Space Baseout folder.',
    enabled: true,
  },
  {
    value: 'dropbox',
    label: 'Dropbox',
    helper: dropboxEnabled
      ? 'Connect your Dropbox account; backups land in a per-Space Baseout folder.'
      : 'Coming soon — connect your Dropbox account.',
    enabled: dropboxEnabled,
  },
  {
    value: 'box',
    label: 'Box',
    helper: boxEnabled
      ? 'Connect your Box account; backups land in a per-Space Baseout folder.'
      : 'Coming soon — connect your Box account.',
    enabled: boxEnabled,
  },
  {
    value: 'onedrive',
    label: 'OneDrive',
    helper: oneDriveEnabled
      ? 'Connect your Microsoft account; backups land in a per-Space Baseout folder in your OneDrive.'
      : 'Coming soon — connect your OneDrive.',
    enabled: oneDriveEnabled,
  },
  {
    value: 's3',
    label: 'Amazon S3',
    helper: 'Growth+ — your own S3 bucket. Coming soon.',
    enabled: false,
  },
]

const NAME = 'backup-storage'
---

<section
  class="rounded-lg border border-base-300 p-4 sm:p-6"
  data-storage-picker
  data-space-id={spaceId}
  aria-labelledby="storage-picker-heading"
>
  <h3 id="storage-picker-heading" class="text-base font-semibold">
    Storage destination
  </h3>
  <p class="mt-1 text-sm text-base-content/70">
    Where Baseout writes the CSV backup. R2 is the managed default; bring-
    your-own-storage providers ship in a later phase.
  </p>

  <fieldset class="mt-4 grid gap-3" data-storage-fieldset>
    <legend class="sr-only">Storage destination</legend>
    {ALL_OPTIONS.map((opt) => (
      <label
        class:list={[
          'flex min-h-11 items-start gap-3 rounded-md border border-base-300 p-3 cursor-pointer',
          'hover:bg-base-200/50',
          !opt.enabled && 'opacity-60 cursor-not-allowed',
        ]}
        aria-disabled={!opt.enabled ? 'true' : undefined}
        title={!opt.enabled ? 'Coming soon' : undefined}
      >
        <input
          type="radio"
          name={NAME}
          value={opt.value}
          class="radio radio-primary mt-0.5"
          checked={opt.value === selectedStorageType}
          disabled={!opt.enabled}
          data-storage-radio
        />
        <span class="flex-1">
          <span class="block text-sm font-medium">
            {opt.label}
            {!opt.enabled && (
              <span class="ml-2 align-middle inline-block px-1.5 py-0.5 rounded bg-base-200 text-xs text-base-content/70">
                Coming soon
              </span>
            )}
          </span>
          <span class="block text-xs text-base-content/70">{opt.helper}</span>
        </span>
      </label>
    ))}
  </fieldset>

  <form
    method="POST"
    action="/api/connections/storage/google-drive/authorize"
    class:list={[
      'mt-3 flex items-center justify-between gap-3 rounded-md border border-base-300 p-3',
      selectedStorageType !== 'google_drive' && 'hidden',
    ]}
    data-storage-drive-connect
    data-astro-reload
  >
    <input type="hidden" name="returnTo" value={Astro.url.pathname} />
    <span class="text-sm text-base-content/80">
      Connect a Google account to use this destination. Re-clicking issues a
      fresh consent and keeps the same per-Space folder.
    </span>
    <button
      type="submit"
      class="btn btn-sm btn-primary"
      data-storage-drive-connect-btn
    >
      Connect Google Drive
    </button>
  </form>

  {boxEnabled && (
    <form
      method="POST"
      action="/api/connections/storage/box/authorize"
      class:list={[
        'mt-3 flex items-center justify-between gap-3 rounded-md border border-base-300 p-3',
        selectedStorageType !== 'box' && 'hidden',
      ]}
      data-storage-box-connect
      data-astro-reload
    >
      <input type="hidden" name="returnTo" value={Astro.url.pathname} />
      <span class="text-sm text-base-content/80">
        Connect a Box account to use this destination. Re-clicking issues a
        fresh consent and keeps the same per-Space folder.
      </span>
      <button
        type="submit"
        class="btn btn-sm btn-primary"
        data-storage-box-connect-btn
      >
        Connect Box
      </button>
    </form>
  )}

  {dropboxEnabled && (
    <form
      method="POST"
      action="/api/connections/storage/dropbox/authorize"
      class:list={[
        'mt-3 flex items-center justify-between gap-3 rounded-md border border-base-300 p-3',
        selectedStorageType !== 'dropbox' && 'hidden',
      ]}
      data-storage-dropbox-connect
      data-astro-reload
    >
      <input type="hidden" name="returnTo" value={Astro.url.pathname} />
      <span class="text-sm text-base-content/80">
        Connect a Dropbox account to use this destination. Re-clicking
        issues a fresh consent and keeps the same per-Space folder.
      </span>
      <button
        type="submit"
        class="btn btn-sm btn-primary"
        data-storage-dropbox-connect-btn
      >
        Connect Dropbox
      </button>
    </form>
  )}

  {oneDriveEnabled && (
    <form
      method="POST"
      action="/api/connections/storage/onedrive/authorize"
      class:list={[
        'mt-3 flex items-center justify-between gap-3 rounded-md border border-base-300 p-3',
        selectedStorageType !== 'onedrive' && 'hidden',
      ]}
      data-storage-onedrive-connect
      data-astro-reload
    >
      <input type="hidden" name="returnTo" value={Astro.url.pathname} />
      <span class="text-sm text-base-content/80">
        Connect a Microsoft account to use this destination. Re-clicking
        issues a fresh consent and keeps the same per-Space folder.
      </span>
      <button
        type="submit"
        class="btn btn-sm btn-primary"
        data-storage-onedrive-connect-btn
      >
        Connect OneDrive
      </button>
    </form>
  )}

  <p
    role="status"
    class="mt-3 hidden text-sm text-success"
    data-storage-status
  ></p>
  <p
    role="alert"
    class="mt-3 hidden text-sm text-error"
    data-storage-error
  ></p>
</section>

<script>
  import { saveBackupConfig } from '../../lib/backups/save-config'
  import { setButtonLoading } from '../../lib/ui'

  const root = document.querySelector<HTMLElement>('[data-storage-picker]')
  if (root) {
    const spaceId = root.dataset.spaceId!
    const status = root.querySelector<HTMLParagraphElement>(
      '[data-storage-status]',
    )
    const error = root.querySelector<HTMLParagraphElement>(
      '[data-storage-error]',
    )
    const radios = root.querySelectorAll<HTMLInputElement>(
      '[data-storage-radio]',
    )
    const driveConnectForm = root.querySelector<HTMLFormElement>(
      '[data-storage-drive-connect]',
    )
    const driveConnectBtn = root.querySelector<HTMLButtonElement>(
      '[data-storage-drive-connect-btn]',
    )
    const boxConnectForm = root.querySelector<HTMLFormElement>(
      '[data-storage-box-connect]',
    )
    const boxConnectBtn = root.querySelector<HTMLButtonElement>(
      '[data-storage-box-connect-btn]',
    )
    const dropboxConnectForm = root.querySelector<HTMLFormElement>(
      '[data-storage-dropbox-connect]',
    )
    const dropboxConnectBtn = root.querySelector<HTMLButtonElement>(
      '[data-storage-dropbox-connect-btn]',
    )
    const oneDriveConnectForm = root.querySelector<HTMLFormElement>(
      '[data-storage-onedrive-connect]',
    )
    const oneDriveConnectBtn = root.querySelector<HTMLButtonElement>(
      '[data-storage-onedrive-connect-btn]',
    )

    function showStatus(msg: string) {
      if (!status || !error) return
      status.textContent = msg
      status.hidden = false
      status.classList.remove('hidden')
      error.hidden = true
      error.classList.add('hidden')
    }
    function showError(msg: string) {
      if (!status || !error) return
      error.textContent = msg
      error.hidden = false
      error.classList.remove('hidden')
      status.hidden = true
      status.classList.add('hidden')
    }

    function toggleDriveConnect(selectedValue: string) {
      if (!driveConnectForm) return
      const visible = selectedValue === 'google_drive'
      driveConnectForm.classList.toggle('hidden', !visible)
    }

    function toggleBoxConnect(selectedValue: string) {
      if (!boxConnectForm) return
      const visible = selectedValue === 'box'
      boxConnectForm.classList.toggle('hidden', !visible)
    }

    function toggleDropboxConnect(selectedValue: string) {
      if (!dropboxConnectForm) return
      const visible = selectedValue === 'dropbox'
      dropboxConnectForm.classList.toggle('hidden', !visible)
    }

    function toggleOneDriveConnect(selectedValue: string) {
      if (!oneDriveConnectForm) return
      const visible = selectedValue === 'onedrive'
      oneDriveConnectForm.classList.toggle('hidden', !visible)
    }

    async function handleChange(value: string) {
      toggleDriveConnect(value)
      toggleBoxConnect(value)
      toggleDropboxConnect(value)
      toggleOneDriveConnect(value)
      const result = await saveBackupConfig({ spaceId, storageType: value })
      if (result.ok) {
        let msg: string
        if (value === 'google_drive') {
          msg =
            'Storage destination saved. If this Space isn’t connected to Drive yet, click Connect Google Drive below.'
        } else if (value === 'box') {
          msg =
            'Storage destination saved. If this Space isn’t connected to Box yet, click Connect Box below.'
        } else if (value === 'dropbox') {
          msg =
            'Storage destination saved. If this Space isn’t connected to Dropbox yet, click Connect Dropbox below.'
        } else if (value === 'onedrive') {
          msg =
            'Storage destination saved. If this Space isn’t connected to OneDrive yet, click Connect OneDrive below.'
        } else {
          msg = 'Storage destination saved.'
        }
        showStatus(msg)
      } else if (result.error === 'unsupported_storage_type') {
        showError('That storage destination is not yet supported.')
      } else {
        showError('Could not save the storage destination. Please try again.')
      }
    }

    for (const radio of radios) {
      radio.addEventListener('change', () => {
        if (radio.checked) {
          void handleChange(radio.value)
        }
      })
    }

    if (driveConnectForm && driveConnectBtn) {
      driveConnectForm.addEventListener('submit', () => {
        // Loading state covers the redirect latency to Google's consent
        // screen. data-astro-reload on the form ensures Astro doesn't try
        // to client-route the cross-origin response.
        setButtonLoading(driveConnectBtn, true)
      })
    }

    if (boxConnectForm && boxConnectBtn) {
      boxConnectForm.addEventListener('submit', () => {
        // Loading state covers the redirect latency to Box's consent screen.
        setButtonLoading(boxConnectBtn, true)
      })
    }

    if (dropboxConnectForm && dropboxConnectBtn) {
      dropboxConnectForm.addEventListener('submit', () => {
        // Loading state covers the redirect latency to Dropbox's consent screen.
        setButtonLoading(dropboxConnectBtn, true)
      })
    }

    if (oneDriveConnectForm && oneDriveConnectBtn) {
      oneDriveConnectForm.addEventListener('submit', () => {
        // Loading state covers the redirect latency to Microsoft's consent screen.
        setButtonLoading(oneDriveConnectBtn, true)
      })
    }

    // After returning from a storage-provider OAuth round-trip the page
    // SSRs from the top; scroll the user back to the storage section so
    // they land where they left off. Airtable's connected=1 is excluded —
    // it lives in a different card above.
    const params = new URLSearchParams(window.location.search)
    const connected = params.get('connected')
    const storageError = params.get('storage_error')
    const STORAGE_PROVIDERS = new Set([
      'google_drive',
      'dropbox',
      'box',
      'onedrive',
    ])
    if ((connected && STORAGE_PROVIDERS.has(connected)) || storageError) {
      root.scrollIntoView({ behavior: 'smooth', block: 'start' })
    }
  }
</script>
