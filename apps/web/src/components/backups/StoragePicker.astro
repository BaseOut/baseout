---
/**
 * Wizard step 4 — Storage destination picker.
 *
 * Per openspec/changes/system-r2-park, managed R2 is paused. Google Drive
 * is the recommended user-facing destination. Drive requires an OAuth
 * connection first — the row exposes a "Connect Google Drive" link that
 * goes through /api/connections/storage/google-drive/authorize. Once
 * connected, the radio is selectable and `oauth_account_email` shows.
 *
 * Per openspec/changes/system-local-fs-dev-writer, a "Local disk (dev
 * only)" option appears when `localFsAvailable` is true (gated to
 * non-production builds). Selecting it writes CSVs under
 * apps/workflows/.backups/ via the workflows-side local_fs StorageWriter;
 * the engine auto-provisions the matching storage_destinations row on
 * first kickoff.
 *
 * R2 stays in the list as a "Paused" row so existing customers see the
 * reason; other rows remain disabled with a "Coming soon" label.
 *
 * Props:
 *   spaceId                  — UUID of the active Space
 *   selectedStorageType      — currently saved value (null until the user
 *                              picks something)
 *   googleDriveConnected     — true if storage_destinations has a google_drive
 *                              row for this Space (callback success)
 *   googleDriveAccountEmail  — `oauth_account_email` for display
 *   localFsAvailable         — show + enable the Local disk option
 *                              (non-production only)
 */

interface Props {
  spaceId: string
  selectedStorageType?: string | null
  googleDriveConnected?: boolean
  googleDriveAccountEmail?: string | null
  localFsAvailable?: boolean
}

const {
  spaceId,
  selectedStorageType = null,
  googleDriveConnected = false,
  googleDriveAccountEmail = null,
  localFsAvailable = false,
} = Astro.props as Props

const ALL_OPTIONS: {
  value: string
  label: string
  helper: string
  enabled: boolean
  comingSoonLabel?: string
  hidden?: boolean
}[] = [
  {
    value: 'google_drive',
    label: 'Google Drive',
    helper: googleDriveConnected
      ? `Connected as ${googleDriveAccountEmail ?? 'Google account'}.`
      : 'Recommended — connect a Google account so Baseout can write CSVs into a Baseout-<space> folder.',
    enabled: googleDriveConnected,
  },
  {
    value: 'local_fs',
    label: 'Local disk (dev only)',
    helper: 'Writes CSVs to apps/workflows/.backups/ on the Trigger.dev runner. No OAuth required. Visible in non-production builds only.',
    enabled: localFsAvailable,
    hidden: !localFsAvailable,
  },
  {
    value: 'r2_managed',
    label: 'Cloudflare R2 (managed by Baseout)',
    helper: 'Paused — managed storage is on hold per system-r2-park; revisit later.',
    enabled: false,
    comingSoonLabel: 'Paused',
  },
  {
    value: 'dropbox',
    label: 'Dropbox',
    helper: 'Coming soon — proxy-streamed to your Dropbox.',
    enabled: false,
  },
  {
    value: 'box',
    label: 'Box',
    helper: 'Coming soon — proxy-streamed to your Box.',
    enabled: false,
  },
  {
    value: 'onedrive',
    label: 'OneDrive',
    helper: 'Coming soon — pick a folder in your OneDrive.',
    enabled: false,
  },
  {
    value: 's3',
    label: 'Amazon S3',
    helper: 'Growth+ — your own S3 bucket. Coming soon.',
    enabled: false,
  },
]

const NAME = 'backup-storage'
---

<section
  class="rounded-lg border border-base-300 p-4 sm:p-6"
  data-storage-picker
  data-space-id={spaceId}
  aria-labelledby="storage-picker-heading"
>
  <h3 id="storage-picker-heading" class="text-base font-semibold">
    Storage destination
  </h3>
  <p class="mt-1 text-sm text-base-content/70">
    Where Baseout writes the CSV backup. Connect a destination so the
    engine has somewhere to write — managed storage is paused for now.
  </p>

  <fieldset class="mt-4 grid gap-3" data-storage-fieldset>
    <legend class="sr-only">Storage destination</legend>
    {ALL_OPTIONS.filter((opt) => !opt.hidden).map((opt) => {
      const isGoogle = opt.value === 'google_drive'
      const showConnectAction = isGoogle && !googleDriveConnected
      const isComingSoon = !opt.enabled && !showConnectAction
      return (
        <label
          class:list={[
            'flex min-h-11 items-start gap-3 rounded-md border border-base-300 p-3 cursor-pointer',
            'hover:bg-base-200/50',
            isComingSoon && 'opacity-60 cursor-not-allowed',
          ]}
          aria-disabled={isComingSoon ? 'true' : undefined}
          title={isComingSoon ? (opt.comingSoonLabel ?? 'Coming soon') : undefined}
        >
          <input
            type="radio"
            name={NAME}
            value={opt.value}
            class="radio radio-primary mt-0.5"
            checked={opt.value === selectedStorageType}
            disabled={!opt.enabled}
            data-storage-radio
          />
          <span class="flex-1">
            <span class="block text-sm font-medium">
              {opt.label}
              {isComingSoon && (
                <span class="ml-2 align-middle inline-block px-1.5 py-0.5 rounded bg-base-200 text-xs text-base-content/70">
                  {opt.comingSoonLabel ?? 'Coming soon'}
                </span>
              )}
              {isGoogle && googleDriveConnected && (
                <span class="ml-2 align-middle inline-block px-1.5 py-0.5 rounded bg-success/10 text-xs text-success">
                  Connected
                </span>
              )}
            </span>
            <span class="block text-xs text-base-content/70">{opt.helper}</span>
            {showConnectAction && (
              <form
                method="POST"
                action="/api/connections/storage/google-drive/authorize"
                class="mt-2"
                data-astro-reload
              >
                <input type="hidden" name="returnTo" value="/integrations" />
                <button
                  type="submit"
                  class="btn btn-primary btn-sm"
                  data-connect-google-drive
                >
                  Connect Google Drive
                </button>
              </form>
            )}
          </span>
        </label>
      )
    })}
  </fieldset>

  <p
    role="status"
    class="mt-3 hidden text-sm text-success"
    data-storage-status
  ></p>
  <p
    role="alert"
    class="mt-3 hidden text-sm text-error"
    data-storage-error
  ></p>
</section>

<script>
  import { saveBackupConfig } from '../../lib/backups/save-config'

  const root = document.querySelector<HTMLElement>('[data-storage-picker]')
  if (root) {
    const spaceId = root.dataset.spaceId!
    const status = root.querySelector<HTMLParagraphElement>(
      '[data-storage-status]',
    )
    const error = root.querySelector<HTMLParagraphElement>(
      '[data-storage-error]',
    )
    const radios = root.querySelectorAll<HTMLInputElement>(
      '[data-storage-radio]',
    )

    function showStatus(msg: string) {
      if (!status || !error) return
      status.textContent = msg
      status.hidden = false
      status.classList.remove('hidden')
      error.hidden = true
      error.classList.add('hidden')
    }
    function showError(msg: string) {
      if (!status || !error) return
      error.textContent = msg
      error.hidden = false
      error.classList.remove('hidden')
      status.hidden = true
      status.classList.add('hidden')
    }

    async function handleChange(value: string) {
      const result = await saveBackupConfig({ spaceId, storageType: value })
      if (result.ok) {
        showStatus('Storage destination saved.')
      } else if (result.error === 'unsupported_storage_type') {
        showError('That storage destination is not yet supported.')
      } else {
        showError('Could not save the storage destination. Please try again.')
      }
    }

    for (const radio of radios) {
      radio.addEventListener('change', () => {
        if (radio.checked) {
          void handleChange(radio.value)
        }
      })
    }
  }
</script>
