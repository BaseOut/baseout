---
/**
 * SpacePipelineHero — the unconfigured Space's empty state, drawn as the product
 * model itself (Airbyte-style): a Source anchor (Airtable, the one platform every
 * backup starts from) → the Baseout hub (this Space) → a Destinations column
 * (Drive / Dropbox / S3 / databases).
 *
 * Teaching-first and decorative: tiles aren't clickable, the single CTA opens the
 * setup wizard. Connection lines softly take turns lighting up (restrained — no
 * traveling pulses); honors prefers-reduced-motion.
 *
 * Brand marks: Airtable + Google Drive are official multicolor assets; Dropbox and
 * AWS are Font Awesome brand glyphs tinted with their brand colors; the database
 * tile uses a generic glyph (Postgres-blue) to stand for the whole DB category
 * rather than fake a specific logo.
 *
 * NOTE: classes are prefixed `sph-` because daisyUI globally defines `.hero`.
 */
import Button from '../ui/Button.astro';

interface Props {
  spaceName: string;
}
const { spaceName } = Astro.props;

// Coordinates in the 760×420 viewBox; HTML tiles reuse the same numbers as
// percentages (the stage keeps the 760/420 aspect) so curves + tiles scale together.
const SRC = { x: 120, y: 196 };
const HUB = { x: 380, y: 196 };
const DEST_X = 660;
const DESTS = [
  { y: 58, img: '/brands/google-drive.svg', alt: 'Google Drive' },
  { y: 150, img: '/brands/dropbox.svg', alt: 'Dropbox' },
  { y: 246, img: '/brands/aws.svg', alt: 'Amazon S3' },
  { y: 338, icon: 'lucide--database', alt: 'Postgres and other databases' },
];
const xp = (n: number) => `${(n / 760) * 100}%`;
const yp = (n: number) => `${(n / 420) * 100}%`;
// Airtable → hub: a straight run between the two big tiles. Hub → each destination: a gentle S-curve.
const leftPath = `M ${SRC.x + 52} ${SRC.y} H ${HUB.x - 52}`;
const rightPath = (y: number) => `M ${HUB.x + 52} ${HUB.y} C 525 ${HUB.y}, 560 ${y}, ${DEST_X - 34} ${y}`;
---

<section class="sph" aria-label={`Set up ${spaceName}'s backup`}>
  <h2 class="sph-title">Set up this Space&rsquo;s backup</h2>
  <p class="sph-sub">Connect Airtable to storage you control.</p>

  <div class="sph-stage" aria-hidden="true">
    <svg class="sph-net" viewBox="0 0 760 420" preserveAspectRatio="none">
      <path class="net-base" d={leftPath} />
      {DESTS.map((d) => <path class="net-base" d={rightPath(d.y)} />)}
      <path class="net-on net-on-left" d={leftPath} />
      {DESTS.map((d, i) => <path class={`net-on net-on-${i}`} d={rightPath(d.y)} />)}
    </svg>

    <span class="sph-col-label" style={`left:${xp(SRC.x)};top:29%`}>Sources</span>
    <span class="sph-col-label" style={`left:${xp(DEST_X)};top:3%`}>Destinations</span>

    {/* Source anchor: Airtable, hub-sized — the platform everything starts from */}
    <span class="sph-anchor" style={`left:${xp(SRC.x)};top:${yp(SRC.y)}`}>
      <img src="/airtable.svg" alt="Airtable" />
    </span>
    <span class="sph-anchor-name" style={`left:${xp(SRC.x)};top:${yp(SRC.y + 64)}`}>Airtable</span>

    {/* Hub: Baseout + this Space */}
    <span class="sph-hub" style={`left:${xp(HUB.x)};top:${yp(HUB.y)}`}>
      <img src="/images/logo/icon-dark.svg" alt="" class="brand-logo-cyan" />
      <img src="/images/logo/icon-light.svg" alt="" class="brand-logo-blue" />
    </span>
    <span class="sph-hub-name" style={`left:${xp(HUB.x)};top:${yp(HUB.y + 64)}`}>{spaceName}</span>

    {/* Destination tiles */}
    {DESTS.map((d) => (
      <span class="sph-tile" style={`left:${xp(DEST_X)};top:${yp(d.y)}`}>
        {d.img ? <img src={d.img} alt={d.alt} /> : <span class={`iconify ${d.icon} sph-db`} title={d.alt}></span>}
      </span>
    ))}
  </div>

  <div class="sph-cta">
    <Button href="/integrations/configure?first=1" variant="primary">Set up backup</Button>
  </div>
</section>

<style>
  .sph { text-align: center; padding-top: .25rem; }
  .sph-title { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.01em; }
  .sph-sub { font-size: .875rem; color: oklch(from var(--color-base-content) l c h / .6); margin: .35rem auto 0; }

  .sph-stage { position: relative; width: min(100%, 44rem); aspect-ratio: 760 / 420; margin: 1.5rem auto 0; }
  .sph-stage::before { content: ''; position: absolute; left: 50%; top: 46.7%; width: 44%; aspect-ratio: 1; transform: translate(-50%, -50%); border-radius: 999px; background: radial-gradient(circle, oklch(from var(--color-primary) l c h / .10), transparent 65%); pointer-events: none; }

  .sph-net { position: absolute; inset: 0; width: 100%; height: 100%; }
  .net-base { fill: none; stroke: oklch(from var(--color-base-content) l c h / .22); stroke-width: 1.5; stroke-dasharray: 3 5; stroke-linecap: round; }
  .net-on { fill: none; stroke: var(--color-primary); stroke-width: 1.75; stroke-linecap: round; opacity: 0; }

  /* Restrained motion: lines take turns lighting up — opacity crossfade only. */
  .net-on-left { animation: sphPulse 4s ease-in-out infinite; }
  .net-on-0 { animation: sphTurn 16s ease-in-out infinite; }
  .net-on-1 { animation: sphTurn 16s ease-in-out 4s infinite; }
  .net-on-2 { animation: sphTurn 16s ease-in-out 8s infinite; }
  .net-on-3 { animation: sphTurn 16s ease-in-out 12s infinite; }
  @keyframes sphTurn { 0% { opacity: 0; } 5% { opacity: .85; } 20% { opacity: .85; } 25% { opacity: 0; } 100% { opacity: 0; } }
  @keyframes sphPulse { 0% { opacity: 0; } 20% { opacity: .85; } 80% { opacity: .85; } 100% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .net-on { animation: none !important; opacity: 0; }
    .net-on-left { opacity: .5; }
  }

  .sph-tile, .sph-anchor, .sph-hub { position: absolute; transform: translate(-50%, -50%); display: grid; place-items: center; background: var(--color-base-100); border: 1px solid var(--color-base-300); border-radius: 18%; box-shadow: 0 2px 10px oklch(from var(--color-base-content) l c h / .06); }
  .sph-tile { width: 9.2%; aspect-ratio: 1; }
  .sph-tile img { width: 52%; height: auto; }
  .sph-db { font-size: 1.6rem; color: #336791; } /* Postgres blue — represents the DB category */

  /* Airtable anchor — same footprint as the hub, with an accent ring so it reads as the primary input */
  .sph-anchor { width: 13%; aspect-ratio: 1; border-radius: 22%; border-color: oklch(from var(--color-base-content) l c h / .2); box-shadow: 0 4px 16px oklch(from var(--color-base-content) l c h / .08); }
  .sph-anchor img { width: 50%; height: auto; }
  .sph-anchor-name { position: absolute; transform: translateX(-50%); font-size: .8rem; font-weight: 650; color: oklch(from var(--color-base-content) l c h / .75); white-space: nowrap; }

  .sph-hub { width: 13%; aspect-ratio: 1; border-radius: 22%; border-color: oklch(from var(--color-primary) l c h / .35); box-shadow: 0 4px 18px oklch(from var(--color-primary) l c h / .14); }
  .sph-hub img { width: 56%; height: auto; }
  .sph-hub-name { position: absolute; transform: translateX(-50%); font-size: .8rem; font-weight: 650; color: oklch(from var(--color-base-content) l c h / .75); white-space: nowrap; }

  .sph-col-label { position: absolute; transform: translate(-50%, -50%); font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: oklch(from var(--color-base-content) l c h / .45); }

  .sph-cta { margin-top: 1.75rem; }
  .sph-cta :global(.btn) { min-width: 14rem; }

  @media (max-width: 480px) {
    .sph-db { font-size: 1.1rem; }
    .sph-anchor-name, .sph-hub-name { font-size: .7rem; }
  }
</style>
