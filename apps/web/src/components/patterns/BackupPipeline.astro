---
import Badge from '../ui/Badge.astro';

interface PipelineNode {
  label: string;
  detail?: string;
  status: string;
  tone?: 'primary' | 'success' | 'warning' | 'error' | 'default';
  href?: string;
}

interface Props {
  source: PipelineNode;
  bases: PipelineNode;
  destination: PipelineNode;
}

const { source, bases, destination } = Astro.props;
const nodes = [source, bases, destination];
---

<div class="grid items-stretch gap-2 text-sm sm:grid-cols-[1fr_auto_1fr_auto_1fr]">
  {nodes.map((node, index) => (
    <>
      {node.href ? (
        <a href={node.href} class="flex min-w-0 flex-col gap-1 rounded-box border border-base-300 bg-base-100 px-3 py-3 text-base-content no-underline transition-colors hover:border-primary/45 hover:bg-base-200/50">
          <span class="text-xs font-bold uppercase tracking-wider text-base-content/45">{index === 0 ? 'Source' : index === 1 ? 'Backs up' : 'Destination'}</span>
          <span class="truncate font-semibold">{node.label}</span>
          {node.detail && <span class="truncate text-xs text-base-content/55">{node.detail}</span>}
          <Badge variant={node.tone ?? 'default'} size="sm" dot>{node.status}</Badge>
        </a>
      ) : (
        <div class="flex min-w-0 flex-col gap-1 rounded-box border border-base-300 bg-base-100 px-3 py-3 text-base-content">
          <span class="text-xs font-bold uppercase tracking-wider text-base-content/45">{index === 0 ? 'Source' : index === 1 ? 'Backs up' : 'Destination'}</span>
          <span class="truncate font-semibold">{node.label}</span>
          {node.detail && <span class="truncate text-xs text-base-content/55">{node.detail}</span>}
          <Badge variant={node.tone ?? 'default'} size="sm" dot>{node.status}</Badge>
        </div>
      )}
      {index < nodes.length - 1 && (
        <span class="grid place-items-center self-center text-success max-sm:h-6 sm:w-6" aria-hidden="true">
          <span class="h-px w-full bg-success/50 max-sm:h-full max-sm:w-px"></span>
        </span>
      )}
    </>
  ))}
</div>
