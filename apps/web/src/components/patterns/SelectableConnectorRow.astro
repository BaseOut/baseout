---
import Badge from '../ui/Badge.astro';

interface Props {
  name: string;
  description?: string;
  icon?: string;
  statusLabel?: string;
  statusVariant?: 'default' | 'primary' | 'success' | 'warning' | 'error';
  control?: 'radio' | 'checkbox';
  checked?: boolean;
  disabled?: boolean;
  nameAttr?: string;
  value?: string;
}

const {
  name,
  description,
  icon = 'lucide--plug',
  statusLabel,
  statusVariant = 'default',
  control = 'radio',
  checked = false,
  disabled = false,
  nameAttr = 'connector',
  value = name,
} = Astro.props;
---

<label class={`flex cursor-pointer items-center gap-3 rounded-box border border-base-300 bg-base-100 p-3 transition-colors hover:bg-base-200/50 ${disabled ? 'cursor-not-allowed opacity-55' : ''}`}>
  <input type={control} name={nameAttr} value={value} checked={checked} disabled={disabled} class={control === 'checkbox' ? 'checkbox checkbox-primary' : 'radio radio-primary'} />
  <span class="grid size-10 place-items-center rounded-box bg-base-200 text-base-content/70">
    <span class={`iconify ${icon} size-5`} aria-hidden="true"></span>
  </span>
  <span class="min-w-0 flex-1">
    <span class="block truncate font-medium text-base-content">{name}</span>
    {description && <span class="block truncate text-sm text-base-content/55">{description}</span>}
  </span>
  {statusLabel && <Badge variant={statusVariant} size="sm" dot>{statusLabel}</Badge>}
</label>
