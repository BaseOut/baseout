---
interface Step {
  label: string;
  status?: 'complete' | 'current' | 'upcoming';
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="flex flex-wrap items-center gap-2 text-sm">
  {steps.map((step, index) => {
    const state = step.status ?? 'upcoming';
    const active = state === 'complete' || state === 'current';
    return (
      <>
        <li class={active ? 'flex items-center gap-2 text-base-content' : 'flex items-center gap-2 text-base-content/55'}>
          <span class={active ? 'grid size-6 place-items-center rounded-full bg-primary text-xs font-semibold text-primary-content' : 'grid size-6 place-items-center rounded-full border border-base-300 text-xs font-semibold'}>
            {state === 'complete' ? <span class="iconify lucide--check size-3" aria-hidden="true"></span> : index + 1}
          </span>
          <span>{step.label}</span>
        </li>
        {index < steps.length - 1 && <span class="h-px w-6 bg-base-300" aria-hidden="true"></span>}
      </>
    );
  })}
</ol>
