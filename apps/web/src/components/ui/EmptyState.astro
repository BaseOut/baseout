---
import { cn } from '../../lib/ui';

interface Props {
  icon?: string;
  title: string;
  description?: string;
  actionHref?: string;
  actionLabel?: string;
  compact?: boolean;
  class?: string;
}

const {
  icon = 'lucide--inbox',
  title,
  description,
  actionHref,
  actionLabel,
  compact = false,
  class: className = '',
} = Astro.props;
---

<section class={cn('rounded-box border border-dashed border-base-300 bg-base-100 text-center', compact ? 'p-6' : 'p-10', className)}>
  <span class={cn('iconify mx-auto text-base-content/35', icon, compact ? 'size-8' : 'size-10')} aria-hidden="true"></span>
  <h2 class={cn('font-semibold text-base-content', compact ? 'mt-3 text-base' : 'mt-4 text-lg')}>{title}</h2>
  {description && <p class="mx-auto mt-2 max-w-xl text-sm text-base-content/60">{description}</p>}
  {Astro.slots.has('default') && <div class="mx-auto mt-3 max-w-xl text-sm text-base-content/60"><slot /></div>}
  {actionHref && actionLabel && (
    <a href={actionHref} class="btn btn-primary mt-5">
      {actionLabel}
    </a>
  )}
</section>
