---
import { cn } from '../../lib/ui';

interface Props {
  id: string;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  title?: string;
  open?: boolean;
  class?: string;
}

const {
  id,
  size = 'md',
  title,
  open = false,
  class: className = '',
} = Astro.props;

const sizeMap: Record<string, string> = {
  sm:   'max-w-sm',
  md:   'max-w-lg',
  lg:   'max-w-2xl',
  xl:   'max-w-4xl',
  full: 'max-w-none w-full h-full rounded-none',
};

const boxClasses = cn(
  'modal-box',
  sizeMap[size] || sizeMap.md,
  className,
);
---

<dialog
  id={id}
  class="modal"
  data-autoshow={open ? '' : undefined}
  aria-labelledby={title ? `${id}-title` : undefined}
>
  <div class={boxClasses}>
    {title && (
      <div class="flex items-center justify-between gap-4 pb-4 border-b border-base-300/20">
        <h2 id={`${id}-title`} class="font-headline font-semibold text-lg">{title}</h2>
        <form method="dialog">
          <button
            class="btn btn-sm btn-circle btn-ghost"
            aria-label="Close"
          >
            <span class="material-symbols-outlined icon-lg">close</span>
          </button>
        </form>
      </div>
    )}
    <div class="py-4">
      <slot />
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  document
    .querySelectorAll<HTMLDialogElement>('dialog.modal[data-autoshow]')
    .forEach((dialog) => {
      dialog.showModal();
    });
</script>
