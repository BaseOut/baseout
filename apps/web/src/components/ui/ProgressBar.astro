---
import { cn } from '../../lib/ui';

interface Props {
  value: number;
  max?: number;
  label?: string;
  showValue?: boolean;
  variant?: 'primary' | 'success' | 'warning' | 'error';
  class?: string;
}

const {
  value,
  max = 100,
  label,
  showValue = false,
  variant = 'primary',
  class: className = '',
} = Astro.props;

const percent = Math.min(100, Math.max(0, (value / max) * 100));

const variantMap: Record<string, string> = {
  primary: 'progress-primary',
  success: 'progress-success',
  warning: 'progress-warning',
  error:   'progress-error',
};

const progressClasses = cn(
  'progress w-full',
  variantMap[variant] || 'progress-primary',
  className,
);

const valueText = max !== 100
  ? `${value} of ${max}`
  : `${Math.round(percent)}%`;
---

{(label || showValue) && (
  <div class="flex items-center justify-between mb-1.5">
    {label && <span class="text-sm font-medium text-base-content">{label}</span>}
    {showValue && <span class="text-xs opacity-60">{valueText}</span>}
  </div>
)}

<progress
  class={progressClasses}
  value={value}
  max={max}
  aria-label={label || `Progress: ${valueText}`}
></progress>
