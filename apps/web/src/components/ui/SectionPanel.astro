---
import { cn } from '../../lib/ui';

interface Props {
  title?: string;
  description?: string;
  variant?: 'default' | 'tonal';
  padded?: boolean;
  class?: string;
}

const {
  title,
  description,
  variant = 'default',
  padded = true,
  class: className = '',
} = Astro.props;

const classes = cn(
  'rounded-box border',
  variant === 'tonal' ? 'border-base-300/60 bg-base-200/60' : 'border-base-300 bg-base-100',
  padded && 'p-5',
  className,
);
---

<section class={classes}>
  {(title || description || Astro.slots.has('actions')) && (
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        {title && <h2 class="text-lg font-semibold text-base-content">{title}</h2>}
        {description && <p class="mt-1 text-sm text-base-content/60">{description}</p>}
      </div>
      {Astro.slots.has('actions') && <div class="flex shrink-0 items-center gap-2"><slot name="actions" /></div>}
    </div>
  )}
  <slot />
</section>
