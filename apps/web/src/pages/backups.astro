---
import { and, desc, eq } from 'drizzle-orm';
import SidebarLayout from '../layouts/SidebarLayout.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import BackupsListView from '../views/BackupsListView.astro';
import RunBackupButton from '../components/patterns/RunBackupButton.astro';
import { getBreadcrumbs } from '../lib/config';
import { getIntegrationsState } from '../lib/integrations';
import { describeDestination, isLocalDestination } from '../lib/backups/destination';
import { listRecentRuns } from '../lib/backup-runs/list';
import type { BackupRunRowLike, IncludedBase } from '../lib/backup-runs/list';
import type { BackupRunSummary } from '../lib/backup-runs/types';
import {
  atBases,
  backupConfigurationBases,
  backupConfigurations,
  backupRuns,
  connections,
} from '../db/schema';

const breadcrumbs = getBreadcrumbs('/backups');
const { account, db } = Astro.locals;

const orgId = account?.organization?.id ?? null;
const spaceId = account?.space?.id ?? null;

const integrations =
  orgId && spaceId ? await getIntegrationsState(db, orgId, spaceId) : null;
const airtable =
  integrations?.connections.find((c) => c.platformSlug === 'airtable') ?? null;
const hasAirtableConnection = airtable?.status === 'active';

const initialRuns: BackupRunSummary[] =
  spaceId && db && hasAirtableConnection
    ? await listRecentRuns(spaceId, 25, {
        fetchRuns: async (sid, lim) => {
          const rows = await db
            .select({
              id: backupRuns.id,
              status: backupRuns.status,
              isTrial: backupRuns.isTrial,
              triggeredBy: backupRuns.triggeredBy,
              recordCount: backupRuns.recordCount,
              tableCount: backupRuns.tableCount,
              attachmentCount: backupRuns.attachmentCount,
              startedAt: backupRuns.startedAt,
              completedAt: backupRuns.completedAt,
              errorMessage: backupRuns.errorMessage,
              triggerRunIds: backupRuns.triggerRunIds,
              createdAt: backupRuns.createdAt,
              connectionId: backupRuns.connectionId,
              connectionDisplayName: connections.displayName,
              configStorageType: backupConfigurations.storageType,
              configMode: backupConfigurations.mode,
            })
            .from(backupRuns)
            .leftJoin(connections, eq(connections.id, backupRuns.connectionId))
            .leftJoin(
              backupConfigurations,
              eq(backupConfigurations.spaceId, backupRuns.spaceId),
            )
            .where(eq(backupRuns.spaceId, sid))
            .orderBy(desc(backupRuns.createdAt))
            .limit(lim);
          return rows as BackupRunRowLike[];
        },
        fetchIncludedBases: async (sid) => {
          const rows = await db
            .select({ id: atBases.id, name: atBases.name })
            .from(backupConfigurationBases)
            .innerJoin(
              backupConfigurations,
              eq(
                backupConfigurations.id,
                backupConfigurationBases.backupConfigurationId,
              ),
            )
            .innerJoin(
              atBases,
              eq(atBases.id, backupConfigurationBases.atBaseId),
            )
            .where(
              and(
                eq(backupConfigurations.spaceId, sid),
                eq(backupConfigurationBases.isIncluded, true),
              ),
            )
            .orderBy(atBases.name);
          return rows as IncludedBase[];
        },
      })
    : [];

const spaceName = account?.space?.name ?? null;

// Where backups currently go (defaults to dev local-disk). Drives the header
// indicator: shows the destination + a link to change it, or a setup prompt
// when a chosen cloud provider isn't connected. The full picker lives in the
// wizard at /integrations/configure.
const storageType = integrations?.policy?.storageType ?? null;
const destination =
  spaceId && hasAirtableConnection
    ? describeDestination(storageType, integrations?.storageDestination ?? null)
    : null;
// When already on dev local-disk there's nothing to switch to; otherwise offer
// a one-click switch so a Space stuck on an unconnected cloud provider can run.
const onLocal = isLocalDestination(storageType);
const CONFIGURE_HREF = '/integrations/configure';
---

<SidebarLayout pageTitle="Backups" breadcrumbs={breadcrumbs} spaceScoped={true}>
  <div class="mx-auto max-w-[1200px] space-y-6">
    <header class="flex flex-wrap items-start justify-between gap-4">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold tracking-tight">Backups</h1>
        <p class="text-sm text-base-content/60 mt-1">
          {spaceName
            ? `Every backup run for ${spaceName}. Open any run for its full detail.`
            : 'Every backup run for this Space. Open any run for its full detail.'}
        </p>
        {destination && (
          <div class="text-sm mt-2 flex items-center gap-2 flex-wrap">
            {destination.needsSetup ? (
              <span class="inline-flex items-center gap-1.5">
                <span class="iconify lucide--triangle-alert size-4 text-warning" aria-hidden="true"></span>
                <span class="text-base-content/70">{destination.label} isn't connected yet.</span>
              </span>
            ) : (
              <span class="inline-flex items-center gap-1.5">
                <span class="iconify lucide--hard-drive size-4 text-base-content/50" aria-hidden="true"></span>
                <span class="text-base-content/70">Backing up to <span class="font-medium text-base-content">{destination.label}</span></span>
              </span>
            )}
            {!onLocal && (
              <Button type="button" variant="tonal" size="sm" data-use-local-dest data-space-id={spaceId}>
                Use dev local disk
              </Button>
            )}
            <a href={CONFIGURE_HREF} class="link link-primary">
              {destination.needsSetup ? 'Set up a cloud destination' : 'Change destination'}
            </a>
          </div>
        )}
      </div>
      {spaceId && hasAirtableConnection && (
        <RunBackupButton
          spaceId={spaceId}
          connectionStatus={airtable?.status ?? null}
        />
      )}
    </header>

    {!spaceId || !hasAirtableConnection ? (
      <Card variant="outlined">
        <p class="text-sm">
          Connect Airtable on the
          <a href="/integrations" class="link link-primary mx-1">Integrations</a>
          page to start backing up your bases.
        </p>
      </Card>
    ) : (
      <div data-backup-history data-space-id={spaceId}>
        <BackupsListView runs={initialRuns} embedded={true} />
        {/* Hydrates the $backupRuns store for the live-poll loop wired in
            BackupsListView. Same JSON-script pattern as BackupHistoryWidget;
            `<` is escaped so run data can't break out of the script tag. */}
        <script
          type="application/json"
          data-backup-history-state
          is:inline
          set:html={JSON.stringify(initialRuns).replace(/</g, '\\u003c')}
        />
      </div>
    )}
  </div>
</SidebarLayout>

<script>
  import { saveBackupConfig } from '../lib/backups/save-config';
  import { setButtonLoading } from '../lib/ui';

  // One-click switch to the dev local-disk destination so backups can run
  // without a cloud connection. Delegated on document so it survives Astro
  // ClientRouter navigations (the button is server-rendered per page).
  document.addEventListener('click', async (event) => {
    const btn = (event.target as HTMLElement | null)?.closest('[data-use-local-dest]');
    if (!(btn instanceof HTMLButtonElement)) return;
    const spaceId = btn.dataset.spaceId;
    if (!spaceId) return;
    setButtonLoading(btn, true);
    try {
      const res = await saveBackupConfig({ spaceId, storageType: 'local_fs' });
      if (res.ok) window.location.reload();
    } finally {
      setButtonLoading(btn, false);
    }
  });
</script>
