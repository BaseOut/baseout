---
/**
 * Single backup-run detail (production). Renders the redesigned
 * BackupRunDetailView from REAL run-level data. Fetches per-base / per-table
 * detail from the engine's GET /api/internal/runs/:runId/detail endpoint
 * (server-run-detail, commit 050c396). When the engine is unavailable or the
 * run is a legacy run with no per-base snapshot, falls through to
 * metricsPending mode: real run-level totals, placeholder per-base table.
 */
import { env } from 'cloudflare:workers';
import { and, eq, sql } from 'drizzle-orm';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import BackupRunDetailView from '../../views/BackupRunDetailView.astro';
import { getBreadcrumbs } from '../../lib/config';
import { createBackupEngine } from '../../lib/backup-engine';
import type { EngineRunDetailBase } from '../../lib/backup-engine';
import {
  backupConfigurationBases,
  backupConfigurations,
  backupRuns,
  connections,
} from '../../db/schema';

const breadcrumbs = getBreadcrumbs('/backups');
const { account, db } = Astro.locals;
const spaceId = account?.space?.id ?? null;
const id = Astro.url.searchParams.get('id');

// No id, no Space, or no DB → back to the list.
if (!id || !spaceId || !db) return Astro.redirect('/backups');

const rows = await db
  .select({
    id: backupRuns.id,
    status: backupRuns.status,
    triggeredBy: backupRuns.triggeredBy,
    recordCount: backupRuns.recordCount,
    tableCount: backupRuns.tableCount,
    attachmentCount: backupRuns.attachmentCount,
    startedAt: backupRuns.startedAt,
    completedAt: backupRuns.completedAt,
    errorMessage: backupRuns.errorMessage,
    connectionDisplayName: connections.displayName,
    configStorageType: backupConfigurations.storageType,
    configMode: backupConfigurations.mode,
  })
  .from(backupRuns)
  .leftJoin(connections, eq(connections.id, backupRuns.connectionId))
  .leftJoin(backupConfigurations, eq(backupConfigurations.spaceId, backupRuns.spaceId))
  .where(and(eq(backupRuns.id, id), eq(backupRuns.spaceId, spaceId)))
  .limit(1);

const row = rows[0];
if (!row) return Astro.redirect('/backups');

// Count the bases currently in this Space's config — used as the summary.bases
// figure when per-base detail is unavailable (metricsPending fallback).
const baseCountRows = await db
  .select({ n: sql<number>`count(*)::int` })
  .from(backupConfigurationBases)
  .innerJoin(backupConfigurations, eq(backupConfigurations.id, backupConfigurationBases.backupConfigurationId))
  .where(and(eq(backupConfigurations.spaceId, spaceId), eq(backupConfigurationBases.isIncluded, true)));
const baseCount = baseCountRows[0]?.n ?? 0;

// storage_type → human destination label + provider. (Features §6.2)
const DEST: Record<string, { label: string; provider: string }> = {
  r2_managed: { label: 'Managed storage · Cloudflare R2', provider: 'Cloudflare R2' },
  google_drive: { label: 'Google Drive', provider: 'Google Drive' },
  dropbox: { label: 'Dropbox', provider: 'Dropbox' },
  box: { label: 'Box', provider: 'Box' },
  onedrive: { label: 'OneDrive', provider: 'OneDrive' },
  s3: { label: 'Amazon S3', provider: 'Amazon S3' },
  frame_io: { label: 'Frame.io', provider: 'Frame.io' },
  byos: { label: 'Your storage', provider: 'BYOS' },
};
const dest = DEST[row.configStorageType ?? 'r2_managed'] ?? DEST.r2_managed;

const knownStatuses = ['succeeded', 'failed', 'running', 'cancelled', 'trial_succeeded'] as const;
const status = (knownStatuses as readonly string[]).includes(row.status)
  ? (row.status as (typeof knownStatuses)[number])
  : 'cancelled';

// Run-level depth — inferred from run-level totals (no per-layer flags stored).
const depth = {
  schema: (row.tableCount ?? 0) > 0,
  data: (row.recordCount ?? 0) > 0 || status === 'succeeded' || status === 'trial_succeeded',
  attachments: (row.attachmentCount ?? 0) > 0,
};

// Fetch per-base / per-table detail from the engine (best-effort).
// On unavailable engine or legacy run (empty bases[]), fall through to
// metricsPending mode which shows run-level totals + the placeholder table.
type BaseRunStatus = 'ok' | 'failed' | 'running' | 'pending';
const KNOWN_BASE_STATUSES: ReadonlySet<BaseRunStatus> = new Set(['ok', 'failed', 'running', 'pending']);

function mapEngineBase(b: EngineRunDetailBase) {
  const baseStatus: BaseRunStatus =
    KNOWN_BASE_STATUSES.has(b.status as BaseRunStatus)
      ? (b.status as BaseRunStatus)
      : 'pending';
  return {
    id: b.atBaseId,
    name: b.baseName,
    status: baseStatus,
    startedAt: b.startedAt,
    completedAt: b.completedAt,
    // Snapshot gaps: destination details are not captured per-base by the engine.
    // Default destKind based on storageType (file-based vs DB), folder/url/dbRef to null.
    destKind: (row.configStorageType === 'managed_pg' ? 'database' : 'file') as 'file' | 'database',
    folder: null as string | null,
    folderUrl: null as string | null,
    dbRef: null as string | null,
    tables: b.tablesCount,
    fields: b.tables.reduce((s, t) => s + t.fieldCount, 0),
    records: b.recordsCount,
    recordsRemaining: null as number | null,
    attachments: b.attachmentsCount,
    attachmentsRemaining: null as number | null,
    failed: 0,
    error: b.errorMessage,
  };
}

let engineBases: ReturnType<typeof mapEngineBase>[] = [];

if (env.BACKUP_ENGINE && env.BACKUP_ENGINE_INTERNAL_TOKEN) {
  const engine = createBackupEngine({
    binding: env.BACKUP_ENGINE,
    internalToken: env.BACKUP_ENGINE_INTERNAL_TOKEN,
  });
  const detailRes = await engine.getRunDetail(row.id);
  if (detailRes.ok && detailRes.bases.length > 0) {
    engineBases = detailRes.bases.map(mapEngineBase);
  }
}

const metricsPending = engineBases.length === 0;

const run = {
  id: row.id,
  status,
  triggeredBy: row.triggeredBy,
  startedAt: row.startedAt ? new Date(row.startedAt).toISOString() : null,
  completedAt: row.completedAt ? new Date(row.completedAt).toISOString() : null,
  etaSeconds: null,
  depth,
  destinationLabel: dest.label,
  destProvider: dest.provider,
  destIcon: null,
  // Run-level totals from the DB row are always shown in the summary stats.
  // When metricsPending=false, the view sums bases[] instead — they match.
  summary: {
    bases: metricsPending ? baseCount : engineBases.length,
    tables: row.tableCount ?? 0,
    records: row.recordCount ?? 0,
    attachments: row.attachmentCount ?? 0,
  },
  bases: engineBases,
  failedAttachments: [],
};
---

<SidebarLayout pageTitle="Backup run" breadcrumbs={breadcrumbs} spaceScoped={true}>
  <BackupRunDetailView run={run} spaceId={spaceId} metricsPending={metricsPending} />
</SidebarLayout>
