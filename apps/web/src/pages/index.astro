---
import { and, desc, eq } from 'drizzle-orm';
import SidebarLayout from '../layouts/SidebarLayout.astro';
import SpaceHomeView from '../views/SpaceHomeView.astro';
import { getBreadcrumbs } from '../lib/config';
import { getIntegrationsState } from '../lib/integrations';
import { listRecentRuns } from '../lib/backup-runs/list';
import { toSourceSummary, toDestinationSummaries } from '../lib/registry-mappers';
import type { BackupRunRowLike, IncludedBase } from '../lib/backup-runs/list';
import type { BackupRunSummary } from '../lib/backup-runs/types';
import type { IntegrationsState } from '../stores/connections';
import {
  atBases,
  backupConfigurationBases,
  backupConfigurations,
  backupRuns,
  connections,
} from '../db/schema';

const breadcrumbs = getBreadcrumbs('/');
const { account, db } = Astro.locals;

const orgId = account?.organization?.id ?? null;
const spaceId = account?.space?.id ?? null;
const integrations: IntegrationsState =
  orgId && spaceId
    ? await getIntegrationsState(db, orgId, spaceId)
    : {
        connections: [],
        bases: [],
        tierBasesPerSpace: 5,
        availableFrequencies: ['monthly'],
        hasBackupConfig: false,
        policy: {
          frequency: 'monthly',
          scope: 'schema_and_data',
          schemaFrequency: null,
          schemaNextScheduledAt: null,
          storageType: 'r2_managed',
          nextScheduledAt: null,
          autoAddFutureBases: false,
        },
        storageDestinations: [],
        unreadEvents: [],
      };

const initialRuns: BackupRunSummary[] =
  spaceId && db
    ? await listRecentRuns(spaceId, 10, {
        fetchRuns: async (sid, lim) => {
          const rows = await db
            .select({
              id: backupRuns.id,
              status: backupRuns.status,
              isTrial: backupRuns.isTrial,
              triggeredBy: backupRuns.triggeredBy,
              recordCount: backupRuns.recordCount,
              tableCount: backupRuns.tableCount,
              attachmentCount: backupRuns.attachmentCount,
              startedAt: backupRuns.startedAt,
              completedAt: backupRuns.completedAt,
              errorMessage: backupRuns.errorMessage,
              triggerRunIds: backupRuns.triggerRunIds,
              createdAt: backupRuns.createdAt,
              connectionId: backupRuns.connectionId,
              connectionDisplayName: connections.displayName,
              configStorageType: backupConfigurations.storageType,
              configMode: backupConfigurations.mode,
            })
            .from(backupRuns)
            .leftJoin(connections, eq(connections.id, backupRuns.connectionId))
            .leftJoin(
              backupConfigurations,
              eq(backupConfigurations.spaceId, backupRuns.spaceId),
            )
            .where(eq(backupRuns.spaceId, sid))
            .orderBy(desc(backupRuns.createdAt))
            .limit(lim);
          return rows as BackupRunRowLike[];
        },
        fetchIncludedBases: async (sid) => {
          const rows = await db
            .select({ id: atBases.id, name: atBases.name })
            .from(backupConfigurationBases)
            .innerJoin(
              backupConfigurations,
              eq(
                backupConfigurations.id,
                backupConfigurationBases.backupConfigurationId,
              ),
            )
            .innerJoin(
              atBases,
              eq(atBases.id, backupConfigurationBases.atBaseId),
            )
            .where(
              and(
                eq(backupConfigurations.spaceId, sid),
                eq(backupConfigurationBases.isIncluded, true),
              ),
            )
            .orderBy(atBases.name);
          return rows as IncludedBase[];
        },
      })
    : [];

// Space Home (folds in the old Overview). Map the per-Space state into the
// account-level source/destination shapes the view renders; ?status=running|saved
// carries the post-Configure confirmation. baseMetrics/usage are gated until the
// engine + billing feed them (the view hides those sections when empty).
const spaceName = account?.space?.name ?? 'this Space';
const source = toSourceSummary(integrations, spaceId ?? 'space', spaceName);
const destinations = toDestinationSummaries(integrations, spaceId ?? 'space', spaceName);
const statusParam = Astro.url.searchParams.get('status');
const statusCode: 'saved' | 'running' | null =
  statusParam === 'running' ? 'running' : statusParam === 'saved' ? 'saved' : null;
---

<SidebarLayout pageTitle="Home" breadcrumbs={breadcrumbs} spaceScoped={true}>
  {/* data-backup-history + the JSON tag feed setupBackupHistory (hydrate the
      $backupRuns store + start the 2s poll). Home re-renders via soft reload
      on status transitions — see lib/backups/home-live.ts. */}
  <div data-backup-history data-space-id={spaceId}>
    <SpaceHomeView
      state={integrations}
      source={source}
      destinations={destinations}
      runs={initialRuns}
      statusCode={statusCode}
      baseMetrics={[]}
      usage={[]}
    />
    <script
      type="application/json"
      data-backup-history-state
      is:inline
      set:html={JSON.stringify(initialRuns).replace(/</g, '\\u003c')}
    />
  </div>
</SidebarLayout>

<script
  type="application/json"
  id="account-state"
  is:inline
  set:html={JSON.stringify(account).replace(/</g, '\\u003c')}
/>

<script
  type="application/json"
  id="integrations-state"
  is:inline
  set:html={JSON.stringify(integrations).replace(/</g, '\\u003c')}
/>

<script>
  import { $account } from '../stores/account';
  import { $integrations } from '../stores/connections';
  import { createHomeLiveRender } from '../lib/backups/home-live';
  import { registerBackupHistoryLifecycle, makeFetchRuns } from '../lib/backups/widget-lifecycle';

  const accountEl = document.getElementById('account-state');
  if (accountEl?.textContent) {
    $account.set(JSON.parse(accountEl.textContent));
  }

  const integrationsEl = document.getElementById('integrations-state');
  if (integrationsEl?.textContent) {
    $integrations.set(JSON.parse(integrationsEl.textContent));
  }

  // Live backup status on Home: poll the run store and soft-reload on a
  // status transition so SSR recomputes the KPIs, rail and history table.
  // location.replace(pathname) drops a stale ?status=running param so the
  // rail reflects real run state after the reload. No-ops on pages without
  // the [data-backup-history] root (lifecycle setup returns null).
  registerBackupHistoryLifecycle({
    render: createHomeLiveRender(() => {
      window.location.replace(window.location.pathname);
    }),
    fetchRuns: makeFetchRuns(10),
  });
</script>
