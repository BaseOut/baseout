---
import { and, desc, eq } from 'drizzle-orm';
import SidebarLayout from '../layouts/SidebarLayout.astro';
// Per-Space page = the redesigned Space Overview (the Airbyte "Connection").
// The pre-redesign provider/connect screen survives as IntegrationsView.legacy
// (rollback + design-harness "Old"); first connect now happens in the setup
// wizard's Source step (see /integrations/configure).
import SpaceOverviewView from '../views/SpaceOverviewView.astro';
import { getBreadcrumbs } from '../lib/config';
import { EMPTY_INTEGRATIONS_STATE, getIntegrationsState } from '../lib/integrations';
import { listRecentRuns } from '../lib/backup-runs/list';
import { toSourceSummary, toDestinationSummaries } from '../lib/registry-mappers';
import type { BackupRunRowLike, IncludedBase } from '../lib/backup-runs/list';
import type { BackupRunSummary } from '../lib/backup-runs/types';
import type { IntegrationsState } from '../stores/connections';
import {
  atBases,
  backupConfigurationBases,
  backupConfigurations,
  backupRuns,
  connections,
} from '../db/schema';

const breadcrumbs = getBreadcrumbs('/integrations');
const { account, db } = Astro.locals;

const orgId = account?.organization?.id ?? null;
const spaceId = account?.space?.id ?? null;
const spaceName = account?.space?.name ?? 'this Space';

// Run getIntegrationsState and listRecentRuns in parallel — they're
// independent reads keyed off the same (orgId, spaceId) request scope.
const [state, initialRuns]: [IntegrationsState, BackupRunSummary[]] = await Promise.all([
  orgId && spaceId
    ? getIntegrationsState(db, orgId, spaceId)
    : Promise.resolve(EMPTY_INTEGRATIONS_STATE),
  spaceId && db
    ? listRecentRuns(spaceId, 10, {
        fetchRuns: async (sid, lim) => {
          const rows = await db
            .select({
              id: backupRuns.id,
              status: backupRuns.status,
              isTrial: backupRuns.isTrial,
              triggeredBy: backupRuns.triggeredBy,
              recordCount: backupRuns.recordCount,
              tableCount: backupRuns.tableCount,
              attachmentCount: backupRuns.attachmentCount,
              startedAt: backupRuns.startedAt,
              completedAt: backupRuns.completedAt,
              errorMessage: backupRuns.errorMessage,
              triggerRunIds: backupRuns.triggerRunIds,
              createdAt: backupRuns.createdAt,
              connectionId: backupRuns.connectionId,
              connectionDisplayName: connections.displayName,
              configStorageType: backupConfigurations.storageType,
              configMode: backupConfigurations.mode,
            })
            .from(backupRuns)
            .leftJoin(connections, eq(connections.id, backupRuns.connectionId))
            .leftJoin(
              backupConfigurations,
              eq(backupConfigurations.spaceId, backupRuns.spaceId),
            )
            .where(eq(backupRuns.spaceId, sid))
            .orderBy(desc(backupRuns.createdAt))
            .limit(lim);
          return rows as BackupRunRowLike[];
        },
        fetchIncludedBases: async (sid) => {
          const rows = await db
            .select({ id: atBases.id, name: atBases.name })
            .from(backupConfigurationBases)
            .innerJoin(
              backupConfigurations,
              eq(
                backupConfigurations.id,
                backupConfigurationBases.backupConfigurationId,
              ),
            )
            .innerJoin(
              atBases,
              eq(atBases.id, backupConfigurationBases.atBaseId),
            )
            .where(
              and(
                eq(backupConfigurations.spaceId, sid),
                eq(backupConfigurationBases.isIncluded, true),
              ),
            )
            .orderBy(atBases.name);
          return rows as IncludedBase[];
        },
      })
    : Promise.resolve<BackupRunSummary[]>([]),
]);

// `?connected` / `?error` come from the OAuth callback; `?status=saved|running`
// from the Configure flow's save action.
const connectedParam = Astro.url.searchParams.get('connected');
const errorParam = Astro.url.searchParams.get('error');
const statusParam = Astro.url.searchParams.get('status');
const ovStatus: 'saved' | 'running' | null =
  statusParam === 'running' ? 'running' : statusParam === 'saved' ? 'saved' : null;

// Map the per-Space backend state into the Overview's account-level shapes.
const source = toSourceSummary(state, spaceId ?? 'space', spaceName);
const destinations = toDestinationSummaries(state, spaceId ?? 'space', spaceName);

// Real "last run" label for the Overview (the view falls back to a placeholder).
function relTime(iso: string | null): string {
  if (!iso) return '';
  const m = Math.round((Date.now() - new Date(iso).getTime()) / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.round(h / 24)}d ago`;
}
const lastRun = initialRuns[0] ?? null;
const when = lastRun ? relTime(lastRun.completedAt ?? lastRun.createdAt) : '';
const lastRunLabel = !lastRun
  ? 'No backups yet'
  : lastRun.status === 'succeeded' || lastRun.status === 'trial_succeeded'
    ? `✓ Succeeded ${when}`
    : lastRun.status === 'failed'
      ? `Failed ${when}`
      : lastRun.status === 'running' || lastRun.status === 'queued'
        ? 'Running now'
        : `${lastRun.status} ${when}`;

const CONNECT_ERROR: Record<string, string> = {
  access_denied: 'You declined to give Baseout access to your Airtable.',
  missing_code: 'Airtable did not return an authorization code. Please try again.',
  token_exchange_failed: 'Airtable rejected the connection. Please try again.',
  api_call_failed: 'We connected to Airtable but could not list your bases.',
};
const connectError = errorParam
  ? (CONNECT_ERROR[errorParam] ?? 'Could not connect to Airtable. Please try again.')
  : null;
---

<SidebarLayout pageTitle="Overview" breadcrumbs={breadcrumbs} spaceScoped={true}>
  {connectedParam && (
    <div role="alert" class="alert alert-success mb-4">
      <span class="iconify lucide--circle-check" aria-hidden="true"></span>
      <span>Airtable connected.</span>
    </div>
  )}
  {connectError && (
    <div role="alert" class="alert alert-error mb-4">
      <span class="iconify lucide--circle-alert" aria-hidden="true"></span>
      <span>{connectError}</span>
    </div>
  )}
  <SpaceOverviewView
    state={state}
    source={source}
    destinations={destinations}
    statusCode={ovStatus}
    linkToRegistry={true}
    lastRunLabel={lastRunLabel}
  />
</SidebarLayout>
