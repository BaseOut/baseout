---
/**
 * BackupRunBaseView — one base inside one backup run, drilled down to its tables.
 *
 * This is the leaf of the audit trail: Backups → a run → THIS base. It answers
 * "for this base, in this run, exactly what did we capture?" — every table with
 * its Fields · Records · Views · Attachments, plus the base's status/timing,
 * where its output landed, and any attachments that failed.
 *
 * Distinct from /schema (a run-agnostic view of base STRUCTURE). This page is
 * tied to a single run: counts are what the engine wrote on that run, including
 * remaining-vs-total while it is still in flight.
 *
 * Tables, fields, views and record counts come straight from Airtable metadata +
 * the backup engine; nothing here is synthesized. Harness feeds a fixture.
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Alert from '../components/ui/Alert.astro';

interface FailedAttachment {
  table: string;
  file: string;
  reason: string;
}
interface TableRun {
  id: string;
  name: string;
  status: 'ok' | 'failed' | 'running' | 'pending';
  fields: number;
  records: number;
  recordsRemaining: number | null; // set while running
  views: number;
  attachments: number;
  attachmentsRemaining: number | null;
  failed: number; // failed attachment count in this table
}
interface BaseDetail {
  runId: string;
  runState: string; // harness round-trip for the back link
  atBaseId: string; // Airtable base id (appXXXXXXXXXXXXXX)
  name: string;
  status: 'ok' | 'failed' | 'running' | 'pending';
  startedAt: string | null;
  completedAt: string | null;
  depth: { schema: boolean; data: boolean; attachments: boolean };
  destKind: 'file' | 'database';
  destProvider: string; // e.g. "Google Drive" — named in the folder-link tooltip
  destIcon: string | null; // brand mark for the destination provider (falls back to a folder icon)
  folder: string | null; // human path shown to the user
  folderUrl: string | null; // deep link into the user's storage (provider returns the folder id on write)
  dbRef: string | null;
  error: string | null;
  tables: TableRun[];
  failedAttachments: FailedAttachment[];
}
interface Props {
  base: BaseDetail;
}
const { base } = Astro.props;

const nf = new Intl.NumberFormat('en-US');
const running = base.status === 'running';
const failed = base.status === 'failed';

const totalFields = base.tables.reduce((s, t) => s + t.fields, 0);
const totalRecords = base.tables.reduce((s, t) => s + t.records, 0);
const totalViews = base.tables.reduce((s, t) => s + t.views, 0);
const totalAttachments = base.tables.reduce((s, t) => s + t.attachments, 0);

function durationStr(start: string | null, end: string | null): string {
  if (!start || !end) return '—';
  const sec = Math.round((new Date(end).getTime() - new Date(start).getTime()) / 1000);
  if (sec < 60) return `${sec}s`;
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return s ? `${m}m ${s}s` : `${m}m`;
}
function absTime(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
}

type StatusVariant = 'success' | 'warning' | 'error' | 'default';
const baseStatusMeta: Record<string, { label: string; variant: StatusVariant }> = {
  ok: { label: 'Backed up', variant: 'success' },
  running: { label: 'Running', variant: 'warning' },
  failed: { label: 'Failed', variant: 'error' },
  pending: { label: 'Pending', variant: 'default' },
};
const bsm = baseStatusMeta[base.status] ?? baseStatusMeta.pending;

const tableStatusMeta: Record<string, { label: string; variant: StatusVariant }> = {
  ok: { label: 'Backed up', variant: 'success' },
  running: { label: 'Running', variant: 'warning' },
  failed: { label: 'Failed', variant: 'error' },
  pending: { label: 'Pending', variant: 'default' },
};

const depthChips = [
  { label: 'Schema', on: base.depth.schema },
  { label: 'Data', on: base.depth.data },
  { label: 'Attachments', on: base.depth.attachments },
];

const backHref = `/backups/run?id=${base.runId}&state=${base.runState}`;
const airtableHref = `https://airtable.com/${base.atBaseId}`;
---

<div class="mx-auto max-w-[1200px]" data-base-detail>
  <div class="rb-nav">
    <a href={backHref} class="rb-back-link" aria-label="Back to backup run"><span class="iconify lucide--arrow-left" aria-hidden="true"></span></a>
    <nav class="rb-crumbs" aria-label="Breadcrumb">
      <a href="/backups">Backups</a>
      <span class="rb-crumb-sep" aria-hidden="true">/</span>
      <a href={backHref}>Backup run</a>
      <span class="rb-crumb-sep" aria-hidden="true">/</span>
      <span class="rb-crumb-cur" aria-current="page">{base.name}</span>
    </nav>
  </div>

  {/* Header */}
  <header class="rb-head">
    <div class="min-w-0">
      <div class="flex items-center gap-2.5 flex-wrap">
        <h1 class="text-title">{base.name}</h1>
        <Badge variant={bsm.variant}>{running && <span class="loading loading-spinner loading-xs"></span>}{bsm.label}</Badge>
      </div>
      <p class="text-sm text-base-content/60 mt-1">
        Base in this run ·
        {running
          ? <> started <span class="mono-data">{absTime(base.startedAt)}</span> · <span class="text-warning font-medium">in progress</span></>
          : failed
            ? <> attempted <span class="mono-data">{absTime(base.startedAt)}</span> · stopped before completing</>
            : <> backed up <span class="mono-data">{absTime(base.completedAt)}</span> · <span class="mono-data">{durationStr(base.startedAt, base.completedAt)}</span></>}
      </p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <Button href={airtableHref} variant="ghost" size="sm" class="gap-1.5" target="_blank" rel="noreferrer"><span class="iconify lucide--external-link"></span>Open in Airtable</Button>
    </div>
  </header>

  {/* Failed-attachments banner */}
  {base.failedAttachments.length > 0 && (
    <Alert variant="warning">
      <span class="flex flex-1 flex-wrap items-center gap-2 min-w-0">
        <span class="flex-1 min-w-0"><b>{base.failedAttachments.length} attachment{base.failedAttachments.length === 1 ? '' : 's'}</b> in this base couldn't be backed up. Every table below was otherwise captured.</span>
        <Button type="button" variant="warning" size="sm" data-open-failed>Review</Button>
      </span>
    </Alert>
  )}

  {/* Summary */}
  <section class="rb-summary">
    <div class="rb-stats">
      <div class="rb-stat"><span class="rb-stat-k">Tables</span><span class="rb-stat-v">{nf.format(base.tables.length)}</span></div>
      <div class="rb-stat"><span class="rb-stat-k">Fields</span><span class="rb-stat-v">{nf.format(totalFields)}</span></div>
      <div class="rb-stat"><span class="rb-stat-k">Records</span><span class="rb-stat-v">{failed ? '—' : nf.format(totalRecords)}</span></div>
      <div class="rb-stat"><span class="rb-stat-k">Views</span><span class="rb-stat-v">{nf.format(totalViews)}</span></div>
      <div class="rb-stat"><span class="rb-stat-k">Attachments</span><span class="rb-stat-v">{failed ? '—' : nf.format(totalAttachments)}</span></div>
    </div>
    <div class="rb-meta">
      <div class="rb-meta-row">
        <span class="rb-meta-k">Captured</span>
        <span class="rb-depth">{depthChips.map((d) => (<span class={`rb-depth-chip ${d.on ? 'on' : 'off'}`}>{d.on && <span class="iconify lucide--check"></span>}{d.label}</span>))}</span>
      </div>
      <div class="rb-meta-row">
        <span class="rb-meta-k">Destination</span>
        {failed
          ? <span class="rb-meta-v rb-dim">— nothing written</span>
          : base.destKind === 'file'
            ? <a href={base.folderUrl ?? '#'} target="_blank" rel="noreferrer" title={`Open ${base.name} in ${base.destProvider} (opens in a new tab)`} class="rb-row-link rb-folder mono-data">{base.destIcon ? <img src={base.destIcon} alt="" width="16" height="16" class="rb-dest-ic" /> : <span class="iconify lucide--folder"></span>}{base.folder}<span class="iconify lucide--external-link rb-ext"></span></a>
            : <span class="rb-db mono-data" title="Backed up as rows in your database"><span class="iconify lucide--database"></span>{base.dbRef}</span>}
      </div>
    </div>
  </section>

  {/* Per-table breakdown */}
  <section class="rb-panel">
    <div class="rb-panel-head">
      <h2>Tables in this base</h2>
      <span class="rb-hint">Counts recorded as the engine wrote each table</span>
    </div>
    <div class="rb-gridwrap">
      <table>
        <thead>
          <tr>
            <th>Table</th><th>Status</th>
            <th class="num">Fields</th><th class="num">Records</th>
            <th class="num">Views</th><th class="num">Attachments</th>
          </tr>
        </thead>
        <tbody>
          {base.tables.map((t) => {
            const tsm = tableStatusMeta[t.status] ?? tableStatusMeta.pending;
            const isRunning = t.status === 'running';
            const skipped = t.status === 'failed' || t.status === 'pending';
            return (
              <tr>
                <td class="strong"><span class="rb-tname"><span class="iconify lucide--layout-grid"></span>{t.name}</span></td>
                <td><Badge variant={tsm.variant}>{isRunning && <span class="loading loading-spinner loading-xs"></span>}{tsm.label}</Badge></td>
                <td class="num">{nf.format(t.fields)}</td>
                <td class="num">{isRunning && t.recordsRemaining != null
                  ? <span>{nf.format(t.records)} <span class="rb-rem">/ {nf.format(t.records + t.recordsRemaining)}</span></span>
                  : skipped ? '—' : nf.format(t.records)}</td>
                <td class="num">{nf.format(t.views)}</td>
                <td class="num">{isRunning && t.attachmentsRemaining != null
                  ? <span>{nf.format(t.attachments)} <span class="rb-rem">/ {nf.format(t.attachments + t.attachmentsRemaining)}</span></span>
                  : skipped ? '—' : nf.format(t.attachments)}
                  {t.failed > 0 && <button type="button" class="rb-failed" data-open-failed>{t.failed} failed</button>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    {failed && base.error && (
      <Alert variant="error" class="mt-4">
        <b>Error.</b> {base.error}
      </Alert>
    )}
  </section>

  <p class="rb-foot">Base <code class="mono-data">{base.atBaseId}</code> · part of run <code class="mono-data">{base.runId}</code> · table, field and view counts come from Airtable metadata; record &amp; attachment counts from the backup engine.</p>

  {/* Failed-attachments slide-over */}
  <div class="rb-drawer" data-failed-drawer hidden>
    <div class="rb-drawer-backdrop" data-close-failed></div>
    <aside class="rb-drawer-panel" role="dialog" aria-label="Failed attachments">
      <header class="rb-drawer-head">
        <div><h3>Failed attachments</h3><p>{base.failedAttachments.length} file{base.failedAttachments.length === 1 ? '' : 's'} in {base.name} couldn't be backed up.</p></div>
        <button type="button" class="rb-drawer-x" data-close-failed aria-label="Close"><span class="iconify lucide--x"></span></button>
      </header>
      <div class="rb-drawer-body">
        <ul class="rb-fail-list">
          {base.failedAttachments.map((f) => (
            <li class="rb-fail">
              <span class="rb-fail-ic"><span class="iconify lucide--file-x"></span></span>
              <div class="min-w-0 flex-1">
                <p class="rb-fail-name">{f.file}</p>
                <p class="rb-fail-loc">{f.table}</p>
                <p class="rb-fail-reason">{f.reason}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
      <footer class="rb-drawer-foot">
        <Button type="button" variant="ghost" size="sm" data-close-failed>Close</Button>
        <Button type="button" variant="primary" size="sm">Retry failed</Button>
      </footer>
    </aside>
  </div>
</div>

<style>
  [data-base-detail] { display: flex; flex-direction: column; gap: 1.1rem; }
  .rb-nav { display: flex; align-items: center; gap: .6rem; }
  .rb-back-link { display: inline-flex; align-items: center; justify-content: center; width: 1.75rem; height: 1.75rem; border-radius: .45rem; border: 1px solid var(--color-base-300); color: oklch(from var(--color-base-content) l c h / .7); flex: none; transition: background .12s ease, color .12s ease; }
  .rb-back-link:hover { background: var(--color-base-200); color: var(--color-base-content); }
  .rb-back-link .iconify { font-size: 1rem; }
  .rb-crumbs { display: flex; align-items: center; gap: .4rem; font-size: .8125rem; flex-wrap: wrap; }
  .rb-crumbs a { display: inline-flex; align-items: center; min-height: 1.5rem; color: oklch(from var(--color-base-content) l c h / .6); font-weight: 500; text-decoration: none; }
  .rb-crumbs a:hover { color: var(--color-base-content); text-decoration: underline; }
  .rb-crumb-sep { color: oklch(from var(--color-base-content) l c h / .35); }
  .rb-crumb-cur { color: oklch(from var(--color-base-content) l c h / .85); font-weight: 600; }
  .rb-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }

  /* Summary */
  .rb-summary { display: grid; grid-template-columns: 2fr 1fr; gap: 1rem; }
  @media (max-width: 760px) { .rb-summary { grid-template-columns: 1fr; } }
  .rb-stats { display: grid; grid-template-columns: repeat(5, 1fr); gap: .75rem; align-content: center; border: 1px solid var(--color-base-300); border-radius: .85rem; background: var(--color-base-100); padding: 1.1rem 1.25rem; }
  @media (max-width: 560px) { .rb-stats { grid-template-columns: repeat(3, 1fr); row-gap: 1rem; } }
  .rb-stat { display: flex; flex-direction: column; gap: .15rem; }
  .rb-stat-k { font-size: .75rem; font-weight: 650; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .66); }
  .rb-stat-v { font-size: 1.5rem; font-weight: 740; letter-spacing: -.02em; font-variant-numeric: tabular-nums; }
  .rb-meta { border: 1px solid var(--color-base-300); border-radius: .85rem; background: var(--color-base-100); padding: 1.1rem 1.25rem; display: flex; flex-direction: column; gap: .75rem; }
  .rb-meta-row { display: flex; flex-direction: column; gap: .3rem; }
  .rb-meta-k { font-size: .75rem; font-weight: 650; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .66); }
  .rb-meta-v { font-size: .85rem; font-weight: 550; }
  .rb-depth { display: flex; gap: .4rem; flex-wrap: wrap; }
  .rb-depth-chip { display: inline-flex; align-items: center; gap: .25rem; font-size: .75rem; font-weight: 600; padding: .15rem .5rem; border-radius: 999px; }
  .rb-depth-chip.on { color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); }
  .rb-depth-chip.off { color: oklch(from var(--color-base-content) l c h / .66); background: oklch(from var(--color-base-content) l c h / .07); }
  .rb-depth-chip .iconify { font-size: .8rem; }

  /* Panel + table */
  .rb-panel { border: 1px solid var(--color-base-300); border-radius: .85rem; background: var(--color-base-100); padding: 1.1rem 1.25rem 1.25rem; }
  .rb-panel-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .rb-panel-head h2 { font-size: .95rem; font-weight: 650; }
  .rb-hint { font-size: .75rem; color: oklch(from var(--color-base-content) l c h / .66); }
  .rb-gridwrap { overflow-x: auto; }
  .rb-gridwrap table { width: 100%; border-collapse: collapse; font-size: .82rem; }
  .rb-gridwrap th { text-align: left; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .66); padding: 0 .65rem .6rem; border-bottom: 1px solid var(--color-base-300); white-space: nowrap; }
  .rb-gridwrap td { padding: .65rem .65rem; border-bottom: 1px solid oklch(from var(--color-base-300) l c h / .5); white-space: nowrap; color: oklch(from var(--color-base-content) l c h / .8); vertical-align: middle; }
  .rb-gridwrap tbody tr:last-child td { border-bottom: 0; }
  .rb-gridwrap .num { text-align: right; font-variant-numeric: tabular-nums; }
  .rb-gridwrap td.strong { font-weight: 600; }
  .rb-tname { display: inline-flex; align-items: center; gap: .45rem; }
  .rb-tname .iconify { font-size: .95rem; color: oklch(from var(--color-base-content) l c h / .45); }
  .rb-row-link { color: var(--color-primary); font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; min-height: 1.5rem; }
  .rb-row-link:hover { text-decoration: underline; }
  .rb-folder { display: inline-flex; align-items: center; gap: .3rem; }
  .rb-folder .iconify, .rb-db .iconify { font-size: .9rem; }
  .rb-dest-ic { width: 16px; height: 16px; object-fit: contain; flex: none; }
  .rb-ext { font-size: .82rem !important; opacity: .55; transition: opacity .12s ease; color: oklch(from var(--color-primary) l c h / .85); }
  .rb-folder:hover .rb-ext { opacity: 1; }
  .rb-db { display: inline-flex; align-items: center; gap: .3rem; color: oklch(from var(--color-base-content) l c h / .7); }
  .rb-dim { color: oklch(from var(--color-base-content) l c h / .66); }
  .rb-rem { color: oklch(from var(--color-base-content) l c h / .66); }
  .rb-failed { margin-left: .4rem; font-size: .75rem; font-weight: 650; color: var(--color-error); background: oklch(from var(--color-error) l c h / .12); border: none; border-radius: .4rem; padding: .1rem .4rem; cursor: pointer; }
  .rb-failed:hover { background: oklch(from var(--color-error) l c h / .2); }

  .rb-foot { font-size: .75rem; color: oklch(from var(--color-base-content) l c h / .64); }
  .rb-foot code { font-size: 0.75rem; padding: .05rem .3rem; border-radius: 4px; background: oklch(from var(--color-base-content) l c h / .07); }

  /* Slide-over */
  .rb-drawer { position: fixed; inset: 0; z-index: 300; }
  .rb-drawer[hidden] { display: none; }
  .rb-drawer-backdrop { position: absolute; inset: 0; background: rgb(2 6 23 / .55); opacity: 0; transition: opacity .2s ease; }
  .rb-drawer.is-open .rb-drawer-backdrop { opacity: 1; }
  .rb-drawer-panel { position: absolute; top: 0; right: 0; height: 100%; width: min(92vw, 28rem); background: var(--color-base-100); border-left: 1px solid var(--color-base-300); box-shadow: -16px 0 50px oklch(from var(--color-base-content) l c h / .12); display: flex; flex-direction: column; transform: translateX(100%); transition: transform .24s cubic-bezier(.22,1,.36,1); }
  .rb-drawer.is-open .rb-drawer-panel { transform: translateX(0); }
  .rb-drawer-head { display: flex; align-items: flex-start; gap: 1rem; padding: 1.1rem 1.2rem; border-bottom: 1px solid var(--color-base-300); }
  .rb-drawer-head h3 { font-size: 1rem; font-weight: 650; }
  .rb-drawer-head p { font-size: .76rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .15rem; }
  .rb-drawer-x { margin-left: auto; color: oklch(from var(--color-base-content) l c h / .5); background: none; border: none; cursor: pointer; font-size: 1.1rem; padding: .2rem; flex: none; }
  .rb-drawer-x:hover { color: var(--color-base-content); }
  .rb-drawer-body { flex: 1; overflow-y: auto; padding: .9rem 1.2rem; }
  .rb-drawer-foot { display: flex; justify-content: flex-end; gap: .5rem; padding: .9rem 1.2rem; border-top: 1px solid var(--color-base-300); }
  .rb-fail-list { display: flex; flex-direction: column; gap: .2rem; }
  .rb-fail { display: flex; gap: .7rem; padding: .7rem 0; border-bottom: 1px solid oklch(from var(--color-base-300) l c h / .6); }
  .rb-fail:last-child { border-bottom: 0; }
  .rb-fail-ic { width: 1.9rem; height: 1.9rem; border-radius: .45rem; display: grid; place-items: center; flex: none; background: oklch(from var(--color-error) l c h / .12); color: var(--color-error); }
  .rb-fail-name { font-size: .82rem; font-weight: 600; overflow-wrap: anywhere; }
  .rb-fail-loc { font-size: .75rem; color: oklch(from var(--color-base-content) l c h / .64); margin-top: .05rem; }
  .rb-fail-reason { font-size: .75rem; color: var(--color-error); margin-top: .15rem; }

  /* Light-theme contrast: the semantic status colors are tuned for accents/icons and for
     the dark theme; as SMALL TEXT on white they fail WCAG AA. Darken them on light only
     (dark keeps the brighter token). Icon/background graphics keep the bright token. */
  :global([data-theme="baseout-light"]) .rb-depth-chip.on { color: oklch(from var(--color-success) calc(l - 0.16) c h); }
  :global([data-theme="baseout-light"]) .rb-failed,
  :global([data-theme="baseout-light"]) .rb-fail-reason { color: oklch(from var(--color-error) calc(l - 0.06) c h); }
</style>

<script>
  function wireBaseDetail() {
    const root = document.querySelector<HTMLElement>('[data-base-detail]');
    if (!root) return;
    const drawer = root.querySelector<HTMLElement>('[data-failed-drawer]');
    const open = () => { if (!drawer) return; drawer.hidden = false; requestAnimationFrame(() => drawer.classList.add('is-open')); };
    const close = () => { if (!drawer) return; drawer.classList.remove('is-open'); window.setTimeout(() => { drawer.hidden = true; }, 220); };
    root.querySelectorAll('[data-open-failed]').forEach((b) => b.addEventListener('click', open));
    root.querySelectorAll('[data-close-failed]').forEach((b) => b.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && drawer && !drawer.hidden) close(); });
  }
  wireBaseDetail();
  document.addEventListener('astro:after-swap', wireBaseDetail);
</script>
