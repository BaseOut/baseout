  .rd-drawer-head h3 { font-size: 1rem; font-weight: 650; }
  .rd-drawer-head p { font-size: .76rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .15rem; }
  .rd-drawer-x { margin-left: auto; color: oklch(from var(--color-base-content) l c h / .5); background: none; border: none; cursor: pointer; font-size: 1.1rem; padding: .2rem; flex: none; }
  .rd-drawer-x:hover { color: var(--color-base-content); }
  .rd-drawer-body { flex: 1; overflow-y: auto; padding: .9rem 1.2rem; }
