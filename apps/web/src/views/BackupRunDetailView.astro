<script>
  function wireRunDetail() {
    const root = document.querySelector<HTMLElement>('[data-run-detail]');
    if (!root) return;
    const drawer = root.querySelector<HTMLElement>('[data-failed-drawer]');
    const open = () => { if (!drawer) return; drawer.hidden = false; requestAnimationFrame(() => drawer.classList.add('is-open')); };
    const close = () => { if (!drawer) return; drawer.classList.remove('is-open'); window.setTimeout(() => { drawer.hidden = true; }, 220); };
    root.querySelectorAll('[data-open-failed]').forEach((b) => b.addEventListener('click', open));
    root.querySelectorAll('[data-close-failed]').forEach((b) => b.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && drawer && !drawer.hidden) close(); });
  }
  wireRunDetail();
  document.addEventListener('astro:after-swap', wireRunDetail);
</script>
