  /* Light-theme contrast: the semantic status colors are tuned for accents/icons and for
     the dark theme; as SMALL TEXT on white they fail WCAG AA. Darken them on light only
     (dark keeps the brighter token). Icon/background graphics keep the bright token. */
  :global([data-theme="baseout-light"]) .rd-badge.is-ok,
