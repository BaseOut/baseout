---
/**
 * BackupsListView — the Backups page: an auditable table of every run for this
 * Space, each row drilling into the run detail. Replaces the old accordion
 * history widget (which expanded inline and polled). Run a one-off from the header.
 */
import type { BackupRunSummary } from '../lib/backup-runs/types';

interface Props {
  runs?: BackupRunSummary[];
  /**
   * Production embed (apps/web). When true the host page owns the header +
   * the real Run-backup control, and every row drills by run id (the harness
   * `?state=running|failed` preview links are dropped). Default false keeps the
   * design-harness behavior byte-identical.
   */
  embedded?: boolean;
}
const { runs = [], embedded = false } = Astro.props;
const nf = new Intl.NumberFormat('en-US');

function since(iso: string | null): string {
  if (!iso) return '—';
  const ms = Date.now() - new Date(iso).getTime();
  const m = Math.round(ms / 60000);
  if (m < 1) return 'just now';
  if (m < 60) return `${m}m ago`;
  const h = Math.round(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.round(h / 24)}d ago`;
}
function durationStr(start: string | null, end: string | null): string {
  if (!start || !end) return '—';
  const sec = Math.round((new Date(end).getTime() - new Date(start).getTime()) / 1000);
  if (sec < 60) return `${sec}s`;
  const mm = Math.floor(sec / 60);
  const ss = sec % 60;
  return ss ? `${mm}m ${ss}s` : `${mm}m`;
}

const statusMeta: Record<string, { label: string; cls: string }> = {
  succeeded: { label: 'Succeeded', cls: 'is-ok' },
  trial_succeeded: { label: 'Trial run', cls: 'is-ok' },
  running: { label: 'Running', cls: 'is-run' },
  queued: { label: 'Queued', cls: 'is-muted' },
  failed: { label: 'Failed', cls: 'is-fail' },
  cancelled: { label: 'Cancelled', cls: 'is-muted' },
};
const triggerLabel = (t: string) =>
  t.startsWith('schedule') ? 'Scheduled' : t.startsWith('webhook') ? 'Webhook' : t.startsWith('onboarding') ? 'Trial' : 'Manual';

const isOk = (s: string) => s === 'succeeded' || s === 'trial_succeeded';
const detailHref = (r: BackupRunSummary) =>
  embedded
    ? `/backups/run?id=${r.id}`
    : r.status === 'running' || r.status === 'queued'
      ? '/backups/run?state=running'
      : r.status === 'failed'
        ? '/backups/run?state=failed'
        : `/backups/run?id=${r.id}`;
---

<div class="mx-auto max-w-[1200px] bl">
  {!embedded && (
    <header class="bl-head">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold tracking-tight">Backups</h1>
        <p class="text-sm text-base-content/60 mt-1">Every backup run for this Space. Open any run for its full per-base detail.</p>
      </div>
      <a href="/backups/run?state=running" class="btn btn-primary btn-sm shrink-0">Run backup now</a>
    </header>
  )}

  {runs.length > 0 ? (
    <section class="bl-panel">
      <div class="bl-panel-head"><h2>Backup history</h2><span class="bl-count">{runs.length} run{runs.length === 1 ? '' : 's'}</span></div>
      <div class="bl-tablewrap">
        <table class="bl-table">
          <thead>
            <tr>
              <th>Status</th><th>When</th><th>Trigger</th>
              <th class="num">Bases</th><th class="num">Records</th><th class="num">Attachments</th><th class="num">Duration</th><th></th>
            </tr>
          </thead>
          <tbody>
            {runs.map((r) => {
              const sm = statusMeta[r.status] ?? statusMeta.cancelled;
              const ok = isOk(r.status);
              const active = r.status === 'running' || r.status === 'queued';
              return (
                <tr class="bl-row" onclick={`window.location='${detailHref(r)}'`}>
                  <td><span class={`bl-pill ${sm.cls}`}>{r.status === 'running' && <span class="bl-spin"></span>}{sm.label}</span></td>
                  <td>{active ? <span class="bl-dim">{r.status === 'running' ? 'in progress' : 'queued'}</span> : since(r.completedAt)}</td>
                  <td class="bl-dim">{triggerLabel(r.triggeredBy)}</td>
                  <td class="num">{r.includedBases.length}</td>
                  <td class="num">{ok ? nf.format(r.recordCount ?? 0) : '—'}</td>
                  <td class="num">{ok ? nf.format(r.attachmentCount ?? 0) : '—'}</td>
                  <td class="num bl-dim">{active ? '—' : durationStr(r.startedAt, r.completedAt)}</td>
                  <td class="num"><a href={detailHref(r)} class="bl-link" onclick="event.stopPropagation()">Details →</a></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  ) : (
    <section class="bl-empty">
      <span class="bl-empty-ic"><span class="iconify lucide--archive"></span></span>
      <p class="bl-empty-title">No backups yet</p>
      <p class="bl-empty-sub">Run your first backup, or wait for the next scheduled one. Each run lands here with full audit detail.</p>
      {!embedded && <a href="/backups/run?state=running" class="btn btn-primary btn-sm">Run backup now</a>}
    </section>
  )}
</div>

<style>
  .bl { display: flex; flex-direction: column; gap: 1.25rem; }
  .bl-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }

  .bl-panel { border: 1px solid var(--color-base-300); border-radius: .85rem; background: var(--color-base-100); padding: 1.1rem 1.25rem 1.25rem; }
  .bl-panel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .bl-panel-head h2 { font-size: .95rem; font-weight: 650; }
  .bl-count { font-size: .76rem; color: oklch(from var(--color-base-content) l c h / .5); }

  .bl-tablewrap { overflow-x: auto; }
  .bl-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
  .bl-table th { text-align: left; font-size: .66rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .45); padding: 0 .7rem .6rem; border-bottom: 1px solid var(--color-base-300); white-space: nowrap; }
  .bl-table td { padding: .7rem .7rem; border-bottom: 1px solid oklch(from var(--color-base-300) l c h / .5); white-space: nowrap; color: oklch(from var(--color-base-content) l c h / .8); }
  .bl-table tbody tr:last-child td { border-bottom: 0; }
  .bl-table .num { text-align: right; font-variant-numeric: tabular-nums; }
  .bl-row { cursor: pointer; transition: background .12s ease; }
  .bl-row:hover { background: oklch(from var(--color-base-200) l c h / .5); }
  .bl-dim { color: oklch(from var(--color-base-content) l c h / .55); }
  .bl-link { color: var(--color-primary); font-weight: 600; text-decoration: none; }
  .bl-link:hover { text-decoration: underline; }
  .bl-pill { display: inline-flex; align-items: center; gap: .3rem; font-size: .66rem; font-weight: 650; padding: .15rem .55rem; border-radius: 999px; }
  .bl-pill.is-ok { color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); }
  .bl-pill.is-fail { color: var(--color-error); background: oklch(from var(--color-error) l c h / .14); }
  .bl-pill.is-run { color: var(--color-warning); background: oklch(from var(--color-warning) l c h / .14); }
  .bl-pill.is-muted { color: oklch(from var(--color-base-content) l c h / .55); background: oklch(from var(--color-base-content) l c h / .08); }
  .bl-spin { width: .6rem; height: .6rem; border-radius: 999px; border: 1.5px solid oklch(from var(--color-warning) l c h / .3); border-top-color: var(--color-warning); animation: bl-spin .7s linear infinite; }
  @keyframes bl-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .bl-spin { animation: none; } }

  .bl-empty { border: 1px dashed var(--color-base-300); border-radius: .85rem; background: oklch(from var(--color-base-200) l c h / .3); padding: 3rem 1.5rem; display: flex; flex-direction: column; align-items: center; text-align: center; gap: .5rem; }
  .bl-empty-ic { width: 3rem; height: 3rem; border-radius: .8rem; display: grid; place-items: center; background: var(--color-base-100); border: 1px solid var(--color-base-300); margin-bottom: .3rem; }
  .bl-empty-ic .iconify { font-size: 1.4rem; color: oklch(from var(--color-base-content) l c h / .55); }
  .bl-empty-title { font-size: 1rem; font-weight: 650; }
  .bl-empty-sub { font-size: .85rem; color: oklch(from var(--color-base-content) l c h / .6); max-width: 42ch; margin-bottom: .6rem; }
</style>
