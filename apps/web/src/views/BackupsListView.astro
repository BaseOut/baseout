---
/**
 * BackupsListView — the Backups page: an auditable table of every run for this
 * Space, each row drilling into the run detail. Replaces the old accordion
 * history widget (which expanded inline and polled). Run a one-off from the header.
 *
 * Primitives (search input, faceted filters, page select, buttons, status badges,
 * table) come from the catalog (daisyUI / styleguide). The toolbar/pager layout,
 * the clickable rows, and the empty / no-match states are the bespoke composition.
 *
 * Filters follow the faceted-filter pattern (shadcn DataTableFacetedFilter; see
 * Deel / Profound on Mobbin): each facet is a dropdown of checkboxes with a
 * selected-count badge on its trigger. Status & trigger are multi-select; date is
 * a single mutually-exclusive range (radios).
 */
import type { BackupRunSummary } from '../lib/backup-runs/types';
import {
  durationStr,
  isActiveStatus,
  isOkStatus,
  sinceLabel,
  statusMetaFor,
  triggerKey,
  triggerLabel,
} from '../lib/backups/list-row';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import TextInput from '../components/ui/TextInput.astro';
import Select from '../components/ui/Select.astro';

interface Props {
  runs?: BackupRunSummary[];
  /**
   * Production embed (apps/web). When true the host page (backups.astro) owns the
   * header + the real Run-backup control, so the view's own header is dropped, and
   * every row drills by run id (the harness `?state=running|failed` preview links
   * are skipped). Default false keeps the design-harness behavior byte-identical.
   */
  embedded?: boolean;
}
const { runs = [], embedded = false } = Astro.props;
const nf = new Intl.NumberFormat('en-US');

// Status badge meta, ok/active predicates, and trigger + time formatting live
// in lib/backups/list-row.ts so these SSR rows and the live-poll re-render
// (widget-lifecycle → backupRowHtml) share one taxonomy and can't drift.
const detailHref = (r: BackupRunSummary) =>
  embedded
    ? `/backups/run?id=${r.id}`
    : r.status === 'running' || r.status === 'queued'
      ? '/backups/run?state=running'
      : r.status === 'failed'
        ? '/backups/run?state=failed'
        : `/backups/run?id=${r.id}`;

// Faceted filter options (value, label). Status & trigger are multi-select
// (checkboxes); date is single-select (radios, mutually-exclusive ranges).
const statusOpts: [string, string][] = [['succeeded', 'Succeeded'], ['failed', 'Failed'], ['running', 'Running'], ['queued', 'Queued'], ['cancelled', 'Cancelled']];
const triggerOpts: [string, string][] = [['scheduled', 'Scheduled'], ['manual', 'Manual'], ['webhook', 'Webhook'], ['trial', 'Trial']];
const dateOpts: [string, string][] = [['', 'All time'], ['7', 'Last 7 days'], ['30', 'Last 30 days'], ['90', 'Last 90 days']];
---

<div class="mx-auto max-w-[1200px] bl">
  {!embedded && (
    <header class="bl-head">
      <div class="min-w-0">
        <h1 class="text-title">Backups</h1>
        <p class="text-sm text-base-content/60 mt-1">Every backup run for this Space. Open any run for its full per-base detail.</p>
      </div>
      <Button href="/backups/run?state=running" variant="primary" class="shrink-0"><span class="iconify lucide--play size-4" aria-hidden="true"></span>Run backup now</Button>
    </header>
  )}

  {runs.length > 0 ? (
    <section class="bl-panel" data-bl-list>
      <div class="bl-panel-head"><h2>Backup history</h2></div>

      {/* Toolbar — search + faceted filters. Filtering/search/paging is done
          client-side over the loaded runs for the prototype; the real app pushes
          these to the runs query (?status=&trigger=&since=&q=&page=). */}
      <div class="bl-toolbar">
        <TextInput type="search" data-bl-search placeholder="Search by Run ID or error…" icon="search" size="sm" class="grow min-w-[12rem]" aria-label="Search runs" />

        <div class="bl-facet-popover" data-bl-facet="status">
          <div tabindex="0" role="button" class="bl-facet-trigger" data-bl-facet-trigger aria-label="Filter by status">
            Status
            <span class="bl-facet-count" data-bl-facet-count hidden></span>
            <span class="iconify lucide--chevron-down size-3 opacity-50" aria-hidden="true"></span>
          </div>
          <div tabindex="0" class="bl-facet-menu">
            {statusOpts.map(([v, label]) => (
              <label class="bl-facet-opt">
                <input type="checkbox" class="checkbox checkbox-primary checkbox-xs" value={v} /> {label}
              </label>
            ))}
          </div>
        </div>

        <div class="bl-facet-popover" data-bl-facet="trigger">
          <div tabindex="0" role="button" class="bl-facet-trigger" data-bl-facet-trigger aria-label="Filter by trigger">
            Trigger
            <span class="bl-facet-count" data-bl-facet-count hidden></span>
            <span class="iconify lucide--chevron-down size-3 opacity-50" aria-hidden="true"></span>
          </div>
          <div tabindex="0" class="bl-facet-menu">
            {triggerOpts.map(([v, label]) => (
              <label class="bl-facet-opt">
                <input type="checkbox" class="checkbox checkbox-primary checkbox-xs" value={v} /> {label}
              </label>
            ))}
          </div>
        </div>

        <div class="bl-facet-popover" data-bl-facet="date">
          <div tabindex="0" role="button" class="bl-facet-trigger" data-bl-facet-trigger aria-label="Filter by date">
            Date
            <span class="bl-facet-count" data-bl-facet-count hidden></span>
            <span class="iconify lucide--chevron-down size-3 opacity-50" aria-hidden="true"></span>
          </div>
          <div tabindex="0" class="bl-facet-menu">
            {dateOpts.map(([v, label]) => (
              <label class="bl-facet-opt">
                <input type="radio" name="bl-date" class="radio radio-primary radio-xs" value={v} checked={v === ''} /> {label}
              </label>
            ))}
          </div>
        </div>

        <Button type="button" variant="danger-ghost" size="sm" class="gap-1" data-bl-clear hidden>
          <span class="iconify lucide--x size-3.5" aria-hidden="true"></span>Clear
        </Button>
      </div>

      <div class="bl-gridwrap">
        <table class="table text-sm">
          <thead>
            <tr class="text-xs uppercase tracking-wider text-base-content/60">
              <th>Status</th><th>When</th><th>Trigger</th>
              <th class="text-right">Bases</th><th class="text-right">Records</th><th class="text-right">Attachments</th><th class="text-right">Duration</th><th></th>
            </tr>
          </thead>
          <tbody>
            {runs.map((r) => {
              const sm = statusMetaFor(r.status);
              const ok = isOkStatus(r.status);
              const active = isActiveStatus(r.status);
              return (
                <tr
                  class="bl-row"
                  data-run-id={r.id}
                  data-status={r.status}
                  data-trigger={triggerKey(r.triggeredBy)}
                  data-date={r.completedAt ?? r.createdAt}
                  data-search={`${r.id} ${(r.errorMessage ?? '').toLowerCase()}`}
                  onclick={`window.location='${detailHref(r)}'`}
                >
                  <td><Badge variant={sm.variant}>{r.status === 'running' && <span class="loading loading-spinner loading-xs"></span>}{sm.label}</Badge></td>
                  <td>{active ? <span class="text-base-content/64">{r.status === 'running' ? 'in progress' : 'queued'}</span> : sinceLabel(r.completedAt)}</td>
                  <td class="text-base-content/64">{triggerLabel(r.triggeredBy)}</td>
                  <td class="text-right tabular-nums">{r.includedBases.length}</td>
                  <td class="text-right tabular-nums">{ok ? nf.format(r.recordCount ?? 0) : '—'}</td>
                  <td class="text-right tabular-nums">{ok ? nf.format(r.attachmentCount ?? 0) : '—'}</td>
                  <td class="text-right tabular-nums text-base-content/64 mono-data">{active ? '—' : durationStr(r.startedAt, r.completedAt)}</td>
                  <td class="text-right"><Button href={detailHref(r)} variant="ghost" size="sm" class="text-primary" onclick="event.stopPropagation()">Details →</Button></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* No rows match the active filters (distinct from the no-runs-at-all empty state) */}
      <div class="bl-nomatch" data-bl-nomatch hidden>
        <span class="bl-nomatch-ic"><span class="iconify lucide--search-x" aria-hidden="true"></span></span>
        <p class="bl-nomatch-title">No runs match these filters</p>
        <Button type="button" variant="ghost" size="sm" data-bl-clear>Clear filters</Button>
      </div>

      <div class="bl-pager" data-bl-pager>
        <div data-bl-pagesize-wrap>
          <Select
            label="Rows"
            size="sm"
            class="inline-flex w-auto min-w-0"
            options={[{ value: '10', label: '10' }, { value: '20', label: '20' }, { value: '50', label: '50' }]}
            value="20"
          />
        </div>
        <div class="ml-auto text-sm text-base-content/70"><span class="mono-data" data-bl-range>1–20</span> of <span class="mono-data" data-bl-total>0</span></div>
        <div class="bl-pager-nav">
          <Button type="button" variant="ghost" size="sm" icon data-bl-prev aria-label="Previous page"><span class="iconify lucide--chevron-left size-4" aria-hidden="true"></span></Button>
          <Button type="button" variant="ghost" size="sm" icon data-bl-next aria-label="Next page"><span class="iconify lucide--chevron-right size-4" aria-hidden="true"></span></Button>
        </div>
      </div>
    </section>
  ) : (
    <section class="bl-empty">
      <span class="bl-empty-ic"><span class="iconify lucide--archive"></span></span>
      <p class="bl-empty-title">No backups yet</p>
      <p class="bl-empty-sub">Run your first backup, or wait for the next scheduled one. Each run lands here with full audit detail.</p>
      <Button href="/backups/run?state=running" variant="primary" size="lg"><span class="iconify lucide--play size-4" aria-hidden="true"></span>Run backup now</Button>
    </section>
  )}
</div>

<script>
  import { registerBackupHistoryLifecycle, makeFetchRuns } from '../lib/backups/widget-lifecycle';
  import { backupRowHtml } from '../lib/backups/list-row';
  import type { BackupRunSummary } from '../lib/backup-runs/types';

  // Re-applies the active filter/search/page pass over whatever rows are in the
  // DOM. Set by initBackupsList; called by the live-poll re-render below after
  // it rebuilds the <tbody>.
  let reflow = (): void => {};

  // Client-side faceted filter / search / pagination over the loaded run rows. In
  // production these become server query params; here the full list is rendered
  // and we show/hide. Status & trigger are multi-select; date is a single range.
  function initBackupsList() {
    const root = document.querySelector<HTMLElement>('[data-bl-list]');
    if (!root) { reflow = () => {}; return; }
    const searchEl = root.querySelector<HTMLInputElement>('[data-bl-search]')!;
    const facets = Array.from(root.querySelectorAll<HTMLElement>('[data-bl-facet]'));
    // Avoid querySelector<HTMLSelectElement>: worker-configuration.d.ts declares
    // an HTMLRewriter `Element` global that breaks the generic constraint.
    const pageSizeEl = root.querySelector('[data-bl-pagesize-wrap] select') as unknown as HTMLSelectElement;
    const clearEls = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-bl-clear]'));
    const rangeEl = root.querySelector<HTMLElement>('[data-bl-range]')!;
    const totalEl = root.querySelector<HTMLElement>('[data-bl-total]')!;
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-bl-prev]')!;
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-bl-next]')!;
    const pager = root.querySelector<HTMLElement>('[data-bl-pager]')!;
    const noMatch = root.querySelector<HTMLElement>('[data-bl-nomatch]')!;
    const tableWrap = root.querySelector<HTMLElement>('.bl-gridwrap')!;
    const DAY = 86_400_000;
    let page = 1;

    const facetValues = (key: string): string[] => {
      const f = facets.find((el) => el.dataset.blFacet === key);
      if (!f) return [];
      return Array.from(f.querySelectorAll<HTMLInputElement>('input:checked'))
        .map((i) => i.value)
        .filter((v) => v !== '');
    };

    type Filters = { status: string[]; trigger: string[]; date: string; q: string };
    const getFilters = (): Filters => ({
      status: facetValues('status'),
      trigger: facetValues('trigger'),
      date: facetValues('date')[0] || '',
      q: (searchEl.value || '').trim().toLowerCase(),
    });
    const anyFilter = (f: Filters) => !!(f.status.length || f.trigger.length || f.date || f.q);
    const matches = (row: HTMLElement, f: Filters) => {
      if (f.status.length && !f.status.includes(row.dataset.status as string)) return false;
      if (f.trigger.length && !f.trigger.includes(row.dataset.trigger as string)) return false;
      if (f.date) {
        const age = (Date.now() - new Date(row.dataset.date as string).getTime()) / DAY;
        if (age > Number(f.date)) return false;
      }
      if (f.q && !(row.dataset.search || '').includes(f.q)) return false;
      return true;
    };

    // Reflect each facet's selection count on its trigger (badge + active style).
    const syncFacets = (f: Filters) => {
      facets.forEach((el) => {
        const key = el.dataset.blFacet as string;
        const n = key === 'date' ? (f.date ? 1 : 0) : (((f as Record<string, string[] | string>)[key] as string[]) || []).length;
        const badge = el.querySelector<HTMLElement>('[data-bl-facet-count]')!;
        const trigger = el.querySelector<HTMLElement>('[data-bl-facet-trigger]')!;
        badge.textContent = String(n);
        badge.hidden = n === 0;
        trigger.classList.toggle('bl-facet-on', n > 0);
      });
    };

    const render = () => {
      // Re-query each pass so rows rebuilt by the live-poll re-render are seen.
      const rows = Array.from(root.querySelectorAll<HTMLTableRowElement>('.bl-row'));
      const f = getFilters();
      const matched = rows.filter((r) => matches(r, f));
      const size = Number(pageSizeEl.value);
      const pages = Math.max(1, Math.ceil(matched.length / size));
      if (page > pages) page = pages;
      const start = (page - 1) * size;
      const end = start + size;
      rows.forEach((r) => (r.style.display = 'none'));
      matched.slice(start, end).forEach((r) => (r.style.display = ''));

      const empty = matched.length === 0;
      totalEl.textContent = String(matched.length);
      rangeEl.textContent = empty ? '0' : `${start + 1}–${Math.min(end, matched.length)}`;
      prevBtn.disabled = page <= 1;
      nextBtn.disabled = page >= pages;
      noMatch.hidden = !empty;
      tableWrap.style.display = empty ? 'none' : '';
      pager.style.display = empty ? 'none' : '';
      syncFacets(f);
      clearEls.forEach((el) => (el.hidden = !anyFilter(f)));
    };

    searchEl.addEventListener('input', () => { page = 1; render(); });
    facets.forEach((el) => el.addEventListener('change', () => { page = 1; render(); }));
    pageSizeEl.addEventListener('change', () => { page = 1; render(); });
    clearEls.forEach((el) => el.addEventListener('click', () => {
      searchEl.value = '';
      facets.forEach((fc) => fc.querySelectorAll<HTMLInputElement>('input').forEach((i) => {
        if (i.type === 'checkbox') i.checked = false;
        else if (i.type === 'radio') i.checked = i.value === '';
      }));
      page = 1;
      render();
    }));
    prevBtn.addEventListener('click', () => { if (page > 1) { page--; render(); } });
    nextBtn.addEventListener('click', () => { page++; render(); });
    reflow = render;
    render();
  }
  initBackupsList();
  document.addEventListener('astro:page-load', initBackupsList);

  // Live progress: subscribe to the polled run store and re-render the table
  // body in place so a run's status flips (running → succeeded / failed) and
  // new runs appear without a full page reload. The hydration tag and the
  // [data-backup-history] root (with data-space-id) live on the host page
  // (backups.astro); in the design harness they're absent, so this no-ops.
  registerBackupHistoryLifecycle({
    render(runs: readonly BackupRunSummary[]) {
      const tbody = document.querySelector<HTMLElement>('[data-bl-list] tbody');
      if (!tbody) {
        // Empty-state DOM has no table. Once the first run exists the panel
        // structure must change (empty → table), which SSR owns — re-render
        // via a one-time soft reload. Only the first-ever run for a Space hits
        // this; subsequent updates are live (a tbody is always present).
        if (runs.length > 0) window.location.reload();
        return;
      }
      tbody.innerHTML = runs.map(backupRowHtml).join('');
      reflow();
    },
    fetchRuns: makeFetchRuns(25),
  });
</script>

<style>
  /* Composition + layout only. The controls, badges and table inside are daisyUI
     primitives (see /styleguide); the facet dropdowns are daisyUI `dropdown`. */
  .bl { display: flex; flex-direction: column; gap: 1.25rem; }
  .bl-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }

  .bl-panel { border: 1px solid var(--color-base-300); border-radius: .85rem; background: var(--color-base-100); padding: 1.1rem 1.25rem 1.25rem; }
  .bl-panel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
  .bl-panel-head h2 { font-size: .95rem; font-weight: 650; }

  .bl-toolbar { display: flex; align-items: center; gap: .55rem; flex-wrap: wrap; margin-bottom: 1rem; }

  /* Faceted filter popover — opens menu on focus within. */
  .bl-facet-popover { position: relative; display: inline-block; }
  .bl-facet-trigger {
    display: inline-flex; align-items: center; gap: .375rem; min-height: 2rem; padding: 0 .75rem;
    border-radius: var(--radius-field, .5rem); border: 1px solid var(--color-base-300);
    background: var(--color-neutral, var(--color-base-200)); font-size: .875rem; font-weight: 500; cursor: pointer;
  }
  .bl-facet-trigger.bl-facet-on { background: color-mix(in oklch, var(--color-primary) 14%, transparent); border-color: color-mix(in oklch, var(--color-primary) 30%, transparent); color: var(--color-primary); }
  .bl-facet-popover:not(:focus-within) .bl-facet-menu { display: none; }
  .bl-facet-count { display: inline-flex; align-items: center; justify-content: center; min-width: 1.1rem; height: 1.1rem; padding: 0 .25rem; border-radius: 999px; font-size: .68rem; font-weight: 700; color: var(--color-primary-content, #fff); background: var(--color-primary); }
  .bl-facet-menu { z-index: 20; position: absolute; left: 0; margin-top: .4rem; width: 13rem; border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); padding: .35rem; box-shadow: 0 10px 28px oklch(0 0 0 / .14); }
  .bl-facet-opt { display: flex; align-items: center; gap: .6rem; padding: .4rem .5rem; border-radius: .45rem; font-size: .82rem; cursor: pointer; user-select: none; }
  .bl-facet-opt:hover { background: oklch(from var(--color-base-200) l c h / .6); }

  .bl-gridwrap { overflow-x: auto; }
  .bl-gridwrap :is(th, td) { white-space: nowrap; }
  .bl-row { cursor: pointer; }
  .bl-row:hover { background: oklch(from var(--color-base-200) l c h / .5); }

  .bl-pager { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; padding-top: .9rem; border-top: 1px solid var(--color-base-300); }
  .bl-pager-nav { display: inline-flex; gap: .35rem; }

  /* No-match state (distinct from the no-runs-at-all empty) */
  .bl-nomatch { display: flex; flex-direction: column; align-items: center; text-align: center; gap: .55rem; padding: 2.5rem 1rem; }
  .bl-nomatch-ic { width: 2.5rem; height: 2.5rem; border-radius: .7rem; display: grid; place-items: center; background: var(--color-base-200); }
  .bl-nomatch-ic .iconify { font-size: 1.2rem; color: oklch(from var(--color-base-content) l c h / .6); }
  .bl-nomatch-title { font-size: .9rem; font-weight: 600; }

  .bl-empty { border: 1px dashed var(--color-base-300); border-radius: .85rem; background: oklch(from var(--color-base-200) l c h / .3); padding: 3rem 1.5rem; display: flex; flex-direction: column; align-items: center; text-align: center; gap: .5rem; }
  .bl-empty-ic { width: 3rem; height: 3rem; border-radius: .8rem; display: grid; place-items: center; background: var(--color-base-100); border: 1px solid var(--color-base-300); margin-bottom: .3rem; }
  .bl-empty-ic .iconify { font-size: 1.4rem; color: oklch(from var(--color-base-content) l c h / .55); }
  .bl-empty-title { font-size: 1rem; font-weight: 650; }
  .bl-empty-sub { font-size: .85rem; color: oklch(from var(--color-base-content) l c h / .6); max-width: 42ch; margin-bottom: .6rem; }
</style>
