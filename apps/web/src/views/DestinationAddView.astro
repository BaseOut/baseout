---
/**
 * DestinationAddView — add an account-level destination (skeleton).
 *
 * Step 1: pick a type. File storage is the required everyday store; a database is an
 * optional, encouraged extra (soft upsell, never a blocker). Step 2 (when ?type is set):
 * authenticate + point it somewhere, then Save & Test. The created destination becomes a
 * reusable account object, then linkable to Spaces.
 */
import Button from '../components/ui/Button.astro';

interface Props {
  /** provider slug picked in step 1; null shows the type picker */
  selectedType?: string | null;
}
const { selectedType = null } = Astro.props;

interface TypeDef { id: string; label: string; icon: string; kind: 'file' | 'database'; note: string; field: 'folder' | 'connection'; managed?: boolean; }
const fileTypes: TypeDef[] = [
  { id: 'r2', label: 'Baseout R2', icon: 'lucide--box', kind: 'file', note: 'Managed storage, zero setup', field: 'folder', managed: true },
  { id: 'google_drive', label: 'Google Drive', icon: 'lucide--hard-drive', kind: 'file', note: 'Your own Drive', field: 'folder' },
  { id: 'dropbox', label: 'Dropbox', icon: 'lucide--hard-drive', kind: 'file', note: 'Your own Dropbox', field: 'folder' },
  { id: 'box', label: 'Box', icon: 'lucide--hard-drive', kind: 'file', note: 'Your own Box', field: 'folder' },
  { id: 's3', label: 'Amazon S3', icon: 'lucide--cloud', kind: 'file', note: 'Your own S3 bucket', field: 'folder' },
];
const dbTypes: TypeDef[] = [
  { id: 'postgres', label: 'Postgres', icon: 'lucide--database', kind: 'database', note: 'Self-hosted or cloud', field: 'connection' },
  { id: 'neon', label: 'Neon', icon: 'lucide--database', kind: 'database', note: 'Serverless Postgres', field: 'connection' },
  { id: 'supabase', label: 'Supabase', icon: 'lucide--database', kind: 'database', note: 'Postgres + APIs', field: 'connection' },
  { id: 'byodb', label: 'Other database', icon: 'lucide--database', kind: 'database', note: 'Connection string', field: 'connection' },
];
const all = [...fileTypes, ...dbTypes];
const sel = all.find((t) => t.id === selectedType) ?? null;
---

<div class="mx-auto max-w-3xl space-y-6">
  <a href="/settings/destinations" class="back-link"><span class="iconify lucide--arrow-left" aria-hidden="true"></span> Destinations</a>

  {!sel ? (
    <>
      <header>
        <h1 class="text-2xl font-bold tracking-tight">Add a destination</h1>
        <p class="text-sm text-base-content/60 mt-1">Pick where backups go. You set it up once and reuse it across Spaces.</p>
      </header>

      <section>
        <h2 class="add-section-title">File storage <span class="add-req">required for every backup</span></h2>
        <div class="add-grid">
          {fileTypes.map((t) => (
            <a href={`/settings/destinations/new?type=${t.id}`} class="add-card">
              <span class="add-ic"><span class={`iconify ${t.icon}`} aria-hidden="true"></span></span>
              <span class="min-w-0"><span class="add-name">{t.label}{t.managed && <span class="add-tag">Managed</span>}</span><span class="add-note">{t.note}</span></span>
            </a>
          ))}
        </div>
      </section>

      <section>
        <div class="add-db-head">
          <h2 class="add-section-title">Database <span class="add-rec">Recommended</span></h2>
          <p class="add-db-blurb">Add a database to query your backup with SQL and power live dashboards. Optional — your file backup runs without it.</p>
        </div>
        <div class="add-grid">
          {dbTypes.map((t) => (
            <a href={`/settings/destinations/new?type=${t.id}`} class="add-card">
              <span class="add-ic add-ic-db"><span class={`iconify ${t.icon}`} aria-hidden="true"></span></span>
              <span class="min-w-0"><span class="add-name">{t.label}</span><span class="add-note">{t.note}</span></span>
            </a>
          ))}
        </div>
      </section>
    </>
  ) : (
    <>
      <header class="flex items-center gap-3">
        <span class="add-ic add-ic-lg"><span class={`iconify ${sel.icon}`} aria-hidden="true"></span></span>
        <div>
          <h1 class="text-xl font-bold tracking-tight leading-tight">Connect {sel.label}</h1>
          <p class="text-sm text-base-content/55 leading-tight mt-0.5">{sel.kind === 'database' ? 'Database destination' : 'File storage destination'}</p>
        </div>
      </header>

      <form method="POST" action="/api/destinations" class="add-form" data-astro-reload>
        <label class="add-field">
          <span class="add-label">Name</span>
          <input type="text" name="name" placeholder={`${sel.label} backup`} class="input input-bordered w-full" />
          <span class="add-hint">A label you'll recognise when linking it to Spaces.</span>
        </label>

        {sel.managed ? (
          <p class="add-managed"><span class="iconify lucide--shield-check" aria-hidden="true"></span> Managed by Baseout — no account to connect or folder to choose.</p>
        ) : sel.field === 'folder' ? (
          <label class="add-field">
            <span class="add-label">Folder</span>
            <input type="text" name="folder" placeholder="/Baseout" class="input input-bordered w-full font-mono text-sm" />
            <span class="add-hint">Each Space writes to its own subfolder. You’ll authorize the account after saving.</span>
          </label>
        ) : (
          <label class="add-field">
            <span class="add-label">Connection string</span>
            <input type="password" name="connection" placeholder="postgres://user:••••@host:5432/db" autocomplete="off" class="input input-bordered w-full font-mono text-sm" />
            <span class="add-hint">Stored encrypted. Baseout writes one schema per Space.</span>
          </label>
        )}

        <div class="add-actions">
          <a href="/settings/destinations/new" class="btn btn-ghost btn-sm">Back</a>
          <Button href={`/settings/destinations?status=added&type=${sel.id}`} variant="primary">Save destination</Button>
        </div>
      </form>
    </>
  )}
</div>

<style>
  .back-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .8125rem; font-weight: 500; color: oklch(from var(--color-base-content) l c h / .6); text-decoration: none; }
  .back-link:hover { color: var(--color-base-content); }
  .back-link .iconify { font-size: .95rem; }

  .add-section-title { font-size: .95rem; font-weight: 700; display: flex; align-items: center; gap: .55rem; margin-bottom: .8rem; }
  .add-req { font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .03em; color: oklch(from var(--color-base-content) l c h / .45); }
  .add-rec { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: var(--color-primary); background: oklch(from var(--color-primary) l c h / .12); padding: .1rem .45rem; border-radius: 999px; }
  .add-db-head { margin-bottom: .8rem; }
  .add-db-blurb { font-size: .8rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .15rem; max-width: 46ch; }

  .add-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr)); gap: .6rem; }
  .add-card { display: flex; align-items: center; gap: .7rem; padding: .7rem .8rem; border: 1px solid var(--color-base-300); border-radius: .65rem; background: var(--color-base-100); text-decoration: none; color: inherit; transition: border-color .12s ease, background .12s ease; }
  .add-card:hover { border-color: oklch(from var(--color-primary) l c h / .5); background: oklch(from var(--color-primary) l c h / .04); }
  .add-ic { width: 2.1rem; height: 2.1rem; border-radius: .55rem; display: grid; place-items: center; background: oklch(from var(--color-base-200) l c h / .8); flex: none; }
  .add-ic .iconify { font-size: 1.1rem; color: oklch(from var(--color-base-content) l c h / .7); }
  .add-ic-db { background: oklch(from var(--color-primary) l c h / .1); }
  .add-ic-db .iconify { color: var(--color-primary); }
  .add-ic-lg { width: 2.6rem; height: 2.6rem; }
  .add-ic-lg .iconify { font-size: 1.35rem; }
  .add-name { display: flex; align-items: center; gap: .4rem; font-size: .875rem; font-weight: 600; }
  .add-tag { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); padding: .05rem .35rem; border-radius: 999px; }
  .add-note { display: block; font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .5); margin-top: .05rem; }

  .add-form { display: flex; flex-direction: column; gap: 1.1rem; max-width: 30rem; }
  .add-field { display: flex; flex-direction: column; gap: .35rem; }
  .add-label { font-size: .8125rem; font-weight: 600; }
  .add-hint { font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .5); }
  .add-managed { display: flex; align-items: center; gap: .45rem; font-size: .8125rem; color: oklch(from var(--color-base-content) l c h / .75); padding: .7rem .8rem; border-radius: .55rem; background: oklch(from var(--color-success) l c h / .08); border: 1px solid oklch(from var(--color-success) l c h / .2); }
  .add-managed .iconify { color: var(--color-success); flex: none; }
  .add-actions { display: flex; align-items: center; justify-content: flex-end; gap: .5rem; margin-top: .3rem; }
</style>
