---
/**
 * DestinationAddView — add an account-level destination (skeleton).
 */
import BackLink from '../components/ui/BackLink.astro';
import Button from '../components/ui/Button.astro';
import TextInput from '../components/ui/TextInput.astro';
import { getDestinationProviders, type DestinationProvider } from '../lib/provider-catalog';

interface Props {
  selectedType?: string | null;
  providers?: DestinationProvider[];
}
const { selectedType = null, providers = getDestinationProviders() } = Astro.props;

const fileTypes = providers.filter((p) => p.kind === 'file');
const dbTypes = providers.filter((p) => p.kind === 'database');
const sel = providers.find((p) => p.slug === selectedType && p.availability === 'available') ?? null;

const tierLabel = (t?: string) => (t === 'growth' ? 'Growth+' : t === 'pro' ? 'Pro+' : null);
const iconFor = (p: DestinationProvider) =>
  p.managed ? 'lucide--box' : p.slug === 's3' ? 'lucide--cloud' : p.kind === 'database' ? 'lucide--database' : 'lucide--hard-drive';
const selIcon = sel ? iconFor(sel) : 'lucide--hard-drive';
const selField: 'folder' | 'connection' = sel?.kind === 'database' ? 'connection' : 'folder';
---

<div class="mx-auto max-w-3xl space-y-6">
  <BackLink href="/settings/destinations" label="Destinations" />

  {!sel ? (
    <>
      <header>
        <h1 class="text-2xl font-bold tracking-tight">Add a destination</h1>
        <p class="text-sm text-base-content/60 mt-1">Pick where backups go. You set it up once and reuse it across Spaces.</p>
      </header>

      <section>
        <h2 class="mb-3 flex items-center gap-2 text-base font-bold">File storage <span class="text-[0.7rem] font-semibold uppercase tracking-wide text-base-content/45">required for every backup</span></h2>
        <div class="grid gap-2.5 sm:grid-cols-[repeat(auto-fill,minmax(13rem,1fr))]">
          {fileTypes.map((t) => (
            t.availability === 'available' ? (
              <a href={`/settings/destinations/new?type=${t.slug}`} class="flex items-center gap-3 rounded-lg border border-base-300 bg-base-100 p-3 no-underline text-inherit transition-colors hover:border-primary/50 hover:bg-primary/5">
                <span class="grid size-9 shrink-0 place-items-center rounded-lg bg-base-200/80"><span class={`iconify ${iconFor(t)} text-lg text-base-content/70`} aria-hidden="true"></span></span>
                <span class="min-w-0"><span class="flex items-center gap-1.5 text-sm font-semibold">{t.label}{t.managed && <span class="rounded-full bg-success/15 px-1.5 py-0.5 text-[0.62rem] font-bold uppercase tracking-wide text-success">Managed</span>}</span><span class="block text-xs text-base-content/50">{t.note}</span></span>
              </a>
            ) : (
              <div class="flex cursor-not-allowed items-center gap-3 rounded-lg border border-base-300 bg-base-100 p-3 opacity-60" aria-disabled="true" title="Coming soon">
                <span class="grid size-9 shrink-0 place-items-center rounded-lg bg-base-200/80"><span class={`iconify ${iconFor(t)} text-lg text-base-content/70`} aria-hidden="true"></span></span>
                <span class="min-w-0"><span class="flex items-center gap-1.5 text-sm font-semibold">{t.label}<span class="rounded-full bg-base-content/10 px-1.5 py-0.5 text-[0.62rem] font-bold uppercase tracking-wide text-base-content/60">{tierLabel(t.tier) ? `${tierLabel(t.tier)} · Coming soon` : 'Coming soon'}</span></span><span class="block text-xs text-base-content/50">{t.note}</span></span>
              </div>
            )
          ))}
        </div>
      </section>

      <section>
        <div class="mb-3">
          <h2 class="flex items-center gap-2 text-base font-bold">Database <span class="rounded-full bg-primary/15 px-2 py-0.5 text-[0.68rem] font-bold uppercase tracking-wide text-primary">Recommended</span></h2>
          <p class="mt-1 max-w-prose text-sm text-base-content/60">Add a database to query your backup with SQL and power live dashboards. Optional — your file backup runs without it.</p>
        </div>
        <div class="grid gap-2.5 sm:grid-cols-[repeat(auto-fill,minmax(13rem,1fr))]">
          {dbTypes.map((t) => (
            t.availability === 'available' ? (
              <a href={`/settings/destinations/new?type=${t.slug}`} class="flex items-center gap-3 rounded-lg border border-base-300 bg-base-100 p-3 no-underline text-inherit transition-colors hover:border-primary/50 hover:bg-primary/5">
                <span class="grid size-9 shrink-0 place-items-center rounded-lg bg-primary/10"><span class={`iconify ${iconFor(t)} text-lg text-primary`} aria-hidden="true"></span></span>
                <span class="min-w-0"><span class="text-sm font-semibold">{t.label}</span><span class="block text-xs text-base-content/50">{t.note}</span></span>
              </a>
            ) : (
              <div class="flex cursor-not-allowed items-center gap-3 rounded-lg border border-base-300 bg-base-100 p-3 opacity-60" aria-disabled="true" title="Coming soon">
                <span class="grid size-9 shrink-0 place-items-center rounded-lg bg-primary/10"><span class={`iconify ${iconFor(t)} text-lg text-primary`} aria-hidden="true"></span></span>
                <span class="min-w-0"><span class="flex items-center gap-1.5 text-sm font-semibold">{t.label}<span class="rounded-full bg-base-content/10 px-1.5 py-0.5 text-[0.62rem] font-bold uppercase tracking-wide text-base-content/60">{tierLabel(t.tier) ? `${tierLabel(t.tier)} · Coming soon` : 'Coming soon'}</span></span><span class="block text-xs text-base-content/50">{t.note}</span></span>
              </div>
            )
          ))}
        </div>
      </section>
    </>
  ) : (
    <>
      <header class="flex items-center gap-3">
        <span class="grid size-11 shrink-0 place-items-center rounded-lg bg-base-200/80"><span class={`iconify ${selIcon} text-xl text-base-content/70`} aria-hidden="true"></span></span>
        <div>
          <h1 class="text-xl font-bold tracking-tight leading-tight">Connect {sel.label}</h1>
          <p class="text-sm text-base-content/55 leading-tight mt-0.5">{sel.kind === 'database' ? 'Database destination' : 'File storage destination'}</p>
        </div>
      </header>

      <form method="POST" action="/api/destinations" class="flex max-w-lg flex-col gap-4" data-astro-reload>
        <TextInput label="Name" type="text" name="name" placeholder={`${sel.label} backup`} hint="A label you'll recognise when linking it to Spaces." />

        {sel.managed ? (
          <p class="flex items-center gap-2 rounded-lg border border-success/20 bg-success/10 px-3 py-2.5 text-sm text-base-content/75"><span class="iconify lucide--shield-check text-success" aria-hidden="true"></span> Managed by Baseout — no account to connect or folder to choose.</p>
        ) : selField === 'folder' ? (
          <TextInput label="Folder" type="text" name="folder" placeholder="/Baseout" class="font-mono text-sm" hint="Each Space writes to its own subfolder. You'll authorize the account after saving." />
        ) : (
          <TextInput label="Connection string" type="password" name="connection" placeholder="postgres://user:••••@host:5432/db" autocomplete="off" class="font-mono text-sm" hint="Stored encrypted. Baseout writes one schema per Space." />
        )}

        <div class="mt-1 flex items-center justify-end gap-2">
          <Button href="/settings/destinations/new" variant="ghost" size="sm">Back</Button>
          <Button href={`/settings/destinations?status=added&type=${sel.slug}`} variant="primary">Save destination</Button>
        </div>
      </form>
    </>
  )}
</div>
