---
/**
 * DestinationDetailView — a destination's own management/health page (skeleton).
 *
 * Status + reconnect live on the destination itself, not on any single backup:
 * reconnecting once restores backups for every Space using it. "In use by" lists the
 * linked Spaces; Remove is guarded while any Space depends on it. Editing happens here
 * with sections in place (no setup wizard re-run).
 */
import Button from '../components/ui/Button.astro';
import Alert from '../components/ui/Alert.astro';
import SectionPanel from '../components/ui/SectionPanel.astro';
import DefinitionList from '../components/patterns/DefinitionList.astro';
import EntityDetailHeader from '../components/patterns/EntityDetailHeader.astro';
import type { DestinationSummary } from '../stores/destinations';

interface Props {
  destination: DestinationSummary;
  /** harness: simulate a successful reconnect */
  reconnected?: boolean;
}
const { destination: d, reconnected = false } = Astro.props;

const status = reconnected ? 'connected' : d.status;
const needsReconnect = status === 'reconnect';
const needsConnect = status === 'needs_connection';
const inUseCount = d.inUseBy.length;
// BYOS providers have OAuth authorize + disconnect routes; managed (local_fs /
// r2_managed) don't. Honest-pending: a destination is per-Space today, so
// "disconnect" removes it from this Space (the account-level shared model is later).
const isByos = d.provider !== 'local_fs' && d.provider !== 'r2_managed';
const kindLabel = d.kind === 'database' ? 'Database' : 'File storage';
const statusBadge =
  status === 'connected' ? { variant: 'success' as const, label: 'Connected', dot: true }
  : status === 'connecting' ? { variant: 'warning' as const, label: 'Connecting', dot: true }
  : status === 'needs_connection' ? { variant: 'warning' as const, label: 'Needs connection', dot: false }
  : { variant: 'warning' as const, label: 'Reconnect required', dot: false };
const connectionItems = [
  { term: 'Type', description: `${kindLabel} · ${d.providerLabel}` },
  { term: 'Writes to', description: d.detail },
  { term: 'Per-Space subfolder', description: 'Each Space writes to its own subfolder under this destination.' },
];
---

<div class="mx-auto max-w-3xl space-y-6">
  {reconnected && (
    <Alert variant="success">{d.status === 'needs_connection' ? 'Connected. Link this destination to a Space to start backing up to it.' : 'Reconnected. Backups to this destination will resume on their next scheduled run.'}</Alert>
  )}

  <EntityDetailHeader
    title={d.name}
    description={`${kindLabel} · ${d.providerLabel} · ${d.detail} · added ${d.addedAt}`}
    backHref="/destinations"
    backLabel="Back to destinations"
    statusLabel={statusBadge.label}
    statusVariant={statusBadge.variant}
    statusDot={statusBadge.dot}
  >
    {isByos && (needsReconnect || needsConnect) && (
      <form slot="actions" method="POST" action={`/api/connections/storage/${d.provider}/authorize`} data-astro-reload>
        <input type="hidden" name="returnTo" value={`/destinations/detail?id=${d.id}`} />
        <Button type="submit" variant="primary">{needsConnect ? 'Connect' : 'Reconnect'}</Button>
      </form>
    )}
    <Button slot="actions" href={`/destinations/new?type=${d.provider}`} variant="secondary">Edit</Button>
  </EntityDetailHeader>

  {needsReconnect && (
    <Alert variant="warning">This destination lost access. Backups to it are paused for {inUseCount === 1 ? 'the Space' : `all ${inUseCount} Spaces`} below. Reconnect once to restore {inUseCount === 1 ? 'it' : 'them all'}.</Alert>
  )}

  {needsConnect && (
    <Alert variant="warning">This destination isn’t connected yet. Connect it, then link it to a Space to start backing up.</Alert>
  )}

  <SectionPanel title="Connection">
    <DefinitionList items={connectionItems} />
  </SectionPanel>

  <SectionPanel title={`In use by ${inUseCount} Space${inUseCount === 1 ? '' : 's'}`}>
    {inUseCount > 0 ? (
      <ul class="dst-chips">
        {d.inUseBy.map((s) => (<li class="dst-chip"><span class="iconify lucide--folder" aria-hidden="true"></span>{s}</li>))}
      </ul>
    ) : (
      <p class="text-sm text-base-content/55">No Spaces use this destination yet.</p>
    )}
    <p class="dst-note">{status === 'reconnect' ? 'Reconnecting restores backups for every Space listed here.' : 'Changing this connection affects every Space listed here.'}</p>
  </SectionPanel>

  <SectionPanel title="Disconnect destination" class="dst-danger">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div class="min-w-0">
        <p class="text-sm text-base-content/60 mt-1">
          {isByos
            ? 'Disconnect this destination from the Space. Files already in your account are kept; future backups fall back to local disk until you connect another destination.'
            : 'Managed destinations are switched by connecting a different destination, not disconnected here.'}
        </p>
        <p class="text-sm text-error hidden mt-2" data-disconnect-error role="alert"></p>
      </div>
      <Button type="button" variant="outline" size="sm" class="shrink-0 border-error text-error" disabled={!isByos} data-disconnect data-provider={d.provider}>Disconnect</Button>
    </div>
  </SectionPanel>
</div>

<script>
  import { setButtonLoading } from '../lib/ui';

  // Per-Space disconnect (BYOS only): removes the storage_destinations row for the
  // active Space + flips storageType back to local_fs, then returns to the registry.
  document.addEventListener('click', async (event) => {
    const btn = (event.target as HTMLElement | null)?.closest('[data-disconnect]');
    if (!(btn instanceof HTMLButtonElement)) return;
    const provider = btn.dataset.provider;
    if (!provider) return;
    const errEl = document.querySelector<HTMLElement>('[data-disconnect-error]');
    setButtonLoading(btn, true);
    try {
      const res = await fetch(`/api/connections/storage/${provider}/disconnect`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
      });
      if (res.ok) {
        window.location.href = '/destinations';
        return;
      }
      if (errEl) {
        errEl.textContent = 'Could not disconnect. Please try again.';
        errEl.classList.remove('hidden');
      }
    } finally {
      setButtonLoading(btn, false);
    }
  });
</script>

<style>
  .dst-chips { margin-top: .75rem; display: flex; flex-wrap: wrap; gap: .4rem; }
  .dst-chip { display: inline-flex; align-items: center; gap: .35rem; font-size: .8rem; padding: .3rem .6rem; border: 1px solid var(--color-base-300); border-radius: 999px; background: oklch(from var(--color-base-200) l c h / .4); }
  .dst-chip .iconify { font-size: .85rem; color: oklch(from var(--color-base-content) l c h / .5); }
  .dst-note { margin-top: .75rem; font-size: .75rem; color: oklch(from var(--color-base-content) l c h / .55); }

  .dst-danger { border-color: oklch(from var(--color-error) l c h / .3); }
</style>
