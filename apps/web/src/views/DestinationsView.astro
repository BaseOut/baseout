---
/**
 * DestinationsView — account-level Destinations registry (skeleton).
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Alert from '../components/ui/Alert.astro';
import EmptyState from '../components/ui/EmptyState.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import type { DestinationSummary } from '../stores/destinations';
import type { DestinationProvider } from '../lib/provider-catalog';

interface Props {
  destinations: DestinationSummary[];
  notice?: string | null;
  addHref?: string;
  rowHref?: string | null;
  providers?: DestinationProvider[];
}
const { destinations, notice = null, addHref = '/settings/destinations/new', rowHref = null, providers = [] } = Astro.props;

const tierLabel = (t?: string) => (t === 'growth' ? 'Growth+' : t === 'pro' ? 'Pro+' : null);
const availableProviders = providers.filter((p) => p.availability === 'available');
const comingSoonProviders = providers.filter((p) => p.availability === 'coming_soon');

const kindMeta: Record<string, { icon: string; label: string }> = {
  file: { icon: 'lucide--hard-drive', label: 'File storage' },
  database: { icon: 'lucide--database', label: 'Database' },
};
const statusMeta: Record<string, { variant: 'success' | 'warning' | 'error' | 'default'; label: string; dot: boolean }> = {
  connected: { variant: 'success', label: 'Connected', dot: true },
  reconnect: { variant: 'warning', label: 'Reconnect', dot: false },
  connecting: { variant: 'warning', label: 'Connecting', dot: true },
  needs_connection: { variant: 'warning', label: 'Needs connection', dot: false },
};
const needsAttention = destinations.filter((d) => d.status === 'reconnect');
const affectedSpaces = [...new Set(needsAttention.flatMap((d) => d.inUseBy))];
const detailHref = (d: DestinationSummary) =>
  d.status === 'needs_connection'
    ? `/settings/destinations/detail?id=${d.id}&new=1&type=${d.provider}`
    : `/settings/destinations/detail?id=${d.id}`;

const registryColumns = 'minmax(0,1.5fr) minmax(0,1fr) 9.5rem 6rem 6rem';
---

<div class="mx-auto max-w-5xl space-y-6">
  <PageHeader title="Destinations" description="Storage and databases your Spaces back up to. Set up once on your account, reuse across Spaces.">
    <Button slot="actions" href={addHref} variant="primary">Add destination</Button>
  </PageHeader>

  {notice && (
    <Alert variant="success">{notice}</Alert>
  )}

  {needsAttention.length > 0 && (
    <Alert variant="warning" title={`${needsAttention.length} destination${needsAttention.length === 1 ? '' : 's'} need${needsAttention.length === 1 ? 's' : ''} reconnecting.`}>
      Backups to {needsAttention.length === 1 ? 'it are' : 'them are'} paused, affecting {affectedSpaces.length} Space{affectedSpaces.length === 1 ? '' : 's'}.
    </Alert>
  )}

  {destinations.length === 0 ? (
    <EmptyState
      icon="lucide--hard-drive"
      title="No destinations yet"
      description="Add a file store (Google Drive, Dropbox, Box, S3) and optionally a database. You can reuse it across every Space."
      actionHref={addHref}
      actionLabel="Add destination"
    />
  ) : (
    <div class="overflow-hidden rounded-box border border-base-300 bg-base-100" role="table">
      <div class="grid items-center gap-3 border-b border-base-300 bg-base-200/50 px-4 py-3 text-xs font-bold uppercase tracking-wider text-base-content/55" style={`grid-template-columns: ${registryColumns};`} role="row">
        <span>Name</span><span>Type</span><span>Status</span><span>In use by</span><span class="text-right">Last write</span>
      </div>
      {destinations.map((d) => (
        <a href={rowHref ?? detailHref(d)} class="grid items-center gap-3 border-b border-base-300/50 px-4 py-3 text-sm text-base-content no-underline transition-colors last:border-b-0 hover:bg-base-200/50" style={`grid-template-columns: ${registryColumns};`} role="row">
          <span class="min-w-0 font-semibold">{d.name}<span class="block truncate text-xs font-normal text-base-content/50">{d.detail}</span></span>
          <span class="inline-flex min-w-0 items-center gap-1.5 text-base-content/75"><span class={`iconify ${kindMeta[d.kind].icon} text-base opacity-50`} aria-hidden="true"></span>{d.providerLabel}</span>
          <span><Badge variant={statusMeta[d.status].variant} dot={statusMeta[d.status].dot}>{statusMeta[d.status].label}</Badge></span>
          <span class="text-base-content/70">{d.inUseBy.length} Space{d.inUseBy.length === 1 ? '' : 's'}</span>
          <span class="text-right font-mono tabular-nums text-base-content/55">{d.lastWrite ?? '—'}</span>
        </a>
      ))}
    </div>
  )}

  {providers.length > 0 && (
    <section class="mt-6">
      <h2 class="mb-3 text-xs font-bold uppercase tracking-wider text-base-content/50">What you can connect</h2>
      <div class="grid gap-2 sm:grid-cols-[repeat(auto-fill,minmax(14rem,1fr))]">
        {availableProviders.map((p) => (
          <div class="flex items-center justify-between gap-2 rounded-lg border border-base-300 bg-base-100 px-3 py-2.5">
            <span class="inline-flex min-w-0 items-center gap-1.5 text-sm font-semibold">{p.label}{p.managed && <span class="rounded-full bg-success/15 px-1.5 py-0.5 text-[0.6rem] font-bold uppercase tracking-wide text-success">Managed</span>}</span>
            <Badge variant="success" dot>Available</Badge>
          </div>
        ))}
        {comingSoonProviders.map((p) => (
          <div class="flex items-center justify-between gap-2 rounded-lg border border-base-300 bg-base-100 px-3 py-2.5 opacity-70">
            <span class="inline-flex min-w-0 items-center gap-1.5 text-sm font-semibold">{p.label}{tierLabel(p.tier) && <span class="rounded-full bg-base-content/10 px-1.5 py-0.5 text-[0.6rem] font-bold uppercase tracking-wide text-base-content/60">{tierLabel(p.tier)}</span>}</span>
            <Badge variant="default">Coming soon</Badge>
          </div>
        ))}
      </div>
    </section>
  )}
</div>
