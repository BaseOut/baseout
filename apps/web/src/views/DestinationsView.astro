---
/**
 * DestinationsView — account-level Destinations registry (skeleton).
 *
 * Lives in account settings, not inside a Space: destinations are created once and
 * reused. List is a dense status table (utility-admin density), with an "in use by N
 * Spaces" column as the reuse indicator. A broken destination surfaces loudly at the
 * top with "affects N Spaces". Reach a destination's own management via its row.
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import type { DestinationSummary } from '../stores/destinations';

interface Props {
  destinations: DestinationSummary[];
  notice?: string | null;
}
const { destinations, notice = null } = Astro.props;

const kindMeta: Record<string, { icon: string; label: string }> = {
  file: { icon: 'lucide--hard-drive', label: 'File storage' },
  database: { icon: 'lucide--database', label: 'Database' },
};
const statusMeta: Record<string, { variant: 'success' | 'warning' | 'error' | 'default'; label: string; dot: boolean }> = {
  connected: { variant: 'success', label: 'Connected', dot: true },
  reconnect: { variant: 'warning', label: 'Reconnect', dot: false },
  connecting: { variant: 'warning', label: 'Connecting', dot: true },
  needs_connection: { variant: 'warning', label: 'Needs connection', dot: false },
};
const needsAttention = destinations.filter((d) => d.status === 'reconnect');
const affectedSpaces = [...new Set(needsAttention.flatMap((d) => d.inUseBy))];
const detailHref = (d: DestinationSummary) =>
  d.status === 'needs_connection'
    ? `/settings/destinations/detail?id=${d.id}&new=1&type=${d.provider}`
    : `/settings/destinations/detail?id=${d.id}`;
---

<div class="mx-auto max-w-5xl space-y-6">
  <header class="flex items-end justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Destinations</h1>
      <p class="text-sm text-base-content/60 mt-1">Storage and databases your Spaces back up to. Set up once on your account, reuse across Spaces.</p>
    </div>
    <Button href="/settings/destinations/new" variant="primary">Add destination</Button>
  </header>

  {notice && (
    <p class="dst-ok" role="status"><span class="iconify lucide--circle-check" aria-hidden="true"></span><span>{notice}</span></p>
  )}

  {needsAttention.length > 0 && (
    <div class="dst-alert" role="status">
      <span class="iconify lucide--triangle-alert" aria-hidden="true"></span>
      <span>
        <b>{needsAttention.length} destination{needsAttention.length === 1 ? '' : 's'} need{needsAttention.length === 1 ? 's' : ''} reconnecting.</b>
        {' '}Backups to {needsAttention.length === 1 ? 'it are' : 'them are'} paused, affecting {affectedSpaces.length} Space{affectedSpaces.length === 1 ? '' : 's'}.
      </span>
    </div>
  )}

  {destinations.length === 0 ? (
    <div class="dst-empty">
      <span class="iconify lucide--hard-drive dst-empty-ic" aria-hidden="true"></span>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-medium">No destinations yet</p>
        <p class="text-xs text-base-content/55 mt-0.5">Add a file store (Google Drive, Dropbox, Box, S3) and optionally a database. You can reuse it across every Space.</p>
      </div>
      <Button href="/settings/destinations/new" variant="primary" class="shrink-0">Add destination</Button>
    </div>
  ) : (
    <div class="dst-table" role="table">
      <div class="dst-head" role="row">
        <span>Name</span><span>Type</span><span>Status</span><span>In use by</span><span class="dst-r">Last write</span>
      </div>
      {destinations.map((d) => (
        <a href={detailHref(d)} class="dst-row" role="row">
          <span class="dst-name">{d.name}<span class="dst-sub">{d.detail}</span></span>
          <span class="dst-type"><span class={`iconify ${kindMeta[d.kind].icon}`} aria-hidden="true"></span>{d.providerLabel}</span>
          <span><Badge variant={statusMeta[d.status].variant} dot={statusMeta[d.status].dot}>{statusMeta[d.status].label}</Badge></span>
          <span class="dst-inuse">{d.inUseBy.length} Space{d.inUseBy.length === 1 ? '' : 's'}</span>
          <span class="dst-last dst-r">{d.lastWrite ?? '—'}</span>
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .dst-ok, .dst-alert { display: flex; align-items: flex-start; gap: .5rem; padding: .625rem .8rem; border-radius: .55rem; font-size: .8125rem; line-height: 1.45; }
  .dst-ok { color: var(--color-success, oklch(.6 .16 150)); background: oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .08); border: 1px solid oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .22); }
  .dst-alert { color: oklch(from var(--color-base-content) l c h / .9); background: oklch(from var(--color-warning) l c h / .12); border: 1px solid oklch(from var(--color-warning) l c h / .3); }
  .dst-ok .iconify, .dst-alert .iconify { font-size: 1rem; flex: none; margin-top: .05rem; }
  .dst-alert .iconify { color: var(--color-warning); }

  .dst-empty { display: flex; align-items: center; gap: .9rem; padding: 1.1rem; border: 1px dashed var(--color-base-300); border-radius: .7rem; background: oklch(from var(--color-base-200) l c h / .3); }
  .dst-empty-ic { font-size: 1.4rem; color: oklch(from var(--color-base-content) l c h / .35); flex: none; }

  .dst-table { border: 1px solid var(--color-base-300); border-radius: .7rem; overflow: hidden; background: var(--color-base-100); }
  .dst-head, .dst-row { display: grid; grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr) 9.5rem 6rem 6rem; align-items: center; gap: .75rem; padding: .7rem .9rem; }
  .dst-row :global(.badge) { white-space: nowrap; }
  .dst-head { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .5); background: oklch(from var(--color-base-200) l c h / .5); border-bottom: 1px solid var(--color-base-300); }
  .dst-row { border-bottom: 1px solid oklch(from var(--color-base-300) l c h / .5); text-decoration: none; color: inherit; transition: background .12s ease; }
  .dst-row:last-child { border-bottom: 0; }
  .dst-row:hover { background: oklch(from var(--color-base-200) l c h / .5); }
  .dst-r { text-align: right; }
  .dst-name { display: flex; flex-direction: column; gap: .1rem; font-weight: 600; font-size: .875rem; min-width: 0; }
  .dst-sub { font-weight: 400; font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .5); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .dst-type { display: inline-flex; align-items: center; gap: .4rem; font-size: .8125rem; color: oklch(from var(--color-base-content) l c h / .75); min-width: 0; }
  .dst-type .iconify { font-size: .95rem; flex: none; color: oklch(from var(--color-base-content) l c h / .5); }
  .dst-inuse { font-size: .8125rem; color: oklch(from var(--color-base-content) l c h / .7); }
  .dst-last { font-size: .8rem; color: oklch(from var(--color-base-content) l c h / .55); font-variant-numeric: tabular-nums; }
</style>
