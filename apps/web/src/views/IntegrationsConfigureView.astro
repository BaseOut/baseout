---
/**
 * Integrations — CONFIGURE route (the dedicated heavy-config page).
 * Reached from the overview's "Configure" / "Finish setup". Research-backed:
 * heavy config lives on its own route (not inline, not a modal); the same page
 * serves first-time setup and later edits, with a verify ("Run first backup")
 * step at the end. Sectioned, top to bottom: bases → layers → schedule →
 * destination → connection.
 *
 * Production wiring: schedule + first-run save via lib/backups/configure-save;
 * the destination step embeds the working StoragePicker until account-level
 * destinations land (shared-destinations). `linkedDestinations` previews that
 * future state in the design harness. Layers are informational until the
 * per-layer backend exists (web-integrations-redesign follow-up).
 */
import Button from '../components/ui/Button.astro';
import StoragePicker from '../components/backups/StoragePicker.astro';
import { formatNextScheduledAt } from '../lib/backups/format';
import type { IntegrationsState } from '../stores/connections';
import type { DestinationSummary } from '../stores/destinations';

interface Props {
  state: IntegrationsState;
  /** Harness preview of account-level destinations (shared-destinations). */
  linkedDestinations?: DestinationSummary[];
}
const { state, linkedDestinations = [] } = Astro.props;

const airtable = state.connections.find((c) => c.platformSlug === 'airtable') ?? null;
const bases = state.bases;
const spaceId = Astro.locals.account?.space?.id ?? '';
const spaceName = Astro.locals.account?.space?.name ?? 'this Space';
const includedCount = bases.filter((b) => b.isIncluded).length;
const cap = state.tierBasesPerSpace;
// First-time setup (came straight from Connect, ?first=1, or no config yet) vs returning edit.
const isFirstSetup = Astro.url.searchParams.get('first') === '1' || !state.hasBackupConfig;
---

<div class="mx-auto max-w-2xl space-y-8">
  {/* Back + header */}
  <div>
    <a href="/integrations" class="back-link"><span class="iconify lucide--arrow-left"></span> Integrations</a>
    <div class="flex items-center gap-3 mt-3">
      <img src="/airtable.svg" alt="" width="36" height="36" class="config-logo" />
      <div>
        <h1 class="text-2xl font-bold tracking-tight leading-tight">{isFirstSetup ? 'Set up your Airtable backup' : 'Configure Airtable backup'}</h1>
        <p class="text-sm text-base-content/60 mt-0.5">Choose what to back up, when, and where, for <span class="font-medium text-base-content/80">{spaceName}</span>.</p>
      </div>
    </div>
  </div>

  {/* 1 — Bases */}
  <section class="cfg-section">
    <div class="cfg-head">
      <h2><span class="cfg-n">1</span> Bases to back up</h2>
    </div>
    {bases.length > 0 ? (
      <div>
        {includedCount > 0 ? (
          <a href="/integrations/configure/bases?first=1" class="bases-summary">
            <span class="min-w-0">
              <span class="block text-sm font-medium">Backing up {includedCount} of {bases.length} bases</span>
              <span class="block text-xs text-base-content/55 mt-0.5 truncate">{bases.filter((b) => b.isIncluded).slice(0, 3).map((b) => b.name).join(', ')}{includedCount > 3 ? `, +${includedCount - 3} more` : ''}</span>
            </span>
            <span class="bases-manage">Manage bases <span class="iconify lucide--arrow-right"></span></span>
          </a>
        ) : (
          <div class="bases-empty">
            <span class="iconify lucide--database bases-empty-ic"></span>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium">Choose which bases to back up</p>
              <p class="text-xs text-base-content/55 mt-0.5">Nothing is protected until you pick. Search and select from your {bases.length} Airtable bases.</p>
            </div>
            <a href="/integrations/configure/bases?first=1" class="btn btn-sm btn-primary shrink-0">Choose bases</a>
          </div>
        )}
        {cap !== null && <p class="text-xs text-base-content/50 mt-2">Your plan covers up to {cap} bases per Space.</p>}
      </div>
    ) : (
      <p class="text-sm text-base-content/60">No bases were discovered yet. <button type="button" class="link link-hover font-medium" data-rescan-submit data-space-id={spaceId}>Rescan workspace</button>.</p>
    )}
  </section>

  {/* 2 — Layers. Informational for now: every backup currently captures all
      three layers; per-layer opt-in/out ships with its backend
      (web-integrations-redesign follow-up). Inputs stay disabled so nothing
      pretends to persist. */}
  <section class="cfg-section">
    <div class="cfg-head"><h2><span class="cfg-n">2</span> What gets backed up</h2></div>
    <ul class="divide-y divide-base-300/60 border border-base-300 rounded-box overflow-hidden bg-base-100" data-backup-layers>
      <li class="px-3.5 py-3 flex items-center justify-between gap-3">
        <label class="flex items-center gap-3 flex-1 min-w-0 cursor-not-allowed">
          <input type="checkbox" class="checkbox checkbox-sm" checked disabled />
          <span class="min-w-0"><span class="block font-medium">Schema</span><span class="block text-xs text-base-content/50 mt-0.5">Tables, fields, views and relationships. Always captured.</span></span>
        </label>
        <span class="badge badge-sm badge-ghost shrink-0">Always on</span>
      </li>
      <li class="px-3.5 py-3 flex items-center justify-between gap-3">
        <label class="flex items-center gap-3 flex-1 min-w-0 cursor-not-allowed">
          <input type="checkbox" class="checkbox checkbox-sm" checked disabled data-layer="data" />
          <span class="min-w-0"><span class="block font-medium">Data</span><span class="block text-xs text-base-content/50 mt-0.5">Every row and field value.</span></span>
        </label>
        <span class="badge badge-sm badge-ghost shrink-0">Included</span>
      </li>
      <li class="px-3.5 py-3 flex items-center justify-between gap-3">
        <label class="flex items-center gap-3 flex-1 min-w-0 cursor-not-allowed">
          <input type="checkbox" class="checkbox checkbox-sm" checked disabled data-layer="attachments" />
          <span class="min-w-0"><span class="block font-medium">Attachments</span><span class="block text-xs text-base-content/50 mt-0.5">Files attached to records, stored as binaries.</span></span>
        </label>
        <span class="badge badge-sm badge-ghost shrink-0">Included</span>
      </li>
    </ul>
    <p class="text-xs text-base-content/50 mt-2">Choosing layers per backup is coming soon — today every backup captures all three.</p>
  </section>

  {/* 3 — Schedule */}
  {spaceId && (
    <section class="cfg-section">
      <div class="cfg-head"><h2><span class="cfg-n">3</span> Schedule</h2></div>
      <ul class="divide-y divide-base-300/60 border border-base-300 rounded-box overflow-hidden bg-base-100">
        {[
          { value: 'monthly', label: 'Monthly', helper: 'One scheduled backup per month' },
          { value: 'weekly', label: 'Weekly', helper: 'One scheduled backup per week' },
          { value: 'daily', label: 'Daily', helper: 'One scheduled backup per day' },
          { value: 'instant', label: 'Instant', helper: 'Webhook-driven — captures changes as they happen' },
        ].map((f) => {
          const allowed = (state.availableFrequencies as readonly string[]).includes(f.value);
          return (
            <li class={`px-3.5 py-3 flex items-center justify-between gap-3 ${!allowed ? 'opacity-55' : ''}`}>
              <label class={`flex items-center gap-3 flex-1 min-w-0 ${allowed ? 'cursor-pointer' : 'cursor-not-allowed'}`}>
                <input type="radio" name="frequency" value={f.value} checked={state.policy.frequency === f.value} disabled={!allowed} class="radio radio-sm radio-primary" />
                <span class="min-w-0"><span class="block font-medium">{f.label}</span><span class="block text-xs text-base-content/50 mt-0.5">{f.helper}</span></span>
              </label>
              {!allowed && <a href="/settings" class="badge badge-sm badge-warning badge-outline shrink-0 no-underline">Upgrade</a>}
            </li>
          );
        })}
      </ul>
      <p class="text-xs text-base-content/60 mt-2.5">Next backup: <span class="font-medium text-base-content/80">{formatNextScheduledAt(state.policy.nextScheduledAt)}</span></p>
    </section>
  )}

  {/* 4 — Destination. Today: the per-Space StoragePicker (managed or BYOS via
      OAuth), saved instantly on change. The linked-destinations branch previews
      the account-level registry (shared-destinations) in the design harness. */}
  {spaceId && (
    <section class="cfg-section">
      <div class="cfg-head"><h2><span class="cfg-n">4</span> Destination</h2></div>
      {linkedDestinations.length > 0 ? (
        <div class="dest-linked">
          {linkedDestinations.map((d) => {
            const chip = d.status === 'connected' ? { cls: 'is-ok', label: 'Connected' } : { cls: 'is-warn', label: 'Reconnect' };
            return (
              <div class="dest-linked-row">
                <span class="dest-opt-ic"><span class={`iconify ${d.kind === 'database' ? 'lucide--database' : 'lucide--hard-drive'}`}></span></span>
                <span class="min-w-0 flex-1">
                  <span class="dest-opt-name">{d.name} <span class={`dest-chip ${chip.cls}`}>{chip.label}</span></span>
                  <span class="dest-opt-sub">{d.kind === 'database' ? 'Database' : 'File storage'} · {d.providerLabel} · {d.detail}</span>
                </span>
              </div>
            );
          })}
          <a href="/settings/destinations" class="dest-manage">Manage destinations <span class="iconify lucide--arrow-right"></span></a>
        </div>
      ) : (
        <StoragePicker
          spaceId={spaceId}
          selectedStorageType={state.policy.storageType}
          connectedType={state.storageDestination?.type ?? null}
          connectedAccountEmail={state.storageDestination?.accountEmail ?? null}
        />
      )}
    </section>
  )}

  {/* Connection — manage the Airtable link (rescan / disconnect) */}
  {airtable && (
    <section class="cfg-section">
      <div class="cfg-head"><h2 class="cfg-plain">Connection</h2></div>
      <div class="conn-card">
        <div class="conn-row">
          <div class="min-w-0">
            <p class="text-sm font-medium">Connected{airtable.airtableUserId && <span> as <code class="text-[11px]">{airtable.airtableUserId}</code></span>}</p>
            <p class="text-xs text-base-content/55 mt-0.5">{airtable.basesCount} base{airtable.basesCount === 1 ? '' : 's'} discovered in your Airtable workspace.</p>
          </div>
          <button type="button" class="btn btn-ghost btn-sm shrink-0" data-rescan-submit data-space-id={spaceId}>Rescan workspace</button>
        </div>
        <p class="text-xs text-base-content/60 mt-2 hidden" data-rescan-result role="status" aria-live="polite"></p>
      </div>
    </section>
  )}

  {/* Footer — single action for the whole form */}
  <div class="cfg-footer">
    <p class="text-xs text-base-content/55 min-w-0">{isFirstSetup ? 'We run your first backup right after saving — this can take a moment.' : 'Changes apply to scheduled and on-demand backups.'}</p>
    <div class="flex items-center gap-2 shrink-0">
      <Button href="/integrations" variant="ghost">Cancel</Button>
      <Button type="button" variant="primary" data-save-config data-space-id={spaceId} data-running={isFirstSetup ? '1' : undefined}>{isFirstSetup ? 'Save & run first backup' : 'Save changes'}</Button>
    </div>
  </div>
  <p class="text-xs hidden mt-2 text-right" data-save-status role="status" aria-live="polite"></p>
</div>

<style>
  .back-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .8125rem; font-weight: 500; color: oklch(from var(--color-base-content) l c h / .6); text-decoration: none; }
  .back-link:hover { color: var(--color-base-content); }
  .back-link .iconify { font-size: .95rem; }
  .config-logo { border-radius: 9px; flex: none; }

  .cfg-section { }
  .cfg-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: .875rem; }
  .cfg-head h2 { font-size: 1rem; font-weight: 650; display: flex; align-items: center; gap: .6rem; }
  .cfg-n {
    display: inline-flex; align-items: center; justify-content: center; width: 1.4rem; height: 1.4rem;
    border-radius: 999px; font-size: .75rem; font-weight: 700; flex: none;
    color: oklch(from var(--color-primary) l c h / .95); background: oklch(from var(--color-primary) l c h / .12);
  }
  /* Bases summary → drill-in to the full-width manage screen (version 1 layout) */
  .bases-summary { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .85rem 1rem; border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); text-decoration: none; color: inherit; transition: border-color .12s ease, background .12s ease; }
  .bases-summary:hover { border-color: oklch(from var(--color-primary) l c h / .45); background: oklch(from var(--color-base-200) l c h / .4); }
  .bases-manage { display: inline-flex; align-items: center; gap: .35rem; flex: none; font-size: .82rem; font-weight: 600; color: oklch(from var(--color-primary) l c h / .95); white-space: nowrap; }
  .bases-manage .iconify { font-size: .9rem; }
  .bases-empty { display: flex; align-items: center; gap: .85rem; padding: 1rem 1.1rem; border: 1px dashed var(--color-base-300); border-radius: .7rem; background: oklch(from var(--color-base-200) l c h / .35); }
  .bases-empty-ic { font-size: 1.5rem; flex: none; color: oklch(from var(--color-base-content) l c h / .35); }
  .conn-card { border: 1px solid var(--color-base-300); background: var(--color-base-100); border-radius: .75rem; padding: 1rem 1.125rem; }
  .conn-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  /* Destinations (v1) — drill out to account settings; summary row when linked */
  .dest-empty { display: flex; align-items: center; gap: .85rem; padding: 1rem 1.1rem; border: 1px dashed var(--color-base-300); border-radius: .7rem; background: oklch(from var(--color-base-200) l c h / .35); }
  .dest-empty-ic { font-size: 1.5rem; flex: none; color: oklch(from var(--color-base-content) l c h / .35); }
  .dest-linked { border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); overflow: hidden; }
  .dest-linked-row { display: flex; align-items: center; gap: .7rem; padding: .75rem .9rem; border-bottom: 1px solid oklch(from var(--color-base-300) l c h / .5); }
  .dest-manage { display: flex; align-items: center; justify-content: flex-end; gap: .35rem; padding: .6rem .9rem; font-size: .82rem; font-weight: 600; color: oklch(from var(--color-primary) l c h / .95); text-decoration: none; }
  .dest-manage .iconify { font-size: .9rem; }
  .dest-opt-ic { width: 2rem; height: 2rem; border-radius: .5rem; display: grid; place-items: center; background: oklch(from var(--color-base-200) l c h / .8); flex: none; }
  .dest-opt-ic .iconify { font-size: 1rem; color: oklch(from var(--color-base-content) l c h / .65); }
  .dest-opt-name { display: flex; align-items: center; gap: .45rem; font-size: .875rem; font-weight: 600; }
  .dest-opt-sub { display: block; font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .55); margin-top: .05rem; }
  .dest-chip { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; padding: .08rem .4rem; border-radius: 999px; }
  .dest-chip.is-ok { color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); }
  .dest-chip.is-warn { color: var(--color-warning); background: oklch(from var(--color-warning) l c h / .16); }

  .cfg-footer {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    padding: 1rem 1.25rem; border: 1px solid var(--color-base-300);
    border-radius: .75rem; background: var(--color-base-100);
  }

</style>

<script>
  import { setButtonLoading } from '../lib/ui';
  import { saveConfigureForm } from '../lib/backups/configure-save';

  function wire() {
    // Footer save — persists the schedule, then (on first setup) starts the
    // first backup. Base selection is owned by the Manage screen; the storage
    // destination is owned by StoragePicker (saves instantly on change).
    const saveBtn = document.querySelector<HTMLButtonElement>('[data-save-config]');
    const saveStatus = document.querySelector<HTMLParagraphElement>('[data-save-status]');
    if (saveBtn && saveBtn.dataset.cfgWired !== '1') {
      saveBtn.dataset.cfgWired = '1';
      saveBtn.addEventListener('click', async () => {
        const spaceId = saveBtn.dataset.spaceId;
        if (!spaceId) return;
        const running = saveBtn.dataset.running === '1';
        const frequencyInput = document.querySelector<HTMLInputElement>('input[name="frequency"]:checked');
        const frequency = frequencyInput?.value as
          | 'monthly' | 'weekly' | 'daily' | 'instant' | undefined;
        setButtonLoading(saveBtn, true);
        if (running && saveStatus) {
          saveStatus.textContent = 'Saving and starting your first backup…';
          saveStatus.classList.remove('hidden', 'text-error');
        }
        try {
          const outcome = await saveConfigureForm({ spaceId, frequency, runFirstBackup: running });
          if (outcome.ok) {
            window.location.href = outcome.redirect;
            return;
          }
          if (saveStatus) {
            saveStatus.textContent = outcome.message;
            saveStatus.classList.remove('hidden');
            saveStatus.classList.add('text-error');
          }
          setButtonLoading(saveBtn, false);
        } catch {
          if (saveStatus) {
            saveStatus.textContent = 'Could not save changes. Please try again.';
            saveStatus.classList.remove('hidden');
            saveStatus.classList.add('text-error');
          }
          setButtonLoading(saveBtn, false);
        }
      });
    }

    // Connection — rescan the Airtable workspace for new bases.
    document.querySelectorAll<HTMLButtonElement>('[data-rescan-submit]').forEach((rescanBtn) => {
      if (rescanBtn.dataset.cfgWired === '1') return;
      rescanBtn.dataset.cfgWired = '1';
      const rescanResult = document.querySelector<HTMLParagraphElement>('[data-rescan-result]');
      rescanBtn.addEventListener('click', async () => {
        const spaceId = rescanBtn.dataset.spaceId;
        if (!spaceId) return;
        setButtonLoading(rescanBtn, true);
        try {
          const res = await fetch(`/api/spaces/${encodeURIComponent(spaceId)}/rescan-bases`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: '{}',
          });
          const data = (await res.json().catch(() => ({}))) as { discovered?: number };
          if (rescanResult) {
            const n = res.ok ? (data.discovered ?? 0) : 0;
            rescanResult.textContent = !res.ok
              ? 'Rescan failed. Please try again.'
              : n > 0
                ? `Found ${n} new base${n === 1 ? '' : 's'}. Reload the page to see ${n === 1 ? 'it' : 'them'}.`
                : 'No new bases found — your workspace is up to date.';
            rescanResult.classList.remove('hidden');
          }
        } finally { setButtonLoading(rescanBtn, false); }
      });
    });
  }
  wire();
  document.addEventListener('astro:after-swap', wire);
</script>
