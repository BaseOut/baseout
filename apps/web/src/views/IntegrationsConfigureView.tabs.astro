---
/**
 * IntegrationsConfigureView.tabs — full-width configure with two parity modes:
 *
 *  - FIRST-TIME setup (isFirstSetup): the top nav is a STEPPER. Steps unlock in
 *    order (you can step back to completed ones, not jump ahead); the Bases step
 *    gates Next until ≥1 base is chosen; the final step's primary action is
 *    "Start first backup" — bottom-right.
 *  - EDIT (returning): the same four panels, but a FREE tab bar (jump anywhere)
 *    and a "Save changes" button in the exact same bottom-right spot, so the two
 *    screens stay visually consistent.
 *
 * Panels are shared; only the nav + footer differ. Bases uses the shared
 * full-width BaseSelectionTable. Other panels mirror the vertical view (A/B;
 * the winning layout keeps one copy).
 */
import BaseSelectionTable from '../components/patterns/BaseSelectionTable.astro';
import BackLink from '../components/ui/BackLink.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import { formatNextScheduledAt } from '../lib/backups/format';
import type { IntegrationsState } from '../stores/connections';
import type { DestinationSummary } from '../stores/destinations';

interface Props {
  state: IntegrationsState;
  /** account-level destinations to pick from in the Destination step */
  destinations?: DestinationSummary[];
}
const { state, destinations = [] } = Astro.props;
const fileDestinations = destinations.filter((d) => d.kind === 'file');
const dbDestinations = destinations.filter((d) => d.kind === 'database');
const destChip = (s: string) => (s === 'connected' ? { cls: 'is-ok', label: 'Connected' } : { cls: 'is-warn', label: s === 'connecting' ? 'Connecting' : 'Reconnect' });
const bases = state.bases;
const spaceId = Astro.locals.account?.space?.id ?? '';
const spaceName = Astro.locals.account?.space?.name ?? 'this Space';
const cap = state.tierBasesPerSpace;
const includedCount = bases.filter((b) => b.isIncluded).length;
const isFirstSetup = Astro.url.searchParams.get('first') === '1' || !state.hasBackupConfig;

const STEPS = [
  { key: 'bases', label: 'Bases' },
  { key: 'layers', label: 'What to back up' },
  { key: 'schedule', label: 'Schedule' },
  { key: 'dest', label: 'Destination' },
];
---

<div class="mx-auto max-w-5xl space-y-6">
  {/* Back + header */}
  <div>
    <BackLink href="/integrations" label="Integrations" />
    <div class="flex items-center gap-3 mt-3">
      <img src="/airtable.svg" alt="" width="36" height="36" class="config-logo" />
      <div>
        <h1 class="text-2xl font-bold tracking-tight leading-tight">{isFirstSetup ? 'Set up your Airtable backup' : 'Configure Airtable backup'}</h1>
        <p class="text-sm text-base-content/60 mt-0.5">Choose what to back up, when, and where, for <span class="font-medium text-base-content/80">{spaceName}</span>.</p>
      </div>
    </div>
  </div>

  <div class:list={['tabs-shell', isFirstSetup ? 'stepper-mode' : 'tabs-mode']} data-tabs>
    {/* Top bar: nav (left) + the primary action (right), so it stays in view. */}
    {isFirstSetup ? (
      <div class="bar">
        <ol class="stepper" data-stepper>
          {STEPS.map((s, i) => (
            <li class="step" data-step-nav={s.key} data-index={i}>
              <span class="step-dot"><span class="step-num">{i + 1}</span><span class="iconify lucide--check step-check"></span></span>
              <span class="step-label">{s.label}</span>
            </li>
          ))}
        </ol>
        <div class="bar-actions">
          <Button type="button" variant="ghost" size="sm" data-step-back hidden><span class="iconify lucide--arrow-left"></span> Back</Button>
          <Button type="button" variant="primary" size="sm" data-step-next data-target="/integrations?status=running">Next</Button>
        </div>
      </div>
    ) : (
      <div class="bar">
        <div class="tabbar" role="tablist">
          {STEPS.map((s, i) => (
            <label class="tab-opt">
              <input type="radio" name="cfg-tab" value={s.key} checked={i === 0} />
              <span>{s.label}{s.key === 'bases' ? <span class="tab-count" data-bases-badge>{includedCount}</span> : null}</span>
            </label>
          ))}
        </div>
        <div class="bar-actions">
          <Button href="/integrations" variant="ghost" size="sm">Cancel</Button>
          <Button type="button" variant="primary" size="sm" data-save-config data-target="/integrations?status=saved">Save changes</Button>
        </div>
      </div>
    )}

    {/* Panels (shared) */}
    <div class="tab-body">
      {/* Contextual hint for the current step — sits next to the section, only when meaningful */}
      <p class="step-hint" data-step-hint></p>
      {/* BASES */}
      <section class="tab-panel panel-bases" data-step="bases">
        <div class="panel-head">
          <h2>Bases to back up</h2>
          <p>Pick which bases this Space protects. Search, sort, or select all up to your plan limit.</p>
        </div>
        {bases.length > 0 ? (
          <BaseSelectionTable bases={bases} cap={cap} spaceId={spaceId} embedded={true} />
        ) : (
          <p class="text-sm text-base-content/60">No bases were discovered yet. <button type="button" class="link link-hover font-medium" data-rescan-submit>Rescan workspace</button>.</p>
        )}
      </section>

      {/* LAYERS */}
      <section class="tab-panel panel-layers" data-step="layers">
        <div class="panel-head"><h2>What gets backed up</h2><p>Pick how deep each backup goes.</p></div>
        <ul class="divide-y divide-base-300/60 border border-base-300 rounded-box overflow-hidden bg-base-100">
          <li class="px-3.5 py-3 flex items-center justify-between gap-3">
            <label class="flex items-center gap-3 flex-1 min-w-0 cursor-not-allowed">
              <input type="checkbox" class="checkbox checkbox-sm" checked disabled />
              <span class="min-w-0"><span class="block font-medium">Schema</span><span class="block text-xs text-base-content/50 mt-0.5">Tables, fields, views and relationships. Always captured.</span></span>
            </label>
            <Badge variant="default" size="sm" class="shrink-0">Always on</Badge>
          </li>
          <li class="px-3.5 py-3 flex items-center justify-between gap-3">
            <label class="flex items-center gap-3 flex-1 min-w-0 cursor-pointer">
              <input type="checkbox" class="checkbox checkbox-sm" checked />
              <span class="min-w-0"><span class="block font-medium">Data</span><span class="block text-xs text-base-content/50 mt-0.5">Every row and field value. On by default.</span></span>
            </label>
          </li>
          <li class="px-3.5 py-3 flex items-center justify-between gap-3">
            <label class="flex items-center gap-3 flex-1 min-w-0 cursor-pointer">
              <input type="checkbox" class="checkbox checkbox-sm" />
              <span class="min-w-0"><span class="block font-medium">Attachments</span><span class="block text-xs text-base-content/50 mt-0.5">Files attached to records, stored as binaries.</span></span>
            </label>
            <Badge variant="warning" size="sm" outline class="shrink-0">Billed on storage</Badge>
          </li>
        </ul>
        <p class="text-xs text-base-content/50 mt-2.5">Airtable's API can't export automations, interfaces, forms or views — those aren't backed up.</p>
      </section>

      {/* SCHEDULE */}
      <section class="tab-panel panel-schedule" data-step="schedule">
        <div class="panel-head"><h2>Schedule</h2><p>How often a backup runs automatically.</p></div>
        <ul class="divide-y divide-base-300/60 border border-base-300 rounded-box overflow-hidden bg-base-100">
          {[
            { value: 'monthly', label: 'Monthly', helper: 'One scheduled backup per month' },
            { value: 'weekly', label: 'Weekly', helper: 'One scheduled backup per week' },
            { value: 'daily', label: 'Daily', helper: 'One scheduled backup per day' },
            { value: 'instant', label: 'Instant', helper: 'Webhook-driven — captures changes as they happen' },
          ].map((f) => {
            const allowed = (state.availableFrequencies as readonly string[]).includes(f.value);
            return (
              <li class={`px-3.5 py-3 flex items-center justify-between gap-3 ${!allowed ? 'opacity-55' : ''}`}>
                <label class={`flex items-center gap-3 flex-1 min-w-0 ${allowed ? 'cursor-pointer' : 'cursor-not-allowed'}`}>
                  <input type="radio" name="frequency" value={f.value} checked={state.policy.frequency === f.value} disabled={!allowed} class="radio radio-sm radio-primary" />
                  <span class="min-w-0"><span class="block font-medium">{f.label}</span><span class="block text-xs text-base-content/50 mt-0.5">{f.helper}</span></span>
                </label>
                {!allowed && <Button href="/settings/billing" variant="warning" size="sm" outline class="shrink-0">Upgrade</Button>}
              </li>
            );
          })}
        </ul>
        <p class="text-xs text-base-content/60 mt-2.5">Next backup: <span class="font-medium text-base-content/80">{formatNextScheduledAt(state.policy.nextScheduledAt)}</span></p>
      </section>

      {/* DESTINATION — pick a reusable account destination, or add a custom one */}
      <section class="tab-panel panel-dest" data-step="dest">
        <div class="panel-head"><h2>Destination</h2><p>Pick where backups go. Reuse a destination from your account, or add a new one.</p></div>

        <div class="dest-group">
          <div class="dest-group-head"><span class="dest-group-title">File storage</span><span class="dest-req">Required</span></div>
          {fileDestinations.length > 0 ? (
            <fieldset class="dest-options">
              <legend class="sr-only">File destination</legend>
              {fileDestinations.map((d, i) => {
                const chip = destChip(d.status);
                return (
                  <label class="dest-opt">
                    <input type="radio" name="dest-file" value={d.id} checked={i === 0} class="radio radio-sm radio-primary" />
                    <span class="dest-opt-ic"><span class="iconify lucide--hard-drive"></span></span>
                    <span class="min-w-0 flex-1">
                      <span class="dest-opt-name">{d.name} <span class={`dest-chip ${chip.cls}`}>{chip.label}</span></span>
                      <span class="dest-opt-sub">{d.providerLabel} · {d.detail}</span>
                    </span>
                  </label>
                );
              })}
            </fieldset>
          ) : (
            <p class="dest-empty-note">No file storage on your account yet — add one to continue.</p>
          )}
        </div>

        <div class="dest-group">
          <div class="dest-group-head"><span class="dest-group-title">Database</span><span class="dest-rec">Recommended</span></div>
          <p class="dest-blurb">Query your backup with SQL and power live dashboards. Optional — your file backup runs without it.</p>
          <fieldset class="dest-options">
            <legend class="sr-only">Database destination</legend>
            {dbDestinations.map((d) => {
              const chip = destChip(d.status);
              return (
                <label class="dest-opt">
                  <input type="radio" name="dest-db" value={d.id} class="radio radio-sm radio-primary" />
                  <span class="dest-opt-ic dest-opt-ic-db"><span class="iconify lucide--database"></span></span>
                  <span class="min-w-0 flex-1">
                    <span class="dest-opt-name">{d.name} <span class={`dest-chip ${chip.cls}`}>{chip.label}</span></span>
                    <span class="dest-opt-sub">{d.providerLabel} · {d.detail}</span>
                  </span>
                </label>
              );
            })}
            <label class="dest-opt dest-opt-skip">
              <input type="radio" name="dest-db" value="" checked class="radio radio-sm radio-primary" />
              <span class="min-w-0 flex-1"><span class="dest-opt-name">Skip for now</span><span class="dest-opt-sub">Add a database later from settings.</span></span>
            </label>
          </fieldset>
        </div>

        <a href="/settings/destinations/new" class="dest-add"><span class="iconify lucide--plus"></span> Add a custom destination</a>
      </section>
    </div>
  </div>

  <p class="text-xs hidden mt-2 text-right" data-save-status role="status" aria-live="polite"></p>
</div>

<style>
  .back-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .8125rem; font-weight: 500; color: oklch(from var(--color-base-content) l c h / .6); text-decoration: none; }
  .back-link:hover { color: var(--color-base-content); }
  .back-link .iconify { font-size: .95rem; }
  .config-logo { border-radius: 9px; flex: none; }

  .tabs-shell { border: 1px solid var(--color-base-300); border-radius: .85rem; background: var(--color-base-100); overflow: hidden; }

  /* Top bar holds the nav (left) + the primary action (right) */
  .bar { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; padding: .6rem .8rem .6rem 1.1rem; border-bottom: 1px solid var(--color-base-300); background: oklch(from var(--color-base-200) l c h / .45); }
  .bar-actions { margin-left: auto; display: flex; align-items: center; gap: .5rem; flex: none; }
  .step-hint { font-size: .78rem; line-height: 1.4; color: oklch(from var(--color-base-content) l c h / .65); margin-bottom: 1rem; padding: .55rem .75rem; border-radius: .5rem; background: oklch(from var(--color-base-200) l c h / .55); }
  .step-hint:empty { display: none; }
  .step-hint.is-warn { color: oklch(from var(--color-base-content) l c h / .9); background: oklch(from var(--color-warning) l c h / .12); border: 1px solid oklch(from var(--color-warning) l c h / .3); }

  /* Free tabs (edit mode) */
  .tabbar { display: flex; gap: .15rem; flex-wrap: wrap; }
  .tab-opt { position: relative; display: inline-flex; flex: none; }
  .tab-opt input { position: absolute; inset: 0; margin: 0; opacity: 0; cursor: pointer; }
  .tab-opt span { display: inline-flex; align-items: center; gap: .4rem; padding: .45rem .85rem; font-size: .82rem; font-weight: 600; border-radius: .5rem; white-space: nowrap; color: oklch(from var(--color-base-content) l c h / .6); }
  .tab-opt input:checked + span { background: var(--color-base-100); color: var(--color-base-content); box-shadow: inset 0 0 0 1px var(--color-base-300); }
  .tab-count { display: inline-flex; align-items: center; justify-content: center; min-width: 1.15rem; height: 1.15rem; padding: 0 .3rem; border-radius: 999px; font-size: .68rem; font-weight: 700; color: oklch(from var(--color-primary) l c h / .95); background: oklch(from var(--color-primary) l c h / .14); }

  /* Stepper (first-run) */
  .stepper { display: flex; align-items: center; gap: 0; margin: 0; padding: 0; list-style: none; flex-wrap: wrap; }
  .step { display: flex; align-items: center; gap: .5rem; flex: none; }
  .step:not(:last-child)::after { content: ''; width: clamp(1rem, 6vw, 4rem); height: 2px; background: var(--color-base-300); margin: 0 .7rem; }
  .step.is-done:not(:last-child)::after { background: oklch(from var(--color-primary) l c h / .5); }
  .step-dot { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 1.6rem; height: 1.6rem; border-radius: 999px; flex: none; font-size: .78rem; font-weight: 700; border: 1.5px solid var(--color-base-300); color: oklch(from var(--color-base-content) l c h / .5); background: var(--color-base-100); }
  .step-check { display: none; font-size: .9rem; }
  .step.is-current .step-dot { border-color: var(--color-primary); color: var(--color-primary); }
  .step.is-done .step-dot { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .step.is-done .step-num { display: none; }
  .step.is-done .step-check { display: inline; }
  .step.is-done, .step.is-current { cursor: pointer; }
  .step.is-locked { cursor: default; }
  .step-label { font-size: .82rem; font-weight: 600; white-space: nowrap; color: oklch(from var(--color-base-content) l c h / .55); }
  .step.is-current .step-label { color: var(--color-base-content); }
  .step.is-locked .step-label { opacity: .5; }

  /* Panels — visibility differs per mode */
  .tab-body { padding: 1.25rem; }
  .tab-panel { display: none; }
  .tabs-mode:has(input[value="bases"]:checked) .panel-bases { display: block; }
  .tabs-mode:has(input[value="layers"]:checked) .panel-layers { display: block; }
  .tabs-mode:has(input[value="schedule"]:checked) .panel-schedule { display: block; }
  .tabs-mode:has(input[value="dest"]:checked) .panel-dest { display: block; }
  .stepper-mode .tab-panel.is-active { display: block; }
  .panel-head { margin-bottom: 1rem; }
  .panel-head h2 { font-size: 1.05rem; font-weight: 650; }
  .panel-head p { font-size: .8rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .15rem; }

  /* Destination picker (v2) — reusable account destinations + add custom */
  .dest-group { border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); padding: .9rem 1rem; }
  .dest-group + .dest-group { margin-top: .75rem; }
  .dest-group-head { display: flex; align-items: center; gap: .5rem; }
  .dest-group-title { font-size: .875rem; font-weight: 650; }
  .dest-req { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: oklch(from var(--color-base-content) l c h / .45); }
  .dest-rec { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: var(--color-primary); background: oklch(from var(--color-primary) l c h / .12); padding: .08rem .4rem; border-radius: 999px; }
  .dest-blurb { font-size: .75rem; color: oklch(from var(--color-base-content) l c h / .6); margin: .3rem 0 .1rem; }
  .dest-options { display: grid; gap: .5rem; margin-top: .7rem; }
  .dest-opt { display: flex; align-items: center; gap: .65rem; padding: .6rem .7rem; border: 1px solid var(--color-base-300); border-radius: .55rem; cursor: pointer; transition: border-color .12s ease, background .12s ease; }
  .dest-opt:hover { background: oklch(from var(--color-base-200) l c h / .5); }
  .dest-opt:has(input:checked) { border-color: oklch(from var(--color-primary) l c h / .55); background: oklch(from var(--color-primary) l c h / .05); }
  .dest-opt-ic { width: 2rem; height: 2rem; border-radius: .5rem; display: grid; place-items: center; background: oklch(from var(--color-base-200) l c h / .8); flex: none; }
  .dest-opt-ic .iconify { font-size: 1rem; color: oklch(from var(--color-base-content) l c h / .65); }
  .dest-opt-ic-db { background: oklch(from var(--color-primary) l c h / .1); }
  .dest-opt-ic-db .iconify { color: var(--color-primary); }
  .dest-opt-name { display: flex; align-items: center; gap: .45rem; font-size: .85rem; font-weight: 600; }
  .dest-opt-sub { display: block; font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .55); margin-top: .05rem; }
  .dest-opt-skip .dest-opt-name { color: oklch(from var(--color-base-content) l c h / .7); }
  .dest-chip { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; padding: .08rem .4rem; border-radius: 999px; }
  .dest-chip.is-ok { color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); }
  .dest-chip.is-warn { color: var(--color-warning); background: oklch(from var(--color-warning) l c h / .16); }
  .dest-empty-note { font-size: .8rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .5rem; }
  .dest-add { display: inline-flex; align-items: center; gap: .35rem; margin-top: .9rem; font-size: .82rem; font-weight: 600; color: oklch(from var(--color-primary) l c h / .95); text-decoration: none; }
  .dest-add:hover { text-decoration: underline; }
  .dest-add .iconify { font-size: .95rem; }
</style>

<script>
  import { setButtonLoading } from '../lib/ui';

  function selectedBaseIds(): string[] {
    return Array.from(document.querySelectorAll<HTMLInputElement>('[data-base-checkbox]:checked')).map((el) => el.value);
  }

  async function runSave(btn: HTMLButtonElement, target: string, running: boolean) {
    const saveStatus = document.querySelector<HTMLParagraphElement>('[data-save-status]');
    setButtonLoading(btn, true);
    if (running && saveStatus) { saveStatus.textContent = 'Saving and starting your first backup…'; saveStatus.classList.remove('hidden', 'text-error'); }
    try {
      await fetch('/api/spaces/current/backup-config/bases', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ atBaseIds: selectedBaseIds() }) }).catch(() => {});
      if (running) await new Promise((r) => setTimeout(r, 1100));
      window.location.href = target;
    } catch {
      if (saveStatus) { saveStatus.textContent = 'Could not save. Please try again.'; saveStatus.classList.remove('hidden'); saveStatus.classList.add('text-error'); }
      setButtonLoading(btn, false);
    }
  }

  function wireStepper() {
    const stepper = document.querySelector<HTMLElement>('[data-stepper]');
    if (!stepper) return false;
    const steps = Array.from(stepper.querySelectorAll<HTMLElement>('[data-step-nav]'));
    const keys = steps.map((s) => s.dataset.stepNav!);
    const panelFor = (key: string) => document.querySelector<HTMLElement>(`.tab-panel[data-step="${key}"]`);
    const backBtn = document.querySelector<HTMLButtonElement>('[data-step-back]');
    const nextBtn = document.querySelector<HTMLButtonElement>('[data-step-next]');
    const hint = document.querySelector<HTMLElement>('[data-step-hint]');
    let current = 0;

    const basesChosen = () => selectedBaseIds().length > 0;

    function render() {
      steps.forEach((s, i) => {
        s.classList.toggle('is-current', i === current);
        s.classList.toggle('is-done', i < current);
        s.classList.toggle('is-locked', i > current);
      });
      keys.forEach((k, i) => panelFor(k)?.classList.toggle('is-active', i === current));
      const last = current === keys.length - 1;
      if (backBtn) backBtn.hidden = current === 0;
      const blocked = keys[current] === 'bases' && !basesChosen();
      if (nextBtn) { nextBtn.textContent = last ? 'Start first backup' : 'Next'; nextBtn.toggleAttribute('disabled', blocked); }
      if (hint) {
        hint.textContent = blocked
          ? 'Pick at least one base to continue.'
          : last ? 'We run your first backup right after this — it can take a moment.'
          : '';
        hint.classList.toggle('is-warn', blocked);
      }
    }

    steps.forEach((s, i) => s.addEventListener('click', () => { if (i <= current) { current = i; render(); } }));
    backBtn?.addEventListener('click', () => { if (current > 0) { current--; render(); } });
    nextBtn?.addEventListener('click', () => {
      if (current < keys.length - 1) { current++; render(); return; }
      runSave(nextBtn, nextBtn.dataset.target || '/integrations?status=running', true);
    });
    // Re-evaluate the Bases gate as the selection changes.
    document.addEventListener('change', (e) => { if ((e.target as HTMLElement)?.matches?.('[data-base-checkbox]')) render(); });

    render();
    return true;
  }

  function wire() {
    // Edit mode: free tabs + a single Save button + live bases badge.
    const saveBtn = document.querySelector<HTMLButtonElement>('[data-save-config]');
    if (saveBtn) saveBtn.addEventListener('click', () => runSave(saveBtn, saveBtn.dataset.target || '/integrations', saveBtn.dataset.target === '/integrations?status=running'));
    const badge = document.querySelector<HTMLElement>('[data-bases-badge]');
    if (badge) document.addEventListener('change', (e) => { if ((e.target as HTMLElement)?.matches?.('[data-base-checkbox]')) badge.textContent = String(selectedBaseIds().length); });

    wireStepper();
  }
  wire();
  document.addEventListener('astro:after-swap', wire);
</script>
