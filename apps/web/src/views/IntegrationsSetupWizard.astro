---
/**
 * IntegrationsSetupWizard — the per-Space backup setup, as a left-to-right
 * stepper that fits the account-level model (Sources / Destinations are reusable
 * account objects; this Space references them).
 *
 * Steps: Source → Bases → Destination → Options (depth + schedule) → Review.
 *
 * Empty-first: when the account has no Sources / Destinations yet, the Source and
 * Destination steps open on a "connect your first…" card whose button opens a
 * right-hand DRAWER to create one inline — the wizard never unmounts, and the new
 * object is auto-selected on success (prototype simulates the create client-side).
 *
 * Decisions baked in (founder + our edge analysis): one Source per Space; changing
 * the Source resets the base selection; reconnect happens in-context; no draft of
 * an abandoned wizard. Destination = 1 file (required) + 1 optional database.
 */
import BaseSelectionTable from '../components/patterns/BaseSelectionTable.astro';
import BackLink from '../components/ui/BackLink.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import TextInput from '../components/ui/TextInput.astro';
import { formatNextScheduledAt } from '../lib/backups/format';
import type { IntegrationsState } from '../stores/connections';
import type { SourceSummary } from '../stores/sources';
import type { DestinationSummary } from '../stores/destinations';

interface Props {
  state: IntegrationsState;
  sources?: SourceSummary[];
  destinations?: DestinationSummary[];
  /** 'setup' = first-run gated stepper; 'edit' = free tabs + Save (reached via Configure). */
  mode?: 'setup' | 'edit';
  /**
   * Production (apps/web) only — the real Space id. When set, the client wires
   * to real endpoints (Airtable OAuth connect, saveBaseSelection +
   * saveConfigureForm, managed-storage save) instead of the harness fakes.
   * Default null = full design-harness behavior (byte-identical).
   */
  realSpaceId?: string | null;
}
const { state, sources = [], destinations = [], mode = 'setup', realSpaceId = null } = Astro.props;
const isEdit = mode === 'edit';

const spaceName = Astro.locals.account?.space?.id ? (Astro.locals.account?.space?.name ?? 'this Space') : 'this Space';
const spaceId = Astro.locals.account?.space?.id ?? '';
const cap = state.tierBasesPerSpace;
const bases = state.bases;

const fileDestinations = destinations.filter((d) => d.kind === 'file');
const dbDestinations = destinations.filter((d) => d.kind === 'database');
const noSources = sources.length === 0;
const noFileDest = fileDestinations.length === 0;

const statusChip = (s: string) =>
  s === 'connected' ? { cls: 'is-ok', label: 'Connected' } : { cls: 'is-warn', label: s === 'needs_connection' ? 'Needs connection' : 'Lost access' };
// Action verb for the inline reconnect button on a non-connected row.
const reconnectLabel = (s: string) => (s === 'needs_connection' ? 'Connect' : 'Reconnect');

const ALL_STEPS = [
  { key: 'source', label: 'Source' },
  { key: 'bases', label: 'Bases' },
  { key: 'dest', label: 'Destination' },
  { key: 'options', label: 'Options' },
  { key: 'review', label: 'Review' },
];
// Edit mode has no Review/Run step — you jump between tabs and Save.
const STEPS = isEdit ? ALL_STEPS.filter((s) => s.key !== 'review') : ALL_STEPS;

const FREQS = [
  { value: 'monthly', label: 'Monthly', helper: 'One scheduled backup per month' },
  { value: 'weekly', label: 'Weekly', helper: 'One scheduled backup per week' },
  { value: 'daily', label: 'Daily', helper: 'One scheduled backup per day' },
  { value: 'instant', label: 'Instant', helper: 'Webhook-driven — captures changes as they happen' },
];

// Cleanup schedule = tiered rolling retention, keyed to the backup frequency (On2Air
// model). Older versions are progressively thinned (daily→weekly→monthly) so storage
// stays bounded; whatever is older than the max-retention cutoff is removed.
// (Informational in the wizard; the cutoff persistence is an engine/retention concern.)
const CLEANUP_TIERS: Record<string, string[]> = {
  monthly: ['Monthly versions kept'],
  weekly: ['3 months of weekly backups', 'then monthly'],
  daily: ['30 days of daily backups', 'then 2 months of weekly', 'then monthly'],
  instant: ['3 days of continuous backups', 'then 27 days of daily', 'then 2 months of weekly', 'then monthly'],
};
const freqLabel = (v: string) => FREQS.find((f) => f.value === v)?.label ?? 'Monthly';
const initialFreq = state.policy.frequency;
const initialTiers = CLEANUP_TIERS[initialFreq] ?? CLEANUP_TIERS.monthly;
---

<div class="mx-auto max-w-5xl space-y-6" data-wizard data-mode={mode} data-space-id={realSpaceId ?? undefined}>
  {/* Header */}
  <div>
    <BackLink href="/" label="Home" />
    <h1 class="text-2xl font-bold tracking-tight leading-tight mt-3">{isEdit ? "Edit this Space's backup" : "Set up this Space's backup"}</h1>
    <p class="text-sm text-base-content/60 mt-0.5">{isEdit ? 'Change the source, bases, destination or schedule — jump between tabs in any order' : 'Pick a source, the bases to protect, and where they go'} — for <span class="font-medium text-base-content/80">{spaceName}</span>.</p>
  </div>

  <div class="tabs-shell" data-tabs>
    {/* Nav bar: free tabs (edit) or a gated stepper (setup) + the primary action */}
    <div class="bar">
      {isEdit ? (
        <div class="tabbar" role="tablist">
          {STEPS.map((s, i) => (
            <label class="tab-opt"><input type="radio" name="wz-tab" value={s.key} checked={i === 0} /><span>{s.label}</span></label>
          ))}
        </div>
      ) : (
        <ol class="stepper" data-stepper>
          {STEPS.map((s, i) => (
            <li class="step" data-step-nav={s.key} data-index={i}>
              <span class="step-dot"><span class="step-num">{i + 1}</span><span class="iconify lucide--check step-check"></span></span>
              <span class="step-label">{s.label}</span>
            </li>
          ))}
        </ol>
      )}
      <div class="bar-actions">
        {isEdit ? (
          <>
            <Button href="/" variant="ghost" size="sm">Cancel</Button>
            <Button type="button" variant="primary" size="sm" data-save-edit>Save changes</Button>
          </>
        ) : (
          <>
            <Button type="button" variant="ghost" size="sm" data-step-back hidden><span class="iconify lucide--arrow-left"></span> Back</Button>
            <Button type="button" variant="primary" size="sm" data-step-next>Next</Button>
          </>
        )}
      </div>
    </div>

    <div class="tab-body">
      <p class="step-hint" data-step-hint></p>

      {/* STEP 1 — SOURCE */}
      <section class={`tab-panel panel-source${noSources ? ' is-empty' : ''}`} data-step="source" data-picker="source">
        <div class="panel-head"><h2>Where does this Space back up from?</h2><p>One Airtable source per Space. Connect once on your account, reuse across Spaces.</p></div>

        <div class="picker-empty" data-picker-empty>
          <span class="picker-empty-ic"><img src="/airtable.svg" alt="" width="26" height="26" /></span>
          <div class="min-w-0">
            <p class="picker-empty-title">No Airtable source yet</p>
            <p class="picker-empty-sub">Baseout reads your bases read-only. Connect an account to continue.</p>
          </div>
          <Button type="button" variant="primary" size="sm" class="shrink-0" data-open-drawer="source">Connect Airtable</Button>
        </div>

        <fieldset class="opt-options" data-picker-list>
          <legend class="sr-only">Source</legend>
          {sources.map((s, i) => {
            const chip = statusChip(s.status);
            return (
              <label class="opt-opt">
                <input type="radio" name="wz-source" value={s.id} checked={i === 0} class="radio radio-sm radio-primary" data-source-radio />
                <span class="opt-ic"><img src="/airtable.svg" alt="" width="18" height="18" /></span>
                <span class="min-w-0 flex-1">
                  <span class="opt-name">{s.name} <span class={`opt-chip ${chip.cls}`}>{chip.label}</span></span>
                  <span class="opt-sub">{s.account} · {s.basesAvailable} bases</span>
                </span>
                {s.status !== 'connected' && (
                  <button type="button" class="opt-reconnect" data-reconnect="source" data-reconnect-auth={s.auth === 'pat' ? 'secret' : 'oauth'} data-reconnect-secret-label="Personal access token"><span class="iconify lucide--rotate-cw"></span>{reconnectLabel(s.status)}</button>
                )}
              </label>
            );
          })}
        </fieldset>
        <button type="button" class="picker-add" data-open-drawer="source" data-picker-add><span class="iconify lucide--plus"></span> Add another source</button>

        {/* Heads-up before a source switch clears the base selection (bases belong to a source) */}
        <div class="switch-confirm" data-switch-confirm hidden>
          <span class="switch-confirm-ic"><span class="iconify lucide--info"></span></span>
          <div class="min-w-0 flex-1">
            <p class="switch-confirm-title">Switch to <span data-switch-name>—</span>?</p>
            <p class="switch-confirm-sub">Bases belong to a source. Your <span data-switch-count>0</span> selected base<span data-switch-plural></span> will be cleared so you don't back up the wrong ones.</p>
          </div>
          <div class="switch-confirm-actions">
            <Button type="button" variant="ghost" size="sm" data-switch-cancel>Keep current</Button>
            <Button type="button" variant="warning" size="sm" data-switch-go>Switch &amp; clear</Button>
          </div>
        </div>
      </section>

      {/* STEP 2 — BASES */}
      <section class="tab-panel panel-bases" data-step="bases">
        <div class="panel-head"><h2>Which bases to back up</h2><p>Pick the bases this Space protects. Search, sort, or select all up to your plan limit.</p></div>
        <p class="bases-reset-note" data-bases-reset-note hidden><span class="iconify lucide--info"></span> Base selection cleared — these are the bases for <span class="font-medium" data-bases-reset-name>—</span>. Pick the ones to back up.</p>
        {bases.length > 0 ? (
          <BaseSelectionTable bases={bases} cap={cap} spaceId={spaceId} embedded={true} />
        ) : (
          <p class="text-sm text-base-content/60">The selected source didn't reveal any bases. <button type="button" class="link link-hover font-medium" data-open-drawer="source">Pick another source</button>.</p>
        )}
      </section>

      {/* STEP 3 — DESTINATION */}
      <section class={`tab-panel panel-dest${noFileDest ? ' is-empty' : ''}`} data-step="dest" data-picker="dest">
        <div class="panel-head"><h2>Where do backups go?</h2><p>A file store is required; a database is an optional extra you can add now or later.</p></div>

        <div class="picker-empty" data-picker-empty>
          <span class="picker-empty-ic"><span class="iconify lucide--hard-drive"></span></span>
          <div class="min-w-0">
            <p class="picker-empty-title">No destination yet</p>
            <p class="picker-empty-sub">Pick storage you control — Google Drive, S3, Dropbox, or managed Baseout R2.</p>
          </div>
          <Button type="button" variant="primary" size="sm" class="shrink-0" data-open-drawer="dest">Add a destination</Button>
        </div>

        <div class="dest-groups" data-picker-list>
          <div class="dest-group">
            <div class="dest-group-head"><span class="dest-group-title">File storage</span><span class="dest-req">Required</span></div>
            <fieldset class="opt-options" data-dest-file>
              <legend class="sr-only">File destination</legend>
              {fileDestinations.map((d, i) => {
                const chip = statusChip(d.status);
                return (
                  <label class="opt-opt">
                    <input type="radio" name="wz-dest-file" value={d.id} checked={i === 0} class="radio radio-sm radio-primary" data-dest-file-radio />
                    <span class="opt-ic"><span class="iconify lucide--hard-drive"></span></span>
                    <span class="min-w-0 flex-1">
                      <span class="opt-name">{d.name} <span class={`opt-chip ${chip.cls}`}>{chip.label}</span></span>
                      <span class="opt-sub">{d.providerLabel} · {d.detail}</span>
                    </span>
                    {d.status !== 'connected' && (
                      <button type="button" class="opt-reconnect" data-reconnect="dest" data-reconnect-auth="oauth"><span class="iconify lucide--rotate-cw"></span>{reconnectLabel(d.status)}</button>
                    )}
                  </label>
                );
              })}
            </fieldset>
          </div>

          <div class="dest-group">
            <div class="dest-group-head"><span class="dest-group-title">Database</span><span class="dest-rec">Recommended</span></div>
            <p class="dest-blurb">Query your backup with SQL and power live dashboards. Optional — your file backup runs without it.</p>
            <fieldset class="opt-options" data-dest-db>
              <legend class="sr-only">Database destination</legend>
              {dbDestinations.map((d) => {
                const chip = statusChip(d.status);
                return (
                  <label class="opt-opt">
                    <input type="radio" name="wz-dest-db" value={d.id} class="radio radio-sm radio-primary" data-dest-db-radio />
                    <span class="opt-ic opt-ic-db"><span class="iconify lucide--database"></span></span>
                    <span class="min-w-0 flex-1">
                      <span class="opt-name">{d.name} <span class={`opt-chip ${chip.cls}`}>{chip.label}</span></span>
                      <span class="opt-sub">{d.providerLabel} · {d.detail}</span>
                    </span>
                    {d.status !== 'connected' && (
                      <button type="button" class="opt-reconnect" data-reconnect="dest" data-reconnect-auth="secret" data-reconnect-secret-label="Connection string"><span class="iconify lucide--rotate-cw"></span>{reconnectLabel(d.status)}</button>
                    )}
                  </label>
                );
              })}
              <label class="opt-opt opt-skip">
                <input type="radio" name="wz-dest-db" value="" checked class="radio radio-sm radio-primary" data-dest-db-radio />
                <span class="min-w-0 flex-1"><span class="opt-name">Skip for now</span><span class="opt-sub">Add a database later from Destinations.</span></span>
              </label>
            </fieldset>
          </div>

          <button type="button" class="picker-add" data-open-drawer="dest"><span class="iconify lucide--plus"></span> Add a custom destination</button>
        </div>
        <p class="dest-folder-note" data-dest-folder>Each backup writes to <span class="font-medium">/Baseout/{spaceName}</span> in the destination you pick.</p>
      </section>

      {/* STEP 4 — OPTIONS (depth + schedule) */}
      <section class="tab-panel panel-options" data-step="options">
        <div class="panel-head"><h2>What gets backed up, and how often</h2><p>Choose the depth of each backup and the schedule.</p></div>

        <h3 class="opt-subhead">Depth</h3>
        <ul class="opt-list">
          <li class="opt-row">
            <label class="opt-check cursor-not-allowed">
              <input type="checkbox" class="checkbox checkbox-sm" checked disabled />
              <span class="min-w-0"><span class="opt-row-name">Schema</span><span class="opt-row-sub">Tables, fields, views and relationships. Always captured.</span></span>
            </label>
            <Badge variant="default" size="sm" class="shrink-0">Always on</Badge>
          </li>
          <li class="opt-row">
            <label class="opt-check">
              <input type="checkbox" class="checkbox checkbox-sm" checked />
              <span class="min-w-0"><span class="opt-row-name">Data</span><span class="opt-row-sub">Every row and field value. On by default.</span></span>
            </label>
          </li>
          <li class="opt-row">
            <label class="opt-check">
              <input type="checkbox" class="checkbox checkbox-sm" />
              <span class="min-w-0"><span class="opt-row-name">Attachments</span><span class="opt-row-sub">Files attached to records, stored as binaries.</span></span>
            </label>
            <Badge variant="warning" size="sm" outline class="shrink-0">Billed on storage</Badge>
          </li>
        </ul>
        <p class="text-xs text-base-content/50 mt-2.5">Airtable's API can't export automations, interfaces, forms or views — those aren't backed up.</p>

        <h3 class="opt-subhead mt-5">Schedule</h3>
        <ul class="opt-list">
          {FREQS.map((f) => {
            const allowed = (state.availableFrequencies as readonly string[]).includes(f.value);
            return (
              <li class={`opt-row ${!allowed ? 'opacity-55' : ''}`}>
                <label class={`opt-check ${allowed ? '' : 'cursor-not-allowed'}`}>
                  <input type="radio" name="wz-frequency" value={f.value} checked={state.policy.frequency === f.value} disabled={!allowed} class="radio radio-sm radio-primary" data-frequency />
                  <span class="min-w-0"><span class="opt-row-name">{f.label}</span><span class="opt-row-sub">{f.helper}</span></span>
                </label>
                {!allowed && <Button href="/settings/billing" variant="warning" size="sm" outline class="shrink-0">Upgrade</Button>}
              </li>
            );
          })}
        </ul>
        <p class="text-xs text-base-content/60 mt-2.5">Next backup: <span class="font-medium text-base-content/80">{formatNextScheduledAt(state.policy.nextScheduledAt)}</span></p>

        {/* Cleanup schedule — tiered retention keyed to the frequency above (informational). */}
        <h3 class="opt-subhead mt-5">Cleanup schedule</h3>
        <div role="alert" class="alert alert-soft alert-info">
          <span class="iconify lucide--info size-4" aria-hidden="true"></span>
          <span>Older backup versions are thinned automatically so storage stays in check — recent backups are kept in full; as they age we keep them less often.</span>
        </div>
        <div class="cleanup mt-3" data-cleanup data-tiers={JSON.stringify(CLEANUP_TIERS)}>
          <p class="cleanup-lead">With <span class="font-semibold text-base-content" data-cleanup-freq>{freqLabel(initialFreq)}</span> backups we keep:</p>
          <ol class="cleanup-ladder" data-cleanup-ladder>
            {initialTiers.map((t, i) => (
              <li class="cleanup-tier"><span class="cleanup-tier-n">{i + 1}</span>{t}</li>
            ))}
          </ol>
          <label class="cleanup-cutoff">
            <span class="cleanup-cutoff-k">Then remove anything older than</span>
            <select class="select select-sm w-auto" data-cleanup-cutoff aria-label="Maximum retention">
              <option value="1">1 year</option>
              <option value="2">2 years</option>
              <option value="5" selected>5 years</option>
              <option value="0">never (keep forever)</option>
            </select>
          </label>
        </div>
      </section>

      {/* STEP 5 — REVIEW */}
      <section class="tab-panel panel-review" data-step="review">
        <div class="panel-head"><h2>Review and run</h2><p>This is what your Space will back up. We run the first backup right after.</p></div>
        <div class="review-pipe">
          <div class="review-node">
            <span class="review-node-k">Source</span>
            <span class="review-node-v"><img src="/airtable.svg" alt="" class="review-mark" /><span data-review-source>—</span></span>
          </div>
          <span class="review-link" aria-hidden="true"></span>
          <div class="review-node">
            <span class="review-node-k">Backs up</span>
            <span class="review-node-v"><span class="iconify lucide--layout-grid review-mark-ic"></span><span data-review-bases>—</span></span>
          </div>
          <span class="review-link" aria-hidden="true"></span>
          <div class="review-node">
            <span class="review-node-k">Destination</span>
            <span class="review-node-v"><span class="iconify lucide--hard-drive review-mark-ic"></span><span data-review-dest>—</span></span>
          </div>
        </div>
        <div class="review-meta">
          <div class="review-meta-item"><span class="review-meta-k">Schedule</span><span class="review-meta-v" data-review-schedule>—</span></div>
          <div class="review-meta-item"><span class="review-meta-k">Depth</span><span class="review-meta-v" data-review-depth>—</span></div>
          <div class="review-meta-item"><span class="review-meta-k">Folder</span><span class="review-meta-v">/Baseout/{spaceName}</span></div>
        </div>
      </section>
    </div>
  </div>

  <p class="text-xs hidden mt-2 text-right" data-save-status role="status" aria-live="polite"></p>

  {/* ───────── DRAWERS (inline create) ───────── */}

  {/* Source drawer */}
  <div class="drawer-shell" data-drawer="source" hidden>
    <div class="drawer-backdrop" data-drawer-close></div>
    <aside class="drawer-panel" role="dialog" aria-label="Add an Airtable source">
      <header class="drawer-head">
        <div><h3>Add an Airtable source</h3><p>Connect once, reuse across Spaces. Read-only access.</p></div>
        <button type="button" class="drawer-x" data-drawer-close aria-label="Close"><span class="iconify lucide--x"></span></button>
      </header>
      <div class="drawer-body">
        <TextInput label="Name" type="text" data-src-name placeholder="e.g. Ops Airtable" hint="A label to tell this connection apart from other Airtable accounts." />
        <div class="connect" data-src-connect>
          <span class="add-label">Connection method</span>
          <div role="tablist" class="method-tabs">
            <label class="method-tab"><input type="radio" name="wz-src-method" value="oauth" class="sr-only" checked /><span>OAuth</span></label>
            <label class="method-tab"><input type="radio" name="wz-src-method" value="pat" class="sr-only" /><span>Personal access token</span></label>
          </div>
          <div data-src-method="oauth" class="mt-4">
            <p class="add-hint">You approve read-only access on Airtable in a popup, then return here — the wizard stays open.</p>
          </div>
          <div data-src-method="pat" class="mt-4">
            <TextInput label="Personal access token" type="password" data-src-token placeholder="pat••••••••••••••" autocomplete="off" class="font-mono text-sm" hint="A read-only token with data.records:read and schema.bases:read scopes." />
          </div>
        </div>
      </div>
      <footer class="drawer-foot">
        <Button type="button" variant="ghost" size="sm" data-drawer-close>Cancel</Button>
        <Button type="button" variant="primary" size="sm" data-src-create>Test &amp; create</Button>
      </footer>
    </aside>
  </div>

  {/* Destination drawer (pick type → configure) */}
  <div class="drawer-shell" data-drawer="dest" hidden>
    <div class="drawer-backdrop" data-drawer-close></div>
    <aside class="drawer-panel" role="dialog" aria-label="Add a destination">
      <header class="drawer-head">
        <div><h3 data-dest-drawer-title>Add a destination</h3><p data-dest-drawer-sub>Pick where backups go. Reusable across Spaces.</p></div>
        <button type="button" class="drawer-x" data-drawer-close aria-label="Close"><span class="iconify lucide--x"></span></button>
      </header>
      <div class="drawer-body">
        {/* type picker */}
        <div data-dest-pick>
          <p class="add-label mb-2">File storage <span class="add-req">required</span></p>
          <div class="dtype-grid">
            <button type="button" class="dtype" data-dtype="local_fs" data-kind="file" data-label="Local disk (dev)" data-managed="1"><span class="dtype-ic"><span class="iconify lucide--hard-drive"></span></span><span class="min-w-0"><span class="dtype-name">Local disk <span class="add-tag">Dev</span></span><span class="dtype-note">No setup · writes to disk</span></span></button>
            <button type="button" class="dtype" data-dtype="r2" data-kind="file" data-label="Baseout R2" data-managed="1"><span class="dtype-ic"><span class="iconify lucide--box"></span></span><span class="min-w-0"><span class="dtype-name">Baseout R2 <span class="add-tag">Managed</span></span><span class="dtype-note">Zero setup</span></span></button>
            <button type="button" class="dtype" data-dtype="google_drive" data-kind="file" data-label="Google Drive"><span class="dtype-ic"><span class="iconify lucide--hard-drive"></span></span><span class="min-w-0"><span class="dtype-name">Google Drive</span><span class="dtype-note">Your own Drive</span></span></button>
            <button type="button" class="dtype" data-dtype="dropbox" data-kind="file" data-label="Dropbox"><span class="dtype-ic"><span class="iconify lucide--hard-drive"></span></span><span class="min-w-0"><span class="dtype-name">Dropbox</span><span class="dtype-note">Your own Dropbox</span></span></button>
            <button type="button" class="dtype" data-dtype="s3" data-kind="file" data-label="Amazon S3"><span class="dtype-ic"><span class="iconify lucide--cloud"></span></span><span class="min-w-0"><span class="dtype-name">Amazon S3</span><span class="dtype-note">Your own bucket</span></span></button>
          </div>
          <p class="add-label mb-2 mt-4">Database <span class="dest-rec">Recommended</span></p>
          <div class="dtype-grid">
            <button type="button" class="dtype" data-dtype="postgres" data-kind="database" data-label="Postgres"><span class="dtype-ic dtype-ic-db"><span class="iconify lucide--database"></span></span><span class="min-w-0"><span class="dtype-name">Postgres</span><span class="dtype-note">Self-hosted or cloud</span></span></button>
            <button type="button" class="dtype" data-dtype="neon" data-kind="database" data-label="Neon"><span class="dtype-ic dtype-ic-db"><span class="iconify lucide--database"></span></span><span class="min-w-0"><span class="dtype-name">Neon</span><span class="dtype-note">Serverless Postgres</span></span></button>
          </div>
        </div>
        {/* configure (after type pick) */}
        <div data-dest-config hidden>
          <Button type="button" variant="ghost" size="sm" class="mb-3" data-dest-back><span class="iconify lucide--arrow-left"></span> Pick a different type</Button>
          <TextInput label="Name" type="text" data-dest-name placeholder="Backup storage" />
          <div data-dest-field-folder class="mt-3">
            <TextInput label="Folder" type="text" data-dest-folder-input placeholder="/Baseout" class="font-mono text-sm" hint="You authorize the account in a popup after saving. Each Space writes to its own subfolder." />
          </div>
          <div data-dest-field-conn class="mt-3" hidden>
            <TextInput label="Connection string" type="password" data-dest-conn-input placeholder="postgres://user:••••@host:5432/db" autocomplete="off" class="font-mono text-sm" hint="Stored encrypted. Baseout writes one schema per Space." />
          </div>
          <p data-dest-field-managed class="add-managed mt-3" hidden><span class="iconify lucide--shield-check"></span> Managed by Baseout — no account to connect or folder to choose.</p>
        </div>
      </div>
      <footer class="drawer-foot">
        <Button type="button" variant="ghost" size="sm" data-drawer-close>Cancel</Button>
        <Button type="button" variant="primary" size="sm" data-dest-create hidden>Save destination</Button>
      </footer>
    </aside>
  </div>

  {/* Reconnect drawer — re-authorize a broken object in place (no kick-out) */}
  <div class="drawer-shell" data-drawer="reconnect" hidden>
    <div class="drawer-backdrop" data-drawer-close></div>
    <aside class="drawer-panel" role="dialog" aria-label="Reconnect">
      <header class="drawer-head">
        <div><h3 data-reconnect-title>Reconnect</h3><p>Reauthorize to resume backups — your selection and settings are kept.</p></div>
        <button type="button" class="drawer-x" data-drawer-close aria-label="Close"><span class="iconify lucide--x"></span></button>
      </header>
      <div class="drawer-body">
        <div class="reconnect-panel">
          <span class="reconnect-ic"><span class="iconify lucide--wifi-off"></span></span>
          <div class="min-w-0"><p class="reconnect-name" data-reconnect-name>—</p><p class="reconnect-meta">Lost access · backups paused</p></div>
        </div>
        <div data-reconnect-oauth class="mt-4">
          <p class="add-hint">You reauthorize read-only access in a popup, then return here — the wizard stays open.</p>
        </div>
        <div data-reconnect-secret-field hidden>
          <span data-reconnect-secret-label class="sr-only">Personal access token</span>
          <TextInput label="Personal access token" type="password" data-reconnect-secret placeholder="••••••••••••••" autocomplete="off" class="font-mono text-sm mt-4" hint="Stored encrypted. Re-enter to restore access." />
        </div>
      </div>
      <footer class="drawer-foot">
        <Button type="button" variant="ghost" size="sm" data-drawer-close>Cancel</Button>
        <Button type="button" variant="primary" size="sm" data-reconnect-confirm><span class="iconify lucide--rotate-cw"></span> Reconnect</Button>
      </footer>
    </aside>
  </div>

  {/* toast */}
  <div class="wz-toast" data-toast hidden></div>
</div>

<style>
  .back-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .8125rem; font-weight: 500; color: oklch(from var(--color-base-content) l c h / .6); text-decoration: none; background: none; border: none; cursor: pointer; padding: 0; }
  .back-link:hover { color: var(--color-base-content); }
  .back-link .iconify { font-size: .95rem; }

  .tabs-shell { border: 1px solid var(--color-base-300); border-radius: .85rem; background: var(--color-base-100); overflow: hidden; }
  .bar { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; padding: .6rem .8rem .6rem 1.1rem; border-bottom: 1px solid var(--color-base-300); background: oklch(from var(--color-base-200) l c h / .45); }
  .bar-actions { margin-left: auto; display: flex; align-items: center; gap: .5rem; flex: none; }
  .step-hint { font-size: .78rem; line-height: 1.4; color: oklch(from var(--color-base-content) l c h / .65); margin-bottom: 1rem; padding: .55rem .75rem; border-radius: .5rem; background: oklch(from var(--color-base-200) l c h / .55); }
  .step-hint:empty { display: none; }
  .step-hint.is-warn { color: oklch(from var(--color-base-content) l c h / .9); background: oklch(from var(--color-warning) l c h / .12); border: 1px solid oklch(from var(--color-warning) l c h / .3); }

  /* Stepper */
  .stepper { display: flex; align-items: center; gap: 0; margin: 0; padding: 0; list-style: none; flex-wrap: wrap; }
  .step { display: flex; align-items: center; gap: .5rem; flex: none; }
  .step:not(:last-child)::after { content: ''; width: clamp(.6rem, 3.5vw, 2.4rem); height: 2px; background: var(--color-base-300); margin: 0 .6rem; }
  .step.is-done:not(:last-child)::after { background: oklch(from var(--color-primary) l c h / .5); }
  .step-dot { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 1.6rem; height: 1.6rem; border-radius: 999px; flex: none; font-size: .78rem; font-weight: 700; border: 1.5px solid var(--color-base-300); color: oklch(from var(--color-base-content) l c h / .5); background: var(--color-base-100); }
  .step-check { display: none; font-size: .9rem; }
  .step.is-current .step-dot { border-color: var(--color-primary); color: var(--color-primary); }
  .step.is-done .step-dot { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
  .step.is-done .step-num { display: none; }
  .step.is-done .step-check { display: inline; }
  .step.is-done, .step.is-current { cursor: pointer; }
  .step.is-locked { cursor: default; }
  .step-label { font-size: .82rem; font-weight: 600; white-space: nowrap; color: oklch(from var(--color-base-content) l c h / .55); }
  .step.is-current .step-label { color: var(--color-base-content); }
  .step.is-locked .step-label { opacity: .5; }

  /* Free tabs (edit mode) */
  .tabbar { display: flex; gap: .15rem; flex-wrap: wrap; }
  .tab-opt { position: relative; display: inline-flex; flex: none; }
  .tab-opt input { position: absolute; inset: 0; margin: 0; opacity: 0; cursor: pointer; }
  .tab-opt span { display: inline-flex; align-items: center; gap: .4rem; padding: .45rem .85rem; font-size: .82rem; font-weight: 600; border-radius: .5rem; white-space: nowrap; color: oklch(from var(--color-base-content) l c h / .6); }
  .tab-opt input:checked + span { background: var(--color-base-100); color: var(--color-base-content); box-shadow: inset 0 0 0 1px var(--color-base-300); }

  .tab-body { padding: 1.25rem; }
  .tab-panel { display: none; }
  .tab-panel.is-active { display: block; }
  .panel-head { margin-bottom: 1rem; }
  .panel-head h2 { font-size: 1.05rem; font-weight: 650; }
  .panel-head p { font-size: .8rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .15rem; }

  /* Empty-state CTA card (shown when picker has no options) */
  .picker-empty { display: none; align-items: center; gap: .9rem; padding: 1rem 1.1rem; border: 1px dashed var(--color-base-300); border-radius: .7rem; background: oklch(from var(--color-base-200) l c h / .35); }
  .panel-source.is-empty .picker-empty, .panel-dest.is-empty .picker-empty { display: flex; }
  .panel-source.is-empty [data-picker-list], .panel-source.is-empty [data-picker-add],
  .panel-dest.is-empty [data-picker-list], .panel-dest.is-empty [data-dest-folder] { display: none; }
  .picker-empty-ic { width: 2.6rem; height: 2.6rem; border-radius: .6rem; display: grid; place-items: center; background: var(--color-base-100); border: 1px solid var(--color-base-300); flex: none; }
  .picker-empty-ic .iconify { font-size: 1.3rem; color: oklch(from var(--color-base-content) l c h / .6); }
  .picker-empty-title { font-size: .9rem; font-weight: 650; }
  .picker-empty-sub { font-size: .76rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .1rem; }

  /* Radio option rows (source + destination pickers) */
  .opt-options { display: grid; gap: .5rem; }
  .opt-opt { display: flex; align-items: center; gap: .65rem; padding: .6rem .7rem; border: 1px solid var(--color-base-300); border-radius: .55rem; cursor: pointer; transition: border-color .12s ease, background .12s ease; }
  .opt-opt:hover { background: oklch(from var(--color-base-200) l c h / .5); }
  .opt-opt:has(input:checked) { border-color: oklch(from var(--color-primary) l c h / .55); background: oklch(from var(--color-primary) l c h / .05); }
  .opt-ic { width: 2rem; height: 2rem; border-radius: .5rem; display: grid; place-items: center; background: oklch(from var(--color-base-200) l c h / .8); flex: none; }
  .opt-ic .iconify { font-size: 1rem; color: oklch(from var(--color-base-content) l c h / .65); }
  .opt-ic-db { background: oklch(from var(--color-primary) l c h / .1); }
  .opt-ic-db .iconify { color: var(--color-primary); }
  .opt-name { display: flex; align-items: center; gap: .45rem; font-size: .85rem; font-weight: 600; }
  .opt-sub { display: block; font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .55); margin-top: .05rem; }
  .opt-skip .opt-name { color: oklch(from var(--color-base-content) l c h / .7); }
  .opt-chip { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; padding: .08rem .4rem; border-radius: 999px; }
  .opt-chip.is-ok { color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); }
  .opt-chip.is-warn { color: var(--color-warning); background: oklch(from var(--color-warning) l c h / .16); }
  .picker-add { display: inline-flex; align-items: center; gap: .35rem; margin-top: .9rem; font-size: .82rem; font-weight: 600; color: oklch(from var(--color-primary) l c h / .95); background: none; border: none; cursor: pointer; padding: 0; }
  .picker-add:hover { text-decoration: underline; }
  .picker-add .iconify { font-size: .95rem; }

  .dest-group { border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); padding: .9rem 1rem; }
  .dest-group + .dest-group { margin-top: .75rem; }
  .dest-group-head { display: flex; align-items: center; gap: .5rem; margin-bottom: .7rem; }
  .dest-group-title { font-size: .875rem; font-weight: 650; }
  .dest-req { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: oklch(from var(--color-base-content) l c h / .45); }
  .dest-rec { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: var(--color-primary); background: oklch(from var(--color-primary) l c h / .12); padding: .08rem .4rem; border-radius: 999px; }
  .dest-blurb { font-size: .75rem; color: oklch(from var(--color-base-content) l c h / .6); margin: -.3rem 0 .6rem; }
  .dest-folder-note { font-size: .74rem; color: oklch(from var(--color-base-content) l c h / .55); margin-top: .8rem; }

  /* Options step */
  .opt-subhead { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: oklch(from var(--color-base-content) l c h / .55); margin-bottom: .55rem; }
  .opt-list { border: 1px solid var(--color-base-300); border-radius: .7rem; overflow: hidden; background: var(--color-base-100); }
  .opt-row { display: flex; align-items: center; justify-content: space-between; gap: .75rem; padding: .7rem .85rem; }
  .opt-row + .opt-row { border-top: 1px solid oklch(from var(--color-base-300) l c h / .6); }
  .opt-check { display: flex; align-items: center; gap: .75rem; flex: 1; min-width: 0; cursor: pointer; }
  .opt-row-name { display: block; font-weight: 500; font-size: .875rem; }
  .opt-row-sub { display: block; font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .5); margin-top: .05rem; }

  /* Cleanup schedule — the retention ladder for the selected frequency */
  .cleanup { border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); padding: .9rem 1rem 1rem; }
  .cleanup-lead { font-size: .82rem; color: oklch(from var(--color-base-content) l c h / .7); }
  .cleanup-ladder { display: flex; flex-direction: column; gap: .3rem; margin-top: .6rem; }
  .cleanup-tier { display: flex; align-items: center; gap: .55rem; font-size: .85rem; font-weight: 500; }
  .cleanup-tier-n { width: 1.4rem; height: 1.4rem; border-radius: 999px; display: grid; place-items: center; flex: none; font-size: .72rem; font-weight: 700; background: oklch(from var(--color-primary) l c h / .14); color: var(--color-primary); }
  .cleanup-cutoff { display: flex; align-items: center; gap: .6rem; flex-wrap: wrap; margin-top: .85rem; padding-top: .75rem; border-top: 1px solid oklch(from var(--color-base-300) l c h / .6); }
  .cleanup-cutoff-k { font-size: .82rem; color: oklch(from var(--color-base-content) l c h / .7); }

  /* Review step */
  .review-pipe { display: flex; align-items: stretch; gap: .35rem; }
  .review-node { flex: 1; border: 1px solid var(--color-base-300); border-radius: .65rem; padding: .8rem .9rem; background: var(--color-base-100); min-width: 0; }
  .review-node-k { display: block; font-size: .64rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: oklch(from var(--color-base-content) l c h / .45); }
  .review-node-v { display: flex; align-items: center; gap: .45rem; font-size: .9rem; font-weight: 600; margin-top: .35rem; overflow-wrap: anywhere; }
  .review-mark { width: 18px; height: 18px; border-radius: 4px; flex: none; }
  .review-mark-ic { font-size: 1rem; color: oklch(from var(--color-base-content) l c h / .6); flex: none; }
  /* connector: primary line + node dot, echoing the empty-state diagram (ready, not yet running) */
  .review-link { align-self: center; position: relative; width: 1.5rem; height: 2px; border-radius: 2px; background: oklch(from var(--color-primary) l c h / .3); flex: none; display: grid; place-items: center; }
  .review-link::after { content: ''; width: .5rem; height: .5rem; border-radius: 999px; background: var(--color-primary); box-shadow: 0 0 0 3px var(--color-base-100); }
  .review-meta { display: flex; gap: 2.25rem; flex-wrap: wrap; margin-top: 1.1rem; padding: .85rem 1.05rem; border: 1px solid var(--color-base-300); border-radius: .65rem; background: oklch(from var(--color-base-200) l c h / .35); }
  .review-meta-item { display: flex; flex-direction: column; gap: .2rem; }
  .review-meta-k { font-size: .64rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: oklch(from var(--color-base-content) l c h / .45); }
  .review-meta-v { font-size: .85rem; font-weight: 600; }

  /* Drawer */
  .drawer-shell { position: fixed; inset: 0; z-index: 300; }
  .drawer-shell[hidden] { display: none; }
  .drawer-backdrop { position: absolute; inset: 0; background: rgb(2 6 23 / .55); opacity: 0; transition: opacity .2s ease; }
  .drawer-shell.is-open .drawer-backdrop { opacity: 1; }
  .drawer-panel { position: absolute; top: 0; right: 0; height: 100%; width: min(92vw, 30rem); background: var(--color-base-100); border-left: 1px solid var(--color-base-300); box-shadow: -16px 0 50px oklch(from var(--color-base-content) l c h / .12); display: flex; flex-direction: column; transform: translateX(100%); transition: transform .24s cubic-bezier(.22,1,.36,1); }
  .drawer-shell.is-open .drawer-panel { transform: translateX(0); }
  .drawer-head { display: flex; align-items: flex-start; gap: 1rem; padding: 1.1rem 1.2rem; border-bottom: 1px solid var(--color-base-300); }
  .drawer-head h3 { font-size: 1rem; font-weight: 650; }
  .drawer-head p { font-size: .76rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .15rem; }
  .drawer-x { margin-left: auto; color: oklch(from var(--color-base-content) l c h / .5); background: none; border: none; cursor: pointer; font-size: 1.1rem; padding: .2rem; flex: none; }
  .drawer-x:hover { color: var(--color-base-content); }
  .drawer-body { flex: 1; overflow-y: auto; padding: 1.2rem; }
  .drawer-foot { display: flex; justify-content: flex-end; gap: .5rem; padding: .9rem 1.2rem; border-top: 1px solid var(--color-base-300); }

  .add-field { display: flex; flex-direction: column; gap: .35rem; }
  .add-label { font-size: .8125rem; font-weight: 600; }
  .add-hint { font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .5); }
  .add-hint code { font-size: 11px; padding: .05rem .25rem; border-radius: 4px; background: oklch(from var(--color-base-content) l c h / .07); }
  .add-req { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: oklch(from var(--color-base-content) l c h / .45); }
  .add-tag { font-size: .58rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); padding: .04rem .3rem; border-radius: 999px; }
  .add-managed { display: flex; align-items: center; gap: .45rem; font-size: .8125rem; color: oklch(from var(--color-base-content) l c h / .75); padding: .7rem .8rem; border-radius: .55rem; background: oklch(from var(--color-success) l c h / .08); border: 1px solid oklch(from var(--color-success) l c h / .2); }
  .add-managed .iconify { color: var(--color-success); flex: none; }
  .method-tabs { display: flex; gap: .25rem; padding: .25rem; border-radius: .6rem; background: oklch(from var(--color-base-200) l c h / .7); margin-top: .5rem; }
  .method-tab { flex: 1; cursor: pointer; }
  .method-tab > span { display: block; padding: .4rem .9rem; border-radius: .45rem; text-align: center; font-size: .8125rem; font-weight: 600; color: oklch(from var(--color-base-content) l c h / .6); transition: background .15s ease, color .15s ease; }
  .method-tab:has(input:checked) > span { background: var(--color-base-100); color: var(--color-base-content); box-shadow: 0 1px 2px rgb(0 0 0 / .08); }
  .connect:has(input[value="oauth"]:checked) [data-src-method="pat"] { display: none; }
  .connect:has(input[value="pat"]:checked) [data-src-method="oauth"] { display: none; }

  .dtype-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; }
  .dtype { display: flex; align-items: center; gap: .6rem; padding: .6rem .65rem; border: 1px solid var(--color-base-300); border-radius: .6rem; background: var(--color-base-100); cursor: pointer; text-align: left; transition: border-color .12s ease, background .12s ease; }
  .dtype:hover { border-color: oklch(from var(--color-primary) l c h / .5); background: oklch(from var(--color-primary) l c h / .04); }
  .dtype-ic { width: 2rem; height: 2rem; border-radius: .5rem; display: grid; place-items: center; background: oklch(from var(--color-base-200) l c h / .8); flex: none; }
  .dtype-ic .iconify { font-size: 1rem; color: oklch(from var(--color-base-content) l c h / .7); }
  .dtype-ic-db { background: oklch(from var(--color-primary) l c h / .1); }
  .dtype-ic-db .iconify { color: var(--color-primary); }
  .dtype-name { display: flex; align-items: center; gap: .35rem; font-size: .82rem; font-weight: 600; }
  .dtype-note { display: block; font-size: .68rem; color: oklch(from var(--color-base-content) l c h / .5); }

  /* Inline reconnect (broken row → reconnect in place) */
  .opt-reconnect { flex: none; display: inline-flex; align-items: center; gap: .3rem; font-size: .72rem; font-weight: 650; color: var(--color-warning); background: oklch(from var(--color-warning) l c h / .12); border: 1px solid oklch(from var(--color-warning) l c h / .3); border-radius: .45rem; padding: .25rem .55rem; cursor: pointer; transition: background .12s ease; }
  .opt-reconnect:hover { background: oklch(from var(--color-warning) l c h / .22); }
  .opt-reconnect .iconify { font-size: .85rem; }
  .reconnect-panel { display: flex; align-items: center; gap: .7rem; padding: .8rem .9rem; border: 1px solid oklch(from var(--color-warning) l c h / .3); border-radius: .6rem; background: oklch(from var(--color-warning) l c h / .08); }
  .reconnect-ic { width: 2.2rem; height: 2.2rem; border-radius: .5rem; display: grid; place-items: center; background: oklch(from var(--color-warning) l c h / .15); flex: none; }
  .reconnect-ic .iconify { font-size: 1.1rem; color: var(--color-warning); }
  .reconnect-name { font-size: .9rem; font-weight: 650; }
  .reconnect-meta { font-size: .74rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .05rem; }

  /* Source-change → base-reset heads-up */
  .switch-confirm { display: flex; align-items: flex-start; gap: .7rem; margin-top: .9rem; padding: .75rem .9rem; border: 1px solid oklch(from var(--color-warning) l c h / .35); border-radius: .6rem; background: oklch(from var(--color-warning) l c h / .08); }
  .switch-confirm[hidden] { display: none; }
  .switch-confirm-ic { width: 1.9rem; height: 1.9rem; border-radius: .45rem; display: grid; place-items: center; background: oklch(from var(--color-warning) l c h / .15); flex: none; }
  .switch-confirm-ic .iconify { font-size: 1rem; color: var(--color-warning); }
  .switch-confirm-title { font-size: .85rem; font-weight: 650; }
  .switch-confirm-sub { font-size: .76rem; color: oklch(from var(--color-base-content) l c h / .65); margin-top: .1rem; }
  .switch-confirm-actions { display: flex; gap: .4rem; flex: none; align-self: center; }
  .bases-reset-note { display: flex; align-items: center; gap: .45rem; margin-bottom: .9rem; padding: .55rem .75rem; font-size: .78rem; border-radius: .5rem; color: oklch(from var(--color-base-content) l c h / .8); background: oklch(from var(--color-primary) l c h / .08); border: 1px solid oklch(from var(--color-primary) l c h / .22); }
  .bases-reset-note[hidden] { display: none; }
  .bases-reset-note .iconify { font-size: .95rem; flex: none; color: var(--color-primary); }

  .wz-toast { position: fixed; bottom: 1.25rem; left: 50%; transform: translateX(-50%); z-index: 400; background: var(--color-base-content); color: var(--color-base-100); font-size: .8rem; font-weight: 500; padding: .55rem .9rem; border-radius: .55rem; box-shadow: 0 8px 30px oklch(from var(--color-base-content) l c h / .25); }
  .wz-toast[hidden] { display: none; }
</style>

<script>
  import { setButtonLoading } from '../lib/ui';
  import { saveBaseSelection } from '../lib/backups/save-selection';
  import { saveConfigureForm } from '../lib/backups/configure-save';
  import { saveBackupConfig } from '../lib/backups/save-config';
  import { connectLocalFs } from '../lib/backups/connect-local-fs';

  function wizard() {
    const root = document.querySelector<HTMLElement>('[data-wizard]');
    if (!root) return;
    const isEdit = root.dataset.mode === 'edit';
    // Production wires to real endpoints when the Space id is present; absent in
    // the design harness, which keeps its client-side simulation.
    const prodSpaceId = root.dataset.spaceId || null;
    const isProd = !!prodSpaceId;
    const FREQS_ALLOWED = ['monthly', 'weekly', 'daily', 'instant'] as const;
    type Freq = (typeof FREQS_ALLOWED)[number];
    const chosenFrequency = (): Freq | undefined => {
      const v = $<HTMLInputElement>('[data-frequency]:checked')?.value;
      return v && (FREQS_ALLOWED as readonly string[]).includes(v) ? (v as Freq) : undefined;
    };

    // Persist + (optionally) run the first backup. Production calls the real
    // helpers; the harness simulates and reflects the setup in the overview.
    async function commit(runFirst: boolean, btn: HTMLButtonElement) {
      const atBaseIds = $$('[data-base-checkbox]:checked').map((el) => (el as HTMLInputElement).value);
      const saveStatus = $<HTMLParagraphElement>('[data-save-status]');
      setButtonLoading(btn, true);
      if (saveStatus && (runFirst || isProd)) {
        saveStatus.textContent = runFirst ? 'Saving and starting your first backup…' : 'Saving changes…';
        saveStatus.classList.remove('hidden');
      }
      if (isProd) {
        const sel = await saveBaseSelection(prodSpaceId!, atBaseIds);
        if (!sel.ok) {
          setButtonLoading(btn, false);
          if (saveStatus) saveStatus.textContent = 'Could not save your base selection. Please try again.';
          return;
        }
        const outcome = await saveConfigureForm({ spaceId: prodSpaceId!, frequency: chosenFrequency(), runFirstBackup: runFirst });
        if (outcome.ok) { window.location.href = outcome.redirect; return; }
        setButtonLoading(btn, false);
        if (saveStatus) saveStatus.textContent = outcome.message;
        return;
      }
      // Harness fallback — simulate, then reflect the setup in the overview.
      fetch('/api/spaces/current/backup-config/bases', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ atBaseIds }) }).catch(() => {});
      if (runFirst) {
        const nm = (sel: string) => $<HTMLInputElement>(sel)?.closest('.opt-opt')?.querySelector('.opt-name')?.childNodes[0]?.textContent?.trim();
        const params = new URLSearchParams({ status: 'running', src: nm('[data-source-radio]:checked') || 'Airtable', dest: nm('[data-dest-file-radio]:checked') || 'storage', bases: String(atBaseIds.length) });
        setTimeout(() => { window.location.href = `/?${params.toString()}`; }, 1100);
      } else {
        setTimeout(() => { window.location.href = '/?status=saved'; }, 800);
      }
    }

    const STEP_KEYS = ['source', 'bases', 'dest', 'options', 'review'];
    let current = 0;

    // Concrete HTMLElement|Document, not ParentNode: worker-configuration.d.ts
    // (Cloudflare HTMLRewriter) augments ParentNode.append/prepend, so a ParentNode
    // annotation conflicts with lib.dom here. See BaseSelectionTable.astro for the same note.
    const $ = <T extends HTMLElement = HTMLElement>(s: string, r: HTMLElement | Document = root) => r.querySelector<T>(s);
    const $$ = <T extends HTMLElement = HTMLElement>(s: string, r: HTMLElement | Document = root) => Array.from(r.querySelectorAll<T>(s));
    const steps = $$('[data-step-nav]');
    const panelFor = (k: string) => $(`.tab-panel[data-step="${k}"]`);
    const backBtn = $<HTMLButtonElement>('[data-step-back]');
    const nextBtn = $<HTMLButtonElement>('[data-step-next]');
    const hint = $('[data-step-hint]');

    // Astro scopes styles via a data-astro-cid-* attr; JS-injected nodes lack it,
    // so stamp the component's cid onto created options to inherit the scoped CSS.
    const cidAttr = Array.from(root.attributes).find((a) => a.name.startsWith('data-astro-cid-'))?.name;
    const stamp = (el: HTMLElement) => { if (!cidAttr) return; el.setAttribute(cidAttr, ''); el.querySelectorAll<HTMLElement>('*').forEach((c) => c.setAttribute(cidAttr, '')); };

    const basesChosen = () => $$('[data-base-checkbox]:checked').length;
    const nameOf = (input?: HTMLElement | null) => input?.closest('.opt-opt')?.querySelector('.opt-name')?.childNodes[0]?.textContent?.trim() ?? 'this connection';
    // A row is "broken" when its status chip is the amber warn variant (lost access / needs connection).
    const rowBroken = (input?: HTMLElement | null) => !!input?.closest('.opt-opt')?.querySelector('.opt-chip.is-warn');

    function gateFor(key: string): string | null {
      if (key === 'source') {
        const src = $<HTMLInputElement>('[data-source-radio]:checked');
        if (!src) return 'Pick or connect an Airtable source to continue.';
        if (rowBroken(src)) return `Reconnect ${nameOf(src)} to continue — this source has lost access.`;
      }
      if (key === 'bases' && basesChosen() === 0) return 'Pick at least one base to continue.';
      if (key === 'dest') {
        const file = $<HTMLInputElement>('[data-dest-file-radio]:checked');
        if (!file) return 'Pick or add a file destination to continue.';
        if (rowBroken(file)) return `Reconnect ${nameOf(file)} to continue — this destination has lost access.`;
        const db = $<HTMLInputElement>('[data-dest-db-radio]:checked');
        if (db && db.value && rowBroken(db)) return `Reconnect ${nameOf(db)} to continue.`;
      }
      if (key === 'review') {
        const broken = [$<HTMLInputElement>('[data-source-radio]:checked'), $<HTMLInputElement>('[data-dest-file-radio]:checked')].find((el) => rowBroken(el));
        if (broken) return `Reconnect ${nameOf(broken)} before running the first backup.`;
        const db = $<HTMLInputElement>('[data-dest-db-radio]:checked');
        if (db && db.value && rowBroken(db)) return `Reconnect ${nameOf(db)} before running the first backup.`;
      }
      return null;
    }

    function fillReview() {
      const src = $<HTMLInputElement>('[data-source-radio]:checked');
      const srcName = src?.closest('.opt-opt')?.querySelector('.opt-name')?.childNodes[0]?.textContent?.trim() ?? '—';
      $('[data-review-source]')!.textContent = srcName;
      $('[data-review-bases]')!.textContent = `${basesChosen()} base${basesChosen() === 1 ? '' : 's'}`;
      const file = $<HTMLInputElement>('[data-dest-file-radio]:checked');
      const fileName = file?.closest('.opt-opt')?.querySelector('.opt-name')?.childNodes[0]?.textContent?.trim() ?? '—';
      const db = $<HTMLInputElement>('[data-dest-db-radio]:checked');
      const dbName = db && db.value ? db.closest('.opt-opt')?.querySelector('.opt-name')?.childNodes[0]?.textContent?.trim() : '';
      $('[data-review-dest]')!.textContent = dbName ? `${fileName} + ${dbName}` : fileName;
      const freq = $<HTMLInputElement>('[data-frequency]:checked');
      $('[data-review-schedule]')!.textContent = freq ? freq.value.charAt(0).toUpperCase() + freq.value.slice(1) : 'Monthly';
      const depth = ['Schema'];
      const checks = $$<HTMLInputElement>('.panel-options .opt-check input[type="checkbox"]');
      if (checks[1]?.checked) depth.push('Data');
      if (checks[2]?.checked) depth.push('Attachments');
      $('[data-review-depth]')!.textContent = depth.join(' · ');
    }

    function render() {
      if (isEdit) {
        const key = $<HTMLInputElement>('input[name="wz-tab"]:checked')?.value || 'source';
        STEP_KEYS.forEach((k) => panelFor(k)?.classList.toggle('is-active', k === key));
        // Block Save while a selected object is broken — reconnect in place first.
        const broken = [$<HTMLInputElement>('[data-source-radio]:checked'), $<HTMLInputElement>('[data-dest-file-radio]:checked')].find((el) => rowBroken(el));
        const db = $<HTMLInputElement>('[data-dest-db-radio]:checked');
        const g = broken ? `Reconnect ${nameOf(broken)} to save — it has lost access.`
          : (db && db.value && rowBroken(db)) ? `Reconnect ${nameOf(db)} to save — it has lost access.` : null;
        if (hint) { hint.textContent = g ?? ''; hint.classList.toggle('is-warn', !!g); }
        $<HTMLButtonElement>('[data-save-edit]')?.toggleAttribute('disabled', !!g);
        return;
      }
      steps.forEach((s, i) => {
        s.classList.toggle('is-current', i === current);
        s.classList.toggle('is-done', i < current);
        s.classList.toggle('is-locked', i > current);
      });
      STEP_KEYS.forEach((k, i) => panelFor(k)?.classList.toggle('is-active', i === current));
      const key = STEP_KEYS[current];
      const last = current === STEP_KEYS.length - 1;
      if (backBtn) backBtn.hidden = current === 0;
      const gate = gateFor(key);
      if (nextBtn) { nextBtn.textContent = last ? 'Run first backup' : 'Next'; nextBtn.toggleAttribute('disabled', !!gate); }
      if (hint) { hint.textContent = gate ?? (last ? 'We run your first backup right after this — it can take a moment.' : ''); hint.classList.toggle('is-warn', !!gate); }
      if (key === 'review') fillReview();
    }

    function go(i: number) { current = Math.max(0, Math.min(STEP_KEYS.length - 1, i)); render(); }

    steps.forEach((s, i) => s.addEventListener('click', () => { if (i <= current) go(i); }));
    backBtn?.addEventListener('click', () => go(current - 1));
    nextBtn?.addEventListener('click', () => {
      if (current < STEP_KEYS.length - 1) { go(current + 1); return; }
      commit(true, nextBtn);
    });

    // Cleanup schedule — rebuild the retention ladder for the chosen frequency.
    const cleanup = $<HTMLElement>('[data-cleanup]');
    const cleanupTiers: Record<string, string[]> = cleanup ? JSON.parse(cleanup.dataset.tiers || '{}') : {};
    const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
    function updateCleanup(freq: string) {
      const ladder = $<HTMLElement>('[data-cleanup-ladder]');
      const freqEl = $<HTMLElement>('[data-cleanup-freq]');
      const tiers = cleanupTiers[freq] ?? cleanupTiers.monthly ?? [];
      if (freqEl) freqEl.textContent = cap(freq);
      if (ladder) ladder.innerHTML = tiers
        .map((t, i) => `<li class="cleanup-tier"><span class="cleanup-tier-n">${i + 1}</span>${t}</li>`)
        .join('');
    }

    // Re-evaluate gates as selections change.
    root.addEventListener('change', (e) => {
      const t = e.target as HTMLElement;
      if (t?.matches?.('[data-source-radio]')) { onSourceChange(t as HTMLInputElement); return; }
      if (t?.matches?.('[data-base-checkbox]')) { hideBasesResetNote(); render(); return; }
      if (t?.matches?.('[data-dest-file-radio], [data-dest-db-radio]')) render();
      if (t?.matches?.('[data-frequency]')) updateCleanup((t as HTMLInputElement).value);
    });

    // Edit mode: free tabs (jump anywhere) + Save changes.
    if (isEdit) {
      $$('input[name="wz-tab"]').forEach((r) => r.addEventListener('change', render));
      $('[data-save-edit]')?.addEventListener('click', () => {
        commit(false, $<HTMLButtonElement>('[data-save-edit]')!);
      });
    }

    // ── Toast ──
    let toastTimer = 0;
    const toast = (msg: string) => {
      const el = $('[data-toast]'); if (!el) return;
      el.textContent = msg; el.hidden = false;
      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => { el.hidden = true; }, 2600);
    };

    // ── Drawers ──
    const openDrawer = (name: string) => { const d = $(`.drawer-shell[data-drawer="${name}"]`); if (!d) return; d.hidden = false; requestAnimationFrame(() => d.classList.add('is-open')); };
    const closeDrawer = (d: HTMLElement) => { d.classList.remove('is-open'); window.setTimeout(() => { d.hidden = true; }, 220); };
    $$('[data-open-drawer]').forEach((b) => b.addEventListener('click', () => openDrawer(b.dataset.openDrawer!)));
    $$('[data-drawer-close]').forEach((b) => b.addEventListener('click', () => { const d = b.closest<HTMLElement>('.drawer-shell'); if (d) closeDrawer(d); }));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') $$<HTMLElement>('.drawer-shell.is-open').forEach(closeDrawer); });

    // ── Source create (simulated) ──
    function injectSourceOption(name: string, method: string) {
      const panel = $('.panel-source')!;
      const list = $<HTMLElement>('[data-picker-list]', panel)!;
      // the Space uses one source at a time → keep the options, just move the selection
      $$('[data-source-radio]', list).forEach((r) => ((r as HTMLInputElement).checked = false));
      const baseCount = $$('[data-base-checkbox]').length;
      const label = document.createElement('label');
      label.className = 'opt-opt';
      label.innerHTML = `<input type="radio" name="wz-source" value="src-new" checked class="radio radio-sm radio-primary" data-source-radio />
        <span class="opt-ic"><img src="/airtable.svg" alt="" width="18" height="18" /></span>
        <span class="min-w-0 flex-1"><span class="opt-name">${name} <span class="opt-chip is-ok">Connected</span></span>
        <span class="opt-sub">${method === 'pat' ? 'Personal access token' : 'OAuth'} · ${baseCount} bases</span></span>`;
      stamp(label);
      // insertBefore(node, firstChild) prepends; .prepend collides with the
      // Cloudflare HTMLRewriter Element.prepend signature under worker types.
      list.insertBefore(label, list.firstChild);
      panel.classList.remove('is-empty');
      // A newly-created source is a fresh base scope — clear any prior selection.
      const hadBases = $$('[data-base-checkbox]:checked').length;
      lastSourceId = 'src-new';
      if (hadBases) { $<HTMLButtonElement>('[data-bst-clear]')?.click(); showBasesResetNote(name); }
    }
    $('[data-src-create]')?.addEventListener('click', () => {
      const btn = $<HTMLButtonElement>('[data-src-create]')!;
      const nameInput = $<HTMLInputElement>('[data-src-name]');
      const method = $<HTMLInputElement>('[data-src-connect] input[name="wz-src-method"]:checked')?.value ?? 'oauth';
      if (isProd) {
        // Real Airtable OAuth: POST the connect form; the callback returns into
        // the wizard (first-time connects redirect to /integrations/configure?first=1).
        if (method !== 'oauth') { toast('API-key connect is coming soon — use OAuth.'); return; }
        setButtonLoading(btn, true);
        const f = document.createElement('form');
        f.method = 'POST';
        f.action = '/api/connections/airtable/start';
        const rt = document.createElement('input');
        rt.type = 'hidden';
        rt.name = 'returnTo';
        rt.value = '/integrations/configure?first=1';
        f.appendChild(rt);
        document.body.appendChild(f);
        f.submit();
        return;
      }
      const name = (nameInput?.value || '').trim() || 'Airtable';
      setButtonLoading(btn, true);
      setTimeout(() => {
        setButtonLoading(btn, false);
        injectSourceOption(name, method);
        const d = $<HTMLElement>('.drawer-shell[data-drawer="source"]'); if (d) closeDrawer(d);
        toast(method === 'oauth' ? 'Airtable connected.' : 'Source created.');
        render();
      }, 850);
    });

    // ── Destination create (simulated, type → configure) ──
    const destPick = $('[data-dest-pick]')!, destConfig = $('[data-dest-config]')!;
    const destCreateBtn = $<HTMLButtonElement>('[data-dest-create]')!;
    let pendingDest: { type: string; kind: string; label: string; managed: boolean } | null = null;

    $$('[data-dtype]').forEach((b) => b.addEventListener('click', () => {
      pendingDest = { type: b.dataset.dtype!, kind: b.dataset.kind!, label: b.dataset.label!, managed: b.dataset.managed === '1' };
      destPick.hidden = true; destConfig.hidden = false; destCreateBtn.hidden = false;
      $('[data-dest-drawer-title]')!.textContent = `Connect ${pendingDest.label}`;
      $('[data-dest-drawer-sub]')!.textContent = pendingDest.kind === 'database' ? 'Database destination' : 'File storage destination';
      ($<HTMLInputElement>('[data-dest-name]')!).value = '';
      ($<HTMLInputElement>('[data-dest-name]')!).placeholder = `${pendingDest.label} backup`;
      $('[data-dest-field-folder]')!.hidden = !(pendingDest.kind === 'file' && !pendingDest.managed);
      $('[data-dest-field-conn]')!.hidden = pendingDest.kind !== 'database';
      $('[data-dest-field-managed]')!.hidden = !pendingDest.managed;
    }));
    $('[data-dest-back]')?.addEventListener('click', () => { destPick.hidden = false; destConfig.hidden = true; destCreateBtn.hidden = true; pendingDest = null; });

    function injectDestOption(kind: string, name: string, label: string, detail: string) {
      const groupSel = kind === 'database' ? '[data-dest-db]' : '[data-dest-file]';
      const list = $<HTMLElement>(groupSel)!;
      const radioName = kind === 'database' ? 'wz-dest-db' : 'wz-dest-file';
      const dataAttr = kind === 'database' ? 'data-dest-db-radio' : 'data-dest-file-radio';
      // uncheck siblings
      $$(`input[name="${radioName}"]`, list).forEach((r) => ((r as HTMLInputElement).checked = false));
      const el = document.createElement('label');
      el.className = 'opt-opt';
      el.innerHTML = `<input type="radio" name="${radioName}" value="dest-new-${kind}" checked class="radio radio-sm radio-primary" ${dataAttr} />
        <span class="opt-ic ${kind === 'database' ? 'opt-ic-db' : ''}"><span class="iconify ${kind === 'database' ? 'lucide--database' : 'lucide--hard-drive'}"></span></span>
        <span class="min-w-0 flex-1"><span class="opt-name">${name} <span class="opt-chip is-ok">Connected</span></span>
        <span class="opt-sub">${label} · ${detail}</span></span>`;
      stamp(el);
      list.insertBefore(el, list.firstChild);
      $('.panel-dest')!.classList.remove('is-empty');
    }
    destCreateBtn.addEventListener('click', () => {
      if (!pendingDest) return;
      const name = ($<HTMLInputElement>('[data-dest-name]')?.value || '').trim() || `${pendingDest.label} backup`;
      const detail = pendingDest.kind === 'database'
        ? 'database ops_mirror'
        : (pendingDest.managed ? 'managed' : (($<HTMLInputElement>('[data-dest-folder-input]')?.value || '/Baseout').trim()));
      if (isProd) {
        // Managed storage needs no OAuth → real save so setup can finish; external
        // storage + database connect is a backend follow-up (gated "soon").
        if (!pendingDest.managed) { toast('Connecting external storage here is coming soon — managed storage works now.'); return; }
        setButtonLoading(destCreateBtn, true);
        // local_fs is managed too, but needs its storage_destinations row created
        // (connectLocalFs); R2 just sets storageType on the config.
        const saveManaged = pendingDest.type === 'local_fs'
          ? connectLocalFs()
          : saveBackupConfig({ spaceId: prodSpaceId!, storageType: 'r2_managed' });
        saveManaged.then((res) => {
          setButtonLoading(destCreateBtn, false);
          if (!res.ok) { toast('Could not save the destination. Please try again.'); return; }
          injectDestOption('file', name, pendingDest!.label, 'managed');
          const d = $<HTMLElement>('.drawer-shell[data-drawer="dest"]'); if (d) closeDrawer(d);
          destPick.hidden = false; destConfig.hidden = true; destCreateBtn.hidden = true; pendingDest = null;
          toast('Managed storage selected.');
          render();
        });
        return;
      }
      setButtonLoading(destCreateBtn, true);
      setTimeout(() => {
        setButtonLoading(destCreateBtn, false);
        injectDestOption(pendingDest!.kind, name, pendingDest!.label, detail);
        const d = $<HTMLElement>('.drawer-shell[data-drawer="dest"]'); if (d) closeDrawer(d);
        // reset drawer to type-pick for next time
        destPick.hidden = false; destConfig.hidden = true; destCreateBtn.hidden = true; pendingDest = null;
        toast('Destination added.');
        render();
      }, 850);
    });

    // ── Reconnect a broken object in place (no kick-out) ──
    let reconnectingRow: HTMLElement | null = null;
    $$('[data-reconnect]').forEach((b) => b.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      reconnectingRow = b.closest<HTMLElement>('.opt-opt');
      const isSecret = b.dataset.reconnectAuth === 'secret';
      const rowName = reconnectingRow?.querySelector('.opt-name')?.childNodes[0]?.textContent?.trim() || 'this connection';
      const titleEl = $('[data-reconnect-title]'); if (titleEl) titleEl.textContent = `Reconnect ${rowName}`;
      const nameEl = $('[data-reconnect-name]'); if (nameEl) nameEl.textContent = rowName;
      const oauth = $<HTMLElement>('[data-reconnect-oauth]'); if (oauth) oauth.hidden = isSecret;
      const secretField = $<HTMLElement>('[data-reconnect-secret-field]'); if (secretField) secretField.hidden = !isSecret;
      if (isSecret) { const lbl = $('[data-reconnect-secret-label]'); if (lbl) lbl.textContent = b.dataset.reconnectSecretLabel || 'Secret'; }
      openDrawer('reconnect');
    }));
    $('[data-reconnect-confirm]')?.addEventListener('click', () => {
      if (isProd) { toast('Reconnecting here is coming soon — reconnect from the Integrations page.'); return; }
      const btn = $<HTMLButtonElement>('[data-reconnect-confirm]')!;
      setButtonLoading(btn, true);
      setTimeout(() => {
        setButtonLoading(btn, false);
        if (reconnectingRow) {
          const chip = reconnectingRow.querySelector('.opt-chip');
          if (chip) { chip.className = 'opt-chip is-ok'; chip.textContent = 'Connected'; }
          reconnectingRow.querySelector('[data-reconnect]')?.remove();
        }
        const d = $<HTMLElement>('.drawer-shell[data-drawer="reconnect"]'); if (d) closeDrawer(d);
        reconnectingRow = null;
        toast('Reconnected.');
        render();
      }, 850);
    });

    // ── Source change resets the base selection (bases belong to a source) ──
    let lastSourceId = $<HTMLInputElement>('[data-source-radio]:checked')?.value ?? '';
    let pendingSourceId: string | null = null;
    const switchConfirm = $<HTMLElement>('[data-switch-confirm]');
    const sourceRadioByValue = (v: string) => $<HTMLInputElement>(`[data-source-radio][value="${(window.CSS && CSS.escape) ? CSS.escape(v) : v}"]`);
    const sourceNameByValue = (v: string) => nameOf(sourceRadioByValue(v));
    function showBasesResetNote(name: string) {
      const note = $<HTMLElement>('[data-bases-reset-note]'); if (!note) return;
      const n = $('[data-bases-reset-name]'); if (n) n.textContent = name;
      note.hidden = false;
    }
    function hideBasesResetNote() { const n = $<HTMLElement>('[data-bases-reset-note]'); if (n) n.hidden = true; }
    function showSwitchConfirm(name: string, count: number) {
      if (!switchConfirm) return;
      const nm = $('[data-switch-name]'); if (nm) nm.textContent = name;
      const ct = $('[data-switch-count]'); if (ct) ct.textContent = String(count);
      const pl = $('[data-switch-plural]'); if (pl) pl.textContent = count === 1 ? '' : 's';
      switchConfirm.hidden = false;
    }
    function hideSwitchConfirm() { if (switchConfirm) switchConfirm.hidden = true; pendingSourceId = null; }
    function onSourceChange(radio: HTMLInputElement) {
      const newId = radio.value;
      if (newId === lastSourceId) { render(); return; }
      const n = basesChosen();
      if (n === 0) { lastSourceId = newId; hideSwitchConfirm(); render(); return; }
      // bases are at stake — confirm before clearing (keeps the new radio checked meanwhile)
      pendingSourceId = newId;
      showSwitchConfirm(sourceNameByValue(newId), n);
      render();
    }
    $('[data-switch-cancel]')?.addEventListener('click', () => {
      const prev = sourceRadioByValue(lastSourceId); if (prev) prev.checked = true;
      hideSwitchConfirm(); render();
    });
    $('[data-switch-go]')?.addEventListener('click', () => {
      if (pendingSourceId) lastSourceId = pendingSourceId;
      $<HTMLButtonElement>('[data-bst-clear]')?.click(); // resets the table count / cap / view too
      showBasesResetNote(sourceNameByValue(lastSourceId));
      hideSwitchConfirm();
      toast('Base selection cleared.');
      render();
    });

    render();
  }
  wizard();
  document.addEventListener('astro:after-swap', wizard);
</script>
