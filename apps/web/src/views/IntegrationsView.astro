---
/**
 * Integrations overview — redesigned screen (web-integrations-redesign).
 * Research-backed pattern (see openspec/changes/web-integrations-redesign/research-*):
 *   - Overview = a provider CARD that flips empty → connected (status + quick actions).
 *   - Heavy configuration lives on /integrations/configure, not inline, not a modal.
 *   - Edit = that same route opened with sections in place — no wizard re-run.
 *
 * The pre-redesign screen is preserved as IntegrationsView.legacy.astro.
 * API-key connect is rendered disabled until its backend route exists
 * (follow-up in web-integrations-redesign tasks).
 */
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import Alert from '../components/ui/Alert.astro';
import { formatNextScheduledAt } from '../lib/backups/format';
import type { BackupRunSummary } from '../lib/backup-runs/types';
import type { IntegrationsState } from '../stores/connections';

interface Props {
  state: IntegrationsState;
  statusCode: 'connected' | 'error' | 'saved' | 'running' | null;
  errorReason: string | null;
  initialRuns?: BackupRunSummary[];
}
const { state, statusCode, errorReason, initialRuns = [] } = Astro.props;

const airtable = state.connections.find((c) => c.platformSlug === 'airtable') ?? null;
const bases = state.bases;
const spaceId = Astro.locals.account?.space?.id ?? '';
const includedCount = bases.filter((b) => b.isIncluded).length;

const errorLabels: Record<string, string> = {
  access_denied: 'You declined to give Baseout access to your Airtable.',
  missing_code: 'Airtable did not return an authorization code.',
  token_exchange_failed: 'Airtable rejected the connection. Please try again.',
  api_call_failed: 'We connected to Airtable but could not list your bases.',
};
const errorMessage = errorReason ? (errorLabels[errorReason] ?? 'Connection failed. Please try again.') : null;

const statusBadgeMap: Record<string, { variant: 'success' | 'warning' | 'error' | 'default'; label: string; dot: boolean }> = {
  active: { variant: 'success', label: 'Connected', dot: true },
  refreshing: { variant: 'warning', label: 'Refreshing', dot: true },
  pending_reauth: { variant: 'warning', label: 'Reconnect required', dot: false },
  invalid: { variant: 'error', label: 'Disconnected', dot: false },
};
const statusBadge = airtable
  ? (statusBadgeMap[airtable.status] ?? { variant: 'default' as const, label: airtable.status, dot: false })
  : { variant: 'default' as const, label: 'Not connected', dot: false };
const needsReconnect = airtable !== null && (airtable.status === 'pending_reauth' || airtable.status === 'invalid');
const isProtected = airtable !== null && !needsReconnect && includedCount > 0;

const storageLabel: Record<string, string> = {
  r2_managed: 'Baseout managed storage', google_drive: 'Google Drive',
  dropbox: 'Dropbox', box: 'Box', onedrive: 'OneDrive', local_fs: 'Local disk (dev)',
};
const lastSucceeded = initialRuns.find((r) => (r as { status?: string }).status === 'succeeded') ?? null;
const configSummary = `${includedCount} base${includedCount === 1 ? '' : 's'} · ${state.policy.frequency} · ${storageLabel[state.policy.storageType] ?? state.policy.storageType}`;
---

<div class="mx-auto max-w-4xl space-y-6">
  <header>
    <h1 class="text-2xl font-bold tracking-tight">Integrations</h1>
    <p class="text-sm text-base-content/60 mt-1">Connect a platform to back it up on a schedule, to storage you control.</p>
  </header>

  {!airtable ? (
    /* ── EMPTY STATE — full-width provider card, two columns: connect · read-only scope ── */
    <Card variant="outlined" class="p-0 overflow-hidden">
      <div class="grid md:grid-cols-2">
        {/* Left — connect */}
        <div class="p-6 sm:p-8">
          {/* A failed connect attempt is not a separate state — it returns here as inline retry feedback. */}
          {statusCode === 'error' && errorMessage && (
            <Alert variant="error" class="mb-5">{errorMessage} Please try connecting again.</Alert>
          )}
          <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <img src="/airtable.svg" alt="" width="40" height="40" class="provider-logo" />
              <div>
                <p class="font-semibold leading-tight">Airtable</p>
                <p class="text-xs text-base-content/55 leading-tight mt-0.5">Backup integration</p>
              </div>
            </div>
            <Badge variant="default">Not connected</Badge>
          </div>

          <h2 class="text-lg font-semibold mt-6">Connect to start backing up</h2>
          <p class="text-sm text-base-content/60 mt-1.5">
            Back up the bases you choose on a schedule you set, to storage you control.
          </p>

          {/* Labelled group: method choice + action read as one unit */}
          <div class="connect-methods mt-6">
            <span class="field-label">Connection method</span>
            {/* API-key connect ships with its backend route (web-integrations-redesign
                follow-up); until then the tab renders disabled so it's an honest
                affordance, not a dead control. */}
            <div role="tablist" aria-label="Connection method" class="flex gap-1 p-1 rounded-lg bg-base-200/70 mt-2">
              <label class="method-tab flex-1"><input type="radio" name="connect-method" value="oauth" class="sr-only" checked /><span>OAuth</span></label>
              <label class="method-tab method-tab-disabled flex-1" title="API-key connect is coming soon"><input type="radio" name="connect-method" value="apikey" class="sr-only" disabled /><span>API key — soon</span></label>
            </div>

            <div data-method="oauth" class="mt-4">
              <form method="POST" action="/api/connections/airtable/start" data-airtable-connect data-astro-reload>
                <input type="hidden" name="returnTo" value="/integrations" />
                <Button type="submit" variant="primary" class="w-full" data-connect-submit>Connect Airtable</Button>
              </form>
              <p class="text-xs text-base-content/50 mt-2.5 text-center">You approve access on Airtable, then return here.</p>
            </div>
          </div>
        </div>

        {/* Right — read-only scope (trust-first; justifies the card's width) */}
        <div class="scope-col p-6 sm:p-8 border-t md:border-t-0 md:border-l border-base-300/50">
          <span class="field-label">What Baseout reads</span>
          <ul class="scope-list mt-3">
            <li><span class="iconify lucide--check" aria-hidden="true"></span><span><b>Bases</b><span class="scope-note">the workspaces you choose</span></span></li>
            <li><span class="iconify lucide--check" aria-hidden="true"></span><span><b>Tables &amp; fields</b><span class="scope-note">structure and every value</span></span></li>
            <li><span class="iconify lucide--check" aria-hidden="true"></span><span><b>Views</b><span class="scope-note">filters, sorts, grouping</span></span></li>
            <li><span class="iconify lucide--check" aria-hidden="true"></span><span><b>Attachments</b><span class="scope-note">files attached to records</span></span></li>
          </ul>
          <p class="guarantee">
            <span class="iconify lucide--shield-check" aria-hidden="true"></span>
            Read-only. Baseout never writes to your Airtable, and you can disconnect any time.
          </p>
        </div>
      </div>
    </Card>
  ) : (
    /* ──  CONNECTED OVERVIEW — neutral card; status via badge only. Runs/history live on Backups.  ── */
    <div class="space-y-5">
      {/* Workspace rediscovery — dismissible banner per unread event (spec: New bases discovered). */}
      {state.unreadEvents.length > 0 && spaceId && (
        <div class="space-y-2.5" data-space-events-banner data-space-id={spaceId}>
          {state.unreadEvents.map((event) => (
            <div class="discovery-banner" role="status" data-space-event-id={event.id}>
              <span class="iconify lucide--sparkles" aria-hidden="true"></span>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-sm">{event.payload.discovered.length === 1 ? '1 new base discovered in your Airtable workspace.' : `${event.payload.discovered.length} new bases discovered in your Airtable workspace.`}</p>
                <p class="text-xs text-base-content/60 mt-0.5">
                  {event.payload.autoAdded.length > 0 && <span>{event.payload.autoAdded.length} auto-added to your backup. </span>}
                  {event.payload.blockedByTier.length > 0 && <span>{event.payload.blockedByTier.length} not included — you're at your plan limit{event.payload.tierCap !== null ? ` of ${event.payload.tierCap}` : ''}. <a href="/settings" class="link link-hover font-medium">Upgrade</a> to include them.</span>}
                  {event.payload.autoAdded.length === 0 && event.payload.blockedByTier.length === 0 && <span>Add them in <a href="/integrations/configure" class="link link-hover font-medium">Configure</a>, or turn on auto-add for future bases.</span>}
                </p>
              </div>
              <button type="button" class="discovery-dismiss" data-space-event-dismiss data-space-event-id={event.id} aria-label="Dismiss"><span class="iconify lucide--x" aria-hidden="true"></span></button>
            </div>
          ))}
        </div>
      )}
      {/* Success / saved feedback is not a state: a brief confirmation above the status card. */}
      {statusCode === 'connected' && (
        <p class="connect-success" role="status">
          <span class="iconify lucide--circle-check" aria-hidden="true"></span>
          <span>Airtable connected{bases.length > 0 ? `. We found ${bases.length} base${bases.length === 1 ? '' : 's'}.` : '.'}</span>
        </p>
      )}
      {statusCode === 'saved' && (
        <p class="connect-success" role="status">
          <span class="iconify lucide--circle-check" aria-hidden="true"></span>
          <span>Backup configuration saved.</span>
        </p>
      )}
      {statusCode === 'running' && (
        <p class="connect-success" role="status">
          <span class="iconify lucide--circle-check" aria-hidden="true"></span>
          <span>Airtable connected. Your first backup is running — track progress on the Backups page.</span>
        </p>
      )}
      <Card variant="outlined">
        <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="flex items-start gap-3 min-w-0">
          <img src="/airtable.svg" alt="" width="40" height="40" class="provider-logo shrink-0 mt-0.5" />
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <p class="font-semibold leading-tight">Airtable</p>
              <Badge variant={statusBadge.variant} dot={statusBadge.dot}>{statusBadge.label}</Badge>
            </div>
            {isProtected ? (
              <>
                <p class="text-sm text-base-content/70 mt-1.5">Protected · {configSummary}</p>
                <p class="text-xs text-base-content/55 mt-1">Next backup <span class="font-medium text-base-content/75">{formatNextScheduledAt(state.policy.nextScheduledAt)}</span>{lastSucceeded && <span> · Last run <span class="text-success font-medium">✓ succeeded</span></span>}</p>
              </>
            ) : needsReconnect ? (
              <p class="text-sm text-base-content/70 mt-1.5">{airtable.status === 'invalid'
                ? 'Disconnected. Backups will not run until you reconnect Airtable.'
                : 'Backups are paused. Reconnect Airtable to resume protecting this Space.'}</p>
            ) : (
              <p class="text-sm text-base-content/70 mt-1.5">Connected. Finish setup to choose bases, a schedule and a destination.</p>
            )}
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          {needsReconnect ? (
            <form method="POST" action="/api/connections/airtable/start" data-airtable-connect data-astro-reload><input type="hidden" name="returnTo" value="/integrations" /><Button type="submit" variant="primary" data-connect-submit>Reconnect</Button></form>
          ) : (
            /* The first backup runs at the end of setup; on-demand runs live on the Backups page. */
            <Button href="/integrations/configure" variant={isProtected ? 'outline' : 'primary'}>{isProtected ? 'Configure' : 'Finish setup'}</Button>
          )}
        </div>
      </div>
      </Card>
    </div>
  )}
</div>

<style>
  .provider-logo { border-radius: 9px; flex: none; }
  /* Workspace-rediscovery banner */
  .discovery-banner {
    display: flex; align-items: flex-start; gap: .625rem;
    background: var(--color-base-100); border: 1px solid var(--color-base-300);
    border-radius: .625rem; padding: .75rem .875rem;
  }
  .discovery-banner > .iconify { color: var(--color-primary, oklch(.6 .15 250)); font-size: 1.05rem; flex: none; margin-top: .1rem; }
  .discovery-dismiss { flex: none; line-height: 0; padding: 3px; border-radius: 6px; color: oklch(from var(--color-base-content, #000) l c h / .5); }
  .discovery-dismiss:hover { color: var(--color-base-content); background: oklch(from var(--color-base-content, #000) l c h / .08); }
  .discovery-dismiss .iconify { font-size: .95rem; }
  /* Inline connect feedback (not separate states) */
  .connect-error, .connect-success {
    display: flex; align-items: flex-start; gap: .5rem; margin-bottom: 1.25rem;
    padding: .625rem .75rem; border-radius: .5rem; font-size: .8125rem; line-height: 1.45;
  }
  .connect-error {
    color: var(--color-error, oklch(.6 .2 25));
    background: oklch(from var(--color-error, oklch(.6 .2 25)) l c h / .08);
    border: 1px solid oklch(from var(--color-error, oklch(.6 .2 25)) l c h / .25);
  }
  .connect-success {
    margin-bottom: 0;
    color: var(--color-success, oklch(.6 .16 150));
    background: oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .08);
    border: 1px solid oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .22);
  }
  .connect-error .iconify, .connect-success .iconify { font-size: 1rem; flex: none; margin-top: .05rem; }
  .field-label {
    display: block; font-size: .6875rem; font-weight: 600; letter-spacing: .04em;
    text-transform: uppercase; color: oklch(from var(--color-base-content, #000) l c h / .5);
  }
  /* Right column — read-only access scope (trust-first) */
  .scope-col { background: oklch(from var(--color-base-200, #f2f2f2) l c h / .35); }
  .scope-list { display: flex; flex-direction: column; gap: .625rem; }
  .scope-list li { display: flex; align-items: flex-start; gap: .5rem; font-size: .875rem; }
  .scope-list .iconify { color: var(--color-success, oklch(.68 .16 150)); font-size: .95rem; margin-top: .1rem; flex: none; }
  .scope-list b { font-weight: 600; }
  .scope-list .scope-note { display: block; font-size: .75rem; color: oklch(from var(--color-base-content, #000) l c h / .55); margin-top: .05rem; }
  .guarantee {
    display: flex; align-items: flex-start; gap: .45rem; margin-top: 1.125rem; padding-top: .875rem;
    border-top: 1px solid oklch(from var(--color-base-content, #000) l c h / .08);
    font-size: .8125rem; line-height: 1.5; color: oklch(from var(--color-base-content, #000) l c h / .8);
  }
  .guarantee .iconify { color: var(--color-success, oklch(.68 .16 150)); font-size: 1rem; flex: none; margin-top: .05rem; }
  /* Connect-method tabs — :has()-driven, no JS. */
  .connect-methods .method-tab { cursor: pointer; }
  .connect-methods .method-tab-disabled { cursor: not-allowed; }
  .connect-methods .method-tab-disabled > span { opacity: .45; }
  .connect-methods .method-tab > span {
    display: block; padding: .35rem .9rem; border-radius: .5rem; text-align: center;
    font-size: .8125rem; font-weight: 600; color: oklch(from var(--color-base-content, #000) l c h / .6);
    transition: background .15s ease, color .15s ease;
  }
  .connect-methods .method-tab:has(input:checked) > span {
    background: var(--color-base-100, #fff); color: var(--color-base-content, #000);
    box-shadow: 0 1px 2px rgb(0 0 0 / .08);
  }
  .connect-methods:has(input[value="oauth"]:checked) [data-method="apikey"] { display: none; }
  .connect-methods:has(input[value="apikey"]:checked) [data-method="oauth"] { display: none; }
</style>

<script>
  import { setButtonLoading } from '../lib/ui';
  function wire() {
    document.querySelectorAll<HTMLFormElement>('form[data-airtable-connect]').forEach((form) => {
      const submit = form.querySelector<HTMLButtonElement>('[data-connect-submit]');
      form.addEventListener('submit', () => { if (submit) setButtonLoading(submit, true); });
    });
    // Dismiss a workspace-rediscovery banner card (fire-and-forget; harness stub returns ok).
    const spaceId = document.querySelector<HTMLElement>('[data-space-events-banner]')?.dataset.spaceId;
    document.querySelectorAll<HTMLButtonElement>('[data-space-event-dismiss]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.spaceEventId;
        const card = btn.closest<HTMLElement>('[data-space-event-id]');
        if (spaceId && id) fetch(`/api/spaces/${spaceId}/space-events/${id}/dismiss`, { method: 'POST' }).catch(() => {});
        card?.remove();
      });
    });
  }
  wire();
  document.addEventListener('astro:after-swap', wire);
</script>
