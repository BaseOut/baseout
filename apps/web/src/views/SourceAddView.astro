---
/**
 * SourceAddView — add an account-level Airtable source (skeleton).
 *
 * V1 is Airtable-only, so the type is fixed; the choice is the auth method —
 * OAuth or a personal access token — plus a name. "Test & create" makes the
 * source; until it's authorized it lands as "Needs connection". Mirrors the
 * existing Airtable connect (OAuth + token), at the account level.
 */
import Button from '../components/ui/Button.astro';
import { SOURCE_PLATFORMS } from '../lib/provider-catalog';

interface Props {
  /** 'oauth' | 'pat' preselected method */
  method?: string | null;
}
const { method = null } = Astro.props;
const sel = method === 'pat' ? 'pat' : 'oauth';

const comingSoonPlatforms = SOURCE_PLATFORMS.filter((p) => p.availability === 'coming_soon');
---

<div class="mx-auto max-w-2xl space-y-6">
  <a href="/sources" class="back-link"><span class="iconify lucide--arrow-left" aria-hidden="true"></span> Sources</a>

  <header class="flex items-center gap-3">
    <img src="/airtable.svg" alt="" width="36" height="36" class="src-logo" />
    <div>
      <h1 class="text-xl font-bold tracking-tight leading-tight">Add an Airtable source</h1>
      <p class="text-sm text-base-content/55 leading-tight mt-0.5">Connect once, reuse across Spaces. Read-only access.</p>
    </div>
  </header>

  <div class="add-form">
    <label class="add-field">
      <span class="add-label">Name</span>
      <input type="text" name="name" placeholder="e.g. Ops Airtable" class="input input-bordered w-full" />
      <span class="add-hint">A label to tell this connection apart from your other Airtable accounts.</span>
    </label>

    <div class="connect" data-connect>
      <span class="add-label">Connection method</span>
      <div role="tablist" aria-label="Connection method" class="method-tabs">
        <label class="method-tab"><input type="radio" name="src-method" value="oauth" class="sr-only" checked={sel === 'oauth'} /><span>OAuth</span></label>
        <label class="method-tab"><input type="radio" name="src-method" value="pat" class="sr-only" checked={sel === 'pat'} /><span>Personal access token</span></label>
      </div>

      <div data-method="oauth" class="mt-4">
        <button type="button" class="btn btn-outline w-full justify-start gap-2" data-fake-auth>
          <span class="iconify lucide--plug" aria-hidden="true"></span> Authorize Airtable
        </button>
        <p class="add-hint mt-2">You approve read-only access on Airtable, then return here.</p>
        <div class="add-actions">
          <a href="/sources/new" class="btn btn-ghost btn-sm">Cancel</a>
          <Button href="/sources?status=added&method=oauth" variant="primary">Test &amp; create</Button>
        </div>
      </div>

      <div data-method="pat" class="mt-4">
        <label class="block">
          <span class="add-label">Personal access token</span>
          <input type="password" name="token" placeholder="pat••••••••••••••" autocomplete="off" class="input input-bordered w-full font-mono text-sm mt-1.5" />
        </label>
        <p class="add-hint mt-2">Create a read-only token in Airtable's builder hub with the <code>data.records:read</code> and <code>schema.bases:read</code> scopes.</p>
        <div class="add-actions">
          <a href="/sources/new" class="btn btn-ghost btn-sm">Cancel</a>
          <Button href="/sources?status=added&method=pat" variant="primary">Test &amp; create</Button>
        </div>
      </div>
    </div>
  </div>

  {comingSoonPlatforms.length > 0 && (
    <section class="soon-section">
      <h2 class="soon-title">More sources coming soon</h2>
      <div class="soon-grid">
        {comingSoonPlatforms.map((p) => (
          <div class="soon-card" aria-disabled="true" title="Coming soon">
            <span class="min-w-0"><span class="soon-name">{p.label}</span><span class="soon-note">{p.note}</span></span>
            <span class="soon-badge">Coming soon</span>
          </div>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .back-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .8125rem; font-weight: 500; color: oklch(from var(--color-base-content) l c h / .6); text-decoration: none; }
  .back-link:hover { color: var(--color-base-content); }
  .back-link .iconify { font-size: .95rem; }
  .src-logo { border-radius: 9px; flex: none; }

  .add-form { display: flex; flex-direction: column; gap: 1.3rem; max-width: 30rem; }
  .add-field { display: flex; flex-direction: column; gap: .35rem; }
  .add-label { font-size: .8125rem; font-weight: 600; }
  .add-hint { font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .5); }
  .add-hint code { font-size: 11px; padding: .05rem .25rem; border-radius: 4px; background: oklch(from var(--color-base-content) l c h / .07); }
  .add-actions { display: flex; align-items: center; justify-content: flex-end; gap: .5rem; margin-top: 1rem; }

  .method-tabs { display: flex; gap: .25rem; padding: .25rem; border-radius: .6rem; background: oklch(from var(--color-base-200) l c h / .7); margin-top: .5rem; }
  .method-tab { flex: 1; cursor: pointer; }
  .method-tab > span { display: block; padding: .4rem .9rem; border-radius: .45rem; text-align: center; font-size: .8125rem; font-weight: 600; color: oklch(from var(--color-base-content) l c h / .6); transition: background .15s ease, color .15s ease; }
  .method-tab:has(input:checked) > span { background: var(--color-base-100); color: var(--color-base-content); box-shadow: 0 1px 2px rgb(0 0 0 / .08); }

  /* :has()-driven method panels, no JS */
  .connect:has(input[value="oauth"]:checked) [data-method="pat"] { display: none; }
  .connect:has(input[value="pat"]:checked) [data-method="oauth"] { display: none; }

  .soon-section { max-width: 30rem; }
  .soon-title { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .5); margin-bottom: .7rem; }
  .soon-grid { display: flex; flex-direction: column; gap: .5rem; }
  .soon-card { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: .55rem .75rem; border: 1px solid var(--color-base-300); border-radius: .55rem; background: var(--color-base-100); opacity: .7; cursor: not-allowed; }
  .soon-name { display: block; font-size: .8125rem; font-weight: 600; }
  .soon-note { display: block; font-size: .7rem; color: oklch(from var(--color-base-content) l c h / .5); margin-top: .05rem; }
  .soon-badge { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .03em; color: oklch(from var(--color-base-content) l c h / .6); background: oklch(from var(--color-base-content) l c h / .08); padding: .1rem .4rem; border-radius: 999px; white-space: nowrap; flex: none; }
</style>
