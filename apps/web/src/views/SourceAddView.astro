---
/**
 * SourceAddView — add an account-level Airtable source (skeleton).
 */
import BackLink from '../components/ui/BackLink.astro';
import Button from '../components/ui/Button.astro';
import TextInput from '../components/ui/TextInput.astro';
import Badge from '../components/ui/Badge.astro';
import { SOURCE_PLATFORMS } from '../lib/provider-catalog';

interface Props {
  method?: string | null;
}
const { method = null } = Astro.props;
const sel = method === 'pat' ? 'pat' : 'oauth';

const comingSoonPlatforms = SOURCE_PLATFORMS.filter((p) => p.availability === 'coming_soon');
---

<div class="mx-auto max-w-2xl space-y-6">
  <BackLink href="/sources" label="Sources" />

  <header class="flex items-center gap-3">
    <img src="/airtable.svg" alt="" width="36" height="36" class="rounded-lg" />
    <div>
      <h1 class="text-xl font-bold tracking-tight leading-tight">Add an Airtable source</h1>
      <p class="text-sm text-base-content/55 leading-tight mt-0.5">Connect once, reuse across Spaces. Read-only access.</p>
    </div>
  </header>

  <div class="flex max-w-lg flex-col gap-5">
    <TextInput label="Name" type="text" name="name" placeholder="e.g. Ops Airtable" hint="A label to tell this connection apart from your other Airtable accounts." />

    <div data-connect>
      <span class="text-sm font-semibold">Connection method</span>
      <div role="tablist" aria-label="Connection method" class="method-tabs mt-2 flex gap-1 rounded-lg bg-base-200/70 p-1">
        <label class="method-tab flex-1 cursor-pointer"><input type="radio" name="src-method" value="oauth" class="sr-only" checked={sel === 'oauth'} /><span>OAuth</span></label>
        <label class="method-tab flex-1 cursor-pointer"><input type="radio" name="src-method" value="pat" class="sr-only" checked={sel === 'pat'} /><span>Personal access token</span></label>
      </div>

      <div data-method="oauth" class="mt-4">
        <form method="POST" action="/api/connections/airtable/start" data-airtable-connect data-astro-reload>
          <input type="hidden" name="returnTo" value="/sources" />
          <p class="text-xs text-base-content/50">You approve read-only access on Airtable, then return here.</p>
          <div class="mt-4 flex items-center justify-end gap-2">
            <Button href="/sources" variant="ghost" size="sm">Cancel</Button>
            <Button type="submit" variant="primary" data-airtable-connect-btn><span class="iconify lucide--plug" aria-hidden="true"></span> Authorize Airtable</Button>
          </div>
        </form>
      </div>

      <div data-method="pat" class="mt-4">
        <TextInput label="Personal access token" type="password" name="token" placeholder="pat••••••••••••••" autocomplete="off" class="font-mono text-sm" hint="Create a read-only token in Airtable's builder hub with the data.records:read and schema.bases:read scopes." disabled />
        <p class="mt-2 text-xs text-warning">Personal access tokens aren't supported yet — use OAuth above for now.</p>
        <div class="mt-4 flex items-center justify-end gap-2">
          <Button href="/sources" variant="ghost" size="sm">Cancel</Button>
          <Button type="button" variant="primary" disabled>Coming soon</Button>
        </div>
      </div>
    </div>
  </div>

  {comingSoonPlatforms.length > 0 && (
    <section class="max-w-lg">
      <h2 class="mb-3 text-xs font-bold uppercase tracking-wider text-base-content/50">More sources coming soon</h2>
      <div class="flex flex-col gap-2">
        {comingSoonPlatforms.map((p) => (
          <div class="flex cursor-not-allowed items-center justify-between gap-2 rounded-lg border border-base-300 bg-base-100 px-3 py-2.5 opacity-70" aria-disabled="true" title="Coming soon">
            <span class="min-w-0"><span class="block text-sm font-semibold">{p.label}</span><span class="block text-xs text-base-content/50">{p.note}</span></span>
            <Badge variant="default">Coming soon</Badge>
          </div>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .method-tab > span { display: block; padding: .4rem .9rem; border-radius: .45rem; text-align: center; font-size: .8125rem; font-weight: 600; color: oklch(from var(--color-base-content) l c h / .6); transition: background .15s ease, color .15s ease; }
  .method-tab:has(input:checked) > span { background: var(--color-base-100); color: var(--color-base-content); box-shadow: 0 1px 2px rgb(0 0 0 / .08); }
  [data-connect]:has(input[value="oauth"]:checked) [data-method="pat"] { display: none; }
  [data-connect]:has(input[value="pat"]:checked) [data-method="oauth"] { display: none; }
</style>

<script>
  import { setButtonLoading } from '../lib/ui';

  // Spinner while the browser redirects to Airtable's consent screen.
  document.addEventListener('submit', (event) => {
    const form = (event.target as HTMLElement | null)?.closest('[data-airtable-connect]');
    if (!(form instanceof HTMLFormElement)) return;
    const btn = form.querySelector('[data-airtable-connect-btn]');
    if (btn instanceof HTMLButtonElement) setButtonLoading(btn, true);
  });
</script>
