---
/**
 * SourceDetailView — a source's own management/health page (skeleton).
 *
 * Identity (which Airtable account, auth type, bases available) + status/reconnect
 * INDEPENDENT of any Space (one reconnect heals every Space using it) + the
 * founder's key ask: a TABLE of the Spaces using this source with per-Space meta
 * (# bases, destinations, schedule, last backup). Remove is guarded while in use.
 *
 * Status is "last-known-good" (no Airtable revoke webhook) — tied to "last checked".
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import type { SourceSummary } from '../stores/sources';

interface Props {
  source: SourceSummary;
  /** harness: simulate a successful (re)connect */
  reconnected?: boolean;
}
const { source: s, reconnected = false } = Astro.props;

const status = reconnected ? 'connected' : s.status;
const needsReconnect = status === 'reconnect';
const needsConnect = status === 'needs_connection';
const inUseCount = s.inUseBy.length;
const authLabel = s.auth === 'pat' ? 'Personal access token' : 'OAuth';
const statusBadge =
  status === 'connected' ? { variant: 'success' as const, label: 'Connected', dot: true }
  : status === 'needs_connection' ? { variant: 'warning' as const, label: 'Needs connection', dot: false }
  : { variant: 'warning' as const, label: 'Reconnect required', dot: false };

const usageStatus: Record<string, { cls: string; label: string }> = {
  ok: { cls: 'is-ok', label: 'OK' },
  failed: { cls: 'is-err', label: 'Failed' },
  paused: { cls: 'is-warn', label: 'Paused' },
};
---

<div class="mx-auto max-w-4xl space-y-6">
  <a href="/sources" class="back-link"><span class="iconify lucide--arrow-left" aria-hidden="true"></span> Sources</a>

  {reconnected && (
    <p class="src-ok" role="status"><span class="iconify lucide--circle-check" aria-hidden="true"></span><span>{s.status === 'needs_connection' ? 'Connected. This source is ready to use in your Spaces.' : 'Reconnected. Backups from this source will resume on their next scheduled run.'}</span></p>
  )}

  <header class="flex flex-wrap items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="flex items-center gap-2">
        <img src="/airtable.svg" alt="" width="26" height="26" class="src-logo" />
        <h1 class="text-2xl font-bold tracking-tight leading-tight">{s.name}</h1>
        <Badge variant={statusBadge.variant} dot={statusBadge.dot}>{statusBadge.label}</Badge>
      </div>
      <p class="text-sm text-base-content/60 mt-1.5">Airtable · {authLabel} · {s.account} · added {s.addedAt}</p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      {needsReconnect && (<Button href={`/sources/detail?id=${s.id}&reconnected=1`} variant="primary">Reconnect</Button>)}
      {needsConnect && (<Button href={`/sources/detail?id=${s.id}&new=1&method=${s.auth}&reconnected=1`} variant="primary">Connect</Button>)}
      <Button href={`/sources/new?method=${s.auth}`} variant="outline">Edit</Button>
    </div>
  </header>

  {(needsReconnect || needsConnect) && (
    <div class="src-alert" role="status">
      <span class="iconify lucide--triangle-alert" aria-hidden="true"></span>
      <span>{needsConnect
        ? 'This source isn’t connected yet. Authorize Airtable, then use it in a Space.'
        : `Airtable access was lost. Backups from this source are paused for ${inUseCount === 1 ? 'the Space' : `all ${inUseCount} Spaces`} below. Reconnect once to restore ${inUseCount === 1 ? 'it' : 'them all'}.`}</span>
    </div>
  )}

  <section class="src-card">
    <div class="flex items-center justify-between gap-3">
      <h2 class="src-card-title">Connection</h2>
      <button type="button" class="btn btn-ghost btn-xs gap-1" data-refresh-bases><span class="iconify lucide--refresh-cw"></span> Refresh bases</button>
    </div>
    <dl class="src-dl">
      <div><dt>Authorized as</dt><dd>{s.account} <span class="text-base-content/45">({authLabel})</span></dd></div>
      <div><dt>Bases available</dt><dd>{s.basesAvailable} bases this connection can see</dd></div>
      <div><dt>Status checked</dt><dd>{s.lastChecked ?? '—'} <span class="text-base-content/45">· status reflects the last successful check, not live</span></dd></div>
    </dl>
    <p class="src-refresh-note hidden" data-refresh-note role="status"></p>
  </section>

  <section class="src-card src-card--flush">
    <div class="src-card-pad flex items-center gap-2">
      <h2 class="src-card-title">In use by <span class="src-count">{inUseCount} Space{inUseCount === 1 ? '' : 's'}</span></h2>
    </div>
    {inUseCount > 0 ? (
      <div class="use-table" role="table">
        <div class="use-head" role="row">
          <span>Space</span><span class="use-r">Bases</span><span>Destination</span><span>Schedule</span><span>Last backup</span><span>Status</span>
        </div>
        {s.inUseBy.map((u) => (
          <a href={`/integrations?space=${u.spaceId}`} class="use-row" role="row">
            <span class="use-space">{u.spaceName}</span>
            <span class="use-r use-num">{u.baseCount}</span>
            <span class="use-dest">{u.destinations}</span>
            <span class="use-sched">{u.schedule}</span>
            <span class="use-last">{u.lastBackup ?? '—'}</span>
            <span><span class={`use-chip ${usageStatus[u.status].cls}`}>{usageStatus[u.status].label}</span></span>
          </a>
        ))}
      </div>
    ) : (
      <p class="src-card-pad text-sm text-base-content/55">No Spaces use this source yet.</p>
    )}
    <p class="src-card-pad src-note">{needsReconnect ? 'Reconnecting restores backups for every Space listed here.' : 'Each Space includes its own set of bases from this source.'}</p>
  </section>

  <section class="src-card src-danger">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div class="min-w-0">
        <h2 class="src-card-title">Remove source</h2>
        <p class="text-sm text-base-content/60 mt-1">
          {inUseCount > 0
            ? `Remove is disabled while ${inUseCount} Space${inUseCount === 1 ? '' : 's'} use${inUseCount === 1 ? 's' : ''} this source. Move ${inUseCount === 1 ? 'it' : 'them'} to another source first.`
            : 'No Spaces use this source, so it can be removed.'}
        </p>
      </div>
      <button type="button" class="btn btn-sm btn-outline btn-error shrink-0" disabled={inUseCount > 0}>Remove</button>
    </div>
  </section>
</div>

<style>
  .back-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .8125rem; font-weight: 500; color: oklch(from var(--color-base-content) l c h / .6); text-decoration: none; }
  .back-link:hover { color: var(--color-base-content); }
  .back-link .iconify { font-size: .95rem; }
  .src-logo { border-radius: 7px; flex: none; }

  .src-ok, .src-alert { display: flex; align-items: flex-start; gap: .5rem; padding: .625rem .8rem; border-radius: .55rem; font-size: .8125rem; line-height: 1.45; }
  .src-ok { color: var(--color-success, oklch(.6 .16 150)); background: oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .08); border: 1px solid oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .22); }
  .src-alert { color: oklch(from var(--color-base-content) l c h / .9); background: oklch(from var(--color-warning) l c h / .12); border: 1px solid oklch(from var(--color-warning) l c h / .3); }
  .src-ok .iconify { font-size: 1rem; flex: none; margin-top: .05rem; }
  .src-alert .iconify { font-size: 1rem; flex: none; margin-top: .05rem; color: var(--color-warning); }

  .src-card { border: 1px solid var(--color-base-300); border-radius: .7rem; padding: 1.1rem 1.2rem; background: var(--color-base-100); }
  .src-card--flush { padding: 0; overflow: hidden; }
  .src-card-pad { padding: 1.1rem 1.2rem; }
  .src-card--flush .src-card-pad { padding-bottom: .75rem; }
  .src-card--flush .src-note { padding-top: .75rem; }
  .src-card-title { font-size: .9rem; font-weight: 700; display: flex; align-items: center; gap: .5rem; }
  .src-count { font-size: .72rem; font-weight: 600; color: oklch(from var(--color-base-content) l c h / .55); background: oklch(from var(--color-base-200) l c h / .7); padding: .05rem .4rem; border-radius: 999px; }
  .src-dl { margin-top: .8rem; display: flex; flex-direction: column; gap: .55rem; }
  .src-dl > div { display: grid; grid-template-columns: 9rem 1fr; gap: 1rem; font-size: .8125rem; }
  .src-dl dt { color: oklch(from var(--color-base-content) l c h / .5); }
  .src-dl dd { color: oklch(from var(--color-base-content) l c h / .85); }
  .src-refresh-note { font-size: .78rem; color: oklch(from var(--color-base-content) l c h / .6); margin-top: .7rem; }
  .src-note { font-size: .75rem; color: oklch(from var(--color-base-content) l c h / .55); }

  /* Spaces-using-this-source table */
  .use-table { border-top: 1px solid var(--color-base-300); }
  .use-head, .use-row { display: grid; grid-template-columns: minmax(0, 1.3fr) 4rem minmax(0, 1.3fr) 6rem 6rem 5rem; align-items: center; gap: .6rem; padding: .6rem 1.2rem; }
  .use-head { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .5); background: oklch(from var(--color-base-200) l c h / .4); }
  .use-row { border-top: 1px solid oklch(from var(--color-base-300) l c h / .5); text-decoration: none; color: inherit; transition: background .12s ease; }
  .use-row:hover { background: oklch(from var(--color-base-200) l c h / .5); }
  .use-r { text-align: right; }
  .use-space { font-weight: 600; font-size: .8125rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .use-num { font-size: .8rem; font-variant-numeric: tabular-nums; color: oklch(from var(--color-base-content) l c h / .75); }
  .use-dest, .use-sched, .use-last { font-size: .78rem; color: oklch(from var(--color-base-content) l c h / .65); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .use-chip { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .02em; padding: .08rem .4rem; border-radius: 999px; white-space: nowrap; }
  .use-chip.is-ok { color: var(--color-success); background: oklch(from var(--color-success) l c h / .14); }
  .use-chip.is-err { color: var(--color-error); background: oklch(from var(--color-error) l c h / .14); }
  .use-chip.is-warn { color: var(--color-warning); background: oklch(from var(--color-warning) l c h / .16); }

  .src-danger { border-color: oklch(from var(--color-error) l c h / .3); }
</style>

<script>
  function wireSourceDetail() {
    const btn = document.querySelector<HTMLButtonElement>('[data-refresh-bases]');
    const note = document.querySelector<HTMLElement>('[data-refresh-note]');
    if (btn && btn.dataset.wired !== '1') {
      btn.dataset.wired = '1';
      btn.addEventListener('click', () => {
        // Harness: new-base detection is poll-only (no Airtable event); fake a re-check.
        if (note) { note.textContent = 'Re-checked Airtable — no new bases since the last check.'; note.classList.remove('hidden'); }
      });
    }
  }
  wireSourceDetail();
  document.addEventListener('astro:after-swap', wireSourceDetail);
</script>
