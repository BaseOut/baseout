---
/**
 * SourcesView — account-level Sources registry (skeleton).
 *
 * The account's Airtable connections, in account Settings next to Destinations.
 * Dense status table; "in use by N Spaces" is the reuse indicator (the count
 * links into the source's per-Space usage table). A broken source surfaces
 * loudly. Mirrors DestinationsView.
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import type { SourceSummary } from '../stores/sources';
import { SOURCE_PLATFORMS } from '../lib/provider-catalog';

interface Props {
  sources: SourceSummary[];
  notice?: string | null;
  /** Production: where "Add source" goes (default = harness /sources/new). */
  addHref?: string;
  /** Production: override the per-row detail link (per-source detail isn't built
   *  yet); when set, every row links here. Default = harness detail route. */
  rowHref?: string | null;
}
const { sources, notice = null, addHref = '/sources/new', rowHref = null } = Astro.props;

const comingSoonPlatforms = SOURCE_PLATFORMS.filter((p) => p.availability === 'coming_soon');

const statusMeta: Record<string, { variant: 'success' | 'warning' | 'error' | 'default'; label: string; dot: boolean }> = {
  connected: { variant: 'success', label: 'Connected', dot: true },
  reconnect: { variant: 'warning', label: 'Reconnect', dot: false },
  needs_connection: { variant: 'warning', label: 'Needs connection', dot: false },
};
const needsAttention = sources.filter((s) => s.status === 'reconnect');
const affectedSpaces = [...new Set(needsAttention.flatMap((s) => s.inUseBy.map((u) => u.spaceName)))];
const detailHref = (s: SourceSummary) =>
  s.status === 'needs_connection'
    ? `/sources/detail?id=${s.id}&new=1&method=${s.auth}`
    : `/sources/detail?id=${s.id}`;
---

<div class="mx-auto max-w-5xl space-y-6">
  <header class="flex items-end justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Sources</h1>
      <p class="text-sm text-base-content/60 mt-1">The Airtable connections on your account. Connect once, reuse across Spaces.</p>
    </div>
    <Button href={addHref} variant="primary">Add source</Button>
  </header>

  {notice && (
    <p class="src-ok" role="status"><span class="iconify lucide--circle-check" aria-hidden="true"></span><span>{notice}</span></p>
  )}

  {needsAttention.length > 0 && (
    <div class="src-alert" role="status">
      <span class="iconify lucide--triangle-alert" aria-hidden="true"></span>
      <span>
        <b>{needsAttention.length} source{needsAttention.length === 1 ? '' : 's'} need{needsAttention.length === 1 ? 's' : ''} reconnecting.</b>
        {' '}Backups from {needsAttention.length === 1 ? 'it are' : 'them are'} paused, affecting {affectedSpaces.length} Space{affectedSpaces.length === 1 ? '' : 's'}.
      </span>
    </div>
  )}

  {sources.length === 0 ? (
    <div class="src-empty">
      <img src="/airtable.svg" alt="" width="28" height="28" class="src-empty-ic" />
      <div class="min-w-0 flex-1">
        <p class="text-sm font-medium">No sources yet</p>
        <p class="text-xs text-base-content/55 mt-0.5">Connect Airtable once, then reuse it across every Space.</p>
      </div>
      <Button href={addHref} variant="primary" class="shrink-0">Add source</Button>
    </div>
  ) : (
    <div class="src-table" role="table">
      <div class="src-head" role="row">
        <span>Name</span><span>Authorized as</span><span>Status</span><span>In use by</span><span class="src-r">Bases</span>
      </div>
      {sources.map((s) => (
        <a href={rowHref ?? detailHref(s)} class="src-row" role="row">
          <span class="src-name">{s.name}<span class="src-sub">{s.auth === 'pat' ? 'Personal access token' : 'OAuth'}</span></span>
          <span class="src-acct"><img src="/airtable.svg" alt="" width="15" height="15" />{s.account}</span>
          <span><Badge variant={statusMeta[s.status].variant} dot={statusMeta[s.status].dot}>{statusMeta[s.status].label}</Badge></span>
          <span class="src-inuse">{s.inUseBy.length} Space{s.inUseBy.length === 1 ? '' : 's'}</span>
          <span class="src-bases src-r">{s.basesAvailable}</span>
        </a>
      ))}
    </div>
  )}

  {comingSoonPlatforms.length > 0 && (
    <section class="src-avail">
      <h2 class="src-avail-title">More sources coming soon</h2>
      <div class="src-avail-grid">
        {comingSoonPlatforms.map((p) => (
          <div class="src-prov">
            <span class="src-prov-name">{p.label}<span class="src-prov-note">{p.note}</span></span>
            <Badge variant="default">Coming soon</Badge>
          </div>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .src-ok, .src-alert { display: flex; align-items: flex-start; gap: .5rem; padding: .625rem .8rem; border-radius: .55rem; font-size: .8125rem; line-height: 1.45; }
  .src-ok { color: var(--color-success, oklch(.6 .16 150)); background: oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .08); border: 1px solid oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .22); }
  .src-alert { color: oklch(from var(--color-base-content) l c h / .9); background: oklch(from var(--color-warning) l c h / .12); border: 1px solid oklch(from var(--color-warning) l c h / .3); }
  .src-ok .iconify, .src-alert .iconify { font-size: 1rem; flex: none; margin-top: .05rem; }
  .src-alert .iconify { color: var(--color-warning); }

  .src-empty { display: flex; align-items: center; gap: .9rem; padding: 1.1rem; border: 1px dashed var(--color-base-300); border-radius: .7rem; background: oklch(from var(--color-base-200) l c h / .3); }
  .src-empty-ic { border-radius: 7px; flex: none; opacity: .8; }

  .src-table { border: 1px solid var(--color-base-300); border-radius: .7rem; overflow: hidden; background: var(--color-base-100); }
  .src-head, .src-row { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(0, 1.2fr) 9.5rem 7rem 5rem; align-items: center; gap: .75rem; padding: .7rem .9rem; }
  .src-head { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .5); background: oklch(from var(--color-base-200) l c h / .5); border-bottom: 1px solid var(--color-base-300); }
  .src-row { border-bottom: 1px solid oklch(from var(--color-base-300) l c h / .5); text-decoration: none; color: inherit; transition: background .12s ease; }
  .src-row:last-child { border-bottom: 0; }
  .src-row:hover { background: oklch(from var(--color-base-200) l c h / .5); }
  .src-r { text-align: right; }
  .src-name { display: flex; flex-direction: column; gap: .1rem; font-weight: 600; font-size: .875rem; min-width: 0; }
  .src-sub { font-weight: 400; font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .5); }
  .src-acct { display: inline-flex; align-items: center; gap: .4rem; font-size: .8125rem; color: oklch(from var(--color-base-content) l c h / .75); min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .src-acct img { border-radius: 3px; flex: none; }
  .src-inuse { font-size: .8125rem; color: oklch(from var(--color-base-content) l c h / .7); }
  .src-bases { font-size: .82rem; color: oklch(from var(--color-base-content) l c h / .7); font-variant-numeric: tabular-nums; }
  .src-row :global(.badge) { white-space: nowrap; }

  .src-avail { margin-top: 1.5rem; }
  .src-avail-title { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: oklch(from var(--color-base-content) l c h / .5); margin-bottom: .7rem; }
  .src-avail-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr)); gap: .5rem; }
  .src-prov { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: .55rem .75rem; border: 1px solid var(--color-base-300); border-radius: .55rem; background: var(--color-base-100); opacity: .7; }
  .src-prov-name { display: flex; flex-direction: column; gap: .1rem; font-size: .8125rem; font-weight: 600; min-width: 0; }
  .src-prov-note { font-weight: 400; font-size: .7rem; color: oklch(from var(--color-base-content) l c h / .5); }
  .src-prov :global(.badge) { white-space: nowrap; flex: none; }
</style>
