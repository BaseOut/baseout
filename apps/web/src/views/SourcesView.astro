---
/**
 * SourcesView — account-level Sources registry (skeleton).
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Alert from '../components/ui/Alert.astro';
import EmptyState from '../components/ui/EmptyState.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import type { SourceSummary } from '../stores/sources';
import { SOURCE_PLATFORMS } from '../lib/provider-catalog';

interface Props {
  sources: SourceSummary[];
  notice?: string | null;
  addHref?: string;
  rowHref?: string | null;
}
const { sources, notice = null, addHref = '/sources/new', rowHref = null } = Astro.props;

const comingSoonPlatforms = SOURCE_PLATFORMS.filter((p) => p.availability === 'coming_soon');

const statusMeta: Record<string, { variant: 'success' | 'warning' | 'error' | 'default'; label: string; dot: boolean }> = {
  connected: { variant: 'success', label: 'Connected', dot: true },
  reconnect: { variant: 'warning', label: 'Reconnect', dot: false },
  needs_connection: { variant: 'warning', label: 'Needs connection', dot: false },
};
const needsAttention = sources.filter((s) => s.status === 'reconnect');
const affectedSpaces = [...new Set(needsAttention.flatMap((s) => s.inUseBy.map((u) => u.spaceName)))];
const detailHref = (s: SourceSummary) =>
  s.status === 'needs_connection'
    ? `/sources/detail?id=${s.id}&new=1&method=${s.auth}`
    : `/sources/detail?id=${s.id}`;

const registryColumns = 'minmax(0,1.4fr) minmax(0,1.2fr) 9.5rem 7rem 5rem';
---

<div class="mx-auto max-w-5xl space-y-6">
  <PageHeader title="Sources" description="The Airtable connections on your account. Connect once, reuse across Spaces.">
    <Button slot="actions" href={addHref} variant="primary">Add source</Button>
  </PageHeader>

  {notice && (
    <Alert variant="success">{notice}</Alert>
  )}

  {needsAttention.length > 0 && (
    <Alert variant="warning" title={`${needsAttention.length} source${needsAttention.length === 1 ? '' : 's'} need${needsAttention.length === 1 ? 's' : ''} reconnecting.`}>
      Backups from {needsAttention.length === 1 ? 'it are' : 'them are'} paused, affecting {affectedSpaces.length} Space{affectedSpaces.length === 1 ? '' : 's'}.
    </Alert>
  )}

  {sources.length === 0 ? (
    <EmptyState
      icon="lucide--database"
      title="No sources yet"
      description="Connect Airtable once, then reuse it across every Space."
      actionHref={addHref}
      actionLabel="Add source"
    />
  ) : (
    <div class="overflow-hidden rounded-box border border-base-300 bg-base-100" role="table">
      <div class="grid items-center gap-3 border-b border-base-300 bg-base-200/50 px-4 py-3 text-xs font-bold uppercase tracking-wider text-base-content/55" style={`grid-template-columns: ${registryColumns};`} role="row">
        <span>Name</span><span>Authorized as</span><span>Status</span><span>In use by</span><span class="text-right">Bases</span>
      </div>
      {sources.map((s) => (
        <a href={rowHref ?? detailHref(s)} class="grid items-center gap-3 border-b border-base-300/50 px-4 py-3 text-sm text-base-content no-underline transition-colors last:border-b-0 hover:bg-base-200/50" style={`grid-template-columns: ${registryColumns};`} role="row">
          <span class="min-w-0 font-semibold">{s.name}<span class="block text-xs font-normal text-base-content/50">{s.auth === 'pat' ? 'Personal access token' : 'OAuth'}</span></span>
          <span class="inline-flex min-w-0 items-center gap-1.5 overflow-hidden text-ellipsis whitespace-nowrap text-base-content/75"><img src="/airtable.svg" alt="" width="15" height="15" class="rounded-sm" />{s.account}</span>
          <span><Badge variant={statusMeta[s.status].variant} dot={statusMeta[s.status].dot}>{statusMeta[s.status].label}</Badge></span>
          <span class="text-base-content/70">{s.inUseBy.length} Space{s.inUseBy.length === 1 ? '' : 's'}</span>
          <span class="text-right font-mono tabular-nums text-base-content/70">{s.basesAvailable}</span>
        </a>
      ))}
    </div>
  )}

  {comingSoonPlatforms.length > 0 && (
    <section class="mt-6">
      <h2 class="mb-3 text-xs font-bold uppercase tracking-wider text-base-content/50">More sources coming soon</h2>
      <div class="grid gap-2 sm:grid-cols-[repeat(auto-fill,minmax(15rem,1fr))]">
        {comingSoonPlatforms.map((p) => (
          <div class="flex items-center justify-between gap-2 rounded-lg border border-base-300 bg-base-100 px-3 py-2.5 opacity-70">
            <span class="min-w-0 text-sm font-semibold">{p.label}<span class="block text-xs font-normal text-base-content/50">{p.note}</span></span>
            <Badge variant="default">Coming soon</Badge>
          </div>
        ))}
      </div>
    </section>
  )}
</div>
