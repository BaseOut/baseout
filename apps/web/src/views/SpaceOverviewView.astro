---
/**
 * SpaceOverviewView — a Space's backup overview (the "Connection" in Airbyte terms).
 *
 * Replaces the old per-Space "connect Airtable" provider card. Connecting now lives
 * in account Sources; this page shows what THIS Space's backup is: it pulls from one
 * account Source, backs up selected bases, on a schedule, to account Destination(s),
 * with its own per-Space folder. Source/Destination are referenced (managed in their
 * own account pages); editing the config opens the Configure route.
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Alert from '../components/ui/Alert.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import SpacePipelineHero from '../components/patterns/SpacePipelineHero.astro';
import BackupPipeline from '../components/patterns/BackupPipeline.astro';
import DefinitionList from '../components/patterns/DefinitionList.astro';
import SectionPanel from '../components/ui/SectionPanel.astro';
import { formatNextScheduledAt } from '../lib/backups/format';
import type { IntegrationsState } from '../stores/connections';
import type { SourceSummary } from '../stores/sources';
import type { DestinationSummary } from '../stores/destinations';

interface Props {
  state: IntegrationsState;
  /** the account Source this Space pulls from */
  source?: SourceSummary | null;
  /** the account Destination(s) this Space writes to */
  destinations?: DestinationSummary[];
  statusCode?: 'saved' | 'running' | null;
  /**
   * Production (apps/web) overrides — all default-off so the design harness is
   * byte-identical. The account-level Source/Destination detail pages don't
   * exist yet, so production links the pipeline nodes at the /sources and
   * /destinations registries instead of /…/detail. lastRunLabel feeds the real
   * last-run string (harness uses a fixed placeholder).
   */
  linkToRegistry?: boolean;
  lastRunLabel?: string | null;
}
const {
  state,
  source = null,
  destinations = [],
  statusCode = null,
  linkToRegistry = false,
  lastRunLabel = null,
} = Astro.props;

const spaceName = Astro.locals.account?.space?.name ?? 'this Space';
const bases = state.bases;
const includedCount = bases.filter((b) => b.isIncluded).length;
const fileDest = destinations.find((d) => d.kind === 'file') ?? null;
const dbDest = destinations.find((d) => d.kind === 'database') ?? null;

const isConfigured = !!source && includedCount > 0 && !!fileDest;
const sourceBroken = source?.status === 'reconnect';
const brokenDest = destinations.find((d) => d.status === 'reconnect') ?? null;
const running = statusCode === 'running';
const pipeOk = !sourceBroken && !brokenDest; // connectors show a green "connected" check when healthy

// Detail pages aren't built; production points the nodes at the registries.
const sourceHref = linkToRegistry ? '/sources' : `/sources/detail?id=${source?.id ?? ''}`;
const destHref = linkToRegistry ? '/destinations' : `/destinations/detail?id=${fileDest?.id ?? ''}`;
const reconnectHref = linkToRegistry
  ? (sourceBroken ? '/sources' : '/destinations')
  : (sourceBroken ? `/sources/detail?id=${source?.id ?? ''}` : `/destinations/detail?id=${brokenDest?.id ?? ''}`);

const status =
  !isConfigured ? { variant: 'default' as const, label: 'Not set up', dot: false }
  : sourceBroken || brokenDest ? { variant: 'warning' as const, label: 'Backups paused', dot: false }
  : running ? { variant: 'warning' as const, label: 'Backup running', dot: true }
  : { variant: 'success' as const, label: 'Protected', dot: true };

const includedNames = bases.filter((b) => b.isIncluded).slice(0, 3).map((b) => b.name);
const folder = fileDest ? `/Baseout/${spaceName}` : '';
const pipeline = isConfigured ? {
  source: {
    label: source!.name,
    detail: `${source!.account}${sourceBroken ? ' · reconnect' : ''}`,
    status: sourceBroken ? 'Reconnect' : 'Connected',
    tone: sourceBroken ? 'warning' as const : 'success' as const,
    href: sourceHref,
  },
  bases: {
    label: `${includedCount} base${includedCount === 1 ? '' : 's'}`,
    detail: `${includedNames.join(', ')}${includedCount > 3 ? ` +${includedCount - 3}` : ''}`,
    status: 'Active',
    tone: pipeOk ? 'primary' as const : 'warning' as const,
    href: '/integrations/configure/bases',
  },
  destination: {
    label: fileDest!.name,
    detail: `${folder}${dbDest ? ` · + ${dbDest.name}` : ''}`,
    status: brokenDest ? 'Reconnect' : 'Connected',
    tone: brokenDest ? 'warning' as const : 'success' as const,
    href: destHref,
  },
} : null;
const scheduleItems = [
  { term: 'Schedule', description: state.policy.frequency },
  { term: 'Next backup', description: formatNextScheduledAt(state.policy.nextScheduledAt) },
  { term: 'Last run', description: running ? 'Running now' : lastRunLabel ?? 'succeeded 2h ago' },
];
---

<div class="mx-auto max-w-3xl space-y-6">
  <PageHeader title={spaceName} description={isConfigured ? 'This Space backs up Airtable to storage you control, on a schedule.' : 'Set up what this Space backs up, and where.'}>
    <Badge slot="meta" variant={status.variant} dot={status.dot}>{status.label}</Badge>
    {isConfigured && <Button slot="actions" href="/integrations/configure" variant="secondary" size="sm">Configure</Button>}
    {isConfigured && <Button slot="actions" href="/integrations?status=running" variant="primary" size="sm">Run backup now</Button>}
  </PageHeader>

  {statusCode === 'saved' && (
    <Alert variant="success">Backup configuration saved.</Alert>
  )}
  {running && (
    <Alert variant="success">Backup running — track progress on the Backups page.</Alert>
  )}

  {(sourceBroken || brokenDest) && (
    <Alert variant="warning" actionHref={reconnectHref} actionLabel="Reconnect">
      Backups are paused. {sourceBroken
        ? <span>Source <b>{source!.name}</b> lost Airtable access.</span>
        : <span>Destination <b>{brokenDest!.name}</b> lost access.</span>}
    </Alert>
  )}

  {isConfigured ? (
    <>
      {pipeline && <BackupPipeline source={pipeline.source} bases={pipeline.bases} destination={pipeline.destination} />}

      {/* Schedule + run status */}
      <SectionPanel title="Schedule & run status">
        <DefinitionList items={scheduleItems} />
      </SectionPanel>

      <p class="text-xs text-base-content/50">Source and destinations are managed on their own account pages; this Space just references them with its own bases, folder, and schedule.</p>
    </>
  ) : (
    /* Not set up — the product model, drawn (Source → this Space → Destinations) */
    <SpacePipelineHero spaceName={spaceName} />
  )}
</div>
