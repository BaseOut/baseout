---
/**
 * SpaceOverviewView — a Space's backup overview (the "Connection" in Airbyte terms).
 *
 * Replaces the old per-Space "connect Airtable" provider card. Connecting now lives
 * in account Sources; this page shows what THIS Space's backup is: it pulls from one
 * account Source, backs up selected bases, on a schedule, to account Destination(s),
 * with its own per-Space folder. Source/Destination are referenced (managed in their
 * own account pages); editing the config opens the Configure route.
 */
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import RunBackupButton from '../components/backups/RunBackupButton.astro';
import SpacePipelineHero from '../components/integrations/SpacePipelineHero.astro';
import { formatNextScheduledAt } from '../lib/backups/format';
import type { IntegrationsState } from '../stores/connections';
import type { SourceSummary } from '../stores/sources';
import type { DestinationSummary } from '../stores/destinations';

interface Props {
  state: IntegrationsState;
  /** the account Source this Space pulls from */
  source?: SourceSummary | null;
  /** the account Destination(s) this Space writes to */
  destinations?: DestinationSummary[];
  statusCode?: 'saved' | 'running' | null;
  /**
   * Production (apps/web) overrides — all default-off so the design harness is
   * byte-identical. The account-level Source/Destination detail pages don't
   * exist yet, so production links the pipeline nodes at the /sources and
   * /destinations registries instead of /…/detail. lastRunLabel feeds the real
   * last-run string (harness uses a fixed placeholder). runSpaceId, when set,
   * swaps the harness "Run backup now" link for the real RunBackupButton.
   */
  linkToRegistry?: boolean;
  lastRunLabel?: string | null;
  runSpaceId?: string | null;
  connectionStatus?: string | null;
}
const {
  state,
  source = null,
  destinations = [],
  statusCode = null,
  linkToRegistry = false,
  lastRunLabel = null,
  runSpaceId = null,
  connectionStatus = null,
} = Astro.props;

const spaceName = Astro.locals.account?.space?.name ?? 'this Space';
const bases = state.bases;
const includedCount = bases.filter((b) => b.isIncluded).length;
const fileDest = destinations.find((d) => d.kind === 'file') ?? null;
const dbDest = destinations.find((d) => d.kind === 'database') ?? null;

const isConfigured = !!source && includedCount > 0 && !!fileDest;
const sourceBroken = source?.status === 'reconnect';
const brokenDest = destinations.find((d) => d.status === 'reconnect') ?? null;
const running = statusCode === 'running';
const pipeOk = !sourceBroken && !brokenDest; // connectors show a green "connected" check when healthy

// Detail pages aren't built; production points the nodes at the registries.
const sourceHref = linkToRegistry ? '/sources' : `/sources/detail?id=${source?.id ?? ''}`;
const destHref = linkToRegistry ? '/destinations' : `/destinations/detail?id=${fileDest?.id ?? ''}`;
const reconnectHref = linkToRegistry
  ? (sourceBroken ? '/sources' : '/destinations')
  : (sourceBroken ? `/sources/detail?id=${source?.id ?? ''}` : `/destinations/detail?id=${brokenDest?.id ?? ''}`);

const status =
  !isConfigured ? { variant: 'default' as const, label: 'Not set up', dot: false }
  : sourceBroken || brokenDest ? { variant: 'warning' as const, label: 'Backups paused', dot: false }
  : running ? { variant: 'warning' as const, label: 'Backup running', dot: true }
  : { variant: 'success' as const, label: 'Protected', dot: true };

const includedNames = bases.filter((b) => b.isIncluded).slice(0, 3).map((b) => b.name);
const folder = fileDest ? `/Baseout/${spaceName}` : '';
---

<div class="mx-auto max-w-3xl space-y-6">
  <header class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <div class="flex items-center gap-2">
        <h1 class="text-2xl font-bold tracking-tight">{spaceName}</h1>
        <Badge variant={status.variant} dot={status.dot}>{status.label}</Badge>
      </div>
      <p class="text-sm text-base-content/60 mt-1">{isConfigured ? 'This Space backs up Airtable to storage you control, on a schedule.' : 'Set up what this Space backs up, and where.'}</p>
    </div>
    {isConfigured && (
      <div class="flex items-center gap-2 shrink-0">
        <Button href="/integrations/configure" variant="outline">Configure</Button>
        {runSpaceId
          ? <RunBackupButton spaceId={runSpaceId} connectionStatus={connectionStatus} />
          : <Button href="/integrations?status=running" variant="primary">Run backup now</Button>}
      </div>
    )}
  </header>

  {statusCode === 'saved' && (
    <p class="ov-ok" role="status"><span class="iconify lucide--circle-check" aria-hidden="true"></span><span>Backup configuration saved.</span></p>
  )}
  {running && (
    <p class="ov-ok" role="status"><span class="iconify lucide--circle-check" aria-hidden="true"></span><span>Backup running — track progress on the Backups page.</span></p>
  )}

  {(sourceBroken || brokenDest) && (
    <div class="ov-alert" role="status">
      <span class="iconify lucide--triangle-alert" aria-hidden="true"></span>
      <span class="flex-1 min-w-0">
        Backups are paused. {sourceBroken
          ? <span>Source <b>{source!.name}</b> lost Airtable access.</span>
          : <span>Destination <b>{brokenDest!.name}</b> lost access.</span>}
      </span>
      <a href={reconnectHref} class="btn btn-sm btn-primary shrink-0">Reconnect</a>
    </div>
  )}

  {isConfigured ? (
    <>
      {/* The backup pipeline: Source -> bases -> Destination(s) */}
      <section class="ov-pipe">
        <a href={sourceHref} class="ov-node">
          <span class="ov-node-cap">Source</span>
          <span class="ov-node-main"><img src="/airtable.svg" alt="" width="18" height="18" class="ov-mark" />{source!.name}</span>
          <span class="ov-node-sub">{source!.account}{sourceBroken && <span class="ov-warn"> · reconnect</span>}</span>
        </a>
        <span class={`ov-link ${pipeOk ? 'is-ok' : 'is-warn'}`} aria-hidden="true">
          <span class="ov-link-badge"><span class={`iconify ${pipeOk ? 'lucide--check' : 'lucide--triangle-alert'}`}></span></span>
        </span>
        <a href="/integrations/configure/bases" class="ov-node">
          <span class="ov-node-cap">Backs up</span>
          <span class="ov-node-main">{includedCount} base{includedCount === 1 ? '' : 's'}</span>
          <span class="ov-node-sub">{includedNames.join(', ')}{includedCount > 3 ? ` +${includedCount - 3}` : ''}</span>
        </a>
        <span class={`ov-link ${pipeOk ? 'is-ok' : 'is-warn'}`} aria-hidden="true">
          <span class="ov-link-badge"><span class={`iconify ${pipeOk ? 'lucide--check' : 'lucide--triangle-alert'}`}></span></span>
        </span>
        <a href={destHref} class="ov-node">
          <span class="ov-node-cap">Destination</span>
          <span class="ov-node-main"><span class="iconify lucide--hard-drive ov-mark-ic"></span>{fileDest!.name}</span>
          <span class="ov-node-sub">{folder}{dbDest && <span> · + {dbDest.name}</span>}</span>
        </a>
      </section>

      {/* Schedule + run status */}
      <section class="ov-card">
        <dl class="ov-dl">
          <div><dt>Schedule</dt><dd class="capitalize">{state.policy.frequency}</dd></div>
          <div><dt>Next backup</dt><dd>{formatNextScheduledAt(state.policy.nextScheduledAt)}</dd></div>
          <div><dt>Last run</dt><dd>{running ? <span class="text-warning">Running now</span> : lastRunLabel != null ? <span>{lastRunLabel}</span> : <span class="text-success">✓ succeeded 2h ago</span>}</dd></div>
        </dl>
      </section>

      <p class="text-xs text-base-content/50">Source and destinations are managed on their own account pages; this Space just references them with its own bases, folder, and schedule.</p>
    </>
  ) : (
    /* Not set up — the product model, drawn (Source → this Space → Destinations) */
    <SpacePipelineHero spaceName={spaceName} />
  )}
</div>

<style>
  .ov-ok, .ov-alert { display: flex; align-items: center; gap: .6rem; padding: .7rem .85rem; border-radius: .6rem; font-size: .8125rem; line-height: 1.45; }
  .ov-ok { color: var(--color-success, oklch(.6 .16 150)); background: oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .08); border: 1px solid oklch(from var(--color-success, oklch(.6 .16 150)) l c h / .22); }
  .ov-ok .iconify { font-size: 1rem; flex: none; }
  .ov-alert { color: oklch(from var(--color-base-content) l c h / .9); background: oklch(from var(--color-warning) l c h / .12); border: 1px solid oklch(from var(--color-warning) l c h / .3); }
  .ov-alert > .iconify { font-size: 1.05rem; flex: none; color: var(--color-warning); }
  .ov-warn { color: var(--color-warning); font-weight: 600; }

  /* Pipeline: Source -> bases -> destination */
  .ov-pipe { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; align-items: stretch; gap: .5rem; }
  .ov-node { display: flex; flex-direction: column; gap: .25rem; padding: .85rem .9rem; border: 1px solid var(--color-base-300); border-radius: .7rem; background: var(--color-base-100); text-decoration: none; color: inherit; transition: border-color .12s ease, background .12s ease; min-width: 0; }
  .ov-node:hover { border-color: oklch(from var(--color-primary) l c h / .45); background: oklch(from var(--color-base-200) l c h / .4); }
  .ov-node-cap { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: oklch(from var(--color-base-content) l c h / .45); }
  .ov-node-main { display: flex; align-items: center; gap: .4rem; font-size: .9rem; font-weight: 650; min-width: 0; }
  .ov-node-main .ov-mark { border-radius: 4px; flex: none; }
  .ov-mark-ic { font-size: 1rem; color: oklch(from var(--color-base-content) l c h / .6); flex: none; }
  .ov-node-sub { font-size: .72rem; color: oklch(from var(--color-base-content) l c h / .55); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  /* Connector: a status line + check badge ("connected & flowing") between the cards */
  .ov-link { align-self: center; position: relative; display: grid; place-items: center; width: 1.6rem; height: 1.5rem; flex: none; }
  .ov-link::before { content: ''; position: absolute; left: -.4rem; right: -.4rem; top: 50%; height: 2px; transform: translateY(-50%); border-radius: 2px; }
  .ov-link.is-ok::before { background: oklch(from var(--color-success) l c h / .5); }
  .ov-link.is-warn::before { background: oklch(from var(--color-warning) l c h / .55); }
  .ov-link-badge { position: relative; z-index: 1; width: 1.3rem; height: 1.3rem; border-radius: 999px; display: grid; place-items: center; color: #fff; box-shadow: 0 0 0 3px var(--color-base-100); }
  .ov-link.is-ok .ov-link-badge { background: var(--color-success); }
  .ov-link.is-warn .ov-link-badge { background: var(--color-warning); }
  .ov-link-badge .iconify { font-size: .82rem; }
  @media (max-width: 640px) {
    .ov-pipe { grid-template-columns: 1fr; justify-items: center; }
    .ov-link { width: 1.5rem; height: 1.6rem; }
    .ov-link::before { left: 50%; right: auto; top: -.4rem; bottom: -.4rem; width: 2px; height: auto; transform: translateX(-50%); }
  }

  .ov-card { border: 1px solid var(--color-base-300); border-radius: .7rem; padding: 1rem 1.1rem; background: var(--color-base-100); }
  .ov-dl { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .ov-dl dt { font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .03em; color: oklch(from var(--color-base-content) l c h / .5); }
  .ov-dl dd { font-size: .875rem; margin-top: .2rem; }

</style>
