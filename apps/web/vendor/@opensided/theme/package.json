{
    "name": "@opensided/theme",
    "description": "Openside design system — themes, styles, layouts, and React components built on Tailwind CSS + DaisyUI.",
    "version": "3.2.1",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Opensided/openside-ui.git",
        "directory": "theme"
    },
    "type": "module",
    "files": [
        "src/styles/",
        "src/components/",
        "src/contexts/",
        "src/hooks/",
        "src/pages/",
        "src/router/",
        "src/declaration.d.ts"
    ],
    "exports": {
        "./styles": "./src/styles/app.css",
        "./styles/*": "./src/styles/*",
        "./components/*": "./src/components/*",
        "./contexts/*": "./src/contexts/*",
        "./hooks/*": "./src/hooks/*",
        "./pages/*": "./src/pages/*",
        "./router": "./src/router/index.tsx",
        "./router/*": "./src/router/*"
    },
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "deploy": "astro build && wrangler deploy",
        "lint": "eslint .",
        "format": "prettier . --write",
        "prepublishOnly": "npm run lint"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "peerDependencies": {
        "daisyui": ">=5.0.0",
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0",
        "react-router": ">=7.0.0",
        "simplebar-react": ">=3.0.0",
        "tailwindcss": ">=4.0.0",
        "@tailwindcss/vite": ">=4.0.0"
    },
    "dependencies": {
        "tailwindcss-motion": "^1.1.1"
    },
    "devDependencies": {
        "@astrojs/cloudflare": "^12.5.0",
        "@astrojs/react": "^4.3.0",
        "@tanstack/react-table": "^8.21.3",
        "apexcharts": "^5.3.4",
        "astro": "^5.7.0",
        "choices.js": "^11.1.0",
        "daisyui": "^5.0.54",
        "filepond": "^4.32.8",
        "filepond-plugin-image-preview": "^4.6.12",
        "flatpickr": "^4.6.13",
        "react": "^19.1.1",
        "react-apexcharts": "^1.7.0",
        "react-dom": "^19.1.1",
        "react-filepond": "^7.1.3",
        "react-router": "^7.8.2",
        "simplebar-react": "^3.3.2",
        "quill": "^2.0.3",
        "sortablejs": "^1.15.6",
        "swiper": "^11.2.10",
        "tailwindcss": "4.1.12",
        "@tailwindcss/vite": "4.1.12",
        "zod": "^4.1.4",
        "@eslint/js": "^9.34.0",
        "@iconify-json/hugeicons": "^1.2.14",
        "@iconify-json/lucide": "^1.2.65",
        "@iconify-json/ri": "^1.2.5",
        "@iconify/tailwind4": "^1.0.6",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/node": "^24.3.0",
        "@types/react": "^19.1.12",
        "@types/react-dom": "^19.1.8",
        "@types/sortablejs": "^1.15.8",
        "eslint": "^9.34.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^16.3.0",
        "path": "^0.12.7",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.41.0"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com",
        "access": "restricted"
    }
}
