# Local-dev env for @baseout/workflows (Trigger.dev v3, Node runner).
# Copy to .env and fill in. .env is gitignored — never commit real values.
#
#   cp apps/workflows/.env.example apps/workflows/.env
#
# These are read via process.env. For DEPLOYED Trigger.dev environments they are
# NOT read from this file — set them in the Trigger.dev dashboard's env-vars UI
# per environment (Development / Staging / Production). This .env only feeds the
# local `trigger dev` runner. See the project memory "Trigger.dev env setup".

# === Engine callback ===
# URL of the @baseout/server Worker the task POSTs progress/completion to
# (/api/internal/runs/:runId/{progress,complete}).
#
# Two modes:
#
#   (a) Deployed engine (default). Deploy first
#       (`pnpm --filter @baseout/server deploy:dev`) and point here:
#         BACKUP_ENGINE_URL=https://baseout-server-dev.openside.workers.dev
#
#   (b) LOCAL_BACKUP_MODE — fully-local loop (see shared/internal/ops-setup.md).
#       The engine runs locally via `pnpm --filter @baseout/server dev` on :8787,
#       and this Node runner reaches it over plain loopback HTTP. Point here:
#         BACKUP_ENGINE_URL=http://localhost:8787
#       No deploy needed; web also runs with LOCAL_BACKUP_MODE=1 so its
#       BACKUP_ENGINE service binding resolves to the same local engine.
BACKUP_ENGINE_URL=

# Defense-in-depth token on every engine callback. MUST equal apps/server's
# INTERNAL_TOKEN (and apps/web's BACKUP_ENGINE_INTERNAL_TOKEN). In LOCAL_BACKUP_MODE
# this travels over loopback http://localhost:8787 in cleartext — use a throwaway
# local value, never the deployed token.
INTERNAL_TOKEN=

# === Managed R2 backup destination (required only for r2_managed; BYOS skips) ===
# S3-API credentials for the managed R2 bucket (aws4fetch writer on the Node
# runner). Leave blank if you only exercise BYOS destinations locally.
#
# Canonical per-env values + token-rotation procedure live in
# shared/internal/r2-setup.md. DO NOT put these in any apps/*/.dev.vars file —
# Cloudflare Workers never reach R2; only this Node runner does.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
