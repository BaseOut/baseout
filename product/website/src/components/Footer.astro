---
import Logo from './Logo.astro';
---

<footer class="relative bg-slate-900 border-t border-white/10">
  <!-- Background Effects -->
  <div class="absolute inset-0">
    <!-- Brand Color Gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
    
    <!-- Brand Color Orbs -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-0 left-20 w-64 h-64 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
      <div class="absolute bottom-0 right-20 w-80 h-80 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);"></div>
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 z-10">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- Brand Section -->
      <div class="lg:col-span-1">
        <div class="flex items-center space-x-3 mb-6">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center shadow-lg" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);">
            <span class="text-white font-bold text-lg" style="font-family: 'Outfit', sans-serif;">B</span>
          </div>
          <span class="text-2xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">BaseOut</span>
        </div>
        <p class="text-gray-300 mb-6 leading-relaxed" style="font-family: 'Inter', sans-serif;">
          Enterprise-grade data infrastructure for Airtable. Scale your operations while preserving team workflows.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="w-10 h-10 rounded-lg flex items-center justify-center transition-all duration-300 hover:scale-110" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border: 1px solid #4A7C7C30; color: #4A7C7C;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-lg flex items-center justify-center transition-all duration-300 hover:scale-110" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border: 1px solid #4A7C7C30; color: #4A7C7C;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-lg flex items-center justify-center transition-all duration-300 hover:scale-110" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border: 1px solid #4A7C7C30; color: #4A7C7C;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.404-5.939 1.404-5.939s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.096.118.112.22.083.339-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.746-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001 12.017.001z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Product Links -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6" style="font-family: 'Inter', sans-serif;">Product</h3>
        <ul class="space-y-4">
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Features</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Integrations</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">API Documentation</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Enterprise</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Security</a></li>
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6" style="font-family: 'Inter', sans-serif;">Company</h3>
        <ul class="space-y-4">
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">About</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Blog</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Careers</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Press</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Partners</a></li>
        </ul>
      </div>

      <!-- Support Links -->
      <div>
        <h3 class="text-lg font-bold text-white mb-6" style="font-family: 'Inter', sans-serif;">Support</h3>
        <ul class="space-y-4">
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Help Center</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Documentation</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Community</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Contact</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Status</a></li>
        </ul>
      </div>
    </div>

    <!-- Newsletter Signup -->
    <div class="border-t border-white/10 pt-8 mb-8">
      <div class="max-w-md mx-auto text-center lg:max-w-none lg:text-left lg:flex lg:items-center lg:justify-between">
        <div class="lg:flex-1">
          <h3 class="text-xl font-semibold text-white mb-2" style="font-family: 'Inter', sans-serif;">Stay Updated</h3>
          <p class="text-gray-400 mb-4 lg:mb-0" style="font-family: 'Inter', sans-serif;">Get the latest product updates and enterprise data insights delivered to your inbox.</p>
        </div>
        <div class="lg:ml-8 lg:flex-shrink-0">
          <div class="flex flex-col sm:flex-row gap-3 max-w-md">
            <input 
              type="email" 
              placeholder="Enter your email" 
              class="flex-1 px-4 py-3 rounded-lg bg-white/5 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:border-transparent backdrop-blur-sm"
              style="focus:ring-color: #4A7C7C; font-family: 'Inter', sans-serif;"
            />
            <button class="px-6 py-3 rounded-lg font-semibold text-white transition-all duration-300 hover:scale-105 shadow-lg" style="background: linear-gradient(135deg, #D17A3A, #D17A3A); font-family: 'Inter', sans-serif;">
              Subscribe
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col lg:flex-row lg:items-center lg:justify-between">
      <div class="flex flex-col sm:flex-row sm:items-center space-y-4 sm:space-y-0 sm:space-x-6">
        <p class="text-gray-400 text-sm" style="font-family: 'Inter', sans-serif;">
          © 2025 BaseOut. All rights reserved.
        </p>
        <div class="flex space-x-6">
          <a href="#" class="text-gray-400 hover:text-white text-sm transition-colors duration-300" style="font-family: 'Inter', sans-serif;">Privacy Policy</a>
          <a href="#" class="text-gray-400 hover:text-white text-sm transition-colors duration-300" style="font-family: 'Inter', sans-serif;">Terms of Service</a>
          <a href="#" class="text-gray-400 hover:text-white text-sm transition-colors duration-300" style="font-family: 'Inter', sans-serif;">Cookie Policy</a>
        </div>
      </div>
      <div class="mt-4 lg:mt-0">
        <div class="flex items-center space-x-2">
          <span class="w-2 h-2 rounded-full animate-pulse" style="background-color: #3D6B3D;"></span>
          <span class="text-gray-400 text-sm" style="font-family: 'Inter', sans-serif;">All systems operational</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Import Brand Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap');

  footer input:focus {
    ring-color: #4A7C7C;
  }
</style> 