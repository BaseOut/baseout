---
import Logo from './Logo.astro';

const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === '/' && currentPath === '/') return true;
  if (path !== '/' && currentPath.startsWith(path)) return true;
  return false;
};
---

<nav class="bg-white shadow-soft border-b border-gray-100 sticky top-0 z-50 backdrop-blur-sm bg-white/95">
  <div class="max-w-7xl mx-auto container-padding">
    <div class="flex justify-between items-center h-16 md:h-20">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center space-x-3 focus-visible-ring rounded-lg">
          <Logo class="h-8 w-8 md:h-10 md:w-10" />
          <span class="font-outfit font-bold text-xl md:text-2xl text-charcoal">BaseOut</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-8">
        <a 
          href="/features" 
          class={`nav-link ${isActive('/features') ? 'nav-link-active' : ''}`}
        >
          Features
        </a>
        <a 
          href="/platforms" 
          class={`nav-link ${isActive('/platforms') ? 'nav-link-active' : ''}`}
        >
          Platforms
        </a>
        <a 
          href="/pricing" 
          class={`nav-link ${isActive('/pricing') ? 'nav-link-active' : ''}`}
        >
          Pricing
        </a>
        <a 
          href="/blog" 
          class={`nav-link ${isActive('/blog') ? 'nav-link-active' : ''}`}
        >
          Blog
        </a>
        <a 
          href="/support" 
          class={`nav-link ${isActive('/support') ? 'nav-link-active' : ''}`}
        >
          Support
        </a>
        <a 
          href="/about" 
          class={`nav-link ${isActive('/about') ? 'nav-link-active' : ''}`}
        >
          About
        </a>
      </div>

      <!-- Desktop CTA Buttons -->
      <div class="hidden lg:flex items-center space-x-4">
        <a href="/login" class="btn-tertiary">
          Log In
        </a>
        <a href="/signup" class="btn-primary">
          Start Free Trial
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="lg:hidden">
        <button
          type="button"
          id="mobile-menu-button"
          class="inline-flex items-center justify-center p-2 rounded-lg text-slate hover:text-baseout-teal hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-baseout-teal transition-colors duration-200"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger icon -->
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Close icon (hidden by default) -->
          <svg class="hidden h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div class="lg:hidden hidden" id="mobile-menu">
    <div class="border-t border-gray-100 bg-white shadow-lg">
      <div class="container-padding py-6 space-y-4">
        <!-- Mobile Navigation Links -->
        <div class="space-y-4">
          <a 
            href="/features" 
            class={`block text-base font-medium ${isActive('/features') ? 'text-baseout-teal' : 'text-slate hover:text-baseout-teal'} transition-colors duration-200`}
          >
            Features
          </a>
          <a 
            href="/platforms" 
            class={`block text-base font-medium ${isActive('/platforms') ? 'text-baseout-teal' : 'text-slate hover:text-baseout-teal'} transition-colors duration-200`}
          >
            Platforms
          </a>
          <a 
            href="/pricing" 
            class={`block text-base font-medium ${isActive('/pricing') ? 'text-baseout-teal' : 'text-slate hover:text-baseout-teal'} transition-colors duration-200`}
          >
            Pricing
          </a>
          <a 
            href="/blog" 
            class={`block text-base font-medium ${isActive('/blog') ? 'text-baseout-teal' : 'text-slate hover:text-baseout-teal'} transition-colors duration-200`}
          >
            Blog
          </a>
          <a 
            href="/support" 
            class={`block text-base font-medium ${isActive('/support') ? 'text-baseout-teal' : 'text-slate hover:text-baseout-teal'} transition-colors duration-200`}
          >
            Support
          </a>
          <a 
            href="/about" 
            class={`block text-base font-medium ${isActive('/about') ? 'text-baseout-teal' : 'text-slate hover:text-baseout-teal'} transition-colors duration-200`}
          >
            About
          </a>
        </div>

        <!-- Mobile CTA Buttons -->
        <div class="pt-6 border-t border-gray-100 space-y-3">
          <a href="/login" class="block w-full text-center btn-secondary">
            Log In
          </a>
          <a href="/signup" class="block w-full text-center btn-primary">
            Start Free Trial
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = menuButton?.querySelector('svg:first-child');
    const closeIcon = menuButton?.querySelector('svg:last-child');

    if (menuButton && mobileMenu && hamburgerIcon && closeIcon) {
      menuButton.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.contains('hidden');
        
        if (isOpen) {
          // Close menu
          mobileMenu.classList.add('hidden');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          menuButton.setAttribute('aria-expanded', 'false');
        } else {
          // Open menu
          mobileMenu.classList.remove('hidden');
          hamburgerIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
          menuButton.setAttribute('aria-expanded', 'true');
        }
      });

      // Close menu when clicking outside
      document.addEventListener('click', (event) => {
        const target = event.target as Element;
        if (!menuButton.contains(target) && !mobileMenu.contains(target)) {
          mobileMenu.classList.add('hidden');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          menuButton.setAttribute('aria-expanded', 'false');
        }
      });

      // Close menu on escape key
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          mobileMenu.classList.add('hidden');
          hamburgerIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          menuButton.setAttribute('aria-expanded', 'false');
        }
      });
    }
  });
</script> 