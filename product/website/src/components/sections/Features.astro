---
// No props needed for Features section
---

<section class="relative py-24 bg-slate-900">
  <!-- Background Effects -->
  <div class="absolute inset-0">
    <!-- Brand Color Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
    
    <!-- Brand Color Orbs -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-20 w-64 h-64 rounded-full filter blur-3xl animate-pulse-slow" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
      <div class="absolute bottom-20 right-20 w-80 h-80 rounded-full filter blur-3xl animate-float" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);"></div>
    </div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.02]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <!-- Brand-Aligned Section Header -->
    <div class="text-center mb-20">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium mb-6 backdrop-blur-sm border shadow-lg" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border-color: #4A7C7C30; color: #4A7C7C; font-family: 'Inter', sans-serif;">
        <span class="w-2 h-2 rounded-full mr-2 animate-pulse" style="background-color: #3D6B3D;"></span>
        Comprehensive Data Infrastructure
      </div>
      
      <!-- Main Title -->
      <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6" style="font-family: 'Outfit', sans-serif;">
        Everything Your Enterprise
        <span class="block bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C, #D17A3A);">
          Data Needs
        </span>
      </h2>
      
      <!-- Subtitle -->
      <p class="font-primary text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed" style="font-family: 'Inter', sans-serif;">
        BaseOut transforms your Airtable environment into a robust, scalable data infrastructure 
        that meets enterprise standards while preserving operational excellence.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
      <!-- Backup & Recovery -->
      <div class="group relative bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 transition-all duration-500 hover:scale-105 perspective-1000" style="transform-style: preserve-3d;">
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20);"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C); box-shadow: 0 10px 30px #2D5A5A40;">
            <svg class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl font-semibold text-white mb-4 group-hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">
            Enterprise Backup & Recovery
          </h3>
          
          <p class="text-gray-300 mb-6 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Automated daily backups with point-in-time recovery, ensuring your critical data is always protected and recoverable within minutes.
          </p>
          
          <ul class="space-y-3">
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Automated daily backups</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Point-in-time recovery</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Disaster recovery planning</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- AI Analytics -->
      <div class="group relative bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 transition-all duration-500 hover:scale-105 perspective-1000" style="transform-style: preserve-3d;">
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" style="background: linear-gradient(135deg, #2E4A6B20, #2D5A5A20);"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #2E4A6B, #2D5A5A); box-shadow: 0 10px 30px #2E4A6B40;">
            <svg class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl font-semibold text-white mb-4 group-hover:text-white transition-colors duration-300" style="color: #2E4A6B; font-family: 'Inter', sans-serif;">
            AI-Powered Analytics
          </h3>
          
          <p class="text-gray-300 mb-6 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Advanced machine learning algorithms analyze your data patterns and provide actionable insights that go beyond traditional reporting.
          </p>
          
          <ul class="space-y-3">
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Predictive analytics</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Custom reporting</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Data visualization</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Governance & Compliance -->
      <div class="group relative bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 transition-all duration-500 hover:scale-105 perspective-1000" style="transform-style: preserve-3d;">
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" style="background: linear-gradient(135deg, #3D6B3D20, #D17A3A20);"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A); box-shadow: 0 10px 30px #3D6B3D40;">
            <svg class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl font-semibold text-white mb-4 group-hover:text-white transition-colors duration-300" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">
            Governance & Compliance
          </h3>
          
          <p class="text-gray-300 mb-6 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Comprehensive audit trails, access controls, and compliance reporting to meet enterprise security and regulatory requirements.
          </p>
          
          <ul class="space-y-3">
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #2E4A6B;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">SOC 2 compliance</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #2E4A6B;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">GDPR ready</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #2E4A6B;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Audit trails</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Schema Intelligence -->
      <div class="group relative bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 transition-all duration-500 hover:scale-105 perspective-1000" style="transform-style: preserve-3d;">
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" style="background: linear-gradient(135deg, #2D5A5A20, #3D6B3D20);"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #2D5A5A, #3D6B3D); box-shadow: 0 10px 30px #2D5A5A40;">
            <svg class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl font-semibold text-white mb-4 group-hover:text-white transition-colors duration-300" style="color: #2D5A5A; font-family: 'Inter', sans-serif;">
            Schema Intelligence
          </h3>
          
          <p class="text-gray-300 mb-6 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Visual data modeling and relationship mapping that helps you understand and optimize complex data architectures at enterprise scale.
          </p>
          
          <ul class="space-y-3">
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #4A7C7C;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Visual data modeling</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #4A7C7C;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Relationship mapping</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #4A7C7C;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Architecture optimization</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Performance Monitoring -->
      <div class="group relative bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 transition-all duration-500 hover:scale-105 perspective-1000" style="transform-style: preserve-3d;">
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" style="background: linear-gradient(135deg, #D17A3A20, #2E4A6B20);"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #D17A3A, #2E4A6B); box-shadow: 0 10px 30px #D17A3A40;">
            <svg class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl font-semibold text-white mb-4 group-hover:text-white transition-colors duration-300" style="color: #D17A3A; font-family: 'Inter', sans-serif;">
            Performance Monitoring
          </h3>
          
          <p class="text-gray-300 mb-6 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Real-time monitoring and alerting for your Airtable infrastructure, with proactive issue detection and resolution recommendations.
          </p>
          
          <ul class="space-y-3">
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Real-time monitoring</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Proactive alerts</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Performance optimization</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- API & Integrations -->
      <div class="group relative bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/10 transition-all duration-500 hover:scale-105 perspective-1000" style="transform-style: preserve-3d;">
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" style="background: linear-gradient(135deg, #2E4A6B20, #4A7C7C20);"></div>
        
        <div class="relative z-10">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #2E4A6B, #4A7C7C); box-shadow: 0 10px 30px #2E4A6B40;">
            <svg class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"></path>
            </svg>
          </div>
          
          <h3 class="text-2xl font-semibold text-white mb-4 group-hover:text-white transition-colors duration-300" style="color: #2E4A6B; font-family: 'Inter', sans-serif;">
            API & Integrations
          </h3>
          
          <p class="text-gray-300 mb-6 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Seamless integration with your existing technology stack through robust APIs and pre-built connectors for enterprise applications.
          </p>
          
          <ul class="space-y-3">
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">REST API access</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Pre-built connectors</span>
            </li>
            <li class="flex items-start group/item hover:translate-x-2 transition-transform duration-200">
              <span class="w-2 h-2 rounded-full mt-2 mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
              <span class="text-gray-400 text-sm group-hover/item:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Webhook support</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Brand-Compliant CTA Section -->
    <div class="text-center">
      <div class="inline-flex items-center px-6 py-3 rounded-full backdrop-blur-sm border text-sm font-medium mb-8 shadow-lg" style="background: linear-gradient(135deg, #3D6B3D20, #2D5A5A20); border-color: #3D6B3D40; color: #3D6B3D; font-family: 'Inter', sans-serif;">
        <span class="w-2 h-2 rounded-full mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
        Ready to Scale Your Data Infrastructure?
      </div>
      
      <h3 class="font-display text-3xl sm:text-4xl font-bold text-white mb-6" style="font-family: 'Outfit', sans-serif;">
        Start Your
        <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #D17A3A, #3D6B3D);">
          Enterprise Journey
        </span>
      </h3>
      
      <p class="font-primary text-gray-300 text-lg mb-8 max-w-2xl mx-auto" style="font-family: 'Inter', sans-serif;">
        Join enterprise teams who've transformed their data infrastructure while maintaining operational excellence.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1" style="background: linear-gradient(135deg, #D17A3A, #D17A3A); font-family: 'Inter', sans-serif;">
          <span>Start 14-Day Free Trial</span>
          <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        
        <a href="#" class="group inline-flex items-center px-8 py-4 text-lg font-semibold border-2 rounded-xl hover:bg-white/10 transition-all duration-300 backdrop-blur-sm" style="border-color: #4A7C7C; color: #4A7C7C; font-family: 'Inter', sans-serif;">
          <svg class="mr-2 w-5 h-5 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          <span class="group-hover:text-white transition-colors">Schedule Demo</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .perspective-1000 { perspective: 1000px; }
  
  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(45, 90, 90, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45, 90, 90, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  @keyframes float {
    0%, 100% { transform: translate(0px, 0px) rotate(0deg); }
    33% { transform: translate(30px, -30px) rotate(120deg); }
    66% { transform: translate(-20px, 20px) rotate(240deg); }
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.1; }
    50% { opacity: 0.2; }
  }

  .animate-float { animation: float 12s ease-in-out infinite; }
  .animate-pulse-slow { animation: pulse-slow 4s ease-in-out infinite; }
</style> 