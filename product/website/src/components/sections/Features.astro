---
// No props needed for Features section
---

<section id="features" class="section-padding bg-gradient-to-br from-gray-50 to-white relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-20 left-10 w-64 h-64 bg-gradient-to-br from-blue-400 to-purple-400 rounded-full filter blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 bg-gradient-to-br from-purple-400 to-pink-400 rounded-full filter blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto container-padding relative z-10">
    
    <!-- Enhanced Section Header -->
    <div class="text-center mb-20 animate-on-scroll">
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-gradient-to-r from-blue-100 to-purple-100 text-blue-800 text-sm font-medium mb-6">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path>
        </svg>
        Powerful Features
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight">
        Everything Your Enterprise Airtable
        <span class="block bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 bg-clip-text text-transparent">
          Environment Needs
        </span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        BaseOut bridges the gap between Airtable's ease-of-use and enterprise-grade data management requirements. 
        Get the security, governance, and analytics your business demands.
      </p>
    </div>

    <!-- Enhanced Main Features Grid with Magnetic Effect -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-24">
      
      <!-- Enterprise-Grade Security -->
      <div class="group magnetic-card p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-blue-200 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 flex items-start space-x-6">
          <div class="flex-shrink-0">
            <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-lg group-hover:shadow-xl group-hover:shadow-blue-500/30">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-blue-800 transition-colors duration-300">Complete Data Security</h3>
            <p class="text-gray-600 mb-6 leading-relaxed group-hover:text-gray-700 transition-colors duration-300">
              Enterprise-grade backup and disaster recovery with point-in-time restoration. SOC 2 compliant infrastructure 
              with encrypted storage and configurable retention policies. Never lose critical business data again.
            </p>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Automated backup scheduling with configurable frequency</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Point-in-time recovery to any previous state</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">SOC 2 Type II compliance and encryption at rest</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- AI-Powered Analytics -->
      <div class="group magnetic-card p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-purple-200 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 flex items-start space-x-6">
          <div class="flex-shrink-0">
            <div class="w-20 h-20 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-lg group-hover:shadow-xl group-hover:shadow-purple-500/30">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-purple-800 transition-colors duration-300">AI-Powered Analytics</h3>
            <p class="text-gray-600 mb-6 leading-relaxed group-hover:text-gray-700 transition-colors duration-300">
              Advanced insights and custom reporting that goes far beyond Airtable's native limitations. AI-powered 
              anomaly detection, predictive analytics, and custom dashboards for executive decision making.
            </p>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Custom reporting beyond Airtable's limitations</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">AI-powered data insights and anomaly detection</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Executive dashboards and business intelligence</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Schema Intelligence -->
      <div class="group magnetic-card p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-indigo-200 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 flex items-start space-x-6">
          <div class="flex-shrink-0">
            <div class="w-20 h-20 bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-2xl flex items-center justify-center group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-lg group-hover:shadow-xl group-hover:shadow-indigo-500/30">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-indigo-800 transition-colors duration-300">Schema Intelligence</h3>
            <p class="text-gray-600 mb-6 leading-relaxed group-hover:text-gray-700 transition-colors duration-300">
              Visual data modeling and relationship mapping for complex base architectures. Understand your data 
              connections, track schema evolution, and maintain architectural documentation automatically.
            </p>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Interactive schema maps and relationship visualization</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Automatic relationship discovery and documentation</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Schema change tracking and evolution history</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Governance & Compliance -->
      <div class="group magnetic-card p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-green-200 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-green-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 flex items-start space-x-6">
          <div class="flex-shrink-0">
            <div class="w-20 h-20 bg-gradient-to-br from-green-500 to-green-600 rounded-2xl flex items-center justify-center group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-lg group-hover:shadow-xl group-hover:shadow-green-500/30">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-green-800 transition-colors duration-300">Governance & Compliance</h3>
            <p class="text-gray-600 mb-6 leading-relaxed group-hover:text-gray-700 transition-colors duration-300">
              Comprehensive audit trails, security assessments, and compliance automation. Meet GDPR, HIPAA, 
              SOX requirements with automated reporting and governance workflows.
            </p>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Complete audit trails and user activity monitoring</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Security health scoring and risk assessments</span>
              </li>
              <li class="flex items-center group/item">
                <div class="w-6 h-6 bg-green-100 rounded-full flex items-center justify-center mr-3 group-hover/item:bg-green-200 transition-colors">
                  <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <span class="group-hover/item:text-gray-800 transition-colors">Pre-built compliance report templates</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

    </div>

    <!-- Enhanced Additional Features Grid with Staggered Animation -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
      
      <div class="group p-8 bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-orange-200 hover:scale-105 animate-on-scroll" style="animation-delay: 100ms;">
        <div class="w-16 h-16 bg-gradient-to-br from-orange-400 to-orange-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-lg group-hover:shadow-orange-500/30">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3 group-hover:text-orange-800 transition-colors">Knowledge Management</h3>
        <p class="text-gray-600 text-sm leading-relaxed group-hover:text-gray-700 transition-colors">Collaborative documentation and institutional knowledge capture with full-text search across all data.</p>
      </div>

      <div class="group p-8 bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-pink-200 hover:scale-105 animate-on-scroll" style="animation-delay: 200ms;">
        <div class="w-16 h-16 bg-gradient-to-br from-pink-400 to-pink-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-lg group-hover:shadow-pink-500/30">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3 group-hover:text-pink-800 transition-colors">Digital Asset Management</h3>
        <p class="text-gray-600 text-sm leading-relaxed group-hover:text-gray-700 transition-colors">Centralized file and attachment organization with advanced search and categorization capabilities.</p>
      </div>

      <div class="group p-8 bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-teal-200 hover:scale-105 animate-on-scroll" style="animation-delay: 300ms;">
        <div class="w-16 h-16 bg-gradient-to-br from-teal-400 to-teal-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-lg group-hover:shadow-teal-500/30">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-3 group-hover:text-teal-800 transition-colors">Real-Time Sync</h3>
        <p class="text-gray-600 text-sm leading-relaxed group-hover:text-gray-700 transition-colors">Near real-time data replication with configurable sync frequency based on your plan tier and requirements.</p>
      </div>

    </div>

    <!-- Enhanced How BaseOut Works with Better Dark Design -->
    <div class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 rounded-3xl p-12 lg:p-16 text-white relative overflow-hidden shadow-2xl">
      <!-- Background Effects -->
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-blue-500/20 to-purple-500/20"></div>
        <div class="absolute top-10 left-10 w-32 h-32 bg-blue-400 rounded-full filter blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-40 h-40 bg-purple-400 rounded-full filter blur-3xl"></div>
      </div>
      
      <div class="relative z-10">
        <div class="text-center mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold mb-6 text-white">How BaseOut Works</h2>
          <p class="text-xl text-gray-200 max-w-3xl mx-auto leading-relaxed">
            Simple 3-step setup gets you from signup to enterprise-grade data management in under 5 minutes
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="text-center group animate-on-scroll" style="animation-delay: 100ms;">
            <div class="relative mb-8">
              <div class="w-20 h-20 bg-gradient-to-br from-blue-400 to-blue-500 rounded-3xl flex items-center justify-center mx-auto shadow-xl group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                <span class="text-3xl font-bold text-white">1</span>
              </div>
              <!-- Connection line -->
              <div class="hidden md:block absolute top-10 left-full w-full h-0.5 bg-gradient-to-r from-blue-400/50 to-transparent"></div>
            </div>
            <h3 class="text-2xl font-semibold mb-4 text-white group-hover:text-blue-200 transition-colors">Create Account</h3>
            <p class="text-gray-300 leading-relaxed group-hover:text-gray-200 transition-colors">Sign up for BaseOut with your business email and start your 14-day free trial</p>
          </div>

          <div class="text-center group animate-on-scroll" style="animation-delay: 200ms;">
            <div class="relative mb-8">
              <div class="w-20 h-20 bg-gradient-to-br from-purple-400 to-purple-500 rounded-3xl flex items-center justify-center mx-auto shadow-xl group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                <span class="text-3xl font-bold text-white">2</span>
              </div>
              <!-- Connection line -->
              <div class="hidden md:block absolute top-10 left-full w-full h-0.5 bg-gradient-to-r from-purple-400/50 to-transparent"></div>
            </div>
            <h3 class="text-2xl font-semibold mb-4 text-white group-hover:text-purple-200 transition-colors">Connect Airtable</h3>
            <p class="text-gray-300 leading-relaxed group-hover:text-gray-200 transition-colors">Provide secure API connection to your Airtable workspace with enterprise-grade encryption</p>
          </div>

          <div class="text-center group animate-on-scroll" style="animation-delay: 300ms;">
            <div class="relative mb-8">
