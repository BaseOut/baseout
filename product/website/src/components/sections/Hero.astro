---
// No props needed for Hero section
---

<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white min-h-screen flex items-center">
  <!-- Enhanced Background Elements -->
  <div class="absolute inset-0">
    <!-- Primary Gradient Overlay with Brand Colors -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900/95 via-slate-800/90 to-slate-900/95"></div>
    
    <!-- Brand Color Background Orbs -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-10 -left-10 w-96 h-96 bg-gradient-to-r from-teal-600 to-teal-500 rounded-full mix-blend-multiply filter blur-3xl animate-float" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
      <div class="absolute top-20 -right-10 w-80 h-80 bg-gradient-to-r from-teal-700 to-teal-600 rounded-full mix-blend-multiply filter blur-3xl animate-float-delayed" style="background: linear-gradient(135deg, #1A3434, #2D5A5A);"></div>
      <div class="absolute -bottom-20 left-1/4 w-72 h-72 rounded-full mix-blend-multiply filter blur-3xl animate-float-slow" style="background: linear-gradient(135deg, #D17A3A, #3D6B3D);"></div>
    </div>
    
    <!-- Floating Particles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="particle absolute w-2 h-2 rounded-full animate-particle-1" style="background-color: #4A7C7C;"></div>
      <div class="particle absolute w-1 h-1 rounded-full animate-particle-2" style="background-color: #2D5A5A;"></div>
      <div class="particle absolute w-1.5 h-1.5 rounded-full animate-particle-3" style="background-color: #D17A3A;"></div>
      <div class="particle absolute w-1 h-1 rounded-full animate-particle-4" style="background-color: #3D6B3D;"></div>
      <div class="particle absolute w-2 h-2 rounded-full animate-particle-5" style="background-color: #2E4A6B;"></div>
    </div>
    
    <!-- Geometric Patterns -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-1/4 left-1/4 w-32 h-32 border-2 rotate-45 animate-spin-slow" style="border-color: #2D5A5A;"></div>
      <div class="absolute bottom-1/4 right-1/4 w-24 h-24 border-2 rotate-12 animate-pulse-slow" style="border-color: #4A7C7C;"></div>
    </div>
    
    <!-- Enhanced Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 z-10">
    <div class="text-center max-w-5xl mx-auto">
      <!-- Brand-Aligned Badge -->
      <div class="inline-flex items-center px-6 py-3 rounded-full backdrop-blur-sm border text-sm font-medium mb-8 shadow-lg hover:shadow-lg transition-all duration-300 group" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border-color: #4A7C7C30; color: #4A7C7C;">
        <span class="w-2 h-2 rounded-full mr-3 animate-pulse shadow-lg" style="background-color: #3D6B3D; box-shadow: 0 0 10px #3D6B3D50;"></span>
        <span class="group-hover:text-white transition-colors">Evolved from On2Air - Now BaseOut</span>
      </div>

      <!-- Brand-Compliant Main Headline -->
      <h1 class="font-display text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight mb-6 animate-fade-in-up" style="font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;">
        <span class="block text-white drop-shadow-lg">Build Data Infrastructure</span>
        <span class="block bg-gradient-to-r bg-clip-text  animate-gradient-x" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C, #D17A3A);">
          That Scales
        </span>
        <span class="block text-3xl sm:text-4xl lg:text-5xl font-semibold text-gray-100 mt-2 drop-shadow-md">
          with Your Enterprise
        </span>
      </h1>

      <!-- Brand-Aligned Subheadline -->
      <p class="font-primary text-lg sm:text-xl lg:text-2xl text-gray-200 font-light leading-relaxed mb-12 max-w-4xl mx-auto animate-fade-in-up animation-delay-200" style="font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;">
        Transform complex Airtable data challenges into competitive advantages with enterprise-grade 
        <span class="text-white font-medium px-2 py-1 rounded" style="background: linear-gradient(135deg, #2D5A5A30, #4A7C7C30);">backup & recovery</span>, 
        <span class="text-white font-medium px-2 py-1 rounded" style="background: linear-gradient(135deg, #2E4A6B30, #3D6B3D30);">AI-powered analytics</span>, and 
        <span class="text-white font-medium px-2 py-1 rounded" style="background: linear-gradient(135deg, #D17A3A30, #2D5A5A30);">governance & compliance</span> — 
        all while preserving your team's existing Airtable workflows.
      </p>

      <!-- Brand-Compliant Value Props Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 max-w-4xl mx-auto animate-fade-in-up animation-delay-400">
        <div class="group bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/10 transition-all duration-300 hover:scale-105 hover:shadow-2xl" style="hover:box-shadow: 0 25px 50px -12px #2D5A5A40;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 mx-auto group-hover:scale-110 transition-transform duration-300 shadow-lg" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2 transition-colors" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Enterprise Security</h3>
          <p class="text-white/70 text-sm group-hover:text-white/90 transition-colors" style="font-family: 'Inter', sans-serif;">Complete data backup, disaster recovery, and SOC 2 compliance for mission-critical operations.</p>
        </div>

        <div class="group bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/10 transition-all duration-300 hover:scale-105 hover:shadow-2xl" style="hover:box-shadow: 0 25px 50px -12px #2E4A6B40;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 mx-auto group-hover:scale-110 transition-transform duration-300 shadow-lg" style="background: linear-gradient(135deg, #2E4A6B, #2D5A5A);">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2 transition-colors" style="color: #2E4A6B; font-family: 'Inter', sans-serif;">AI-Powered Analytics</h3>
          <p class="text-white/70 text-sm group-hover:text-white/90 transition-colors" style="font-family: 'Inter', sans-serif;">Advanced insights and custom reporting that transcends Airtable's native limitations.</p>
        </div>

        <div class="group bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/10 transition-all duration-300 hover:scale-105 hover:shadow-2xl" style="hover:box-shadow: 0 25px 50px -12px #3D6B3D40;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 mx-auto group-hover:scale-110 transition-transform duration-300 shadow-lg" style="background: linear-gradient(135deg, #3D6B3D, #2D5A5A);">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2 transition-colors" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">Schema Intelligence</h3>
          <p class="text-white/70 text-sm group-hover:text-white/90 transition-colors" style="font-family: 'Inter', sans-serif;">Visual data modeling, relationship mapping, and governance for complex architectures.</p>
        </div>
      </div>

      <!-- Brand-Compliant CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12 animate-fade-in-up animation-delay-600">
        <a href="#" class="group relative inline-flex items-center px-8 py-4 text-lg font-semibold text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1 overflow-hidden" style="background: linear-gradient(135deg, #D17A3A, #D17A3A); font-family: 'Inter', sans-serif;">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(135deg, #D17A3A, #3D6B3D);"></div>
          <span class="relative">Start 14-Day Free Trial</span>
          <svg class="relative ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        
        <a href="#" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-white border-2 rounded-xl hover:bg-white/10 transition-all duration-300 backdrop-blur-sm relative overflow-hidden" style="border-color: #4A7C7C; color: #4A7C7C; font-family: 'Inter', sans-serif;">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20);"></div>
          <svg class="relative mr-2 w-5 h-5 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h1m4 0h1m-7-4h.01M12 5h.01M12 19h.01"></path>
          </svg>
          <span class="relative group-hover:text-white transition-colors">See Live Demo</span>
        </a>
      </div>

      <!-- Brand-Aligned Social Proof -->
      <div class="flex flex-col items-center animate-fade-in-up animation-delay-800">
        <p class="text-gray-300 text-sm mb-6" style="font-family: 'Inter', sans-serif;">Trusted by enterprise teams with mission-critical Airtable environments</p>
        
        <!-- Brand-Compliant Customer Metrics -->
        <div class="flex flex-wrap justify-center gap-8 text-center">
          <div class="group flex flex-col hover:scale-110 transition-transform duration-300">
            <span class="text-3xl font-bold bg-gradient-to-r bg-clip-text  counter" data-target="500" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);">500</span>
            <span class="text-gray-400 text-sm group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">TB+ Data Protected</span>
          </div>
          <div class="group flex flex-col hover:scale-110 transition-transform duration-300">
            <span class="text-3xl font-bold bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #3D6B3D, #2D5A5A);">99.9%</span>
            <span class="text-gray-400 text-sm group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Uptime SLA</span>
          </div>
          <div class="group flex flex-col hover:scale-110 transition-transform duration-300">
            <span class="text-3xl font-bold bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #D17A3A, #2E4A6B);">4.9/5</span>
            <span class="text-gray-400 text-sm group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Customer Rating</span>
          </div>
          <div class="group flex flex-col hover:scale-110 transition-transform duration-300">
            <span class="text-3xl font-bold bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2E4A6B, #3D6B3D);">&lt;5min</span>
            <span class="text-gray-400 text-sm group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">Setup Time</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Brand-Compliant Bottom Gradient -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent to-transparent shadow-lg" style="background: linear-gradient(90deg, transparent, #4A7C7C60, transparent); box-shadow: 0 0 10px #2D5A5A40;"></div>
</section>

<style>
  /* Import Brand Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap');

  .font-primary { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
  .font-display { font-family: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

  /* Enhanced Animations */
  @keyframes float {
    0%, 100% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
    33% { transform: translate(30px, -30px) scale(1.1) rotate(120deg); }
    66% { transform: translate(-20px, 20px) scale(0.9) rotate(240deg); }
  }

  @keyframes float-delayed {
    0%, 100% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
    33% { transform: translate(-25px, -35px) scale(1.05) rotate(-120deg); }
    66% { transform: translate(25px, 15px) scale(0.95) rotate(-240deg); }
  }

  @keyframes float-slow {
    0%, 100% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
    50% { transform: translate(15px, -15px) scale(1.02) rotate(180deg); }
  }

  @keyframes gradient-x {
    0%, 100% { background-size: 200% 200%; background-position: left center; }
    50% { background-size: 200% 200%; background-position: right center; }
  }

  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes pulse-slow { 0%, 100% { opacity: 0.3; } 50% { opacity: 0.8; } }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Particle Animations with Brand Colors */
  @keyframes particle-1 {
    0% { transform: translate(0, 100vh) scale(0); opacity: 0; }
    10% { transform: translate(10px, 90vh) scale(1); opacity: 0.7; }
    90% { transform: translate(-10px, -10vh) scale(1); opacity: 0.7; }
    100% { transform: translate(0, -10vh) scale(0); opacity: 0; }
  }

  @keyframes particle-2 {
    0% { transform: translate(0, 100vh) scale(0); opacity: 0; }
    15% { transform: translate(-20px, 80vh) scale(1); opacity: 0.5; }
    85% { transform: translate(20px, -10vh) scale(1); opacity: 0.5; }
    100% { transform: translate(0, -10vh) scale(0); opacity: 0; }
  }

  @keyframes particle-3 {
    0% { transform: translate(0, 100vh) scale(0); opacity: 0; }
    20% { transform: translate(15px, 75vh) scale(1); opacity: 0.6; }
    80% { transform: translate(-15px, -10vh) scale(1); opacity: 0.6; }
    100% { transform: translate(0, -10vh) scale(0); opacity: 0; }
  }

  @keyframes particle-4 {
    0% { transform: translate(0, 100vh) scale(0); opacity: 0; }
    25% { transform: translate(-25px, 70vh) scale(1); opacity: 0.4; }
    75% { transform: translate(25px, -10vh) scale(1); opacity: 0.4; }
    100% { transform: translate(0, -10vh) scale(0); opacity: 0; }
  }

  @keyframes particle-5 {
    0% { transform: translate(0, 100vh) scale(0); opacity: 0; }
    30% { transform: translate(30px, 65vh) scale(1); opacity: 0.8; }
    70% { transform: translate(-30px, -10vh) scale(1); opacity: 0.8; }
    100% { transform: translate(0, -10vh) scale(0); opacity: 0; }
  }

  .animate-float { animation: float 8s ease-in-out infinite; }
  .animate-float-delayed { animation: float-delayed 10s ease-in-out infinite; }
  .animate-float-slow { animation: float-slow 12s ease-in-out infinite; }
  .animate-gradient-x { animation: gradient-x 4s ease infinite; }
  .animate-spin-slow { animation: spin-slow 20s linear infinite; }
  .animate-pulse-slow { animation: pulse-slow 4s ease-in-out infinite; }
  .animate-fade-in-up { animation: fade-in-up 0.8s ease-out forwards; }

  .animate-particle-1 { 
    animation: particle-1 15s linear infinite;
    left: 10%;
    animation-delay: 0s;
  }
  .animate-particle-2 { 
    animation: particle-2 12s linear infinite;
    left: 25%;
    animation-delay: 3s;
  }
  .animate-particle-3 { 
    animation: particle-3 18s linear infinite;
    left: 50%;
    animation-delay: 6s;
  }
  .animate-particle-4 { 
    animation: particle-4 14s linear infinite;
    left: 75%;
    animation-delay: 9s;
  }
  .animate-particle-5 { 
    animation: particle-5 16s linear infinite;
    left: 90%;
    animation-delay: 12s;
  }

  .animation-delay-200 { animation-delay: 200ms; }
  .animation-delay-400 { animation-delay: 400ms; }
  .animation-delay-600 { animation-delay: 600ms; }
  .animation-delay-800 { animation-delay: 800ms; }

  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(45, 90, 90, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45, 90, 90, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }
</style> 