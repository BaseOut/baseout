---
// No props needed for Hero section
---

<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
  <!-- Background Elements -->
  <div class="absolute inset-0">
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900/90 via-slate-800/80 to-slate-900/90"></div>
    
    <!-- Animated Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 -left-4 w-72 h-72 bg-blue-500 rounded-full mix-blend-multiply filter blur-xl animate-blob"></div>
      <div class="absolute top-0 -right-4 w-72 h-72 bg-purple-500 rounded-full mix-blend-multiply filter blur-xl animate-blob animation-delay-2000"></div>
      <div class="absolute -bottom-8 left-20 w-72 h-72 bg-pink-500 rounded-full mix-blend-multiply filter blur-xl animate-blob animation-delay-4000"></div>
    </div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center max-w-5xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-sm font-medium text-white/90 mb-8">
        <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
        The Evolution of On2Air - Now BaseOut
      </div>

      <!-- Main Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight mb-6">
        <span class="block">The Tool You</span>
        <span class="block bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
          Can't Live Without
        </span>
        <span class="block text-3xl sm:text-4xl lg:text-5xl font-semibold text-white/90 mt-2">
          for Enterprise Airtable
        </span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl lg:text-2xl text-white/80 font-light leading-relaxed mb-12 max-w-4xl mx-auto">
        Transform your critical Airtable environments into enterprise-grade data architecture with 
        <span class="text-white font-medium">complete backup & recovery</span>, 
        <span class="text-white font-medium">AI-powered analytics</span>, and 
        <span class="text-white font-medium">governance & compliance</span> — 
        all while keeping your team's beloved Airtable workflow intact.
      </p>

      <!-- Value Props Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 max-w-4xl mx-auto">
        <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-400 to-blue-600 rounded-lg flex items-center justify-center mb-4 mx-auto">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Enterprise-Grade Security</h3>
          <p class="text-white/70 text-sm">Complete data backup, disaster recovery, and SOC 2 compliance for mission-critical operations.</p>
        </div>

        <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
          <div class="w-12 h-12 bg-gradient-to-br from-purple-400 to-purple-600 rounded-lg flex items-center justify-center mb-4 mx-auto">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">AI-Powered Analytics</h3>
          <p class="text-white/70 text-sm">Advanced insights and custom reporting that goes far beyond Airtable's native limitations.</p>
        </div>

        <div class="bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-white/10">
          <div class="w-12 h-12 bg-gradient-to-br from-pink-400 to-pink-600 rounded-lg flex items-center justify-center mb-4 mx-auto">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Schema Intelligence</h3>
          <p class="text-white/70 text-sm">Visual data modeling, relationship mapping, and governance for complex base architectures.</p>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
        <a href="#" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-slate-900 bg-white rounded-xl hover:bg-gray-50 transition-all duration-200 shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
          Start 14-Day Free Trial
          <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        
        <a href="#" class="inline-flex items-center px-8 py-4 text-lg font-semibold text-white border-2 border-white/30 rounded-xl hover:bg-white/10 transition-all duration-200 backdrop-blur-sm">
          <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1m4 0h1m-6 4h1m4 0h1m-7-4h.01M12 5h.01M12 19h.01"></path>
          </svg>
          See Live Demo
        </a>
      </div>

      <!-- Social Proof -->
      <div class="flex flex-col items-center">
        <p class="text-white/60 text-sm mb-6">Trusted by enterprise teams with mission-critical Airtable environments</p>
        
        <!-- Customer Metrics -->
        <div class="flex flex-wrap justify-center gap-8 text-center">
          <div class="flex flex-col">
            <span class="text-2xl font-bold text-white">500TB+</span>
            <span class="text-white/60 text-sm">Data Protected</span>
          </div>
          <div class="flex flex-col">
            <span class="text-2xl font-bold text-white">99.9%</span>
            <span class="text-white/60 text-sm">Uptime SLA</span>
          </div>
          <div class="flex flex-col">
            <span class="text-2xl font-bold text-white">4.9/5</span>
            <span class="text-white/60 text-sm">Customer Rating</span>
          </div>
          <div class="flex flex-col">
            <span class="text-2xl font-bold text-white">&lt;5min</span>
            <span class="text-white/60 text-sm">Setup Time</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Gradient -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
</section>

<style>
  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }

  .animate-blob {
    animation: blob 7s infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 50px 50px;
  }
</style> 