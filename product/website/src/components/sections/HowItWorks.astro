---
// No props needed for HowItWorks section
---

<section class="relative py-24 bg-slate-900">
  <!-- Background Effects -->
  <div class="absolute inset-0">
    <!-- Brand Color Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"></div>
    
    <!-- Brand Color Orbs -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-64 h-64 rounded-full filter blur-3xl animate-pulse-slow" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
      <div class="absolute bottom-10 right-10 w-80 h-80 rounded-full filter blur-3xl animate-float" style="background: linear-gradient(135deg, #D17A3A, #3D6B3D);"></div>
    </div>
    
    <!-- Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.02]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <!-- Brand-Aligned Section Header -->
    <div class="text-center mb-16">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium mb-6 backdrop-blur-sm border shadow-lg" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border-color: #4A7C7C30; color: #4A7C7C; font-family: 'Inter', sans-serif;">
        <span class="w-2 h-2 rounded-full mr-2 animate-pulse" style="background-color: #3D6B3D;"></span>
        Simple Implementation Process
      </div>
      
      <!-- Main Title -->
      <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6" style="font-family: 'Outfit', sans-serif;">
        How
        <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C, #D17A3A);">
          BaseOut Works
        </span>
      </h2>
      
      <!-- Subtitle -->
      <p class="font-primary text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed" style="font-family: 'Inter', sans-serif;">
        Enterprise-grade data infrastructure setup in under 5 minutes — 
        no complex configurations, no disruption to existing workflows.
      </p>
    </div>

    <!-- Process Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <!-- Step 1: Create Account -->
      <div class="group text-center relative">
        <!-- Step Number -->
        <div class="relative mb-8">
          <div class="w-20 h-20 rounded-3xl flex items-center justify-center mx-auto shadow-xl group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 relative z-10" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C); box-shadow: 0 10px 30px #2D5A5A40;">
            <span class="text-3xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">1</span>
          </div>
          
          <!-- Connection Line -->
          <div class="hidden md:block absolute top-10 left-full w-full h-0.5 bg-gradient-to-r from-transparent to-transparent z-0" style="background: linear-gradient(90deg, #4A7C7C60, transparent);"></div>
        </div>
        
        <!-- Step Content -->
        <div class="space-y-4">
          <h3 class="text-2xl font-semibold text-white group-hover:text-white transition-colors duration-300" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">
            Create Account
          </h3>
          <p class="text-gray-300 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Sign up with your business email and start your 14-day free trial. 
            No credit card required, immediate access to all enterprise features.
          </p>
          
          <!-- Feature Benefits -->
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-center text-gray-400 group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">
              <span class="w-1.5 h-1.5 rounded-full mr-2" style="background-color: #3D6B3D;"></span>
              14-day free trial
            </div>
            <div class="flex items-center justify-center text-gray-400 group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">
              <span class="w-1.5 h-1.5 rounded-full mr-2" style="background-color: #3D6B3D;"></span>
              No credit card required
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Connect Airtable -->
      <div class="group text-center relative">
        <!-- Step Number -->
        <div class="relative mb-8">
          <div class="w-20 h-20 rounded-3xl flex items-center justify-center mx-auto shadow-xl group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 relative z-10" style="background: linear-gradient(135deg, #2E4A6B, #2D5A5A); box-shadow: 0 10px 30px #2E4A6B40;">
            <span class="text-3xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">2</span>
          </div>
          
          <!-- Connection Line -->
          <div class="hidden md:block absolute top-10 left-full w-full h-0.5 bg-gradient-to-r from-transparent to-transparent z-0" style="background: linear-gradient(90deg, #2E4A6B60, transparent);"></div>
        </div>
        
        <!-- Step Content -->
        <div class="space-y-4">
          <h3 class="text-2xl font-semibold text-white group-hover:text-white transition-colors duration-300" style="color: #2E4A6B; font-family: 'Inter', sans-serif;">
            Connect Airtable
          </h3>
          <p class="text-gray-300 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Secure API connection to your Airtable workspace with enterprise-grade encryption. 
            BaseOut only accesses what you explicitly authorize.
          </p>
          
          <!-- Feature Benefits -->
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-center text-gray-400 group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">
              <span class="w-1.5 h-1.5 rounded-full mr-2" style="background-color: #D17A3A;"></span>
              Enterprise-grade encryption
            </div>
            <div class="flex items-center justify-center text-gray-400 group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">
              <span class="w-1.5 h-1.5 rounded-full mr-2" style="background-color: #D17A3A;"></span>
              Read-only access option
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Select Bases -->
      <div class="group text-center relative">
        <!-- Step Number -->
        <div class="relative mb-8">
          <div class="w-20 h-20 rounded-3xl flex items-center justify-center mx-auto shadow-xl group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 relative z-10" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A); box-shadow: 0 10px 30px #3D6B3D40;">
            <span class="text-3xl font-bold text-white" style="font-family: 'Outfit', sans-serif;">3</span>
          </div>
        </div>
        
        <!-- Step Content -->
        <div class="space-y-4">
          <h3 class="text-2xl font-semibold text-white group-hover:text-white transition-colors duration-300" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">
            Configure & Launch
          </h3>
          <p class="text-gray-300 leading-relaxed group-hover:text-gray-200 transition-colors duration-300" style="font-family: 'Inter', sans-serif;">
            Select bases to monitor, configure backup schedules, and activate enterprise features. 
            Your data infrastructure scales automatically.
          </p>
          
          <!-- Feature Benefits -->
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-center text-gray-400 group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">
              <span class="w-1.5 h-1.5 rounded-full mr-2" style="background-color: #4A7C7C;"></span>
              Automated scaling
            </div>
            <div class="flex items-center justify-center text-gray-400 group-hover:text-gray-300 transition-colors" style="font-family: 'Inter', sans-serif;">
              <span class="w-1.5 h-1.5 rounded-full mr-2" style="background-color: #4A7C7C;"></span>
              Instant activation
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Key Benefits Section -->
    <div class="bg-white/5 backdrop-blur-sm rounded-3xl p-8 lg:p-12 border border-white/10 relative overflow-hidden">
      <!-- Background Gradient -->
      <div class="absolute inset-0 opacity-20 rounded-3xl" style="background: linear-gradient(135deg, #2D5A5A10, #4A7C7C10, #3D6B3D10);"></div>
      
      <div class="relative z-10">
        <!-- Section Header -->
        <div class="text-center mb-12">
          <h3 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4" style="font-family: 'Outfit', sans-serif;">
            Why Enterprise Teams
            <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #D17A3A, #3D6B3D);">
              Choose BaseOut
            </span>
          </h3>
          <p class="font-primary text-gray-300 text-lg max-w-2xl mx-auto" style="font-family: 'Inter', sans-serif;">
            Built specifically for organizations that have outgrown basic Airtable capabilities but need to preserve existing workflows.
          </p>
        </div>

        <!-- Benefits Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- No Disruption -->
          <div class="group text-center space-y-4">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C); box-shadow: 0 8px 25px #2D5A5A30;">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-white" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Zero Disruption</h4>
            <p class="text-gray-400 text-sm" style="font-family: 'Inter', sans-serif;">Teams continue using Airtable exactly as before</p>
          </div>

          <!-- Enterprise Security -->
          <div class="group text-center space-y-4">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #3D6B3D, #2D5A5A); box-shadow: 0 8px 25px #3D6B3D30;">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-white" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">Enterprise Security</h4>
            <p class="text-gray-400 text-sm" style="font-family: 'Inter', sans-serif;">SOC 2 compliance with enterprise-grade encryption</p>
          </div>

          <!-- Instant Insights -->
          <div class="group text-center space-y-4">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #2E4A6B, #D17A3A); box-shadow: 0 8px 25px #2E4A6B30;">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-white" style="color: #2E4A6B; font-family: 'Inter', sans-serif;">Instant Insights</h4>
            <p class="text-gray-400 text-sm" style="font-family: 'Inter', sans-serif;">AI-powered analytics available immediately</p>
          </div>

          <!-- Proven Scale -->
          <div class="group text-center space-y-4">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto group-hover:scale-110 transition-all duration-300" style="background: linear-gradient(135deg, #D17A3A, #3D6B3D); box-shadow: 0 8px 25px #D17A3A30;">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-white" style="color: #D17A3A; font-family: 'Inter', sans-serif;">Proven Scale</h4>
            <p class="text-gray-400 text-sm" style="font-family: 'Inter', sans-serif;">Handles enterprise workloads with 99.9% uptime</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Brand-Compliant CTA -->
    <div class="text-center mt-16">
      <div class="inline-flex items-center px-6 py-3 rounded-full backdrop-blur-sm border text-sm font-medium mb-8 shadow-lg" style="background: linear-gradient(135deg, #3D6B3D20, #D17A3A20); border-color: #3D6B3D40; color: #3D6B3D; font-family: 'Inter', sans-serif;">
        <span class="w-2 h-2 rounded-full mr-3 animate-pulse" style="background-color: #D17A3A;"></span>
        Ready to Transform Your Data Infrastructure?
      </div>
      
      <h3 class="font-display text-3xl sm:text-4xl font-bold text-white mb-6" style="font-family: 'Outfit', sans-serif;">
        Experience the
        <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);">
          BaseOut Difference
        </span>
      </h3>
      
      <p class="font-primary text-gray-300 text-lg mb-8 max-w-2xl mx-auto" style="font-family: 'Inter', sans-serif;">
        Join the enterprise teams who've already scaled their data infrastructure while preserving operational excellence.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1" style="background: linear-gradient(135deg, #D17A3A, #D17A3A); font-family: 'Inter', sans-serif;">
          <span>Start Free Trial</span>
          <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        
        <a href="#" class="group inline-flex items-center px-8 py-4 text-lg font-semibold border-2 rounded-xl hover:bg-white/10 transition-all duration-300 backdrop-blur-sm" style="border-color: #4A7C7C; color: #4A7C7C; font-family: 'Inter', sans-serif;">
          <svg class="mr-2 w-5 h-5 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          <span class="group-hover:text-white transition-colors">Watch Demo</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(45, 90, 90, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45, 90, 90, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  @keyframes float {
    0%, 100% { transform: translate(0px, 0px) rotate(0deg); }
    33% { transform: translate(30px, -30px) rotate(120deg); }
    66% { transform: translate(-20px, 20px) rotate(240deg); }
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.1; }
    50% { opacity: 0.2; }
  }

  .animate-float { animation: float 12s ease-in-out infinite; }
  .animate-pulse-slow { animation: pulse-slow 4s ease-in-out infinite; }
</style> 