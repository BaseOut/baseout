    <!-- CTA -->
    <div class="text-center animate-on-scroll">
      <p class="text-slate mb-6">All plans include a 14-day free trial with full feature access</p>
      <a href="/pricing" class="btn-tertiary">
        View detailed pricing →
      </a>
    </div>
  </div>
</section>

<script is:inline>
  // Pricing data
  const pricingData = {
    launch: {
      monthly: { price: 115, period: '/month', savings: '' },
      annual: { price: 99, period: '/month (billed annually)', savings: 'Save $200/year' }
    },
    scale: {
      monthly: { price: 349, period: '/month', savings: '' },
      annual: { price: 299, period: '/month (billed annually)', savings: 'Save $600/year' }
    },
    impact: {
      monthly: { price: 699, period: '/month', savings: '' },
      annual: { price: 599, period: '/month (billed annually)', savings: 'Save $1,200/year' }
    }
  };

  // Current pricing mode (starts with annual)
  let isAnnual = true;

  function togglePricing() {
    isAnnual = !isAnnual;
    
    // Update toggle appearance
    const toggle = document.getElementById('pricing-toggle');
    const indicator = document.getElementById('toggle-indicator');
    const monthlyLabel = document.getElementById('monthly-label');
    const annualLabel = document.getElementById('annual-label');
    
    if (!toggle || !indicator || !monthlyLabel || !annualLabel) return;
    
    if (isAnnual) {
      // Annual mode
      toggle.setAttribute('aria-checked', 'true');
      toggle.classList.add('bg-teal-600');
      toggle.classList.remove('bg-gray-300');
      indicator.classList.add('translate-x-9');
      indicator.classList.remove('translate-x-1');
      monthlyLabel.classList.remove('text-charcoal');
      monthlyLabel.classList.add('text-slate');
      annualLabel.classList.add('text-charcoal');
      annualLabel.classList.remove('text-slate');
    } else {
      // Monthly mode
      toggle.setAttribute('aria-checked', 'false');
      toggle.classList.remove('bg-teal-600');
      toggle.classList.add('bg-gray-300');
      indicator.classList.remove('translate-x-9');
      indicator.classList.add('translate-x-1');
      monthlyLabel.classList.add('text-charcoal');
      monthlyLabel.classList.remove('text-slate');
      annualLabel.classList.remove('text-charcoal');
      annualLabel.classList.add('text-slate');
    }
    
    // Update pricing display
    updatePricing();
  }

  function updatePricing() {
    const mode = isAnnual ? 'annual' : 'monthly';
    
    // Update each plan
    Object.keys(pricingData).forEach(plan => {
      const data = pricingData[plan][mode];
      const priceElement = document.getElementById(`${plan}-price`);
      const periodElement = document.getElementById(`${plan}-period`);
      const savingsElement = document.getElementById(`${plan}-savings`);
      
      if (priceElement) {
        priceElement.textContent = `$${data.price}`;
      }
      
      if (periodElement) {
        periodElement.textContent = data.period;
      }
      
      if (savingsElement) {
        if (data.savings) {
          savingsElement.textContent = data.savings;
          savingsElement.style.display = 'block';
        } else {
          savingsElement.style.display = 'none';
        }
      }
    });
  }

  // Initialize pricing on page load
  document.addEventListener('DOMContentLoaded', function() {
    updatePricing();
  });
</script>

<style>
  .pricing-card {
    background-color: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    border: 1px solid rgb(243 244 246);
    transition: box-shadow 0.3s ease;
  }
  
  .pricing-card:hover {
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  }
  
  .pricing-card.featured {
    position: relative;
    ring-width: 2px;
    ring-color: var(--baseout-teal, #2D5A5A);
    border: 2px solid var(--baseout-teal, #2D5A5A);
  }
  
  .pricing-card.featured::before {
    content: 'Most Popular';
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--baseout-teal, #2D5A5A);
    color: white;
    padding: 0.25rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
  }
</style> 