          </li>
        </ul>
        
        <a href="/signup?plan=impact" class="w-full btn-secondary">
          Start Free Trial
        </a>
      </div>

      <!-- Enterprise Plan -->
      <div class="pricing-card animate-on-scroll">
        <div class="text-center mb-8">
          <h3 class="text-h3 text-charcoal mb-2">Enterprise</h3>
          <p class="text-slate mb-4">For enterprise scale</p>
          <div class="text-4xl font-bold text-baseout-teal mb-1">Custom</div>
          <div class="text-slate text-sm">Contact for pricing</div>
        </div>
        
        <ul class="space-y-3 mb-8 text-sm">
          <li class="flex items-center">
            <svg class="w-4 h-4 text-baseout-mountain mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
