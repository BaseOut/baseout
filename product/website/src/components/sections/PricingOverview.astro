---
// Pricing overview section
---

<section id="pricing" class="section-padding bg-gray-50">
  <div class="max-w-7xl mx-auto container-padding">
    <!-- Section header -->
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-h1 text-charcoal mb-4">
        Simple, Transparent Pricing
      </h2>
      <p class="text-xl text-slate max-w-3xl mx-auto">
        Start with a 14-day free trial, then choose the plan that grows with your data needs.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- Launch Plan -->
      <div class="pricing-card animate-on-scroll">
        <div class="text-center mb-8">
          <h3 class="text-h3 text-charcoal mb-2">Launch</h3>
          <p class="text-slate mb-4">Perfect for getting started</p>
          <div class="text-4xl font-bold text-baseout-teal mb-1">$99</div>
          <div class="text-slate text-sm">/month per environment</div>
        </div>
        
        <ul class="space-y-3 mb-8 text-sm">
          <li class="flex items-center">
            <svg class="w-4 h-4 text-baseout-mountain mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            25 bases
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 text-baseout-mountain mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            4-hour sync
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 text-baseout-mountain mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            50GB storage
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 text-baseout-mountain mr-3" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            Email support
          </li>
        </ul>
        
        <a href="/signup?plan=launch" class="w-full btn-secondary">
          Start Free Trial
        </a>
      </div>

      <!-- Scale Plan -->
      <div class="pricing-card featured animate-on-scroll">
        <div class="text-center mb-8">
          <h3 class="text-h3 text-charcoal mb-2">Scale</h3>
          <p class="text-slate mb-4">For growing businesses</p>
          <div class="text-4xl font-bold text-baseout-teal mb-1">$299</div>
          <div class="text-slate text-sm">/month per environment</div>
