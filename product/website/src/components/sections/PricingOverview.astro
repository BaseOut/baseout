        </ul>
        
        <a href="/signup?plan=scale" class="w-full btn-primary">
          Start Free Trial
        </a>
      </div>

      <!-- Impact Plan -->
      <div class="pricing-card animate-on-scroll">
        <div class="text-center mb-8">
          <h3 class="text-h3 text-charcoal mb-2">Impact</h3>
          <p class="text-slate mb-4">For large organizations</p>
          <div class="text-4xl font-bold text-baseout-teal mb-1">
            <span id="impact-price">$599</span>
          </div>
          <div class="text-slate text-sm">
            <span id="impact-period">/month (billed annually)</span>
          </div>
