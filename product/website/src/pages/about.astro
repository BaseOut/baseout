---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="About - BaseOut Enterprise Data Infrastructure"
  description="Learn about BaseOut's mission to transform enterprise data infrastructure and meet the team building the future of Airtable enterprise solutions."
>
  <Navigation />
  
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white py-24">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900/95 via-slate-800/90 to-slate-900/95"></div>
      <div class="absolute inset-0 opacity-20">
        <div class="absolute top-10 -left-10 w-96 h-96 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
        <div class="absolute bottom-10 -right-10 w-80 h-80 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);"></div>
      </div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 rounded-full backdrop-blur-sm border text-sm font-medium mb-8 shadow-lg" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border-color: #4A7C7C30; color: #4A7C7C; font-family: 'Inter', sans-serif;">
          <span class="w-2 h-2 rounded-full mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
          About BaseOut
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6" style="font-family: 'Outfit', sans-serif;">
          <span class="block text-white">Transforming Enterprise</span>
          <span class="block bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C, #D17A3A);">
            Data Infrastructure
          </span>
        </h1>

        <p class="font-primary text-xl text-gray-200 leading-relaxed mb-12 max-w-3xl mx-auto" style="font-family: 'Inter', sans-serif;">
          We're on a mission to bridge the gap between Airtable's simplicity and enterprise-grade data infrastructure requirements, 
          empowering teams to scale without sacrificing operational excellence.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium mb-6 shadow-lg" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border: 1px solid #4A7C7C30; color: #2D5A5A; font-family: 'Inter', sans-serif;">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            Our Mission
          </div>
          
          <h2 class="font-display text-4xl sm:text-5xl font-bold mb-6" style="color: #1f2937; font-family: 'Outfit', sans-serif;">
            Bridging Simplicity and
            <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);">
              Enterprise Scale
            </span>
          </h2>
          
          <p class="font-primary text-lg text-gray-600 mb-8 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            Airtable revolutionized how teams organize and collaborate with data, but enterprise organizations need more. 
            They need robust backup systems, advanced analytics, and governance controls that don't compromise on usability.
          </p>
          
          <p class="font-primary text-lg text-gray-600 mb-8 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            BaseOut was founded to solve this exact challenge. We believe that powerful enterprise infrastructure shouldn't 
            require sacrificing the intuitive workflows that make teams productive.
          </p>

          <div class="space-y-4">
            <div class="flex items-start space-x-4">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold mb-1" style="color: #2D5A5A; font-family: 'Inter', sans-serif;">Preserve Team Productivity</h3>
                <p class="text-gray-600 text-sm" style="font-family: 'Inter', sans-serif;">Keep teams working in familiar Airtable workflows while adding enterprise capabilities behind the scenes.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold mb-1" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">Scale with Confidence</h3>
                <p class="text-gray-600 text-sm" style="font-family: 'Inter', sans-serif;">Provide enterprise-grade infrastructure that grows with your organization's data needs.</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #D17A3A, #2E4A6B);">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold mb-1" style="color: #D17A3A; font-family: 'Inter', sans-serif;">Unlock Data Insights</h3>
                <p class="text-gray-600 text-sm" style="font-family: 'Inter', sans-serif;">Transform raw data into actionable business intelligence with AI-powered analytics.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Visual Element -->
        <div class="relative">
          <div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100">
            <div class="space-y-6">
              <div class="text-center">
                <div class="w-20 h-20 mx-auto rounded-2xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C); box-shadow: 0 10px 30px #2D5A5A40;">
                  <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                  </svg>
                </div>
                <h3 class="font-semibold text-lg mb-2" style="color: #2D5A5A; font-family: 'Inter', sans-serif;">Enterprise Data Infrastructure</h3>
                <p class="text-gray-600 text-sm" style="font-family: 'Inter', sans-serif;">Built for scale, designed for teams</p>
              </div>

              <div class="grid grid-cols-3 gap-4 text-center">
                <div class="p-4 rounded-xl" style="background: linear-gradient(135deg, #2D5A5A10, #4A7C7C10);">
                  <div class="text-2xl font-bold mb-1" style="color: #2D5A5A; font-family: 'Inter', sans-serif;">99.9%</div>
                  <div class="text-xs text-gray-600" style="font-family: 'Inter', sans-serif;">Uptime SLA</div>
                </div>
                <div class="p-4 rounded-xl" style="background: linear-gradient(135deg, #3D6B3D10, #D17A3A10);">
                  <div class="text-2xl font-bold mb-1" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">&lt; 15min</div>
                  <div class="text-xs text-gray-600" style="font-family: 'Inter', sans-serif;">Recovery Time</div>
                </div>
                <div class="p-4 rounded-xl" style="background: linear-gradient(135deg, #D17A3A10, #2E4A6B10);">
                  <div class="text-2xl font-bold mb-1" style="color: #D17A3A; font-family: 'Inter', sans-serif;">SOC 2</div>
                  <div class="text-xs text-gray-600" style="font-family: 'Inter', sans-serif;">Compliant</div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Floating elements -->
          <div class="absolute -top-6 -right-6 w-12 h-12 rounded-xl opacity-20 animate-bounce" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);"></div>
          <div class="absolute -bottom-4 -left-4 w-8 h-8 rounded-lg opacity-30 animate-pulse" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium mb-6 shadow-lg" style="background: linear-gradient(135deg, #2E4A6B20, #3D6B3D20); border: 1px solid #2E4A6B30; color: #2E4A6B; font-family: 'Inter', sans-serif;">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          Our Values
        </div>
        
        <h2 class="font-display text-4xl sm:text-5xl font-bold mb-6" style="color: #1f2937; font-family: 'Outfit', sans-serif;">
          What Drives Us
          <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2E4A6B, #3D6B3D);">
            Forward
          </span>
        </h2>
        
        <p class="font-primary text-xl text-gray-600 max-w-3xl mx-auto" style="font-family: 'Inter', sans-serif;">
          Our core values shape every decision we make and every product we build.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Customer-Centric -->
        <div class="group text-center p-8 rounded-2xl transition-all duration-300 hover:shadow-xl hover:scale-105" style="background: linear-gradient(135deg, #2D5A5A05, #4A7C7C05); border: 1px solid #4A7C7C20;">
          <div class="w-16 h-16 mx-auto rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C); box-shadow: 0 10px 30px #2D5A5A30;">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold mb-4" style="color: #2D5A5A; font-family: 'Inter', sans-serif;">Customer-Centric</h3>
          <p class="text-gray-600 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            Every feature we build starts with understanding our customers' real-world challenges and designing solutions that truly address their needs.
          </p>
        </div>

        <!-- Innovation -->
        <div class="group text-center p-8 rounded-2xl transition-all duration-300 hover:shadow-xl hover:scale-105" style="background: linear-gradient(135deg, #3D6B3D05, #D17A3A05); border: 1px solid #3D6B3D20;">
          <div class="w-16 h-16 mx-auto rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A); box-shadow: 0 10px 30px #3D6B3D30;">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold mb-4" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">Innovation</h3>
          <p class="text-gray-600 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            We constantly push the boundaries of what's possible in enterprise data infrastructure, leveraging cutting-edge technologies like AI and machine learning.
          </p>
        </div>

        <!-- Reliability -->
        <div class="group text-center p-8 rounded-2xl transition-all duration-300 hover:shadow-xl hover:scale-105" style="background: linear-gradient(135deg, #D17A3A05, #2E4A6B05); border: 1px solid #D17A3A20;">
          <div class="w-16 h-16 mx-auto rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #D17A3A, #2E4A6B); box-shadow: 0 10px 30px #D17A3A30;">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold mb-4" style="color: #D17A3A; font-family: 'Inter', sans-serif;">Reliability</h3>
          <p class="text-gray-600 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            Enterprise teams depend on us to protect their most critical data. We take this responsibility seriously with enterprise-grade security and uptime commitments.
          </p>
        </div>

        <!-- Transparency -->
        <div class="group text-center p-8 rounded-2xl transition-all duration-300 hover:shadow-xl hover:scale-105" style="background: linear-gradient(135deg, #2E4A6B05, #2D5A5A05); border: 1px solid #2E4A6B20;">
          <div class="w-16 h-16 mx-auto rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #2E4A6B, #2D5A5A); box-shadow: 0 10px 30px #2E4A6B30;">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold mb-4" style="color: #2E4A6B; font-family: 'Inter', sans-serif;">Transparency</h3>
          <p class="text-gray-600 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            We believe in open communication about our roadmap, pricing, and security practices. No hidden fees, no surprises, just honest partnership.
          </p>
        </div>

        <!-- Team Collaboration -->
        <div class="group text-center p-8 rounded-2xl transition-all duration-300 hover:shadow-xl hover:scale-105" style="background: linear-gradient(135deg, #4A7C7C05, #3D6B3D05); border: 1px solid #4A7C7C20;">
          <div class="w-16 h-16 mx-auto rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #4A7C7C, #3D6B3D); box-shadow: 0 10px 30px #4A7C7C30;">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold mb-4" style="color: #4A7C7C; font-family: 'Inter', sans-serif;">Team Collaboration</h3>
          <p class="text-gray-600 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            We understand that great products come from great teams. We foster collaboration both within our organization and with our customers.
          </p>
        </div>

        <!-- Continuous Learning -->
        <div class="group text-center p-8 rounded-2xl transition-all duration-300 hover:shadow-xl hover:scale-105" style="background: linear-gradient(135deg, #3D6B3D05, #2E4A6B05); border: 1px solid #3D6B3D20;">
          <div class="w-16 h-16 mx-auto rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #3D6B3D, #2E4A6B); box-shadow: 0 10px 30px #3D6B3D30;">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          
          <h3 class="text-xl font-semibold mb-4" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">Continuous Learning</h3>
          <p class="text-gray-600 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            The enterprise data landscape evolves rapidly. We stay ahead of the curve through continuous learning and adaptation to new technologies and methodologies.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-24 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="absolute inset-0">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-20 left-20 w-64 h-64 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
        <div class="absolute bottom-20 right-20 w-80 h-80 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);"></div>
      </div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center z-10">
      <h2 class="font-display text-4xl sm:text-5xl font-bold mb-6" style="font-family: 'Outfit', sans-serif;">
        Ready to Join Our
        <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #4A7C7C, #D17A3A);">
          Mission?
        </span>
      </h2>
      
      <p class="font-primary text-xl text-gray-300 mb-12 max-w-2xl mx-auto" style="font-family: 'Inter', sans-serif;">
        Experience the difference that purpose-built enterprise data infrastructure can make for your organization.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/pricing" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1" style="background: linear-gradient(135deg, #D17A3A, #D17A3A); font-family: 'Inter', sans-serif;">
          <span>Start Free Trial</span>
          <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        
        <a href="/features" class="group inline-flex items-center px-8 py-4 text-lg font-semibold border-2 rounded-xl hover:bg-white/10 transition-all duration-300 backdrop-blur-sm" style="border-color: #4A7C7C; color: #4A7C7C; font-family: 'Inter', sans-serif;">
          <span class="group-hover:text-white transition-colors">Explore Features</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap');
</style> 