---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Features - BaseOut Enterprise Data Infrastructure"
  description="Comprehensive enterprise-grade features for Airtable backup, analytics, and governance. Discover how BaseOut transforms your data infrastructure."
>
  <Navigation />
  
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white py-24">
    <!-- Background Effects -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900/95 via-slate-800/90 to-slate-900/95"></div>
      <div class="absolute inset-0 opacity-20">
        <div class="absolute top-10 -left-10 w-96 h-96 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
        <div class="absolute bottom-10 -right-10 w-80 h-80 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);"></div>
      </div>
      <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 rounded-full backdrop-blur-sm border text-sm font-medium mb-8 shadow-lg" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border-color: #4A7C7C30; color: #4A7C7C; font-family: 'Inter', sans-serif;">
          <span class="w-2 h-2 rounded-full mr-3 animate-pulse" style="background-color: #3D6B3D;"></span>
          Enterprise Data Infrastructure Features
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6" style="font-family: 'Outfit', sans-serif;">
          <span class="block text-white">Complete Enterprise</span>
          <span class="block bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C, #D17A3A);">
            Data Infrastructure
          </span>
        </h1>

        <p class="font-primary text-xl text-gray-200 leading-relaxed mb-12 max-w-3xl mx-auto" style="font-family: 'Inter', sans-serif;">
          Discover how BaseOut transforms your Airtable environment into a robust, scalable data infrastructure 
          that meets enterprise standards while preserving your team's existing workflows.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#features" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1" style="background: linear-gradient(135deg, #D17A3A, #D17A3A); font-family: 'Inter', sans-serif;">
            <span>Explore Features</span>
            <svg class="ml-2 w-5 h-5 group-hover:translate-y-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </a>
          
          <a href="/pricing" class="group inline-flex items-center px-8 py-4 text-lg font-semibold border-2 rounded-xl hover:bg-white/10 transition-all duration-300 backdrop-blur-sm" style="border-color: #4A7C7C; color: #4A7C7C; font-family: 'Inter', sans-serif;">
            <span class="group-hover:text-white transition-colors">View Pricing</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Categories -->
  <section id="features" class="relative py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Backup & Recovery Features -->
      <div class="mb-32">
        <div class="text-center mb-16">
          <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium mb-6 shadow-lg" style="background: linear-gradient(135deg, #2D5A5A20, #4A7C7C20); border: 1px solid #4A7C7C30; color: #2D5A5A; font-family: 'Inter', sans-serif;">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            Enterprise Backup & Recovery
          </div>
          
          <h2 class="font-display text-4xl sm:text-5xl font-bold mb-6" style="color: #1f2937; font-family: 'Outfit', sans-serif;">
            Never Lose Critical
            <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);">
              Data Again
            </span>
          </h2>
          
          <p class="font-primary text-xl text-gray-600 max-w-3xl mx-auto" style="font-family: 'Inter', sans-serif;">
            Comprehensive backup and disaster recovery solutions designed for mission-critical Airtable environments.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Automated Backups -->
          <div class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 hover:scale-105">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C); box-shadow: 0 10px 30px #2D5A5A40;">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            
            <h3 class="text-2xl font-semibold mb-4" style="color: #2D5A5A; font-family: 'Inter', sans-serif;">Automated Daily Backups</h3>
            <p class="text-gray-600 mb-6 leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Continuous, automated backups with customizable schedules. Set it once and never worry about data loss again.
            </p>
            
            <ul class="space-y-3 text-sm">
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #3D6B3D;"></span>
                <span style="font-family: 'Inter', sans-serif;">Hourly, daily, or custom backup schedules</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #3D6B3D;"></span>
                <span style="font-family: 'Inter', sans-serif;">Incremental backups for storage efficiency</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #3D6B3D;"></span>
                <span style="font-family: 'Inter', sans-serif;">Automatic backup verification</span>
              </li>
            </ul>
          </div>

          <!-- Point-in-Time Recovery -->
          <div class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 hover:scale-105">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #3D6B3D, #2D5A5A); box-shadow: 0 10px 30px #3D6B3D40;">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
              </svg>
            </div>
            
            <h3 class="text-2xl font-semibold mb-4" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">Point-in-Time Recovery</h3>
            <p class="text-gray-600 mb-6 leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Restore your data to any specific moment in time with granular recovery options down to individual records.
            </p>
            
            <ul class="space-y-3 text-sm">
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #D17A3A;"></span>
                <span style="font-family: 'Inter', sans-serif;">Restore to any point in the last 90 days</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #D17A3A;"></span>
                <span style="font-family: 'Inter', sans-serif;">Selective record and field recovery</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #D17A3A;"></span>
                <span style="font-family: 'Inter', sans-serif;">Preview changes before restoring</span>
              </li>
            </ul>
          </div>

          <!-- Disaster Recovery -->
          <div class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 hover:scale-105">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300" style="background: linear-gradient(135deg, #D17A3A, #2E4A6B); box-shadow: 0 10px 30px #D17A3A40;">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            
            <h3 class="text-2xl font-semibold mb-4" style="color: #D17A3A; font-family: 'Inter', sans-serif;">Disaster Recovery Planning</h3>
            <p class="text-gray-600 mb-6 leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Comprehensive disaster recovery with automated failover and business continuity planning.
            </p>
            
            <ul class="space-y-3 text-sm">
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #2E4A6B;"></span>
                <span style="font-family: 'Inter', sans-serif;">Multi-region backup storage</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #2E4A6B;"></span>
                <span style="font-family: 'Inter', sans-serif;">RTO/RPO compliance reporting</span>
              </li>
              <li class="flex items-start">
                <span class="w-2 h-2 rounded-full mt-2 mr-3" style="background-color: #2E4A6B;"></span>
                <span style="font-family: 'Inter', sans-serif;">Automated disaster recovery testing</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- AI Analytics Features -->
      <div class="mb-32">
        <div class="text-center mb-16">
          <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium mb-6 shadow-lg" style="background: linear-gradient(135deg, #2E4A6B20, #3D6B3D20); border: 1px solid #2E4A6B30; color: #2E4A6B; font-family: 'Inter', sans-serif;">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            AI-Powered Analytics
          </div>
          
          <h2 class="font-display text-4xl sm:text-5xl font-bold mb-6" style="color: #1f2937; font-family: 'Outfit', sans-serif;">
            Transform Data Into
            <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #2E4A6B, #3D6B3D);">
              Actionable Insights
            </span>
          </h2>
          
          <p class="font-primary text-xl text-gray-600 max-w-3xl mx-auto" style="font-family: 'Inter', sans-serif;">
            Advanced machine learning algorithms that analyze your data patterns and provide insights beyond traditional reporting.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12 items-center">
          <!-- Feature List -->
          <div class="space-y-8">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #2E4A6B, #3D6B3D); box-shadow: 0 8px 25px #2E4A6B30;">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2" style="color: #2E4A6B; font-family: 'Inter', sans-serif;">Predictive Analytics</h3>
                <p class="text-gray-600" style="font-family: 'Inter', sans-serif;">
                  Machine learning models that predict trends, identify patterns, and forecast future data needs based on historical usage.
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A); box-shadow: 0 8px 25px #3D6B3D30;">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2" style="color: #3D6B3D; font-family: 'Inter', sans-serif;">Custom Reporting</h3>
                <p class="text-gray-600" style="font-family: 'Inter', sans-serif;">
                  Build sophisticated reports and dashboards that go beyond Airtable's native capabilities with advanced filtering and visualization.
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #D17A3A, #2D5A5A); box-shadow: 0 8px 25px #D17A3A30;">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2" style="color: #D17A3A; font-family: 'Inter', sans-serif;">Data Visualization</h3>
                <p class="text-gray-600" style="font-family: 'Inter', sans-serif;">
                  Interactive charts, graphs, and dashboards that make complex data relationships clear and actionable for your team.
                </p>
              </div>
            </div>
          </div>

          <!-- Visual Element -->
          <div class="relative">
            <div class="bg-white rounded-2xl p-8 shadow-xl border border-gray-100">
              <div class="space-y-6">
                <div class="flex items-center justify-between">
                  <span class="text-sm font-medium text-gray-500" style="font-family: 'Inter', sans-serif;">Analytics Dashboard</span>
                  <div class="w-2 h-2 rounded-full animate-pulse" style="background-color: #3D6B3D;"></div>
                </div>
                
                <!-- Mock chart bars -->
                <div class="space-y-4">
                  <div class="flex items-end space-x-2 h-24">
                    <div class="w-8 h-16 rounded-t" style="background: linear-gradient(to top, #2D5A5A, #4A7C7C);"></div>
                    <div class="w-8 h-20 rounded-t" style="background: linear-gradient(to top, #3D6B3D, #D17A3A);"></div>
                    <div class="w-8 h-12 rounded-t" style="background: linear-gradient(to top, #2E4A6B, #4A7C7C);"></div>
                    <div class="w-8 h-24 rounded-t" style="background: linear-gradient(to top, #D17A3A, #3D6B3D);"></div>
                    <div class="w-8 h-8 rounded-t" style="background: linear-gradient(to top, #4A7C7C, #2D5A5A);"></div>
                  </div>
                  
                  <div class="space-y-2">
                    <div class="flex justify-between text-sm">
                      <span style="color: #2D5A5A; font-family: 'Inter', sans-serif;">Data Growth</span>
                      <span style="color: #3D6B3D; font-family: 'Inter', sans-serif;">+23%</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span style="color: #2E4A6B; font-family: 'Inter', sans-serif;">Usage Trends</span>
                      <span style="color: #D17A3A; font-family: 'Inter', sans-serif;">+15%</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative py-24 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="absolute inset-0">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-20 left-20 w-64 h-64 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #2D5A5A, #4A7C7C);"></div>
        <div class="absolute bottom-20 right-20 w-80 h-80 rounded-full filter blur-3xl" style="background: linear-gradient(135deg, #3D6B3D, #D17A3A);"></div>
      </div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center z-10">
      <h2 class="font-display text-4xl sm:text-5xl font-bold mb-6" style="font-family: 'Outfit', sans-serif;">
        Ready to Transform Your
        <span class="bg-gradient-to-r bg-clip-text " style="background: linear-gradient(135deg, #4A7C7C, #D17A3A);">
          Data Infrastructure?
        </span>
      </h2>
      
      <p class="font-primary text-xl text-gray-300 mb-12 max-w-2xl mx-auto" style="font-family: 'Inter', sans-serif;">
        Join enterprise teams who've already scaled their data infrastructure while preserving operational excellence.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/pricing" class="group inline-flex items-center px-8 py-4 text-lg font-semibold text-white rounded-xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1" style="background: linear-gradient(135deg, #D17A3A, #D17A3A); font-family: 'Inter', sans-serif;">
          <span>Start Free Trial</span>
          <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        
        <a href="/about" class="group inline-flex items-center px-8 py-4 text-lg font-semibold border-2 rounded-xl hover:bg-white/10 transition-all duration-300 backdrop-blur-sm" style="border-color: #4A7C7C; color: #4A7C7C; font-family: 'Inter', sans-serif;">
          <span class="group-hover:text-white transition-colors">Learn More</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Import Brand Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600;700;800&display=swap');

  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(45, 90, 90, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45, 90, 90, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
  }
</style> 